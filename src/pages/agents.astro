        <text x="${W/2}" y="${H/2 - 10}" text-anchor="middle" font-family="Inter" font-size="11" fill="#4A90D9" font-weight="700">POLLER</text>
        <text x="${W/2}" y="${H/2 + 6}" text-anchor="middle" font-family="Inter" font-size="9" fill="#71717a">claude -p</text>
        <text x="${W/2}" y="${H/2 + 20}" text-anchor="middle" font-family="Inter" font-size="7" fill="#52525b">2 workers</text>
      `;

      // Hub → agent connections (subtle radial lines)
      nodes.forEach(n => {
        const nx = n.pole === 'tech' ? n.x + NW : n.x;
        const ny = n.y + NH / 2;
        const hx = n.pole === 'tech' ? W/2 - 50 : W/2 + 50;
        svg += `<line x1="${nx}" y1="${ny}" x2="${hx}" y2="${H/2}" stroke="${n.color}" stroke-width="0.6" opacity="0.15"/>`;
      });

      // Task flows (curved, colored, with arrows)
      taskFlows.forEach(function(flow) {
        var from = getNode(flow.from);
        var to = getNode(flow.to);
        if (!from || !to) return;

        var path, lx, ly;
        if (from.pole === to.pole) {
          var side = from.pole === 'tech' ? -1 : 1;
          var fx = from.x + (side === -1 ? 0 : NW), fy = from.y + NH/2;
          var tx = to.x + (side === -1 ? 0 : NW), ty = to.y + NH/2;
          var cx = fx + side * 50;
          path = 'M' + fx + ' ' + fy + ' Q' + cx + ' ' + ((fy+ty)/2) + ' ' + tx + ' ' + ty;
          lx = cx + side * 4; ly = (fy + ty) / 2;
        } else {
          var fx2 = from.x + NW, fy2 = from.y + NH/2;
          var tx2 = to.x, ty2 = to.y + NH/2;
          var mx = W/2, my = (fy2 + ty2) / 2;
          path = 'M' + fx2 + ' ' + fy2 + ' Q' + mx + ' ' + my + ' ' + tx2 + ' ' + ty2;
          lx = (fx2 + tx2) / 2; ly = (fy2 + ty2) / 2 - 10;
        }

        svg += '<path d="' + path + '" fill="none" stroke="' + flow.color + '" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.5" marker-end="url(#arrow)"><animate attributeName="stroke-dashoffset" values="0;-20" dur="2s" repeatCount="indefinite"/></path>';
        svg += '<text x="' + lx + '" y="' + ly + '" text-anchor="middle" font-family="Inter" font-size="8" fill="' + flow.color + '" font-weight="500" opacity="0.8">' + flow.label + '</text>';
      });

      // Data sources
      sources.forEach(function(src) {
        var w = src.label.length * 7 + 20;
        svg += '<rect x="' + src.x + '" y="' + src.y + '" width="' + w + '" height="28" rx="14" fill="#1a1a2e" stroke="#3f3f5a" stroke-width="1"/>';
        svg += '<text x="' + (src.x + w/2) + '" y="' + (src.y + 17) + '" text-anchor="middle" font-family="Inter" font-size="9" fill="#a1a1ba" font-weight="500">' + src.label + '</text>';
      });

      // Agent nodes
      nodes.forEach(function(n) {
        var agent = agents.find(function(a) { return a.slug === n.slug; });
        var health = agent?.health_status || 'unknown';
        var healthColor = { healthy: '#22c55e', warning: '#f59e0b', critical: '#ef4444', unknown: '#52525b' }[health];
        var lastRun = agent?.last_successful_run_at ? timeAgo(new Date(agent.last_successful_run_at)) : 'jamais';
        var agentId = agent?.id || '';
        var schedule = cronToHuman(agent?.schedule);
        var animTag = health !== 'healthy' ? '<animate attributeName="opacity" values="1;0.3;1" dur="1.5s" repeatCount="indefinite"/>' : '';

        svg += '<g style="cursor:pointer;" onclick="openAgent(\'' + agentId + '\')" data-slug="' + n.slug + '">'
          + '<rect x="' + n.x + '" y="' + n.y + '" width="' + NW + '" height="' + NH + '" rx="12" ry="12" fill="url(#grad-' + n.slug + ')" stroke="' + n.color + '" stroke-width="1.5" filter="url(#glow-' + n.slug + ')"/>'
          + '<circle cx="' + (n.x + NW - 14) + '" cy="' + (n.y + 14) + '" r="5" fill="' + healthColor + '" data-health-slug="' + n.slug + '">' + animTag + '</circle>'
          + '<text x="' + (n.x + 14) + '" y="' + (n.y + 24) + '" font-family="Inter" font-size="13" fill="#fafafa" font-weight="600">' + n.icon + ' ' + n.label + '</text>'
          + '<text x="' + (n.x + 14) + '" y="' + (n.y + 42) + '" font-family="Inter" font-size="9" fill="#a1a1aa">' + schedule + ' \u{2022} ' + lastRun + '</text>'
          + '</g>';
      });

      // Human approval
      var humanX = W/2;
      var humanY = H - 50;
      svg += '<rect x="' + (humanX - 55) + '" y="' + (humanY - 16) + '" width="110" height="32" rx="16" fill="#1c1917" stroke="#fbbf24" stroke-width="1.5" filter="url(#glow-human)"/>';
      svg += '<text x="' + humanX + '" y="' + (humanY + 5) + '" text-anchor="middle" font-family="Inter" font-size="11" fill="#fbbf24" font-weight="600">\u{1F464} Approbation</text>';
      svg += '<line x1="' + humanX + '" y1="' + (H/2 + 50) + '" x2="' + humanX + '" y2="' + (humanY - 16) + '" stroke="#fbbf24" stroke-width="1" stroke-dasharray="4 3" opacity="0.3"/>';

      svg += '</svg>';

      // Legend
      svg += '<div style="position:absolute;bottom:14px;left:16px;right:16px;display:flex;gap:18px;font-size:0.72rem;color:#71717a;background:rgba(9,9,11,0.85);padding:8px 14px;border-radius:8px;backdrop-filter:blur(4px);">'
        + '<span style="display:flex;align-items:center;gap:5px;"><span style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block;"></span> Healthy</span>'
        + '<span style="display:flex;align-items:center;gap:5px;"><span style="width:8px;height:8px;border-radius:50%;background:#f59e0b;display:inline-block;"></span> Warning</span>'
        + '<span style="display:flex;align-items:center;gap:5px;"><span style="width:8px;height:8px;border-radius:50%;background:#ef4444;display:inline-block;"></span> Critical</span>'
        + '<span style="display:flex;align-items:center;gap:5px;"><span style="width:20px;height:2px;background:#f59e0b;display:inline-block;"></span> Flux inter-agent</span>'
        + '<span style="display:flex;align-items:center;gap:5px;"><span style="width:20px;height:0;border-top:1px solid #3f3f5a;display:inline-block;"></span> Source de donn\u{00E9}es</span>'
        + '</div>';

      container.innerHTML = svg;
    }

    function updateArchiHealth() {
      agents.forEach(function(a) {
        var dot = document.querySelector('[data-health-slug="' + a.slug + '"]');
        if (dot) {
          var color = { healthy: '#22c55e', warning: '#f59e0b', critical: '#ef4444', unknown: '#52525b' }[a.health_status || 'unknown'];
          dot.setAttribute('fill', color);
        }
      });
    }

    // ─── Usage Stats ────────────────────────────
    async function renderUsageBar() {
      const container = document.getElementById('usage-bar');
      const now = new Date();
      const yesterday = new Date(now - 86400000);

      // Count runs in last 24h
      const { data: recentRuns } = await sb.from('agent_runs')
        .select('id,duration_ms,status,agent_id')
        .gte('started_at', yesterday.toISOString());

      const runs = recentRuns || [];
      const completed = runs.filter(r => r.status === 'completed');
      const failed = runs.filter(r => r.status === 'failed');
      const avgDuration = completed.length > 0
        ? Math.round(completed.reduce((s, r) => s + (r.duration_ms || 0), 0) / completed.length / 1000)
        : 0;

      // Runs per agent
      const perAgent = {};
      runs.forEach(r => {
        const agent = agents.find(a => a.id === r.agent_id);
        const name = agent ? agent.name.replace('Agent ', '') : '?';
        perAgent[name] = (perAgent[name] || 0) + 1;
      });
      const topAgent = Object.entries(perAgent).sort((a, b) => b[1] - a[1])[0];

      container.innerHTML = `
        <span class="health-bar-title">Usage 24h</span>
        <div class="usage-stat"><div class="val">${runs.length}</div><div class="lbl">Runs</div></div>
        <div class="usage-divider"></div>
        <div class="usage-stat"><div class="val">${completed.length}</div><div class="lbl">R\u{00E9}ussis</div></div>
        <div class="usage-divider"></div>
        <div class="usage-stat"><div class="val" style="color:${failed.length > 0 ? '#ef4444' : '#22c55e'}">${failed.length}</div><div class="lbl">\u{00C9}checs</div></div>
        <div class="usage-divider"></div>
        <div class="usage-stat"><div class="val">${avgDuration}s</div><div class="lbl">Dur\u{00E9}e moy</div></div>
        ${topAgent ? `<div class="usage-divider"></div><div class="usage-stat"><div class="val">${topAgent[1]}</div><div class="lbl">${topAgent[0]}</div></div>` : ''}
      `;
    }

    // ─── Global Views ─────────────────────────
    function switchGlobalView(view, btn) {
      document.querySelectorAll('.view-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      ['agents', 'archi', 'bugs', 'contacts', 'content'].forEach(v => {
        const el = document.getElementById('view-' + v);
        if (el) { el.style.display = v === view ? 'block' : 'none'; el.classList.toggle('active', v === view); }
      });
      if (view === 'archi') { if (!archiRendered) renderArchitecture(); updateArchiHealth(); }
      if (view === 'bugs') { loadBugsView(); loadExecResults(); }
      if (view === 'contacts') loadContactsView();
      if (view === 'content') loadContentView();
    }

    // ─── Bugs View ──────────────────────────────
    async function loadBugsView() {
      const container = document.getElementById('bugs-list');
      container.innerHTML = '<p class="empty-state">Chargement...</p>';

      const debugAgent = agents.find(a => a.slug === 'agent-debug');
      if (!debugAgent) { container.innerHTML = '<p class="empty-state">Agent Debug non trouv\u{00E9}</p>'; return; }

      const { data: runs } = await sb.from('agent_runs').select('output,started_at')
        .eq('agent_id', debugAgent.id).eq('status', 'completed')
        .order('started_at', { ascending: false }).limit(5);

      const allBugs = [];
      (runs || []).forEach(r => {
        const bugs = r.output?.output?.bugs_found || r.output?.bugs_found || [];
        bugs.forEach(b => allBugs.push({ ...b, date: r.started_at }));
      });

      if (allBugs.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucun bug d\u{00E9}tect\u{00E9}</p>';
        return;
      }

      const badge = document.getElementById('bugs-count');
      badge.textContent = allBugs.length;
      badge.style.display = 'inline';

      container.innerHTML = allBugs.map(b => {
        const sev = (b.severity || 'medium').toLowerCase();
        const fix = b.fix_proposal;
        return `
          <div class="bug-card severity-${sev}">
            <div class="bug-header">
              <span class="bug-title">${b.bug_id || 'Bug'} \u{2014} ${b.root_cause || 'Cause inconnue'}</span>
              <span class="severity-badge severity-${sev}">${sev}</span>
            </div>
            <div class="bug-meta">
              ${b.affected_users ? 'Utilisateurs : ' + b.affected_users + ' \u{2022} ' : ''}
              ${b.error_type || ''} ${b.error_message ? '\u{2014} ' + b.error_message : ''}
            </div>
            ${fix ? `
              <div class="bug-fix"><strong>${fix.file || ''}</strong>\n${fix.diff || fix.test || 'Pas de diff'}</div>
              <div class="bug-actions">
                <button class="btn-xs btn-approve" onclick="approveBug('${b.bug_id}', this)">Approuver le fix</button>
                <button class="btn-xs btn-reject" onclick="rejectBug('${b.bug_id}', this)">Rejeter</button>
              </div>
            ` : ''}
          </div>
        `;
      }).join('');
    }

    async function approveBug(bugId, btn) {
      btn.textContent = '\u{23F3} Cr\u{00E9}ation t\u{00E2}che...';
      btn.disabled = true;

      // Find the bug details from the card's data
      const card = btn.closest('.bug-card');
      const file = card.querySelector('.bug-fix strong')?.textContent || '';
      const diff = card.querySelector('.bug-fix')?.textContent?.replace(file, '').trim() || '';
      const rootCause = card.querySelector('.bug-title')?.textContent || '';

      // Get Agent Dev id
      const devAgent = agents.find(a => a.slug === 'agent-dev');
      const debugAgent = agents.find(a => a.slug === 'agent-debug');
      if (!devAgent) { btn.textContent = '\u{274C} Agent Dev introuvable'; return; }

      // Create approved task for Agent Dev
      const { error } = await sb.from('agent_tasks').insert({
        created_by_agent: debugAgent?.id || null,
        assigned_to_agent: devAgent.id,
        task_type: 'code_fix',
        payload: {
          bug_id: bugId,
          root_cause: rootCause,
          file: file,
          diff: diff,
          instructions: 'Appliquer le fix propos\u{00E9} par Agent Debug. Cr\u{00E9}er une branche, appliquer, build, commit, push.'
        },
        status: 'approved',
        approved_at: new Date().toISOString(),
        approved_by: 'tech'
      });

      if (error) {
        btn.textContent = '\u{274C} Erreur';
        console.error(error);
      } else {
        btn.textContent = '\u{2705} Approuv\u{00E9} \u{2014} en attente du poller';
        btn.parentElement.querySelector('.btn-reject').style.display = 'none';
      }
    }

    async function rejectBug(bugId, btn) {
      btn.textContent = 'Rejet\u{00E9}';
      btn.disabled = true;
      btn.parentElement.querySelector('.btn-approve').disabled = true;
    }

    // ─── Contacts View ──────────────────────────
    async function loadContactsView() {
      const container = document.getElementById('contacts-list');
      container.innerHTML = '<p class="empty-state">Chargement...</p>';

      // Get from outreach_contacts table
      const { data: dbContacts } = await sb.from('outreach_contacts')
        .select('*').order('updated_at', { ascending: false }).limit(100);

      // Also get from latest marketing run output
      const mktAgent = agents.find(a => a.slug === 'agent-marketing');
      let runContacts = [];
      if (mktAgent) {
        const { data: runs } = await sb.from('agent_runs').select('output')
          .eq('agent_id', mktAgent.id).eq('status', 'completed')
          .order('started_at', { ascending: false }).limit(3);
        (runs || []).forEach(r => {
          const c = r.output?.output?.contacts?.new || [];
          runContacts = runContacts.concat(c);
        });
      }

      const allContacts = (dbContacts || []).concat(
        runContacts.map(c => ({ ...c, status: 'identified', source: 'agent' }))
      );

      if (allContacts.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucun contact pour le moment</p>';
        return;
      }

      const platformIcons = { instagram: '\u{1F4F7}', tiktok: '\u{1F3B5}', youtube: '\u{1F3AC}', email: '\u{1F4E7}', twitter: '\u{1F426}', reddit: '\u{1F4AC}' };

      container.innerHTML = allContacts.map(c => {
        const icon = platformIcons[c.platform] || '\u{1F464}';
        const status = c.status || 'identified';
        return `
          <div class="contact-card">
            <div class="contact-avatar">${icon}</div>
            <div class="contact-info">
              <div class="contact-name">${c.name || 'Inconnu'}</div>
              <div class="contact-handle">${c.handle || c.platform || ''} ${c.followers ? '\u{2022} ' + c.followers + ' followers' : ''}</div>
            </div>
            <span class="contact-status-badge cs-${status}">${status}</span>
          </div>
        `;
      }).join('');
    }

    // ─── Content View ───────────────────────────
    async function loadContentView() {
      const container = document.getElementById('content-list');
      container.innerHTML = '<p class="empty-state">Chargement...</p>';

      const ctnAgent = agents.find(a => a.slug === 'agent-contenu');
      if (!ctnAgent) { container.innerHTML = '<p class="empty-state">Agent Contenu non trouv\u{00E9}</p>'; return; }

      const { data: runs } = await sb.from('agent_runs').select('output,started_at')
        .eq('agent_id', ctnAgent.id).eq('status', 'completed')
        .order('started_at', { ascending: false }).limit(5);

      const allContent = [];
      (runs || []).forEach(r => {
        const out = r.output?.output || r.output || {};
        (out.articles || []).forEach(a => allContent.push({ ...a, type: 'article', date: r.started_at }));
        (out.video_scripts || []).forEach(v => allContent.push({ ...v, type: 'video_script', date: r.started_at }));
        (out.emails || []).forEach(e => allContent.push({ ...e, type: 'email', date: r.started_at }));
      });

      if (allContent.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucun contenu produit pour le moment</p>';
        return;
      }

      const badge = document.getElementById('content-count');
      badge.textContent = allContent.length;
      badge.style.display = 'inline';

      const typeLabels = { article: 'Article', video_script: 'Script vid\u{00E9}o', email: 'Email', caption: 'Caption' };

      container.innerHTML = allContent.map(c => {
        const preview = c.content ? c.content.slice(0, 200) : c.body ? c.body.slice(0, 200) : '';
        return `
          <div class="content-card type-${c.type}">
            <div class="bug-header">
              <span class="bug-title">${c.title || 'Sans titre'}</span>
              <span class="content-type-badge">${typeLabels[c.type] || c.type}</span>
            </div>
            ${c.target_keyword ? `<div class="bug-meta">Keyword : ${c.target_keyword} ${c.word_count ? '\u{2022} ' + c.word_count + ' mots' : ''}</div>` : ''}
            ${preview ? `<div class="content-preview">${preview}...</div>` : ''}
            ${c.review_notes ? `<div class="review-notes">\u{26A0}\u{FE0F} ${c.review_notes}</div>` : ''}
            ${c.needs_medical_review ? '<div class="review-notes">\u{1F3E5} Review m\u{00E9}dicale requise</div>' : ''}
            <div class="bug-actions" style="margin-top:10px;">
              <button class="btn-xs btn-approve">Valider</button>
              <button class="btn-xs btn-reject">Rejeter</button>
            </div>
          </div>
        `;
      }).join('');
    }

    // ─── Exec Results (code_fix tasks) ────────
    async function loadExecResults() {
      const container = document.getElementById('exec-list');
      if (!container) return;

      const { data: tasks } = await sb.from('agent_tasks')
        .select('*')
        .eq('task_type', 'code_fix')
        .in('status', ['approved', 'executing', 'executed', 'rejected'])
        .order('approved_at', { ascending: false })
        .limit(10);

      if (!tasks || tasks.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucune ex\u{00E9}cution de code</p>';
        return;
      }

      container.innerHTML = tasks.map(t => {
        const bugId = t.payload?.bug_id || '?';
        const statusColors = { approved: '#f59e0b', executing: '#60a5fa', executed: '#22c55e', rejected: '#ef4444' };
        const statusLabels = { approved: 'En attente', executing: 'En cours', executed: 'Ex\u{00E9}cut\u{00E9}', rejected: 'Rejet\u{00E9}' };
        const color = statusColors[t.status] || '#71717a';
        const label = statusLabels[t.status] || t.status;

        return `
          <div class="exec-result">
            <div class="exec-status" style="color:${color}">${label} \u{2014} ${bugId}</div>
            ${t.git_branch ? `<div class="exec-branch">\u{1F33F} ${t.git_branch}</div>` : ''}
            ${t.result_summary ? `<div style="font-size:0.8rem;color:#a1a1aa;margin-top:4px;">${t.result_summary}</div>` : ''}
            ${t.git_commit ? `<div style="font-size:0.72rem;color:#71717a;margin-top:4px;">Commit: ${t.git_commit}</div>` : ''}
          </div>
        `;
      }).join('');
    }

    // ─── Export CSV contacts ────────────────────
    async function exportContactsCSV() {
      const { data: contacts } = await sb.from('outreach_contacts')
        .select('*').order('created_at', { ascending: false });

      if (!contacts || contacts.length === 0) {
        alert('Aucun contact \u{00E0} exporter');
        return;
      }

      const headers = ['name', 'platform', 'handle', 'email', 'followers', 'niche', 'status', 'language', 'notes'];
      const csv = [headers.join(',')];
      contacts.forEach(c => {
        csv.push(headers.map(h => {
          const val = (c[h] || '').toString().replace(/"/g, '""');
          return `"${val}"`;
        }).join(','));
      });

      const blob = new Blob([csv.join('\n')], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `contacts_outreach_${new Date().toISOString().split('T')[0]}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    }

    // ─── Realtime ──────────────────────────────
    function setupRealtime() {
      sb.channel('agent-updates')
        .on('postgres_changes', { event: '*', schema: 'public', table: 'agent_runs' }, () => {
          loadData();
        })
        .on('postgres_changes', { event: '*', schema: 'public', table: 'agents' }, () => {
          loadData();
        })
        .subscribe();
    }
  </script>
</body>
</html>
