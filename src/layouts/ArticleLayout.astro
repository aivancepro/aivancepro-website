---
import BaseLayout from './BaseLayout.astro';
import { t } from '../i18n.js';

const {
  lang = 'fr',
  title,
  description,
  canonical,
  alternates = {},
  tag,
  date,
  readTime,
  backLink,
  backLabel,
  jsonLd,
} = Astro.props;

const i = t[lang];
const ctaLabels = {
  fr: { title: 'Essayez le coaching IA gratuitement', text: 'T\u00e9l\u00e9chargez AIVancePro et d\u00e9couvrez un entra\u00eenement vraiment personnalis\u00e9.', playLabel: 'Google Play' },
  en: { title: 'Try AI coaching for free', text: 'Download AIVancePro and discover truly personalized training.', playLabel: 'Google Play' },
  de: { title: 'KI-Coaching kostenlos testen', text: 'Laden Sie AIVancePro herunter und entdecken Sie wirklich personalisiertes Training.', playLabel: 'Google Play' },
};
const cta = ctaLabels[lang];
const storeLabels = {
  fr: { appSmall: "Disponible sur l'", appBig: 'App Store', playSmall: 'Disponible sur', playBig: 'Google Play' },
  en: { appSmall: 'Available on the', appBig: 'App Store', playSmall: 'Get it on', playBig: 'Google Play' },
  de: { appSmall: 'Verfügbar im', appBig: 'App Store', playSmall: 'Jetzt bei', playBig: 'Google Play' },
};
const store = storeLabels[lang];
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  alternates={alternates}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <style>
      .article-header { padding: 9rem 2rem 2rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); }
      .tag { display: inline-block; padding: 0.25rem 0.75rem; background: rgba(37,99,235,0.06); border-radius: 50px; font-size: 0.75rem; color: var(--blue); font-weight: 600; margin-bottom: 1rem; }
      .article-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; line-height: 1.2; color: var(--gray-900); letter-spacing: -0.02em; }
      .meta { color: var(--gray-500); margin-bottom: 0; font-size: 0.9rem; }
      .breadcrumb { font-size: 0.85rem; color: var(--gray-500); margin-bottom: 1rem; }
      .breadcrumb a { color: var(--gray-500); text-decoration: none; }
      .breadcrumb a:hover { color: var(--blue); }
      .article-content { max-width: 750px; margin: 0 auto; padding: 3rem 2rem 4rem; }
      .article-content h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--gray-900); }
      .article-content h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; color: var(--gray-900); }
      .article-content p { color: var(--gray-700); font-size: 0.95rem; margin-bottom: 1.2rem; line-height: 1.8; }
      .article-content ul, .article-content ol { padding-left: 1.5rem; margin-bottom: 1.2rem; }
      .article-content li { color: var(--gray-700); font-size: 0.95rem; margin-bottom: 0.5rem; }
      .article-content strong { color: var(--gray-900); }
      .article-content a { color: var(--blue); }
      .program-box { background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
      .program-box h4 { color: var(--blue); font-size: 1rem; margin-bottom: 0.75rem; }
      .cta { background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 16px; padding: 2.5rem; margin-top: 3rem; text-align: center; }
      .cta h3 { font-size: 1.4rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.5rem; margin-top: 0; }
      .cta p { color: var(--gray-600); margin-bottom: 1.5rem; }
      .store-badges { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
      .store-badge-link { display: inline-flex; align-items: center; gap: 0.6rem; background: linear-gradient(135deg, var(--blue), var(--purple)); color: #fff !important; text-decoration: none; padding: 0.75rem 1.5rem; border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s, opacity 0.2s; box-shadow: 0 4px 15px rgba(37,99,235,0.3); }
      .store-badge-link:hover { transform: translateY(-2px); opacity: 0.92; box-shadow: 0 8px 25px rgba(37,99,235,0.35); color: var(--white); }
      .store-badge-link svg { width: 24px; height: 24px; }
      .store-badge-text { display: flex; flex-direction: column; line-height: 1.2; }
      .store-badge-text .small { font-size: 0.6rem; font-weight: 400; opacity: 0.8; }
      .store-badge-text .big { font-size: 1rem; font-weight: 700; }
      .back { display: inline-block; margin-top: 2rem; color: var(--gray-500); text-decoration: none; font-size: 0.9rem; }
      .back:hover { color: var(--gray-900); }
      @media (max-width: 768px) {
        .article-header { padding: 7rem 1.5rem 2rem; }
        .article-header h1 { font-size: 1.8rem; }
      }
    </style>
  </Fragment>

  <header class="article-header">
    {tag && <span class="tag">{tag}</span>}
    <h1>{title}</h1>
    {date && <p class="meta">{date}{readTime ? ` \u00b7 ${readTime}` : ''}</p>}
  </header>

  <article class="article-content">
    <slot />

    <div class="cta">
      <h3>{cta.title}</h3>
      <p>{cta.text}</p>
      <div class="store-badges">
        <a href={i.links.appStore} class="store-badge-link" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span class="store-badge-text"><span class="small">{store.appSmall}</span><span class="big">{store.appBig}</span></span>
        </a>
        <a href={i.links.playStore} class="store-badge-link" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.5,12.92 20.16,13.19L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/></svg>
          <span class="store-badge-text"><span class="small">{store.playSmall}</span><span class="big">{store.playBig}</span></span>
        </a>
      </div>
    </div>
    {backLink && <a href={backLink} class="back">&larr; {backLabel}</a>}
  </article>
</BaseLayout>
