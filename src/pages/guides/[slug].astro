---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => data.lang === 'fr');
  return guides.map((guide) => ({
    params: { slug: guide.data.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);

const wordCount = guide.body ? guide.body.split(/\s+/).length : 0;

const related = (await getCollection('guides', ({ data }) =>
  data.lang === 'fr' &&
  data.slug !== guide.data.slug
)).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);
---

<ArticleLayout
  lang="fr"
  title={guide.data.title}
  description={guide.data.description}
  canonical={guide.data.canonical}
  alternates={guide.data.alternates}
  tag={guide.data.tag}
  category={guide.data.category}
  date={guide.data.date}
  dateModified={guide.data.dateModified}
  readTime={guide.data.readTime}
  backLink="/guides/"
  backLabel="Retour aux guides"
  image={guide.data.image}
  author={guide.data.author}
  relatedArticles={related}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": guide.data.title,
      "description": guide.data.description,
      "datePublished": guide.data.date,
      "dateModified": guide.data.dateModified || guide.data.date,
      "keywords": guide.data.keywords,
      "inLanguage": "fr",
      "wordCount": wordCount,
      "articleSection": guide.data.tag,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": guide.data.canonical,
      },
      "image": guide.data.image || "https://aivancepro.fr/assets/og-image.png",
      "thumbnailUrl": guide.data.image || "https://aivancepro.fr/assets/og-image.png",
      "author": {
        "@type": "Person",
        "name": guide.data.author || "Theo Stanmore",
        "url": "https://aivancepro.fr/",
      },
      "publisher": {
        "@type": "Organization",
        "name": "AIVancePro",
        "url": "https://aivancepro.fr",
        "logo": {
          "@type": "ImageObject",
          "url": "https://aivancepro.fr/logo.png",
        },
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://aivancepro.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://aivancepro.fr/guides/" },
        { "@type": "ListItem", "position": 3, "name": guide.data.title, "item": guide.data.canonical },
      ],
    },
  ]}
>
  <Content />
</ArticleLayout>
