---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="de"
  title="Mein Konto - AIVancePro"
  description="Verwalten Sie Ihr Abonnement und sehen Sie Ihre AIVancePro-Statistiken ein."
  noFooter={true}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow">
    <style>
      body { background: var(--gray-50); min-height: 100vh; }
      .account-container { max-width: 800px; margin: 0 auto; padding: 5rem 2rem 4rem; }
      .account-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
      .account-header h1 { font-size: 1.8rem; font-weight: 800; color: var(--gray-900); }
      .btn-logout { padding: 0.5rem 1.25rem; border: 1px solid var(--border-light); border-radius: 10px; background: var(--bg-elevated); color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; }
      .btn-logout:hover { border-color: var(--gray-400); color: var(--gray-900); }

      /* Subscription card */
      .sub-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; margin-bottom: 1.5rem; }
      .sub-card.pro { border-color: rgba(74,144,217,0.3); background: linear-gradient(135deg, rgba(74,144,217,0.03), rgba(74,144,217,0.03)); }
      .sub-card.elite { border-color: rgba(74,144,217,0.3); background: linear-gradient(135deg, rgba(74,144,217,0.03), rgba(234,179,8,0.03)); }
      .sub-card.trial { border-color: rgba(234,179,8,0.3); background: linear-gradient(135deg, rgba(234,179,8,0.03), rgba(74,144,217,0.03)); }
      .trial-info { background: rgba(234,179,8,0.08); border: 1px solid rgba(234,179,8,0.2); border-radius: 10px; padding: 0.75rem 1rem; margin-top: 0.75rem; font-size: 0.85rem; color: var(--text-secondary); }
      .trial-info strong { color: #CA8A04; }
      .sub-top { display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
      .sub-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
      .sub-icon.free { background: var(--gray-100); color: var(--gray-500); }
      .sub-icon.pro { background: var(--blue); color: white; }
      .sub-icon.elite { background: linear-gradient(135deg, #5BA0E9, #EAB308); color: white; }
      .sub-icon.trial { background: linear-gradient(135deg, #EAB308, var(--blue)); color: white; }
      .sub-icon svg { width: 24px; height: 24px; }
      .sub-info h2 { font-size: 1.2rem; font-weight: 700; color: var(--gray-900); margin: 0; }
      .sub-badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
      .sub-badge.free { background: var(--gray-100); color: var(--gray-600); }
      .sub-badge.pro { background: rgba(74,144,217,0.1); color: var(--blue); }
      .sub-badge.elite { background: rgba(74,144,217,0.1); color: #5BA0E9; }
      .sub-badge.trial { background: rgba(234,179,8,0.1); color: #CA8A04; }
      .sub-email { color: var(--gray-500); font-size: 0.85rem; margin-top: 0.5rem; }

      /* Stats grid */
      .stats-title { font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1rem; }
      .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
      .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem; text-align: center; }
      .stat-value { font-size: 2rem; font-weight: 800; color: var(--gray-900); line-height: 1; }
      .stat-value.blue { color: var(--blue); }
      .stat-label { font-size: 0.8rem; color: var(--gray-500); margin-top: 0.35rem; font-weight: 500; }

      /* Recent sessions */
      .recent-title { font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1rem; }
      .recent-list { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
      .recent-item { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.25rem; display: flex; align-items: center; gap: 1rem; }
      .recent-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(74,144,217,0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .recent-icon svg { width: 20px; height: 20px; color: var(--blue); }
      .recent-info { flex: 1; }
      .recent-name { font-size: 0.9rem; font-weight: 600; color: var(--gray-900); }
      .recent-meta { font-size: 0.78rem; color: var(--gray-500); margin-top: 0.15rem; }
      .recent-empty { text-align: center; padding: 2rem; color: var(--gray-400); font-size: 0.9rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 1.5rem; }
      .pr-title { font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1rem; }
      .pr-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
      .pr-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.25rem; }
      .pr-exercise { font-size: 0.82rem; color: var(--gray-500); font-weight: 500; }
      .pr-value { font-size: 1.3rem; font-weight: 800; color: var(--blue); margin-top: 0.25rem; }
      .pr-empty { text-align: center; padding: 2rem; color: var(--gray-400); font-size: 0.9rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 1.5rem; }
      .profile-title { font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1rem; }
      .profile-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
      .profile-item { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem 1.25rem; }
      .profile-item-label { font-size: 0.75rem; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.03em; font-weight: 600; }
      .profile-item-value { font-size: 0.95rem; font-weight: 600; color: var(--gray-900); margin-top: 0.25rem; }
      @media (max-width: 640px) {
        .pr-grid { grid-template-columns: 1fr; }
        .profile-grid { grid-template-columns: 1fr; }
      }

      /* Upgrade CTA */
      .upgrade-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; text-align: center; }
      .upgrade-card h3 { font-size: 1.2rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.5rem; }
      .upgrade-card p { color: var(--gray-500); font-size: 0.9rem; margin-bottom: 1.5rem; }
      .upgrade-plans { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; max-width: 500px; margin: 0 auto; }
      .plan-option { border: 1px solid var(--gray-200); border-radius: 14px; padding: 1.25rem; cursor: pointer; transition: all 0.2s; text-decoration: none; color: inherit; display: block; }
      .plan-option:hover { border-color: var(--blue); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(74,144,217,0.1); }
      .plan-option .plan-name { font-weight: 700; font-size: 1rem; color: var(--gray-900); }
      .plan-option .plan-price { font-size: 1.5rem; font-weight: 800; margin: 0.5rem 0 0.25rem; }
      .plan-option .plan-price.blue { color: var(--blue); }
      .plan-option .plan-price.purple { color: #5BA0E9; }
      .plan-option .plan-period { font-size: 0.75rem; color: var(--gray-500); }
      .plan-option .plan-feat { font-size: 0.8rem; color: var(--gray-600); margin-top: 0.75rem; line-height: 1.5; }
      .plan-option.current { opacity: 0.5; pointer-events: none; }
      .plan-option.current .plan-name::after { content: ' (aktuell)'; font-weight: 400; font-size: 0.8rem; color: var(--gray-400); }
      .app-cta { margin-top: 1rem; font-size: 0.8rem; color: var(--gray-400); }
      .app-cta a { color: var(--blue); text-decoration: none; font-weight: 600; }

      /* Loading */
      .loading { text-align: center; padding: 4rem 2rem; color: var(--gray-400); font-size: 0.9rem; }
      .spinner { width: 32px; height: 32px; border: 3px solid var(--gray-200); border-top-color: var(--blue); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
      @keyframes spin { to { transform: rotate(360deg); } }

      @media (max-width: 640px) {
        .stats-grid { grid-template-columns: 1fr 1fr; }
        .upgrade-plans { grid-template-columns: 1fr; }
        .account-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
      }
    </style>
  </Fragment>

  <div class="account-container">
    <div id="loading" class="loading">
      <div class="spinner"></div>
      Laden...
    </div>

    <div id="account-content" style="display:none;">
      <div class="account-header">
        <h1>Mein Konto</h1>
        <button class="btn-logout" id="btn-logout">Abmelden</button>
      </div>

      <!-- Subscription status -->
      <div class="sub-card" id="sub-card">
        <div class="sub-top">
          <div class="sub-icon" id="sub-icon">
            <svg id="icon-zap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            <svg id="icon-sparkles" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
            <svg id="icon-crown" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"/><path d="M5.5 21h13"/></svg>
          </div>
          <div class="sub-info">
            <h2 id="sub-plan-name">Kostenlos</h2>
            <span class="sub-badge free" id="sub-badge">Kostenlos</span>
          </div>
        </div>
        <div class="sub-email" id="sub-email"></div>
      </div>

      <!-- Stats -->
      <h3 class="stats-title">Ihre Statistiken</h3>
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-value blue" id="stat-sessions">-</div>
          <div class="stat-label">Trainings</div>
        </div>
        <div class="stat-card">
          <div class="stat-value blue" id="stat-exercises">-</div>
          <div class="stat-label">&Uuml;bungen</div>
        </div>
        <div class="stat-card">
          <div class="stat-value blue" id="stat-volume">-</div>
          <div class="stat-label">Gesamtvolumen (kg)</div>
        </div>
      </div>

      <!-- Recent sessions -->
      <h3 class="recent-title">Letzte Trainingseinheiten</h3>
      <div id="recent-sessions"></div>

      <!-- Personal records -->
      <h3 class="pr-title">Pers&ouml;nliche Rekorde</h3>
      <div id="personal-records"></div>

      <!-- Profile summary -->
      <h3 class="profile-title">Mein Profil</h3>
      <div id="profile-summary"></div>

      <!-- Upgrade -->
      <div class="upgrade-card" id="upgrade-card">
        <h3 id="upgrade-title">Upgrade Ihren Plan</h3>
        <p id="upgrade-desc">Schalten Sie das volle Potenzial Ihres KI-Coaches frei.</p>
        <div class="upgrade-plans" id="upgrade-plans">
          <div class="plan-option" id="plan-pro">
            <div class="plan-name">Pro</div>
            <div class="plan-price blue">6,99&euro;</div>
            <div class="plan-period">/ Monat</div>
            <div class="plan-feat">250 KI-Nachrichten / Monat<br>Trainingsgenerierung<br>Pl&auml;ne bis 12 Wochen<br>Erweiterte Analysen</div>
          </div>
        </div>
        <p class="app-cta">Abonnieren Sie direkt &uuml;ber die <a href="https://apps.apple.com/de/app/aivancepro/id6756116760" target="_blank" rel="noopener">mobile App</a></p>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script is:inline>
  (function() {
    var SUPABASE_URL = 'https://vzmtvhcvyqzkmestdbko.supabase.co';
    var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ6bXR2aGN2eXF6a21lc3RkYmtvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA4OTA0MTEsImV4cCI6MjA4NjQ2NjQxMX0.rvBz2uIsr3YtLIw84Kor3eVFpH4FiXVZgbufiJH3uio';
    var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

    async function init() {
      var res = await sb.auth.getSession();
      if (!res.data.session) {
        window.location.href = '/de/login/';
        return;
      }

      var user = res.data.session.user;
      var email = user.email;

      // Fetch profile
      var profileRes = await sb.from('public_profile').select('*').eq('user_email', email).single();
      var profile = profileRes.data || {};
      var plan = profile.subscription_status || 'free';

      // Show content
      document.getElementById('loading').style.display = 'none';
      document.getElementById('account-content').style.display = 'block';

      // Set subscription info
      document.getElementById('sub-email').textContent = email;
      var planNames = { free: 'Kostenlos', pro: 'Pro', trial: 'Kostenlose Testphase' };
      var planBadges = { free: 'Kostenlos', pro: 'Pro', trial: 'Test' };
      document.getElementById('sub-plan-name').textContent = planNames[plan] || 'Kostenlos';

      var badge = document.getElementById('sub-badge');
      badge.textContent = planBadges[plan] || 'Kostenlos';
      badge.className = 'sub-badge ' + plan;

      var subCard = document.getElementById('sub-card');
      var subIcon = document.getElementById('sub-icon');
      subCard.className = 'sub-card ' + plan;
      subIcon.className = 'sub-icon ' + plan;

      // Trial info
      if (plan === 'trial') {
        var trialEnd = profile.trial_end_date;
        var trialMsg = 'Sie genie\u00dfen derzeit die kostenlose Testphase mit Zugang zu allen Pro-Funktionen.';
        if (trialEnd) {
          var endDate = new Date(trialEnd);
          var now = new Date();
          var daysLeft = Math.max(0, Math.ceil((endDate - now) / (1000 * 60 * 60 * 24)));
          trialMsg += ' <strong>Noch ' + daysLeft + ' Tag' + (daysLeft > 1 ? 'e' : '') + '</strong>.';
        }
        var trialDiv = document.createElement('div');
        trialDiv.className = 'trial-info';
        trialDiv.innerHTML = trialMsg;
        document.getElementById('sub-card').appendChild(trialDiv);
      }

      // Icons
      document.getElementById('icon-zap').style.display = plan === 'free' ? 'block' : 'none';
      document.getElementById('icon-sparkles').style.display = (plan === 'pro' || plan === 'trial') ? 'block' : 'none';
      document.getElementById('icon-crown').style.display = 'none';

      // Upgrade card
      var upgradeCard = document.getElementById('upgrade-card');
      if (plan === 'pro') {
        upgradeCard.innerHTML = '<h3>Sie sind Pro!</h3><p>Sie haben Zugang zu allen AIVancePro-Funktionen.</p>';
      } else if (plan === 'trial') {
        document.getElementById('upgrade-title').textContent = 'Nach der Testphase weitermachen';
        document.getElementById('upgrade-desc').textContent = 'W\u00e4hlen Sie Ihr Abo, um Ihre Vorteile nach der Testphase zu behalten.';
      }

      // Fetch stats
      var sessionsRes = await sb.from('session').select('*').eq('created_by', email).order('created_at', { ascending: false });
      var sessions = sessionsRes.data || [];
      document.getElementById('stat-sessions').textContent = sessions.length;

      var logsRes = await sb.from('exercise_log').select('id, sets, exercise_name, created_at', { count: 'exact' }).eq('created_by', email);
      var logs = logsRes.data || [];
      document.getElementById('stat-exercises').textContent = logsRes.count || logs.length;

      var totalVolume = 0;
      logs.forEach(function(log) {
        if (log.sets && Array.isArray(log.sets)) {
          log.sets.forEach(function(s) {
            totalVolume += (parseFloat(s.weight) || 0) * (parseInt(s.reps) || 0);
          });
        }
      });
      if (totalVolume >= 1000000) document.getElementById('stat-volume').textContent = (totalVolume / 1000000).toFixed(1) + 'M';
      else if (totalVolume >= 1000) document.getElementById('stat-volume').textContent = Math.round(totalVolume / 1000) + 'k';
      else document.getElementById('stat-volume').textContent = Math.round(totalVolume);

      // Recent sessions
      var recentEl = document.getElementById('recent-sessions');
      if (sessions.length === 0) {
        recentEl.innerHTML = '<div class="recent-empty">Noch keine Trainingseinheiten. Starte dein erstes Workout in der App!</div>';
      } else {
        var html = '<div class="recent-list">';
        sessions.slice(0, 5).forEach(function(s) {
          var d = new Date(s.created_at);
          var dateStr = d.toLocaleDateString('de-DE', { day: 'numeric', month: 'short', year: 'numeric' });
          var name = s.name || s.title || 'Training';
          var duration = s.duration_minutes ? s.duration_minutes + ' Min' : '';
          var muscles = s.target_muscles ? (Array.isArray(s.target_muscles) ? s.target_muscles.join(', ') : s.target_muscles) : '';
          var meta = [dateStr, duration, muscles].filter(Boolean).join(' \u00b7 ');
          html += '<div class="recent-item"><div class="recent-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5h11v11h-11z"/><path d="M6.5 6.5L2 2m4.5 15.5L2 22m15.5-4.5L22 22m-4.5-15.5L22 2"/></svg></div><div class="recent-info"><div class="recent-name">' + name + '</div><div class="recent-meta">' + meta + '</div></div></div>';
        });
        recentEl.innerHTML = html + '</div>';
      }

      // Personal records
      var prEl = document.getElementById('personal-records');
      var prs = profile.personal_records || {};
      var prKeys = Object.keys(prs);
      if (prKeys.length === 0) {
        prEl.innerHTML = '<div class="pr-empty">Noch keine Rekorde. Trainiere weiter!</div>';
      } else {
        var prHtml = '<div class="pr-grid">';
        prKeys.slice(0, 6).forEach(function(exName) {
          var pr = prs[exName];
          var val = typeof pr === 'object' && pr !== null ? (pr.weight ? pr.weight + ' kg' : pr.reps ? pr.reps + ' Wdh' : JSON.stringify(pr)) : pr + ' kg';
          prHtml += '<div class="pr-card"><div class="pr-exercise">' + exName + '</div><div class="pr-value">' + val + '</div></div>';
        });
        prEl.innerHTML = prHtml + '</div>';
      }

      // Profile summary
      var profEl = document.getElementById('profile-summary');
      var goalLabels = { muscle_gain: 'Muskelaufbau', fat_loss: 'Fettabbau', strength: 'Kraft', endurance: 'Ausdauer', general_fitness: 'Allgemeine Fitness', recomposition: 'Rekomposition' };
      var levelLabels = { beginner: 'Anf\u00e4nger', intermediate: 'Fortgeschritten', advanced: 'Profi' };
      var items = [];
      if (profile.primary_goal) items.push({ label: 'Ziel', value: goalLabels[profile.primary_goal] || profile.primary_goal });
      if (profile.experience_level) items.push({ label: 'Niveau', value: levelLabels[profile.experience_level] || profile.experience_level });
      if (profile.training_frequency) items.push({ label: 'H\u00e4ufigkeit', value: profile.training_frequency + 'x / Woche' });
      if (profile.session_duration) items.push({ label: 'Dauer', value: profile.session_duration + ' Min' });
      if (profile.weight) items.push({ label: 'Gewicht', value: profile.weight + ' kg' });
      if (profile.height) items.push({ label: 'Gr\u00f6\u00dfe', value: profile.height + ' cm' });
      if (profile.available_equipment && profile.available_equipment.length > 0) items.push({ label: 'Ausr\u00fcstung', value: profile.available_equipment.join(', ') });
      if (items.length === 0) {
        profEl.innerHTML = '<div class="pr-empty">Profil nicht eingerichtet. Vervollst\u00e4ndige dein Profil in der App.</div>';
      } else {
        var profHtml = '<div class="profile-grid">';
        items.forEach(function(it) { profHtml += '<div class="profile-item"><div class="profile-item-label">' + it.label + '</div><div class="profile-item-value">' + it.value + '</div></div>'; });
        profEl.innerHTML = profHtml + '</div>';
      }

      // Logout
      document.getElementById('btn-logout').addEventListener('click', async function() {
        await sb.auth.signOut();
        window.location.href = '/de/';
      });
    }

    init();
  })();
  </script>
</BaseLayout>
