---

<BaseLayout
  lang="fr"
  title="À propos de Alexandre Saraiva - Fondateur AIVancePro"
  description="Découvrez Alexandre Saraiva, fondateur d'AIVancePro. Ingénieur aérospatial passionné de musculation, il crée des outils de coaching fitness intelligents et personnalisés."
  canonical="https://aivancepro.fr/about/"
  alternates={{ fr: 'https://aivancepro.fr/about/', en: 'https://aivancepro.fr/en/about/', de: 'https://aivancepro.fr/de/about/' }}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <style>
      /* ── Header ── */
      .page-header { padding: 9rem 2rem 3rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); }
      .section-label { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); margin-bottom: 0.75rem; }
      .page-header h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; color: var(--gray-900); }
      .page-header p { color: var(--gray-500); font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.7; }

      /* ── Layout ── */
      .about-content { max-width: 800px; margin: 0 auto; padding: 3rem 2rem 4rem; }

      /* ── Author card ── */
      .author-card { display: flex; gap: 2rem; align-items: flex-start; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 20px; padding: 2.5rem; margin-bottom: 2.5rem; }
      .author-avatar { width: 120px; height: 120px; border-radius: 50%; background: var(--blue); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #fff; font-size: 2.5rem; font-weight: 800; }
      .author-info h2 { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.25rem; }
      .author-role { color: var(--blue); font-weight: 600; font-size: 0.95rem; margin-bottom: 0.75rem; }
      .author-bio { color: var(--gray-600); font-size: 0.95rem; line-height: 1.7; text-align: justify; }
      .author-contact { margin-top: 0.75rem; font-size: 0.9rem; color: var(--gray-500); }
      .author-contact a { color: var(--blue); text-decoration: none; font-weight: 500; }
      .author-contact a:hover { text-decoration: underline; }
      .author-socials { display: flex; gap: 0.75rem; margin-top: 1rem; }
      .author-socials a { color: var(--gray-400); transition: color 0.2s; }
      .author-socials a:hover { color: var(--blue); }
      .author-socials svg { width: 20px; height: 20px; }

      /* ── Stats band ── */
      .stats-band { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2.5rem; }
      .stat-item { background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: 16px; padding: 1.5rem 1rem; text-align: center; }
      .stat-number { font-size: 2rem; font-weight: 800; color: var(--blue); line-height: 1; margin-bottom: 0.35rem; }
      .stat-label { font-size: 0.8rem; color: var(--gray-500); font-weight: 500; }

      /* ── Timeline ── */
      .timeline-section { margin-bottom: 2.5rem; }
      .timeline-section h2 { font-size: 1.4rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1.5rem; }
      .timeline { position: relative; padding-left: 2rem; }
      .timeline::before { content: ''; position: absolute; left: 7px; top: 6px; bottom: 6px; width: 2px; background: var(--gray-200); }
      .timeline-item { position: relative; margin-bottom: 1.75rem; }
      .timeline-item:last-child { margin-bottom: 0; }
      .timeline-dot { position: absolute; left: -2rem; top: 4px; width: 16px; height: 16px; border-radius: 50%; background: var(--blue); border: 3px solid var(--bg); box-shadow: 0 0 0 2px var(--blue); flex-shrink: 0; }
      .timeline-date { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--blue); margin-bottom: 0.2rem; }
      .timeline-title { font-size: 1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.2rem; }
      .timeline-desc { font-size: 0.9rem; color: var(--gray-500); line-height: 1.6; }

      /* ── Generic sections ── */
      .about-section { margin-bottom: 2.5rem; }
      .about-section h2 { font-size: 1.4rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1rem; }
      .about-section p { color: var(--gray-600); font-size: 0.95rem; line-height: 1.8; margin-bottom: 1rem; text-align: justify; }
      .about-section ul { padding-left: 1.5rem; margin-bottom: 1rem; }
      .about-section li { color: var(--gray-600); font-size: 0.95rem; line-height: 1.8; margin-bottom: 0.5rem; }
      .about-section a { color: var(--blue); text-decoration: underline; }
      .about-section .social-card, .about-section .social-card * { text-decoration: none; color: inherit; }
      .about-section strong { color: var(--gray-900); }

      /* ── Expertise grid ── */
      .expertise-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
      .expertise-item { background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: 12px; padding: 1.25rem; text-align: center; }
      .expertise-item .icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
      .expertise-item h3 { font-size: 0.95rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.25rem; }
      .expertise-item p { font-size: 0.85rem; color: var(--gray-500); margin: 0; text-align: center; }

      /* ── Tech stack ── */
      .tech-grid { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1rem; }
      .tech-badge { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: 8px; padding: 0.4rem 0.8rem; font-size: 0.85rem; font-weight: 600; color: var(--gray-700); }
      .tech-badge .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
      .dot-blue { background: #3B82F6; }
      .dot-green { background: #22C55E; }
      .dot-purple { background: #A855F7; }
      .dot-orange { background: #F97316; }
      .dot-pink { background: #EC4899; }
      .dot-teal { background: #14B8A6; }
      .dot-yellow { background: #EAB308; }
      .dot-red { background: #EF4444; }

      /* ── FAQ (same style as homepage) ── */
      .about-faq .faq-item { border-bottom: 1px solid var(--border); }
      .about-faq .faq-question { width: 100%; background: none; border: none; text-align: left; padding: 1.25rem 0; font-size: 1rem; font-weight: 500; color: var(--gray-500); cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-family: inherit; transition: color 0.2s; gap: 1rem; }
      .about-faq .faq-question:hover { color: var(--gray-900); }
      .about-faq .faq-question .faq-icon { width: 24px; height: 24px; flex-shrink: 0; position: relative; display: flex; align-items: center; justify-content: center; }
      .about-faq .faq-question .faq-icon::before, .about-faq .faq-question .faq-icon::after { content: ''; position: absolute; background: var(--gray-400); transition: transform 0.3s, opacity 0.3s; }
      .about-faq .faq-question .faq-icon::before { width: 16px; height: 2px; }
      .about-faq .faq-question .faq-icon::after { width: 2px; height: 16px; }
      .about-faq .faq-item.open .faq-question .faq-icon::after { transform: rotate(90deg); opacity: 0; }
      .about-faq .faq-item.open .faq-question { color: var(--gray-900); font-weight: 600; }
      .about-faq .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
      .about-faq .faq-answer-inner { padding: 0 0 1.5rem; font-size: 0.95rem; color: var(--gray-500); line-height: 1.7; }
      .about-faq .faq-item.open .faq-answer { max-height: 500px; }

      /* ── Social section ── */
      .social-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-top: 1rem; }
      .social-card { display: flex; align-items: center; gap: 0.75rem; background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: 12px; padding: 0.9rem 1rem; text-decoration: none; transition: border-color 0.2s, transform 0.2s; }
      .social-card:hover { border-color: var(--blue); transform: translateY(-2px); }
      .social-card svg { width: 20px; height: 20px; color: var(--gray-500); flex-shrink: 0; }
      .social-card:hover svg { color: var(--blue); }
      .social-card-name { font-size: 0.9rem; font-weight: 600; color: var(--gray-800); text-decoration: none; }
      .social-card-handle { font-size: 0.75rem; color: var(--gray-400); text-decoration: none; }

      /* ── Contact ── */
      .contact-box { background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: 16px; padding: 1.5rem; display: flex; align-items: center; gap: 1rem; margin-top: 1rem; }
      .contact-icon { width: 44px; height: 44px; background: var(--blue); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .contact-icon svg { width: 20px; height: 20px; color: #fff; }
      .contact-text strong { display: block; font-size: 0.95rem; color: var(--gray-900); margin-bottom: 0.2rem; }
      .contact-text a { color: var(--blue); text-decoration: none; font-size: 0.9rem; }
      .contact-text a:hover { text-decoration: underline; }

      /* ── CTA box ── */
      .cta-box { background: var(--blue); border-radius: 20px; padding: 2.5rem; text-align: center; color: #fff; margin-top: 3rem; }
      .cta-box h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.75rem; color: #fff; }
      .cta-box p { opacity: 0.9; margin-bottom: 0; font-size: 0.95rem; }
      .cta-box .store-badge-link { background: rgba(255,255,255,0.15); box-shadow: none; border: 1px solid rgba(255,255,255,0.3); }
      .cta-box .store-badge-link:hover { background: rgba(255,255,255,0.25); box-shadow: none; }

      .back { display: inline-block; margin-top: 2rem; color: var(--gray-500); text-decoration: none; font-size: 0.9rem; }
      .back:hover { color: var(--gray-900); }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .page-header { padding: 7rem 1.5rem 2rem; }
        .page-header h1 { font-size: 2rem; }
        .author-card { flex-direction: column; align-items: center; text-align: center; }
        .author-bio { text-align: left; }
        .author-socials { justify-content: center; }
        .stats-band { grid-template-columns: repeat(2, 1fr); }
        .social-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 480px) {
        .stats-band { grid-template-columns: repeat(2, 1fr); }
        .social-grid { grid-template-columns: 1fr 1fr; }
      }
    </style>
  </Fragment>

