---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = 'fr';
const starSvg = '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';

const reviews = [
  {
    text: "&laquo; Le coach IA est incroyable, il comprend exactement ce dont j'ai besoin et g&eacute;n&egrave;re des s&eacute;ances parfaitement adapt&eacute;es. J'ai progress&eacute; plus en 2 mois qu'en 1 an tout seul. &raquo;",
    author: "Thomas L.",
    source: "App Store",
  },
  {
    text: "&laquo; L'app est super compl&egrave;te : exercices, templates, suivi de progression, communaut&eacute;... Tout y est. Et le timer de repos automatique, c'est un vrai plus en salle. &raquo;",
    author: "Marie D.",
    source: "App Store",
  },
  {
    text: "&laquo; J'utilise AIVancePro depuis 3 mois et les d&eacute;fis entre amis rendent l'entra&icirc;nement tellement plus fun. Le syst&egrave;me de badges motive &agrave; rester r&eacute;gulier. Top ! &raquo;",
    author: "Julien R.",
    source: "Google Play",
  },
];
---

<BaseLayout
  lang={lang}
  title="Avis utilisateurs - AIVancePro"
  description="D&eacute;couvrez les avis des utilisateurs d'AIVancePro. Des milliers de sportifs font confiance &agrave; notre coach IA pour leur entra&icirc;nement."
  canonical="https://aivancepro.fr/avis/"
  alternates={{ fr: 'https://aivancepro.fr/avis/', en: 'https://aivancepro.fr/en/reviews/', de: 'https://aivancepro.fr/de/bewertungen/' }}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "AIVancePro",
      "operatingSystem": "iOS, Android",
      "applicationCategory": "HealthApplication",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "bestRating": "5",
        "ratingCount": "150",
        "reviewCount": "3"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Thomas L." },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "Le coach IA est incroyable, il comprend exactement ce dont j'ai besoin et g\u00e9n\u00e8re des s\u00e9ances parfaitement adapt\u00e9es. J'ai progress\u00e9 plus en 2 mois qu'en 1 an tout seul."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Marie D." },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "L'app est super compl\u00e8te : exercices, templates, suivi de progression, communaut\u00e9... Tout y est. Et le timer de repos automatique, c'est un vrai plus en salle."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Julien R." },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "J'utilise AIVancePro depuis 3 mois et les d\u00e9fis entre amis rendent l'entra\u00eenement tellement plus fun. Le syst\u00e8me de badges motive \u00e0 rester r\u00e9gulier. Top !"
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://aivancepro.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Avis", "item": "https://aivancepro.fr/avis/" }
      ]
    }
  ]}
>
  <Fragment slot="head">
    <style>
      .reviews-hero {
          padding: 8rem 2rem 4rem;
          text-align: center;
          background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
      }
      .reviews-hero h1 {
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: -0.03em;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .reviews-hero p {
          font-size: 1.15rem;
          color: var(--gray-500);
          max-width: 600px;
          margin: 0 auto;
      }
      .reviews-section {
          padding: 3rem 2rem 6rem;
          background: var(--bg-alt);
      }
      .reviews-inner {
          max-width: 1100px;
          margin: 0 auto;
          text-align: center;
      }
      .reviews-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 1.5rem;
          margin-bottom: 2.5rem;
      }
      .review-card {
          background: var(--bg-card);
          border: 1px solid var(--border);
          border-radius: 16px;
          padding: 1.75rem;
          text-align: left;
          transition: transform 0.2s, box-shadow 0.2s;
      }
      .review-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 8px 30px rgba(0,0,0,0.12);
      }
      .review-stars {
          display: flex;
          gap: 2px;
          margin-bottom: 1rem;
      }
      .review-stars :global(svg) {
          width: 18px;
          height: 18px;
          color: #FBBF24;
      }
      .review-text {
          font-size: 0.95rem;
          color: var(--gray-700);
          line-height: 1.7;
          margin-bottom: 1.25rem;
      }
      .review-author {
          font-size: 0.85rem;
          font-weight: 600;
          color: var(--gray-900);
      }
      .review-source {
          font-size: 0.75rem;
          color: var(--gray-400);
          margin-top: 0.15rem;
      }
      .review-cta {
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          color: var(--blue);
          font-weight: 600;
          font-size: 0.95rem;
          text-decoration: none;
          transition: opacity 0.2s;
      }
      .review-cta:hover { opacity: 0.8; }
      .review-cta svg { width: 18px; height: 18px; }

      @media (max-width: 768px) {
          .reviews-hero h1 { font-size: 2rem; }
          .reviews-grid { grid-template-columns: 1fr; }
      }
    </style>
  </Fragment>

  <section class="reviews-hero">
      <h1>Avis utilisateurs</h1>
      <p>Des milliers de sportifs font confiance &agrave; AIVancePro pour leur entra&icirc;nement. D&eacute;couvrez ce qu'ils en pensent.</p>
  </section>

  <section class="reviews-section">
      <div class="reviews-inner">
          <div class="reviews-grid">
              {reviews.map((review, i) => (
                  <div class="review-card">
                      <div class="review-stars" set:html={starSvg.repeat(5)} />
                      <p class="review-text" set:html={review.text} />
                      <div class="review-author">{review.author}</div>
                      <div class="review-source">{review.source}</div>
                  </div>
              ))}
          </div>

          <a href="https://apps.apple.com/fr/app/aivancepro/id6756116760?action=write-review" class="review-cta" target="_blank" rel="noopener">
              Laisser un avis sur l'App Store
              <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </a>
      </div>
  </section>
</BaseLayout>
