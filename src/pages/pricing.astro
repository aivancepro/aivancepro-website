---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="fr"
  title="Tarifs - AIVancePro | Plans Gratuit et Pro"
  description="Découvrez les tarifs AIVancePro. Plan Gratuit et Pro à 6,99€/mois. Comparez les fonctionnalités et choisissez votre plan."
  canonical="https://aivancepro.fr/pricing/"
  alternates={{ fr: 'https://aivancepro.fr/pricing/', en: 'https://aivancepro.fr/en/pricing/', de: 'https://aivancepro.fr/de/preise/' }}
  jsonLd={[
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [
        { '@type': 'Question', name: 'Puis-je changer de plan à tout moment ?', acceptedAnswer: { '@type': 'Answer', text: 'Oui, vous pouvez passer au plan Pro ou revenir au plan Gratuit à tout moment. Le changement prend effet immédiatement.' } },
        { '@type': 'Question', name: 'Y a-t-il un engagement ?', acceptedAnswer: { '@type': 'Answer', text: "Aucun engagement. Vous pouvez annuler votre abonnement à tout moment depuis l'App Store ou Google Play." } },
        { '@type': 'Question', name: 'Le plan Gratuit est-il vraiment gratuit ?', acceptedAnswer: { '@type': 'Answer', text: 'Absolument. Le plan Gratuit vous donne accès au suivi de séances, aux +240 exercices et aux statistiques de base, sans limite de temps et sans carte bancaire.' } },
        { '@type': 'Question', name: 'Comment fonctionne le paiement ?', acceptedAnswer: { '@type': 'Answer', text: "Le paiement est géré directement par l'App Store (iOS) ou Google Play (Android). Votre abonnement se renouvelle automatiquement chaque mois sauf annulation." } },
      ]
    },
    {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://aivancepro.fr/' },
        { '@type': 'ListItem', position: 2, name: 'Tarifs', item: 'https://aivancepro.fr/pricing/' },
      ]
    }
  ]}
>
  <Fragment slot="head">
    <style>
      .pricing-hero {
          padding: 8rem 2rem 4rem;
          text-align: center;
          background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
      }
      .pricing-hero h1 {
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: -0.03em;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .pricing-hero h1 .gradient {
          color: inherit;
      }
      .pricing-hero p {
          font-size: 1.15rem;
          color: var(--gray-500);
          max-width: 550px;
          margin: 0 auto;
      }
      .pricing-section { padding: 3rem 2rem 5rem; }
      .pricing-grid {
          max-width: 1100px;
          margin: 0 auto;
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          max-width: 800px;
          gap: 2rem;
          align-items: start;
      }
      .pricing-card {
          background: var(--bg-card);
          border: 1px solid var(--gray-200);
          border-radius: 20px;
          padding: 2.5rem;
          position: relative;
          transition: transform 0.2s, box-shadow 0.2s;
      }
      .pricing-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
      }
      .pricing-card.featured {
          border-color: var(--blue);
          box-shadow: 0 8px 30px rgba(74, 144, 217, 0.1);
      }
      .pricing-card.featured::before {
          content: 'Populaire';
          position: absolute;
          top: -12px;
          left: 50%;
          transform: translateX(-50%);
          background: var(--blue);
          color: var(--white);
          font-size: 0.75rem;
          font-weight: 700;
          padding: 0.3rem 1rem;
          border-radius: 50px;
      }
      .plan-name { font-size: 1.1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.5rem; }
      .price { font-size: 3rem; font-weight: 800; color: var(--gray-900); letter-spacing: -0.03em; }
      .price span { font-size: 1rem; font-weight: 500; color: var(--gray-500); }
      .price-desc { font-size: 0.85rem; color: var(--gray-500); margin-bottom: 2rem; }
      .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; }
      .pricing-features li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; color: var(--gray-700); }
      .pricing-features li svg { width: 18px; height: 18px; color: var(--blue); flex-shrink: 0; }
      .pricing-features li.disabled { color: var(--gray-400); }
      .pricing-features li.disabled svg { color: var(--gray-300); }
      .btn-pricing { display: block; width: 100%; text-align: center; padding: 0.875rem; border-radius: 12px; font-size: 0.95rem; font-weight: 600; text-decoration: none; transition: all 0.2s; }
      .btn-pricing.primary { background: var(--blue); color: var(--white); box-shadow: 0 4px 15px rgba(74, 144, 217, 0.25); }
      .btn-pricing.primary:hover { opacity: 0.92; transform: translateY(-2px); }
      .btn-pricing.outline { background: var(--bg-elevated); color: var(--text); border: 1px solid var(--border-light); }
      .btn-pricing.outline:hover { border-color: var(--blue); color: var(--blue); }
      .comparison-section { padding: 5rem 2rem; background: var(--bg-card); }
      .comparison-section h2 { text-align: center; font-size: 2rem; font-weight: 800; margin-bottom: 3rem; color: var(--gray-900); }
      .comparison-table { max-width: 900px; margin: 0 auto; border-collapse: collapse; width: 100%; background: var(--bg-card); border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2); }
      .comparison-table th, .comparison-table td { padding: 1rem 1.25rem; text-align: center; border-bottom: 1px solid var(--gray-100); font-size: 0.9rem; }
      .comparison-table th { background: var(--bg-elevated); color: var(--text); font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
      .comparison-table th:first-child { text-align: left; }
      .comparison-table td:first-child { text-align: left; font-weight: 500; color: var(--gray-700); }
      .comparison-table tr:last-child td { border-bottom: none; }
      .comparison-table .check { color: var(--green); font-size: 1.2rem; }
      .comparison-table .cross { color: var(--gray-300); font-size: 1rem; }
      .faq-section { padding: 5rem 2rem; }
      .faq-section h2 { text-align: center; font-size: 2rem; font-weight: 800; margin-bottom: 3rem; color: var(--gray-900); }
      .faq-list { max-width: 700px; margin: 0 auto; }
      .faq-item { border-bottom: 1px solid var(--gray-200); }
      .faq-question { width: 100%; background: none; border: none; text-align: left; padding: 1.5rem 0; font-size: 1.05rem; font-weight: 600; color: var(--gray-900); cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-family: inherit; transition: color 0.2s; }
      .faq-question:hover { color: var(--blue); }
      .faq-question svg { width: 20px; height: 20px; color: var(--gray-400); transition: transform 0.3s; flex-shrink: 0; }
      .faq-item.open .faq-question svg { transform: rotate(180deg); }
      .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
      .faq-answer-inner { padding: 0 0 1.5rem; font-size: 0.95rem; color: var(--gray-500); line-height: 1.7; }
      .faq-item.open .faq-answer { max-height: 300px; }
      @media (max-width: 768px) {
          .pricing-hero { padding: 7rem 1.25rem 3rem; }
          .pricing-hero h1 { font-size: 2.2rem; }
          .pricing-hero p { font-size: 1rem; }
          .pricing-section { padding: 2rem 1.25rem 4rem; }
          .pricing-grid { grid-template-columns: 1fr; max-width: 420px; }
          .pricing-card { padding: 2rem; }
          .comparison-section { padding: 3rem 1.25rem; }
          .comparison-section h2 { font-size: 1.7rem; margin-bottom: 2rem; }
          .comparison-table-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; border-radius: 16px; }
          .comparison-table { font-size: 0.8rem; min-width: 500px; }
          .comparison-table th, .comparison-table td { padding: 0.75rem 0.5rem; }
          .faq-section { padding: 3rem 1.25rem; }
          .faq-section h2 { font-size: 1.7rem; margin-bottom: 2rem; }
          .faq-question { font-size: 0.95rem; padding: 1.25rem 0; }
      }
      @media (max-width: 480px) {
          .pricing-hero { padding: 6.5rem 1rem 2.5rem; }
          .pricing-hero h1 { font-size: 1.8rem; }
          .pricing-section { padding: 1.5rem 1rem 3rem; }
          .pricing-card { padding: 1.5rem; }
          .comparison-section { padding: 2.5rem 1rem; }
          .faq-section { padding: 2.5rem 1rem; }
      }
    </style>
  </Fragment>

    <!-- Hero -->
    <section class="pricing-hero">
        <h1>Choisissez votre <span class="gradient">plan</span></h1>
        <p>7 jours de fonctionnalit&eacute;s Pro offerts &agrave; l'inscription. Premier mois &agrave; -50%.</p>
    </section>

    <!-- Pricing Cards -->
    <section class="pricing-section">
