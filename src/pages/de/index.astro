    <script is:inline>
    // Mobile testimonials carousel
    (function() {
      if (window.innerWidth > 768) return;
      var grid = document.querySelector('.testimonials-grid');
      var track = document.querySelector('.testimonials-track');
      if (!grid || !track) return;
      var cards = grid.querySelectorAll('.testimonial-card');
      var slider = track.querySelector('.testimonials-slider');
      if (!slider || !cards.length) return;
      cards.forEach(function(card) {
        var clone = card.cloneNode(true);
        clone.style.minWidth = '100%';
        clone.style.flex = '0 0 100%';
        slider.appendChild(clone);
      });
      grid.style.display = 'none';
      track.style.display = 'block';
    })();
    </script>

    <script is:inline>
    (function() {
      if (window.innerWidth > 768) return;
      var container = document.querySelector('.hero-phones');
      if (!container) return;
      var phones = container.querySelectorAll('.phone');
      if (phones.length < 2) return;
      var idx = 0;
      var paused = false;
      var timer;
      function scrollTo(i) {
        idx = i;
        phones[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      }
      function next() {
        if (paused) return;
        idx = (idx + 1) % phones.length;
        scrollTo(idx);
      }
      timer = setInterval(next, 3000);
      container.addEventListener('touchstart', function() {
        paused = true;
        clearInterval(timer);
      });
      container.addEventListener('touchend', function() {
        paused = false;
        timer = setInterval(next, 3000);
      });
    })();
    </script>

