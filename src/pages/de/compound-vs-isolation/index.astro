        .article-content h2 { font-size: 1.6rem; font-weight: 800; margin: 3rem 0 1rem; }
        .article-content h3 { font-size: 1.2rem; font-weight: 700; margin: 2rem 0 0.75rem; }
        .article-content p { color: var(--gray-700); font-size: 1rem; line-height: 1.8; margin-bottom: 1.25rem; }
        .article-content ul { margin: 1rem 0 1.5rem 1.5rem; }
        .article-content li { color: var(--gray-700); font-size: 1rem; line-height: 1.8; margin-bottom: 0.5rem; }
