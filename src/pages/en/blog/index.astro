---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="en"
  title="Fitness &amp; Workout Blog - AIVancePro"
  description="Fitness tips, workout advice and training guides. Optimize your performance with the help of AI coaching."
  canonical="https://aivancepro.fr/en/blog/"
  alternates={{ fr: 'https://aivancepro.fr/blog/', en: 'https://aivancepro.fr/en/blog/', de: 'https://aivancepro.fr/de/blog/' }}
>
  <Fragment slot="head">
    <style>
      .blog-header {
        padding: 9rem 2rem 3rem;
        text-align: center;
        background: linear-gradient(180deg, var(--gray-50), var(--white));
      }
      .section-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--blue);
        margin-bottom: 0.75rem;
      }
      .blog-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }
      .blog-header p {
        color: var(--gray-500);
        font-size: 1.1rem;
        max-width: 550px;
        margin: 0 auto;
      }
      .category-filter {
        max-width: 900px;
        margin: 2rem auto 0;
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding: 0 2rem;
      }
      .filter-btn {
        padding: 0.4rem 1rem;
        border-radius: 50px;
        border: 1px solid var(--gray-200);
        background: var(--white);
        color: var(--gray-500);
        font-size: 0.8rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: all 0.2s;
      }
      .filter-btn:hover, .filter-btn.active {
        background: var(--blue);
        color: var(--white);
        border-color: var(--blue);
      }
      .articles {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 2rem 6rem;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
      .article-card {
        background: var(--white);
        border: 1px solid var(--gray-200);
        border-radius: 16px;
        overflow: hidden;
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        color: var(--gray-900);
        display: flex;
        flex-direction: column;
      }
      .article-card:hover {
        border-color: rgba(37, 99, 235, 0.3);
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
      }
      .article-card .card-image {
        width: 100%;
        height: 180px;
        background: linear-gradient(135deg, var(--gray-100), var(--gray-200));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gray-400);
        font-size: 0.8rem;
      }
      .article-card .card-content {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .article-card .tag {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        background: rgba(37, 99, 235, 0.06);
        border-radius: 50px;
        font-size: 0.7rem;
        color: var(--blue);
        font-weight: 600;
        margin-bottom: 0.75rem;
        width: fit-content;
      }
      .article-card h2 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.35;
      }
      .article-card p {
        color: var(--gray-500);
        font-size: 0.85rem;
        line-height: 1.6;
        flex: 1;
      }
      .article-card .meta {
        margin-top: 1rem;
        font-size: 0.75rem;
        color: var(--gray-400);
        font-weight: 500;
      }
      .article-card.featured {
        grid-column: 1 / -1;
        flex-direction: row;
      }
      .article-card.featured .card-image {
        width: 45%;
        height: auto;
        min-height: 250px;
      }
      .article-card.featured .card-content {
        padding: 2rem;
      }
      .article-card.featured h2 {
        font-size: 1.4rem;
      }
      @media (max-width: 768px) {
        .blog-header h1 { font-size: 2rem; }
        .blog-header { padding: 7rem 1.5rem 2rem; }
        .articles { grid-template-columns: 1fr; }
        .article-card.featured { flex-direction: column; }
        .article-card.featured .card-image { width: 100%; min-height: 180px; }
      }
    </style>
  </Fragment>

  <header class="blog-header">
    <div class="section-label">Blog</div>
    <h1>Fitness &amp; Workout</h1>
    <p>Tips, guides and advice to optimize your training and reach your goals.</p>
    <div class="category-filter">
      <button class="filter-btn active" onclick="filterArticles('all', this)">All</button>
      <button class="filter-btn" onclick="filterArticles('ai', this)">AI</button>
      <button class="filter-btn" onclick="filterArticles('workout', this)">Workout</button>
      <button class="filter-btn" onclick="filterArticles('nutrition', this)">Nutrition</button>
      <button class="filter-btn" onclick="filterArticles('tips', this)">Tips</button>
      <button class="filter-btn" onclick="filterArticles('programming', this)">Programming</button>
    </div>
  </header>

  <section class="articles">
    <a href="/en/blog/ai-fitness-coaching/" class="article-card featured" data-category="ai">
      <div class="card-image">Photo AI Coaching</div>
      <div class="card-content">
        <span class="tag">Artificial Intelligence</span>
        <h2>How AI is revolutionizing fitness coaching</h2>
        <p>Discover how artificial intelligence is transforming sports training by offering ultra-personalized programs adapted to each profile.</p>
        <div class="meta">February 7, 2026 &middot; 5 min read</div>
      </div>
    </a>
    <a href="/en/blog/beginner-workout-program/" class="article-card" data-category="workout">
      <div class="card-image">Photo Beginner</div>
      <div class="card-content">
        <span class="tag">Workout</span>
        <h2>Beginner workout program: where to start</h2>
        <p>New to weightlifting? Here's the complete guide to building your first effective training program.</p>
        <div class="meta">February 7, 2026 &middot; 7 min</div>
      </div>
    </a>
    <a href="/en/blog/tracking-fitness-progress/" class="article-card" data-category="tips">
      <div class="card-image">Photo Progress</div>
      <div class="card-content">
        <span class="tag">Progress</span>
        <h2>The importance of tracking fitness progress</h2>
        <p>Why tracking your progress is the key to lasting results.</p>
        <div class="meta">February 7, 2026 &middot; 5 min</div>
      </div>
    </a>
    <a href="/en/blog/workout-motivation-tips/" class="article-card" data-category="tips">
      <div class="card-image">Photo Motivation</div>
      <div class="card-content">
        <span class="tag">Motivation</span>
        <h2>5 tips to stay motivated in your training</h2>
        <p>Motivation is the fuel of athletic success. 5 concrete strategies.</p>
        <div class="meta">February 7, 2026 &middot; 4 min</div>
      </div>
    </a>
    <a href="/en/blog/home-gym-guide/" class="article-card" data-category="tips">
      <div class="card-image">Photo Home Gym</div>
      <div class="card-content">
        <span class="tag">Home Gym</span>
        <h2>Working out at home: complete guide</h2>
        <p>No gym needed to make progress. Create your training space.</p>
        <div class="meta">February 7, 2026 &middot; 6 min</div>
      </div>
    </a>
    <a href="/en/blog/periodization-training-program/" class="article-card" data-category="programming">
      <div class="card-image">Photo Periodization</div>
      <div class="card-content">
        <span class="tag">Programming</span>
        <h2>Periodization: structuring your program</h2>
        <p>Cycles, mesocycles, deload: understand everything to progress sustainably.</p>
        <div class="meta">March 3, 2026 &middot; 6 min</div>
      </div>
    </a>
    <a href="/en/blog/common-workout-mistakes/" class="article-card" data-category="workout">
      <div class="card-image">Photo Mistakes</div>
      <div class="card-content">
        <span class="tag">Tips</span>
        <h2>5 common workout mistakes</h2>
        <p>Common pitfalls that slow your progress and how to fix them.</p>
        <div class="meta">March 3, 2026 &middot; 5 min</div>
      </div>
    </a>
    <a href="/en/blog/nutrition-workout-basics/" class="article-card" data-category="nutrition">
      <div class="card-image">Photo Nutrition</div>
      <div class="card-content">
        <span class="tag">Nutrition</span>
        <h2>Nutrition and workout: the basics</h2>
        <p>Protein, carbs, fats and meal timing to support your progress.</p>
        <div class="meta">March 3, 2026 &middot; 7 min</div>
      </div>
    </a>
    <a href="/en/blog/choosing-exercises-goals/" class="article-card" data-category="workout">
      <div class="card-image">Photo Exercises</div>
      <div class="card-content">
        <span class="tag">Exercises</span>
        <h2>How to choose exercises based on your goals</h2>
        <p>Strength, hypertrophy, endurance: guide to selecting the right exercises.</p>
        <div class="meta">March 3, 2026 &middot; 6 min</div>
      </div>
    </a>
  </section>

  <script>
    function filterArticles(category, btn) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.article-card').forEach(card => {
        card.style.display = (category === 'all' || card.dataset.category === category) ? '' : 'none';
      });
    }
  </script>
</BaseLayout>
