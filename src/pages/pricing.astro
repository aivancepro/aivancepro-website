                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Acc&egrave;s communaut&eacute;</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>5 messages IA / mois</li>
                </ul>
                <a href="https://apps.apple.com/fr/app/aivancepro/id6756116760" class="btn-pricing outline" target="_blank" rel="noopener">Commencer gratuitement</a>
            </div>
            <div class="pricing-card featured">
                <div class="plan-name">Pro</div>
                <div class="price">6,99&euro; <span>/ mois</span></div>
                <div class="price-desc">D&eacute;bloquez tout le potentiel de votre entra&icirc;nement</div>
                <div style="display:inline-block;padding:0.25rem 0.75rem;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);border-radius:50px;font-size:0.75rem;font-weight:600;color:#10B981;margin-bottom:1.5rem">Premier mois &agrave; 3,49&euro; (au lieu de 6,99&euro;)</div>
                <ul class="pricing-features">
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Tout de Free +</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>250 messages IA / mois</li>
