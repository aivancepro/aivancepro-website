---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categoryLabels: Record<string, string> = {
  ai: 'AI',
  workout: 'Workout',
  nutrition: 'Nutrition',
  tips: 'Tips',
  programming: 'Programming',
};

const categoryOrder = Object.keys(categoryLabels);
const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))]
  .sort((a, b) => categoryOrder.indexOf(a!) - categoryOrder.indexOf(b!)) as string[];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  lang="en"
  title="Fitness & Workout Blog - AIVancePro"
  description="Fitness tips, workout advice and training guides. Optimize your performance with the help of AI coaching."
  canonical="https://aivancepro.fr/en/blog/"
  alternates={{ fr: 'https://aivancepro.fr/blog/', en: 'https://aivancepro.fr/en/blog/', de: 'https://aivancepro.fr/de/blog/' }}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Fitness & Workout Blog - AIVancePro",
      "url": "https://aivancepro.fr/en/blog/",
      "description": "Fitness tips, workout advice and training guides. Optimize your performance with the help of AI coaching.",
      "numberOfItems": posts.length,
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aivancepro.fr/en/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://aivancepro.fr/en/blog/" },
      ],
    },
  ]}
>
  <Fragment slot="head">
    <style>
      .blog-header {
        padding: 9rem 2rem 3rem;
        text-align: center;
        background: linear-gradient(180deg, var(--bg-card), var(--bg));
      }
      .section-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--blue);
        margin-bottom: 0.75rem;
      }
      .blog-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }
      .blog-header p {
        color: var(--text-secondary);
        font-size: 1.1rem;
        max-width: 550px;
        margin: 0 auto;
      }
      .category-filter {
        max-width: 900px;
        margin: 2rem auto 0;
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        padding: 0 2rem;
      }
      .filter-btn {
        padding: 0.4rem 1rem;
        border-radius: 50px;
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text-secondary);
        font-size: 0.8rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: all 0.2s;
      }
      .filter-btn:hover, .filter-btn.active {
        background: var(--blue);
        color: var(--white);
        border-color: var(--blue);
      }
      .articles {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 2rem 6rem;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
      .article-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        color: var(--text);
        display: flex;
        flex-direction: column;
      }
      .article-card:hover {
        border-color: var(--blue);
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(74, 144, 217, 0.1);
      }
      .article-card .card-image {
        width: 100%;
        height: 180px;
        background: linear-gradient(135deg, var(--bg-elevated), var(--border));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        font-size: 0.8rem;
      }
      .article-card .card-content {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .article-card .tag {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        background: rgba(74, 144, 217, 0.1);
        border-radius: 50px;
        font-size: 0.7rem;
        color: var(--blue);
        font-weight: 600;
        margin-bottom: 0.75rem;
        width: fit-content;
      }
      .article-card h2 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.35;
      }
      .article-card p {
        color: var(--text-secondary);
        font-size: 0.85rem;
        line-height: 1.6;
        flex: 1;
      }
      .article-card .meta {
        margin-top: 1rem;
        font-size: 0.75rem;
        color: var(--text-muted);
        font-weight: 500;
      }
      .article-card.featured {
        grid-column: 1 / -1;
        flex-direction: row;
      }
      .article-card.featured .card-image {
        width: 45%;
        height: auto;
        min-height: 250px;
      }
      .article-card.featured .card-content {
        padding: 2rem;
      }
      .article-card.featured h2 {
        font-size: 1.4rem;
      }
      @media (max-width: 768px) {
        .blog-header h1 { font-size: 2rem; }
        .blog-header { padding: 7rem 1.5rem 2rem; }
        .articles { grid-template-columns: 1fr; }
        .article-card.featured { flex-direction: column; }
        .article-card.featured .card-image { width: 100%; min-height: 180px; }
      }
    </style>
  </Fragment>

  <header class="blog-header">
    <div class="section-label">Blog</div>
    <h1>Fitness & Workout</h1>
    <p>Tips, guides and advice to optimize your training and reach your goals.</p>
    <div class="category-filter">
      <button class="filter-btn active" onclick="filterArticles('all', this)">All</button>
      {categories.map(cat => (
        <button class="filter-btn" onclick={`filterArticles('${cat}', this)`}>
          {categoryLabels[cat] || cat}
        </button>
      ))}
    </div>
  </header>

  <section class="articles">
    {posts.map((post, i) => (
      <a href={`/en/blog/${post.data.slug}/`} class={`article-card${i === 0 ? ' featured' : ''}`} data-category={post.data.category}>
        <div class="card-image">{post.data.tag}</div>
        <div class="card-content">
          <span class="tag">{post.data.tag}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="meta">{formatDate(post.data.date)} &middot; {post.data.readTime}</div>
        </div>
      </a>
    ))}
  </section>

  <script>
    function filterArticles(category, btn) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.article-card').forEach(card => {
        card.style.display = (category === 'all' || card.dataset.category === category) ? '' : 'none';
      });
    }
  </script>
</BaseLayout>
