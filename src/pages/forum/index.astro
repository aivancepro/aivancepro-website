    var svgX = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>';
    var svgFB = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>';
    var svgLinkedIn = '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>';
    var svgCopyLink = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
    var svgTranslate = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>';

    function shareDropdownHtml(postId, title) {
      var pageUrl = window.location.origin + '/forum/topic/?id=' + postId;
      var fullUrl = encodeURIComponent(pageUrl);
      var encodedTitle = encodeURIComponent(title);
      return '<div class="share-dropdown-wrap">' +
        '<button class="post-action" data-share-toggle>' + svgShare + ' ' + t.share + '</button>' +
        '<div class="share-dropdown">' +
          '<a class="share-x" href="https://x.com/intent/tweet?text=' + encodedTitle + '&url=' + fullUrl + '" target="_blank" rel="noopener" title="X / Twitter">' + svgX + '</a>' +
          '<a class="share-fb" href="https://www.facebook.com/sharer/sharer.php?u=' + fullUrl + '" target="_blank" rel="noopener" title="Facebook">' + svgFB + '</a>' +
          '<a class="share-li" href="https://www.linkedin.com/sharing/share-offsite/?url=' + fullUrl + '" target="_blank" rel="noopener" title="LinkedIn">' + svgLinkedIn + '</a>' +
          '<button class="share-copy" data-copy-url="' + pageUrl + '" title="Copier le lien">' + svgCopyLink + '</button>' +
        '</div></div>';
    }
    var svgTrash = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';

    sb.auth.getSession().then(function(res) {
      if (res.data.session) {
        currentUser = res.data.session.user;
        isAdmin = currentUser.email === ADMIN_EMAIL;
      }
      if (articleSlug) {
        document.getElementById('btnNewPost').click();
        document.getElementById('postCategory').value = 'general';
        document.getElementById('postTitle').setAttribute('placeholder', 'Votre question sur cet article...');
      }
    });

    function loadPosts(search) {
      var container = document.getElementById('forumPosts');
      container.innerHTML = '<div class="forum-loading">' + t.loading + '</div>';
      var query = sb.from('forum_posts').select('*');
      if (currentCat !== 'all') {
        if (currentCat === 'article') query = query.not('article_slug', 'is', null);
        else query = query.eq('category', currentCat);
      }
      if (search) query = query.or('title.ilike.%' + search + '%,body.ilike.%' + search + '%');
      if (currentSort === 'popular') query = query.order('upvotes', { ascending: false });
      else if (currentSort === 'unanswered') query = query.eq('reply_count', 0).order('created_at', { ascending: false });
      else query = query.order('created_at', { ascending: false });
      query = query.limit(50);

      query.then(function(res) {
        if (res.error) { container.innerHTML = '<div class="forum-empty"><h3>Erreur</h3><p>' + res.error.message + '</p></div>'; return; }
        var posts = res.data;
        if (!posts || posts.length === 0) { container.innerHTML = '<div class="forum-empty"><h3>' + t.empty + '</h3><p>' + t.emptyAction + '</p></div>'; return; }

        container.innerHTML = '';
        posts.forEach(function(post) {
          var timeAgo = formatTimeAgo(post.created_at);
          var catClass = post.article_slug ? 'article' : '';
          var catText = post.article_slug ? 'Article' : (catLabels[post.category] || post.category);
          var deleteHtml = isAdmin ? '<button class="post-action delete-action" data-delete-post="' + post.id + '">' + svgTrash + '</button>' : '';

          var thumbHtml = '';
          if (post.article_slug) {
            var guideImgMap = {
              'comprendre-rpe-intensite': 'comprendre-rpe-v2',
              'creer-programme-entrainement': 'creer-programme-v2',
              'debutant-musculation': 'debutant-musculation-v2',
              'understanding-rpe-intensity': 'comprendre-rpe-v2',
              'create-workout-plan': 'creer-programme-v2',
              'beginner-weightlifting': 'debutant-musculation-v2',
              'rpe-intensitaet-verstehen': 'comprendre-rpe-v2',
              'trainingsplan-erstellen': 'creer-programme-v2',
              'anfaenger-krafttraining': 'debutant-musculation-v2'
            };
            var imgFolder = post.article_type === 'guide' ? '/assets/guides/' : '/assets/blog/';
            var imgSlug = (post.article_type === 'guide' && guideImgMap[post.article_slug]) ? guideImgMap[post.article_slug] : post.article_slug;
            thumbHtml = '<img class="post-thumb" src="' + imgFolder + imgSlug + '.webp" onerror="this.onerror=null;this.src=\'' + imgFolder + imgSlug + '.png\';this.onerror=function(){this.style.display=\'none\'}" alt="">';
          }

          var el = document.createElement('div');
          el.className = 'forum-post';
          el.innerHTML = thumbHtml +
            '<div class="post-content"><div class="post-header">' +
              '<span class="post-tag ' + catClass + '">' + catText + '</span>' +
              '<span class="post-author">' + escapeHtml(post.author_name) + '</span>' +
              '<span>·</span><span>' + timeAgo + '</span>' +
            '</div>' +
            '<div class="post-title" id="title-' + post.id + '">' + escapeHtml(post.title) + '</div>' +
            '<div class="post-actions">' +
              '<span class="post-action votes">' + svgUp + '<span class="score">' + (post.upvotes || 0) + '</span>' + svgDown + '</span>' +
              '<span class="post-action">' + svgComment + ' ' + (post.reply_count || 0) + '</span>' +
              shareDropdownHtml(post.id, post.title) +
              '<button class="post-action translate-btn" data-translate-text="' + escapeHtml(post.title) + '" data-translate-target="title-' + post.id + '">' + svgTranslate + ' ' + t.translate + '</button>' +
              deleteHtml +
            '</div></div>';
          el.addEventListener('click', function(e) {
            if (e.target.closest('[data-delete-post]') || e.target.closest('[data-share-toggle]') || e.target.closest('.share-dropdown') || e.target.closest('.translate-btn')) return;
            window.location.href = '/forum/topic/?id=' + post.id + (LANG !== 'fr' ? '&lang=' + LANG : '');
          });
          container.appendChild(el);
        });
      });
    }

    document.getElementById('forumCategories').addEventListener('click', function(e) {
      var btn = e.target.closest('.cat-btn'); if (!btn) return;
      document.querySelectorAll('.cat-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active'); currentCat = btn.dataset.cat;
      loadPosts(document.getElementById('forumSearch').value.trim());
    });
    document.getElementById('forumSort').addEventListener('click', function(e) {
      var btn = e.target.closest('.sort-btn'); if (!btn) return;
      document.querySelectorAll('.sort-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active'); currentSort = btn.dataset.sort;
      loadPosts(document.getElementById('forumSearch').value.trim());
    });
    document.getElementById('forumSearch').addEventListener('input', function() {
      clearTimeout(searchTimeout); var val = this.value.trim();
      searchTimeout = setTimeout(function() { loadPosts(val); }, 350);
    });

    var modal = document.getElementById('newPostModal');
    document.getElementById('btnNewPost').addEventListener('click', function() {
      document.getElementById('modalAuthPrompt').style.display = currentUser ? 'none' : '';
      document.getElementById('modalPostForm').style.display = currentUser ? '' : 'none';
      modal.classList.add('open');
    });
    document.getElementById('btnCancelPost').addEventListener('click', function() { modal.classList.remove('open'); });
    modal.addEventListener('click', function(e) { if (e.target === modal) modal.classList.remove('open'); });

    // Image upload for new post
    document.getElementById('postImageInput').addEventListener('change', async function() {
      if (!this.files[0]) return;
      var preview = document.getElementById('postMediaPreview');
      preview.innerHTML = '<div style="font-size:0.8rem;color:var(--text-muted)">Upload en cours...</div>';
      try {
        postImageUrl = await uploadImage(this.files[0]);
        preview.innerHTML = '<div style="position:relative;display:inline-block;margin-top:0.5rem"><img src="' + postImageUrl + '" style="max-width:100%;max-height:200px;border-radius:10px;border:1px solid var(--border)"><button onclick="document.getElementById(\'postMediaPreview\').innerHTML=\'\';postImageUrl=null" style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:22px;height:22px;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center">&times;</button></div>';
      } catch(err) { preview.innerHTML = '<div style="font-size:0.8rem;color:#ef4444">Erreur d\'upload</div>'; }
      this.value = '';
    });

    // GIF picker for new post
    document.getElementById('postGifBtn').addEventListener('click', async function(e) {
      e.stopPropagation();
      var existing = document.getElementById('postGifPicker');
      if (existing) { existing.remove(); return; }
      var picker = document.createElement('div');
      picker.id = 'postGifPicker';
      picker.style.cssText = 'position:absolute;bottom:100%;left:0;margin-bottom:0.5rem;width:320px;max-height:360px;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,0.15);z-index:100;overflow:hidden';
      picker.innerHTML = '<input style="width:100%;padding:0.6rem 0.85rem;border:none;border-bottom:1px solid var(--border);background:none;color:var(--text);font-size:0.85rem;font-family:inherit;outline:none;box-sizing:border-box" placeholder="Rechercher un GIF..." id="postGifSearch"><div id="postGifGrid" style="display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:4px;max-height:300px;overflow-y:auto"><div style="text-align:center;padding:2rem;color:var(--text-muted);font-size:0.82rem;grid-column:span 2">Chargement...</div></div><div style="text-align:center;padding:0.3rem;font-size:0.65rem;color:var(--text-muted);border-top:1px solid var(--border)">Powered by GIPHY</div>';
      this.style.position = 'relative';
      this.appendChild(picker);
      document.getElementById('postGifSearch').focus();
      // Load trending
      var tRes = await fetch('https://api.giphy.com/v1/gifs/trending?api_key=' + GIPHY_KEY + '&limit=20&rating=g');
      var tData = await tRes.json();
      renderPostGifs((tData.data || []).map(function(g) { return { preview: g.images.fixed_width_small.url, full: g.images.original.url }; }));
      document.getElementById('postGifSearch').addEventListener('input', function() {
        var q = this.value.trim();
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(async function() {
          var url = q ? 'https://api.giphy.com/v1/gifs/search?api_key=' + GIPHY_KEY + '&q=' + encodeURIComponent(q) + '&limit=20&rating=g&lang=fr' : 'https://api.giphy.com/v1/gifs/trending?api_key=' + GIPHY_KEY + '&limit=20&rating=g';
          var r = await fetch(url); var d = await r.json();
          renderPostGifs((d.data || []).map(function(g) { return { preview: g.images.fixed_width_small.url, full: g.images.original.url }; }));
        }, 400);
      });
      picker.addEventListener('click', function(ev) { ev.stopPropagation(); });
    });
    function renderPostGifs(results) {
      var grid = document.getElementById('postGifGrid');
      if (!grid) return;
      if (!results.length) { grid.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--text-muted);font-size:0.82rem;grid-column:span 2">Aucun résultat</div>'; return; }
      grid.innerHTML = '';
      results.forEach(function(gif) {
        var img = document.createElement('img');
        img.src = gif.preview; img.loading = 'lazy';
        img.style.cssText = 'width:100%;border-radius:6px;cursor:pointer';
        img.addEventListener('click', function() {
          postImageUrl = gif.full;
          var preview = document.getElementById('postMediaPreview');
          preview.innerHTML = '<div style="position:relative;display:inline-block;margin-top:0.5rem"><img src="' + postImageUrl + '" style="max-width:100%;max-height:200px;border-radius:10px;border:1px solid var(--border)"><button onclick="document.getElementById(\'postMediaPreview\').innerHTML=\'\';postImageUrl=null" style="position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:22px;height:22px;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center">&times;</button></div>';
          var p = document.getElementById('postGifPicker'); if (p) p.remove();
        });
        grid.appendChild(img);
      });
    }
    document.addEventListener('click', function() { var p = document.getElementById('postGifPicker'); if (p) p.remove(); });

    document.getElementById('btnSubmitPost').addEventListener('click', async function() {
      var title = document.getElementById('postTitle').value.trim();
      var body = document.getElementById('postBody').value.trim();
      if (postImageUrl) body = (body ? body + '\n' : '') + postImageUrl;
      var category = document.getElementById('postCategory').value;
      var errEl = document.getElementById('postError'); var btn = this;
      if (!title || title.length < 5) { errEl.textContent = t.titleError; errEl.style.display = ''; return; }
      if (!body || body.length < 10) { errEl.textContent = t.bodyError; errEl.style.display = ''; return; }
      errEl.style.display = 'none'; btn.disabled = true; btn.textContent = t.publishing;
      var authorName = currentUser.user_metadata?.display_name || currentUser.user_metadata?.full_name || currentUser.email?.split('@')[0] || 'Utilisateur';
      var postData = { title: title, body: body, category: articleSlug ? 'general' : category, author_id: currentUser.id, author_name: authorName };
      if (articleSlug) { postData.article_slug = articleSlug; postData.article_type = articleType || 'blog'; }
      var res = await sb.from('forum_posts').insert(postData).select().single();
      btn.disabled = false; btn.textContent = t.publish;
      if (res.error) { errEl.textContent = 'Erreur : ' + res.error.message; errEl.style.display = ''; return; }
      modal.classList.remove('open'); document.getElementById('postTitle').value = ''; document.getElementById('postBody').value = '';
      document.getElementById('postMediaPreview').innerHTML = ''; postImageUrl = null;
      window.location.href = '/forum/topic/?id=' + res.data.id + (LANG !== 'fr' ? '&lang=' + LANG : '');
    });

    function escapeHtml(str) { var d = document.createElement('div'); d.textContent = str; return d.innerHTML; }
    function formatTimeAgo(dateStr) {
      var diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
      if (diff < 60) return "à l'instant"; if (diff < 3600) return Math.floor(diff / 60) + ' min';
      if (diff < 86400) return Math.floor(diff / 3600) + ' h'; if (diff < 2592000) return Math.floor(diff / 86400) + ' j';
      return Math.floor(diff / 2592000) + ' mois';
    }

    // Share dropdown + Copy + Admin delete
    document.addEventListener('click', async function(e) {
      // Translate button
      var translateBtn = e.target.closest('.translate-btn');
      if (translateBtn) {
        e.stopPropagation();
        var text = translateBtn.dataset.translateText;
        var targetId = translateBtn.dataset.translateTarget;
        var targetEl = document.getElementById(targetId);
        if (!targetEl || translateBtn.dataset.done) return;
        translateBtn.innerHTML = '...';
        fetch('https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=' + LANG + '&dt=t&q=' + encodeURIComponent(text))
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var translated = data[0].map(function(s) { return s[0]; }).join('');
            targetEl.textContent = translated;
            translateBtn.innerHTML = svgTranslate + ' ' + t.translated;
            translateBtn.dataset.done = '1';
          })
          .catch(function() { translateBtn.innerHTML = svgTranslate + ' ' + t.translate; });
        return;
      }
      // Toggle share dropdown
      var toggleBtn = e.target.closest('[data-share-toggle]');
      if (toggleBtn) {
        e.stopPropagation();
        var dropdown = toggleBtn.nextElementSibling;
        var wasOpen = dropdown.classList.contains('open');
        document.querySelectorAll('.share-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
        if (!wasOpen) dropdown.classList.add('open');
        return;
      }
      // Copy link
      var copyBtn = e.target.closest('[data-copy-url]');
      if (copyBtn) {
        e.stopPropagation();
        navigator.clipboard.writeText(copyBtn.dataset.copyUrl).then(function() {
          copyBtn.classList.add('copied');
          setTimeout(function() { copyBtn.classList.remove('copied'); }, 2000);
        });
        return;
      }
      // Close share dropdowns on outside click
      if (!e.target.closest('.share-dropdown')) {
        document.querySelectorAll('.share-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
      }
      // Stop propagation on share dropdown link clicks
      if (e.target.closest('.share-dropdown a')) { e.stopPropagation(); return; }
      var delBtn = e.target.closest('[data-delete-post]');
      if (delBtn && isAdmin) { e.preventDefault(); e.stopPropagation();
        if (!confirm('Supprimer définitivement ce sujet et toutes ses réponses ?')) return;
        var res = await sb.from('forum_posts').delete().eq('id', delBtn.dataset.deletePost);
        if (res.error) { alert('Erreur : ' + res.error.message); return; }
        loadPosts(document.getElementById('forumSearch').value.trim());
      }
    });

    loadPosts();

    // Realtime: auto-refresh when posts or replies change
    sb.channel('forum-index')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'forum_posts' }, function() {
        loadPosts(document.getElementById('forumSearch').value.trim());
      })
      .on('postgres_changes', { event: '*', schema: 'public', table: 'forum_replies' }, function() {
        loadPosts(document.getElementById('forumSearch').value.trim());
      })
      .subscribe();
  })();
  </script>
</BaseLayout>
