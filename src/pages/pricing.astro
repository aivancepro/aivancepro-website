                <tr><td>G&eacute;n&eacute;ration de s&eacute;ances IA</td><td>7 jours d'essai</td><td class="check">&#10003;</td></tr>
                <tr><td>Plans d'entra&icirc;nement</td><td>1 semaine (essai)</td><td>Jusqu'&agrave; 12 semaines</td></tr>
                <tr><td>Cr&eacute;ation de groupes &amp; d&eacute;fis</td><td>7 jours d'essai</td><td class="check">&#10003;</td></tr>
                <tr><td>Analyses avanc&eacute;es</td><td>7 jours d'essai</td><td class="check">&#10003;</td></tr>
                <tr><td>Analyse de surentra&icirc;nement</td><td>7 jours d'essai</td><td class="check">&#10003;</td></tr>
                <tr><td>Support prioritaire</td><td>7 jours d'essai</td><td class="check">&#10003;</td></tr>
                <tr><td>Prix</td><td style="font-weight:700;color:#10B981;">0&euro;</td><td style="font-weight:700;">6,99&euro; / mois</td></tr>
            </tbody>
        </table>
        </div>
    </section>

    <!-- Download QR Code -->
    <section class="qr-section" style="padding: 4rem 2rem; text-align: center;">
        <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.75rem;">T&eacute;l&eacute;chargez sur votre mobile</h2>
        <p style="color: var(--gray-500); font-size: 1rem; margin-bottom: 2rem; max-width: 450px; margin-left: auto; margin-right: auto;">Scannez le QR code avec l'appareil photo de votre t&eacute;l&eacute;phone pour installer AIVancePro.</p>
        <div style="display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap;">
            <div style="text-align: center;">
                <canvas id="qrAppStore" width="160" height="160" style="border-radius: 12px; border: 1px solid var(--border); background: white; padding: 8px;"></canvas>
                <p style="margin-top: 0.75rem; font-size: 0.85rem; font-weight: 600; color: var(--gray-700);">App Store</p>
            </div>
            <div style="text-align: center;">
                <canvas id="qrPlayStore" width="160" height="160" style="border-radius: 12px; border: 1px solid var(--border); background: white; padding: 8px;"></canvas>
                <p style="margin-top: 0.75rem; font-size: 0.85rem; font-weight: 600; color: var(--gray-700);">Google Play</p>
            </div>
        </div>
    </section>

    <script is:inline>
    // Minimal QR code generator (simplified for small URLs)
    (function(){
      function drawQR(canvasId, text) {
        var c = document.getElementById(canvasId);
        if (!c) return;
        var ctx = c.getContext('2d');
        // Use simple fallback: show a styled download prompt
        var s = c.width;
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, s, s);
        ctx.fillStyle = '#4A90D9';
        ctx.font = 'bold 14px Inter, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('Scannez avec', s/2, s/2 - 20);
        ctx.fillText('votre appareil', s/2, s/2);
        ctx.font = '11px Inter, sans-serif';
        ctx.fillStyle = '#6a6a80';
        var short = text.length > 30 ? text.substring(0, 30) + '...' : text;
        ctx.fillText(short, s/2, s/2 + 30);
      }
      // Try loading QR library dynamically
      var script = document.createElement('script');
      script.src = 'https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js';
      script.onload = function() {
        function renderQR(canvasId, text) {
          var c = document.getElementById(canvasId);
          if (!c || typeof qrcode === 'undefined') return;
          var qr = qrcode(0, 'M');
          qr.addData(text);
          qr.make();
          var ctx = c.getContext('2d');
          var size = c.width;
          var pad = 12;
          var modules = qr.getModuleCount();
          var cellSize = (size - pad * 2) / modules;
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, size, size);
          for (var r = 0; r < modules; r++) {
            for (var col = 0; col < modules; col++) {
              if (qr.isDark(r, col)) {
                ctx.fillStyle = '#1a1a2e';
                ctx.fillRect(pad + col * cellSize, pad + r * cellSize, cellSize, cellSize);
              }
            }
          }
        }
        renderQR('qrAppStore', 'https://apps.apple.com/fr/app/aivancepro/id6756116760');
        renderQR('qrPlayStore', 'https://play.google.com/store/apps/details?id=com.aivancepro.app');
      };
      script.onerror = function() {
        drawQR('qrAppStore', 'apps.apple.com/aivancepro');
        drawQR('qrPlayStore', 'play.google.com/aivancepro');
      };
      document.head.appendChild(script);
    })();
    </script>

    <!-- FAQ Pricing -->
    <section class="faq-section">
        <h2>Questions fr&eacute;quentes sur les tarifs</h2>
        <div class="faq-list">
            <div class="faq-item">
                <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                    Puis-je changer de plan &agrave; tout moment ?
                    <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
                </button>
                <div class="faq-answer"><div class="faq-answer-inner">Oui, vous pouvez passer au plan Pro ou revenir au plan Gratuit &agrave; tout moment. Le changement prend effet imm&eacute;diatement.</div></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                    Y a-t-il un engagement ?
                    <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
                </button>
                <div class="faq-answer"><div class="faq-answer-inner">Aucun engagement. Vous pouvez annuler votre abonnement &agrave; tout moment depuis l'App Store ou Google Play.</div></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
                    Le plan Gratuit est-il vraiment gratuit ?
                    <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
                </button>
                <div class="faq-answer"><div class="faq-answer-inner">Absolument. Le plan Gratuit vous donne acc&egrave;s au suivi de s&eacute;ances, aux +240 exercices et aux statistiques de base, sans limite de temps et sans carte bancaire.</div></div>
            </div>
            <div class="faq-item">
