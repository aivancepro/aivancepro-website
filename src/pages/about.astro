import BaseLayout from '../layouts/BaseLayout.astro';

const SUPABASE_URL = 'https://vzmtvhcvyqzkmestdbko.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ6bXR2aGN2eXF6a21lc3RkYmtvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA4OTA0MTEsImV4cCI6MjA4NjQ2NjQxMX0.rvBz2uIsr3YtLIw84Kor3eVFpH4FiXVZgbufiJH3uio';

let usersCount = '—';
let sessionsCount = '—';

try {
  const headers = { 'apikey': SUPABASE_ANON_KEY, 'Prefer': 'count=exact' };
  const [uRes, sRes] = await Promise.all([
    fetch(`${SUPABASE_URL}/rest/v1/public_profile?select=*`, { method: 'HEAD', headers }),
    fetch(`${SUPABASE_URL}/rest/v1/session?select=*`, { method: 'HEAD', headers }),
  ]);
  const uCount = parseInt(uRes.headers.get('content-range')?.split('/')[1] || '0');
  const sCount = parseInt(sRes.headers.get('content-range')?.split('/')[1] || '0');
  if (uCount > 0) usersCount = uCount >= 1000 ? (uCount / 1000).toFixed(1).replace('.0', '') + 'k+' : uCount + '+';
  if (sCount > 0) sessionsCount = sCount >= 1000 ? (sCount / 1000).toFixed(1).replace('.0', '') + 'k+' : sCount + '+';
} catch {}

