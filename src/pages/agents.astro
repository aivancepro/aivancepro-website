---
// Dashboard privé — Agents IA AIVancePro
// Pas de BaseLayout (page standalone, pas de nav/footer)
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>AIVancePro Agents</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #09090b;
      color: #fafafa;
      min-height: 100vh;
    }

    /* ─── Password Gate ─────────────────────── */
    #gate {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      flex-direction: column;
      gap: 16px;
    }
    #gate h1 { font-size: 1.5rem; font-weight: 600; color: #a1a1aa; }
    #gate input {
      background: #18181b;
      border: 1px solid #27272a;
      color: #fafafa;
      padding: 12px 20px;
      border-radius: 8px;
      font-size: 1rem;
      width: 300px;
      outline: none;
      transition: border-color 0.2s;
    }
    #gate input:focus { border-color: #4A90D9; }
    #gate .error { color: #ef4444; font-size: 0.875rem; display: none; }

    /* ─── Dashboard ─────────────────────────── */
    #dashboard { display: none; padding: 24px 20px; max-width: 1200px; margin: 0 auto; }

    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
      padding: 20px 24px;
      background: linear-gradient(135deg, #111115 0%, #0d1117 50%, #111115 100%);
      border: 1px solid #27272a;
      border-radius: 16px;
    }
    .header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, #fafafa 0%, #a1a1aa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .header .status-dot {
      width: 10px; height: 10px;
      background: #22c55e;
      border-radius: 50%;
      display: inline-block;
      animation: pulse 2s infinite;
      box-shadow: 0 0 8px rgba(34, 197, 94, 0.4);
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .header small { color: #71717a; font-size: 0.8rem; }

    /* ─── Escalades ─────────────────────────── */
    #escalades {
      background: linear-gradient(135deg, #1c1917, #1a1510);
      border: 1px solid #78350f;
      border-radius: 12px;
      padding: 16px 20px;
      margin-bottom: 24px;
      display: none;
    }
    #escalades h2 { color: #fbbf24; font-size: 1rem; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .escalade-item {
      background: rgba(39,39,42,0.6);
      border-radius: 8px;
      padding: 12px 14px;
      margin-bottom: 8px;
      font-size: 0.875rem;
      border-left: 3px solid #f59e0b;
    }
    .escalade-item:last-child { margin-bottom: 0; }
    .escalade-item .agent { color: #fbbf24; font-weight: 600; }
    .escalade-item .reason { color: #d4d4d8; margin-top: 4px; }
    .escalade-item .date { color: #71717a; font-size: 0.75rem; margin-top: 4px; }

    /* ─── KPIs Banner ───────────────────────── */
    .kpis {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 12px;
      margin-bottom: 28px;
    }
    .kpi-card {
      background: #18181b;
      border: 1px solid #27272a;
      border-radius: 12px;
      padding: 16px;
      text-align: center;
      transition: border-color 0.2s;
    }
    .kpi-card:hover { border-color: #3f3f46; }
    .kpi-card .value { font-size: 1.5rem; font-weight: 700; color: #4A90D9; }
    .kpi-card .label { font-size: 0.75rem; color: #71717a; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
    .kpi-card .trend { font-size: 0.75rem; margin-top: 4px; }
    .trend-up { color: #22c55e; }
    .trend-down { color: #ef4444; }

    /* ─── Poles & Agents ────────────────────── */
    .poles { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    @media (max-width: 768px) { .poles { grid-template-columns: 1fr; } }

    .pole {
      background: #18181b;
      border: 1px solid #27272a;
      border-radius: 12px;
      padding: 20px;
    }
    .pole h2 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .pole-tech h2 { color: #60a5fa; }
    .pole-marketing h2 { color: #a78bfa; }

    .agent-card {
      background: #27272a;
      border-radius: 10px;
      padding: 14px 14px 14px 18px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      border: 1px solid transparent;
      border-left: 3px solid #3f3f46;
    }
    .agent-card:last-child { margin-bottom: 0; }
    .agent-card:hover { border-color: #3f3f46; background: #2a2a2e; }
    .agent-card.card-idle { border-left-color: #52525b; }
    .agent-card.card-running { border-left-color: #3b82f6; }
    .agent-card.card-error { border-left-color: #ef4444; }

    .agent-card .agent-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .agent-card .agent-name {
      font-weight: 600;
      font-size: 0.95rem;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .agent-card .agent-status {
      font-size: 0.7rem;
      padding: 2px 10px;
      border-radius: 999px;
      font-weight: 500;
      text-transform: capitalize;
    }
    .status-idle { background: #1c1c1e; color: #71717a; }
    .status-running { background: #172554; color: #60a5fa; animation: pulse 1.5s infinite; }
    .status-error { background: #450a0a; color: #f87171; }

    .agent-card .agent-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 8px;
      font-size: 0.75rem;
      color: #a1a1aa;
    }
    .agent-card .agent-meta span { display: flex; align-items: center; gap: 4px; }

    .agent-skills {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin-top: 8px;
    }
    .skill-tag {
      font-size: 0.65rem;
      padding: 2px 7px;
      border-radius: 4px;
      background: #1e1e22;
      color: #71717a;
      border: 1px solid #333;
      font-family: 'SF Mono', 'Fira Code', monospace;
    }

    .agent-card .agent-last-output {
      margin-top: 10px;
      font-size: 0.8rem;
      color: #a1a1aa;
      max-height: 60px;
      overflow: hidden;
      line-height: 1.5;
      padding: 8px 10px;
      background: #1e1e22;
      border-radius: 6px;
      border-left: 2px solid #3f3f46;
    }

    .btn {
      background: #4A90D9;
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 0.8rem;
      cursor: pointer;
      font-weight: 500;
      transition: background 0.2s, transform 0.1s;
    }
    .btn:hover { background: #3b7bc8; }
    .btn:active { transform: scale(0.97); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-sm { padding: 4px 10px; font-size: 0.7rem; }

    /* ─── Agent Modal ───────────────────────── */
    #modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(4px);
      z-index: 100;
      align-items: center;
      justify-content: center;
    }
    #modal {
      background: #18181b;
      border: 1px solid #27272a;
      border-radius: 16px;
      padding: 28px;
      width: 90%;
      max-width: 700px;
      max-height: 85vh;
      overflow-y: auto;
    }
    #modal::-webkit-scrollbar { width: 6px; }
    #modal::-webkit-scrollbar-track { background: transparent; }
    #modal::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 3px; }
    #modal h2 { font-size: 1.25rem; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    #modal .close {
      float: right;
      background: none;
      border: none;
      color: #71717a;
      font-size: 1.5rem;
      cursor: pointer;
      transition: color 0.2s;
      line-height: 1;
    }
    #modal .close:hover { color: #fafafa; }

    .modal-info {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      align-items: center;
      margin-bottom: 16px;
      padding-bottom: 16px;
      border-bottom: 1px solid #27272a;
    }
    .modal-info-item {
      font-size: 0.82rem;
      color: #a1a1aa;
    }
    .modal-info-item strong { color: #d4d4d8; }

    .run-history {
      margin-top: 16px;
    }
    .run-history h3 {
      font-size: 0.9rem;
      color: #a1a1aa;
      margin-bottom: 12px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 500;
    }
    .run-item {
      background: #222225;
      border-radius: 8px;
      padding: 12px 14px;
      margin-bottom: 8px;
      font-size: 0.85rem;
      border-left: 3px solid #3f3f46;
      transition: background 0.15s;
    }
    .run-item:hover { background: #28282c; }
    .run-item.run-completed { border-left-color: #22c55e; }
    .run-item.run-failed { border-left-color: #ef4444; }
    .run-item.run-running { border-left-color: #3b82f6; }
    .run-item.run-pending { border-left-color: #71717a; }
    .run-item .run-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }
    .run-item .run-trigger { color: #71717a; font-size: 0.75rem; }
    .run-item .run-duration { color: #71717a; font-size: 0.75rem; }
    .run-item .run-output {
      color: #a1a1aa;
      font-size: 0.8rem;
      max-height: 100px;
      overflow: hidden;
      white-space: pre-wrap;
      line-height: 1.5;
      margin-top: 6px;
      padding: 8px;
      background: #1a1a1e;
      border-radius: 6px;
    }

    .loading { color: #71717a; text-align: center; padding: 40px; }
    .empty-state { color: #52525b; font-size: 0.85rem; text-align: center; padding: 20px; }

    /* ─── Health Bar (Point 12) ────────────── */
    .health-bar {
      display: flex;
      gap: 10px;
      margin-bottom: 24px;
      padding: 14px 18px;
      background: #18181b;
      border: 1px solid #27272a;
      border-radius: 12px;
      flex-wrap: wrap;
      align-items: center;
    }
    .health-bar-title {
      font-size: 0.78rem;
      color: #71717a;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-right: 6px;
    }
    .health-dot {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 0.78rem;
      color: #a1a1aa;
      cursor: default;
    }
    .health-dot .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
    }
    .dot-healthy { background: #22c55e; }
    .dot-warning { background: #f59e0b; animation: pulse 1.5s infinite; }
    .dot-critical { background: #ef4444; animation: pulse 1s infinite; }
    .dot-unknown { background: #52525b; }

    /* ─── Prompt Versions (Point 14) ───────── */
    .version-list { margin-top: 12px; }
    .version-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 12px;
      background: #222225;
      border-radius: 6px;
      margin-bottom: 6px;
      font-size: 0.78rem;
    }
    .version-item.active { border-left: 3px solid #22c55e; }
    .version-meta { color: #71717a; }
    .version-summary { color: #a1a1aa; margin-left: 12px; flex: 1; }
    .btn-xs {
      padding: 3px 8px;
      font-size: 0.68rem;
      background: #27272a;
      color: #a1a1aa;
      border: 1px solid #3f3f46;
      border-radius: 4px;
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn-xs:hover { background: #3f3f46; color: #fafafa; }

    /* ─── Global Views Nav ─────────────────── */
    .views-nav {
      display: flex;
      gap: 0;
      margin-bottom: 24px;
      border-bottom: 1px solid #27272a;
    }
    .view-tab {
      padding: 10px 20px;
      font-size: 0.85rem;
      font-weight: 500;
      color: #71717a;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .view-tab:hover { color: #a1a1aa; }
    .view-tab.active { color: #fafafa; border-bottom-color: #4A90D9; }
    .view-tab .badge {
      font-size: 0.65rem;
      padding: 1px 6px;
      border-radius: 999px;
      background: #ef4444;
      color: white;
      margin-left: 6px;
      font-weight: 600;
    }
    .global-view { display: none; }
    .global-view.active { display: block; }

    /* ─── Bug Card ─────────────────────────── */
    .bug-card {
      background: #222225;
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 12px;
      border-left: 3px solid #ef4444;
    }
    .bug-card.severity-high { border-left-color: #f97316; }
    .bug-card.severity-medium { border-left-color: #eab308; }
    .bug-card.severity-low { border-left-color: #6b7280; }
    .bug-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    .bug-title { font-weight: 600; font-size: 0.9rem; }
    .severity-badge {
      font-size: 0.68rem;
      padding: 2px 8px;
      border-radius: 4px;
      font-weight: 600;
      text-transform: uppercase;
    }
    .severity-critical { background: #450a0a; color: #fca5a5; }
    .severity-high { background: #431407; color: #fdba74; }
    .severity-medium { background: #422006; color: #fde047; }
    .severity-low { background: #1c1c1e; color: #9ca3af; }
    .bug-meta { font-size: 0.78rem; color: #a1a1aa; margin-bottom: 8px; }
    .bug-fix {
      background: #1a1a1e;
      border-radius: 6px;
      padding: 10px;
      font-family: 'SF Mono', monospace;
      font-size: 0.75rem;
      color: #a1a1aa;
      white-space: pre-wrap;
      max-height: 120px;
      overflow: hidden;
      margin-top: 8px;
    }
    .bug-actions {
      display: flex;
      gap: 8px;
      margin-top: 10px;
    }
    .btn-approve { background: #166534; color: #86efac; }
    .btn-approve:hover { background: #15803d; }
    .btn-reject { background: #450a0a; color: #fca5a5; }
    .btn-reject:hover { background: #7f1d1d; }

    /* ─── Contact Card ─────────────────────── */
    .contact-card {
      background: #222225;
      border-radius: 8px;
      padding: 12px 14px;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.82rem;
    }
    .contact-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #3f3f46;
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .contact-info { flex: 1; }
    .contact-name { font-weight: 600; color: #fafafa; }
    .contact-handle { color: #71717a; font-size: 0.75rem; }
    .contact-status-badge {
      font-size: 0.65rem;
      padding: 2px 8px;
      border-radius: 4px;
    }
    .cs-identified { background: #1c1c1e; color: #71717a; }
    .cs-contacted { background: #172554; color: #60a5fa; }
    .cs-replied { background: #14532d; color: #86efac; }
    .cs-accepted { background: #166534; color: #22c55e; }
    .cs-declined { background: #450a0a; color: #f87171; }
    .cs-ghosted { background: #1c1c1e; color: #52525b; }

    /* ─── Content Card ─────────────────────── */
    .content-card {
      background: #222225;
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 12px;
      border-left: 3px solid #a78bfa;
    }
    .content-card.type-article { border-left-color: #60a5fa; }
    .content-card.type-email { border-left-color: #f59e0b; }
    .content-card.type-video_script { border-left-color: #ec4899; }
    .content-type-badge {
      font-size: 0.65rem;
      padding: 2px 8px;
      border-radius: 4px;
      background: #27272a;
      color: #a1a1aa;
      text-transform: uppercase;
    }
    .content-preview {
      margin-top: 8px;
      font-size: 0.8rem;
      color: #a1a1aa;
      max-height: 80px;
      overflow: hidden;
      line-height: 1.5;
    }
    .review-notes {
      margin-top: 8px;
      padding: 8px 10px;
      background: #1c1917;
      border: 1px solid #78350f;
      border-radius: 6px;
      font-size: 0.75rem;
      color: #fbbf24;
    }

    /* ─── Output Viewer ────────────────────── */
    .output-section {
      margin-bottom: 16px;
    }
    .output-section h4 {
      font-size: 0.82rem;
      color: #a1a1aa;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .output-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 8px;
    }
    .output-metric {
      background: #1a1a1e;
      border-radius: 6px;
      padding: 10px;
      text-align: center;
    }
    .output-metric .val { font-size: 1.1rem; font-weight: 700; color: #4A90D9; }
    .output-metric .lbl { font-size: 0.7rem; color: #71717a; margin-top: 2px; }

    /* ─── Architecture Flowchart ───────────── */
    .archi-container {
      position: relative;
      width: 100%;
      min-height: 600px;
      background: radial-gradient(circle at 50% 50%, #111115 0%, #09090b 100%);
      border: 1px solid #27272a;
      border-radius: 16px;
      overflow: hidden;
    }
    .archi-container svg {
      width: 100%;
      height: 600px;
    }
    .archi-node {
      cursor: pointer;
      transition: filter 0.2s;
    }
    .archi-node:hover { filter: brightness(1.3); }
    .archi-node rect {
      rx: 12;
      ry: 12;
      stroke-width: 1.5;
      transition: stroke 0.2s;
    }
    .archi-node:hover rect { stroke-width: 2.5; }
    .archi-node text {
      font-family: 'Inter', sans-serif;
      fill: #fafafa;
      pointer-events: none;
    }
    .archi-label {
      font-size: 11px;
      font-weight: 600;
    }
    .archi-sublabel {
      font-size: 9px;
      fill: #a1a1aa;
    }
    .archi-health {
      transition: fill 0.3s;
    }
    .archi-pole-label {
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 700;
      fill: #52525b;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    .archi-source {
      cursor: default;
    }
    .archi-source rect {
      rx: 8;
      ry: 8;
      fill: #18181b;
      stroke: #3f3f46;
      stroke-width: 1;
      stroke-dasharray: 4 2;
    }
    .archi-source text {
      font-family: 'Inter', sans-serif;
      font-size: 9px;
      fill: #71717a;
      pointer-events: none;
    }
    .archi-arrow {
      fill: none;
      stroke: #3f3f46;
      stroke-width: 1.2;
      marker-end: url(#arrowhead);
      transition: stroke 0.3s;
    }
    .archi-arrow.active {
      stroke: #4A90D9;
      stroke-width: 1.8;
      animation: flowPulse 2s infinite;
    }
    .archi-arrow.task-flow {
      stroke: #f59e0b;
      stroke-dasharray: 6 3;
      stroke-width: 1.5;
      marker-end: url(#arrowheadTask);
    }
    @keyframes flowPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .archi-legend {
      position: absolute;
      bottom: 12px;
      left: 16px;
      display: flex;
      gap: 16px;
      font-size: 0.7rem;
      color: #52525b;
    }
    .archi-legend span { display: flex; align-items: center; gap: 4px; }
    .legend-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
    }
    .legend-line {
      width: 20px;
      height: 2px;
      display: inline-block;
    }

    /* ─── Usage Stats ──────────────────────── */
    .usage-bar {
      display: flex;
      gap: 12px;
      margin-bottom: 24px;
      padding: 14px 18px;
      background: #18181b;
      border: 1px solid #27272a;
      border-radius: 12px;
      flex-wrap: wrap;
      align-items: center;
    }
    .usage-stat {
      text-align: center;
      min-width: 80px;
    }
    .usage-stat .val { font-size: 1.1rem; font-weight: 700; color: #4A90D9; }
    .usage-stat .lbl { font-size: 0.65rem; color: #71717a; margin-top: 2px; text-transform: uppercase; }
    .usage-divider { width: 1px; height: 30px; background: #27272a; }

    /* ─── Execution Result ─────────────────── */
    .exec-result {
      background: #111113;
      border: 1px solid #27272a;
      border-radius: 8px;
      padding: 12px;
      margin-top: 12px;
    }
    .exec-result .exec-status { font-weight: 600; margin-bottom: 6px; }
    .exec-result .exec-branch { font-size: 0.78rem; color: #60a5fa; font-family: monospace; }
    .exec-result .exec-log {
      margin-top: 8px;
      font-size: 0.72rem;
      color: #71717a;
      max-height: 100px;
      overflow: auto;
      white-space: pre-wrap;
      background: #09090b;
      padding: 8px;
      border-radius: 4px;
    }

    /* ─── Modal Tabs ───────────────────────── */
    .modal-tabs {
      display: flex;
      gap: 0;
      margin-bottom: 20px;
      border-bottom: 1px solid #27272a;
    }
    .modal-tab {
      padding: 8px 18px;
      font-size: 0.82rem;
      font-weight: 500;
      color: #71717a;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .modal-tab:hover { color: #a1a1aa; }
    .modal-tab.active { color: #fafafa; border-bottom-color: #4A90D9; }

    /* ─── Prompt Editor ────────────────────── */
    .prompt-editor { display: none; }
    .prompt-editor.visible { display: block; }
    .prompt-textarea {
      width: 100%;
      min-height: 350px;
      background: #111113;
      border: 1px solid #27272a;
      border-radius: 8px;
      color: #d4d4d8;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
      font-size: 0.78rem;
      line-height: 1.6;
      padding: 14px;
      resize: vertical;
      outline: none;
      transition: border-color 0.2s;
    }
    .prompt-textarea:focus { border-color: #4A90D9; }
    .prompt-actions {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 12px;
    }
    .prompt-status {
      font-size: 0.78rem;
      color: #71717a;
      transition: color 0.2s;
    }
    .prompt-status.saved { color: #22c55e; }
    .prompt-status.error { color: #ef4444; }
    .prompt-char-count {
      font-size: 0.72rem;
      color: #52525b;
      margin-left: auto;
    }
  </style>
</head>
<body>

  <!-- Password Gate -->
  <div id="gate">
    <h1>🔒 AIVancePro Agents</h1>
    <input type="password" id="password" placeholder="Mot de passe" autocomplete="off" />
    <p class="error" id="gate-error">Mot de passe incorrect</p>
  </div>

  <!-- Dashboard -->
  <div id="dashboard">
    <div class="header">
      <div>
        <h1><span class="status-dot"></span>AIVancePro Agents</h1>
        <small>Dashboard interne — <span id="last-refresh"></span></small>
      </div>
      <button class="btn" id="refresh-btn" onclick="loadData()">Rafraîchir</button>
    </div>

    <!-- Health Bar -->
    <div class="health-bar" id="health-bar">
      <span class="health-bar-title">Santé système</span>
    </div>

    <!-- Usage Stats -->
    <div class="usage-bar" id="usage-bar">
      <span class="health-bar-title">Usage 24h</span>
    </div>

    <!-- Global Views Nav -->
    <div class="views-nav">
      <button class="view-tab active" onclick="switchGlobalView('agents', this)">Agents</button>
      <button class="view-tab" onclick="switchGlobalView('archi', this)">Architecture</button>
      <button class="view-tab" onclick="switchGlobalView('bugs', this)">Bugs <span class="badge" id="bugs-count" style="display:none">0</span></button>
      <button class="view-tab" onclick="switchGlobalView('contacts', this)">Contacts</button>
      <button class="view-tab" onclick="switchGlobalView('content', this)">Contenu <span class="badge" id="content-count" style="display:none">0</span></button>
    </div>

    <!-- Main agents view -->
    <div id="view-agents" class="global-view active">

    <!-- Escalades -->
    <div id="escalades">
      <h2>⚠️ Escalades en cours</h2>
      <div id="escalades-list"></div>
    </div>

    <!-- KPIs -->
    <div class="kpis" id="kpis"></div>

    <!-- Pôles & Agents -->
    <div class="poles">
      <div class="pole pole-tech">
        <h2>🛠️ Pôle Tech</h2>
        <div id="agents-tech"></div>
      </div>
      <div class="pole pole-marketing">
        <h2>📢 Pôle Marketing</h2>
        <div id="agents-marketing"></div>
      </div>
    </div>
  </div>

    </div><!-- /view-agents -->

    <!-- Architecture view -->
    <div id="view-archi" class="global-view">
      <div class="archi-container" id="archi-container"></div>
    </div>

    <!-- Bugs view -->
    <div id="view-bugs" class="global-view">
      <h2 style="font-size:1.1rem;margin-bottom:16px;color:#f87171;">Bugs d\u00e9tect\u00e9s par Agent Debug</h2>
      <div id="bugs-list"><p class="empty-state">Chargement...</p></div>
      <h3 style="font-size:0.95rem;margin:24px 0 12px;color:#a1a1aa;">Ex\u00e9cutions de code approuv\u00e9es</h3>
      <div id="exec-list"><p class="empty-state">Chargement...</p></div>
    </div>

    <!-- Contacts view -->
    <div id="view-contacts" class="global-view">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <h2 style="font-size:1.1rem;color:#a78bfa;">Contacts Outreach</h2>
        <button class="btn-xs" onclick="exportContactsCSV()">Exporter CSV</button>
      </div>
      <div id="contacts-list"><p class="empty-state">Chargement...</p></div>
    </div>

    <!-- Content view -->
    <div id="view-content" class="global-view">
      <h2 style="font-size:1.1rem;margin-bottom:16px;color:#60a5fa;">Contenu en attente de review</h2>
      <div id="content-list"><p class="empty-state">Chargement...</p></div>
    </div>
  </div>

  <!-- Agent Detail Modal -->
  <div id="modal-overlay" onclick="closeModal(event)">
    <div id="modal">
      <button class="close" onclick="closeModal()">&times;</button>
      <h2 id="modal-title"></h2>
      <div id="modal-content"></div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script is:inline>
    const SUPABASE_URL = 'https://vzmtvhcvyqzkmestdbko.supabase.co';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ6bXR2aGN2eXF6a21lc3RkYmtvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA4OTA0MTEsImV4cCI6MjA4NjQ2NjQxMX0.rvBz2uIsr3YtLIw84Kor3eVFpH4FiXVZgbufiJH3uio';
    const PASSWORD_HASH = '4aa67387592c6d09909e79cc50d9fecbec5087bf4f39b59f1c90804b3fa9155c';

    // ─── Helpers ─────────────────────────────
    const AGENT_ICONS = {
      'agent-dev': '\u{1F6E0}',       // 🛠
      'agent-debug': '\u{1F41B}',     // 🐛
      'agent-seo-geo': '\u{1F50D}',   // 🔍
      'agent-marketing': '\u{1F4E3}', // 📣
      'agent-contenu': '\u{270D}',    // ✍
      'agent-analyse': '\u{1F4CA}',   // 📊
    };

    const STATUS_LABELS = {
      idle: 'Inactif',
      running: 'En cours',
      error: 'Erreur',
    };

    const STATUS_LABELS_RUN = {
      pending: 'En attente',
      running: 'En cours',
      completed: 'Terminé',
      failed: 'Échoué',
    };

    const TRIGGER_LABELS = {
      manual: 'Manuel',
      cron: 'Automatique',
      webhook: 'Webhook',
      task: 'Inter-agent',
    };

    const DAYS_FR = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];

    function cronToHuman(cron) {
      if (!cron) return 'Sur demande';
      const parts = cron.split(' ');
      if (parts.length < 5) return cron;
      const [min, hour, , , dow] = parts;

      // Every N hours: "0 */6 * * *"
      if (hour.startsWith('*/')) {
        return `Toutes les ${hour.slice(2)}h`;
      }

      // Specific days: "0 9 * * 1,4"
      if (dow !== '*') {
        const days = dow.split(',').map(d => DAYS_FR[parseInt(d)] || d);
        const h = parseInt(hour);
        if (days.length === 1) {
          return `${days[0]} ${h}h${min !== '0' ? min.padStart(2, '0') : ''}`;
        }
        return `${days.join(' & ')} ${h}h${min !== '0' ? min.padStart(2, '0') : ''}`;
      }

      return cron;
    }

    let sb;
    let agents = [];
    let poles = [];

    // ─── Password Gate ─────────────────────────
    const gate = document.getElementById('gate');
    const dashboard = document.getElementById('dashboard');
    const pwInput = document.getElementById('password');
    const gateError = document.getElementById('gate-error');

    // Check si déjà authentifié
    if (sessionStorage.getItem('agents_auth') === 'ok') {
      showDashboard();
    }

    pwInput.addEventListener('keydown', async (e) => {
      if (e.key !== 'Enter') return;
      const val = pwInput.value;
      const hash = Array.from(
        new Uint8Array(await crypto.subtle.digest('SHA-256', new TextEncoder().encode(val)))
      ).map(b => b.toString(16).padStart(2, '0')).join('');

      if (hash === PASSWORD_HASH) {
        sessionStorage.setItem('agents_auth', 'ok');
        showDashboard();
      } else {
        gateError.style.display = 'block';
        pwInput.value = '';
      }
    });

    function showDashboard() {
      gate.style.display = 'none';
      dashboard.style.display = 'block';
      sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
      loadData();
      setupRealtime();
    }

    // ─── Load Data ─────────────────────────────
    async function loadData() {
      document.getElementById('refresh-btn').disabled = true;
      document.getElementById('last-refresh').textContent = new Date().toLocaleTimeString('fr-FR');

      // Charger pôles + agents
      const { data: polesData } = await sb.from('poles').select('*');
      poles = polesData || [];

      const { data: agentsData } = await sb.from('agents').select('*, poles(name)');
      agents = agentsData || [];

      // Charger le dernier run de chaque agent
      const agentIds = agents.map(a => a.id);
      const { data: lastRuns } = await sb
        .from('agent_runs')
        .select('*')
        .in('agent_id', agentIds)
        .order('started_at', { ascending: false });

      // Compter les runs par agent
      const runsByAgent = {};
      const lastRunByAgent = {};
      (lastRuns || []).forEach(r => {
        if (!runsByAgent[r.agent_id]) runsByAgent[r.agent_id] = 0;
        runsByAgent[r.agent_id]++;
        if (!lastRunByAgent[r.agent_id]) lastRunByAgent[r.agent_id] = r;
      });

      // Escalades récentes (7 derniers jours)
      const weekAgo = new Date(Date.now() - 7 * 86400000).toISOString();
      const { data: escalades } = await sb
        .from('agent_runs')
        .select('*, agents(name)')
        .eq('escalated', true)
        .gte('started_at', weekAgo)
        .order('started_at', { ascending: false });

      renderHealthBar(agents);
      renderUsageBar();
      renderEscalades(escalades || []);
      renderKPIs(lastRunByAgent);
      renderAgents('tech', 'Tech', agents, runsByAgent, lastRunByAgent);
      renderAgents('marketing', 'Marketing', agents, runsByAgent, lastRunByAgent);

      document.getElementById('refresh-btn').disabled = false;
    }

    // ─── Render Health Bar (Point 12) ───────────
    function renderHealthBar(allAgents) {
      const container = document.getElementById('health-bar');
      const dots = allAgents.map(a => {
        const icon = AGENT_ICONS[a.slug] || '\u{1F916}';
        const h = a.health_status || 'unknown';
        const lastRun = a.last_successful_run_at
          ? timeAgo(new Date(a.last_successful_run_at))
          : 'jamais';
        return `<span class="health-dot" title="${a.name} — dernier run: ${lastRun}">
          <span class="dot dot-${h}"></span>${icon}
        </span>`;
      }).join('');
      container.innerHTML = `<span class="health-bar-title">Sant\u{00E9} syst\u{00E8}me</span>${dots}`;
    }

    function timeAgo(date) {
      const mins = Math.floor((Date.now() - date.getTime()) / 60000);
      if (mins < 60) return mins + 'min';
      const hours = Math.floor(mins / 60);
      if (hours < 24) return hours + 'h';
      return Math.floor(hours / 24) + 'j';
    }

    // ─── Render Escalades ──────────────────────
    function renderEscalades(escalades) {
      const container = document.getElementById('escalades');
      const list = document.getElementById('escalades-list');

      if (escalades.length === 0) {
        container.style.display = 'none';
        return;
      }

      container.style.display = 'block';
      list.innerHTML = escalades.map(e => `
        <div class="escalade-item">
          <span class="agent">${e.agents?.name || 'Agent inconnu'}</span>
          <div class="reason">${e.escalation_reason || 'Pas de raison'}</div>
          <div class="date">${new Date(e.started_at).toLocaleString('fr-FR')}</div>
        </div>
      `).join('');
    }

    // ─── Render KPIs ───────────────────────────
    function renderKPIs(lastRunByAgent) {
      const container = document.getElementById('kpis');
      // Trouver le dernier run de l'Agent Analyse
      const analyseAgent = agents.find(a => a.slug === 'agent-analyse');
      if (!analyseAgent || !lastRunByAgent[analyseAgent.id]) {
        container.innerHTML = '<div class="kpi-card"><div class="value">—</div><div class="label">Pas encore de données</div></div>';
        return;
      }

      const output = lastRunByAgent[analyseAgent.id].output;
      if (!output || !output.metrics) {
        container.innerHTML = '<div class="kpi-card"><div class="value">—</div><div class="label">Données indisponibles</div></div>';
        return;
      }

      const m = output.metrics;
      const kpis = [
        { value: m.unique_users_7d ?? '—', label: 'Users 7j' },
        { value: m.total_events ?? '—', label: 'Events 7j' },
        { value: m.dau?.current ?? '—', label: 'DAU', trend: m.dau?.trend },
        { value: m.errors?.total ?? 0, label: 'Erreurs' },
        { value: m.new_users_7d ?? '—', label: 'Nouveaux 7j' },
        { value: m.total_users ?? '—', label: 'Total users' },
      ];

      container.innerHTML = kpis.map(k => `
        <div class="kpi-card">
          <div class="value">${k.value}</div>
          <div class="label">${k.label}</div>
          ${k.trend ? `<div class="trend ${k.trend === 'up' ? 'trend-up' : k.trend === 'down' ? 'trend-down' : ''}">${k.trend === 'up' ? '↑' : k.trend === 'down' ? '↓' : '→'} ${k.trend}</div>` : ''}
        </div>
      `).join('');
    }

    // ─── Render Agents ─────────────────────────
    function renderAgents(containerId, poleName, allAgents, runsByAgent, lastRunByAgent) {
      const container = document.getElementById(`agents-${containerId}`);
      const pole = poles.find(p => p.name === poleName);
      if (!pole) { container.innerHTML = '<p class="empty-state">Pôle non trouvé</p>'; return; }

      const poleAgents = allAgents.filter(a => a.pole_id === pole.id);

      container.innerHTML = poleAgents.map(agent => {
        const lastRun = lastRunByAgent[agent.id];
        const runCount = runsByAgent[agent.id] || 0;
        const lastDate = lastRun ? new Date(lastRun.started_at).toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' }) : 'Jamais';
        const icon = AGENT_ICONS[agent.slug] || '\u{1F916}';
        const statusLabel = STATUS_LABELS[agent.status] || agent.status;
        const scheduleLabel = cronToHuman(agent.schedule);
        const skills = agent.skills || [];

        let highlights = '';
        if (lastRun?.output?.highlights) {
          const h = lastRun.output.highlights;
          highlights = (Array.isArray(h) ? h.slice(0, 2).join(' \u{2022} ') : String(h)).slice(0, 120);
        } else if (lastRun?.output?.raw_output) {
          highlights = lastRun.output.raw_output.slice(0, 120);
        }

        return `
          <div class="agent-card card-${agent.status}" onclick="openAgent('${agent.id}')">
            <div class="agent-header">
              <span class="agent-name">${icon} ${agent.name}</span>
              <span class="agent-status status-${agent.status}">${statusLabel}</span>
            </div>
            <div class="agent-meta">
              <span>\u{1F552} ${scheduleLabel}</span>
              <span>\u{1F504} ${runCount} run${runCount > 1 ? 's' : ''}</span>
              <span>\u{1F4C5} ${lastDate}</span>
            </div>
            ${skills.length ? `<div class="agent-skills">${skills.map(s => `<span class="skill-tag">${s}</span>`).join('')}</div>` : ''}
            ${highlights ? `<div class="agent-last-output">${highlights}</div>` : ''}
          </div>
        `;
      }).join('');
    }

    // ─── Agent Modal ───────────────────────────
    let currentModalAgentId = null;

    async function openAgent(agentId) {
      const agent = agents.find(a => a.id === agentId);
      if (!agent) return;

      currentModalAgentId = agentId;
      const icon = AGENT_ICONS[agent.slug] || '\u{1F916}';
      document.getElementById('modal-title').innerHTML = `${icon} ${agent.name}`;
      document.getElementById('modal-overlay').style.display = 'flex';

      const { data: runs } = await sb
        .from('agent_runs')
        .select('*')
        .eq('agent_id', agentId)
        .order('started_at', { ascending: false })
        .limit(10);

      const skills = agent.skills || [];
      const statusLabel = STATUS_LABELS[agent.status] || agent.status;
      const scheduleLabel = cronToHuman(agent.schedule);
      const totalRuns = runs ? runs.length : 0;
      const promptText = (agent.system_prompt || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

      let html = `
        <div class="modal-info">
          <div class="modal-info-item"><strong>Planning :</strong> ${scheduleLabel}</div>
          <div class="modal-info-item"><strong>Status :</strong> <span class="agent-status status-${agent.status}">${statusLabel}</span></div>
          <div class="modal-info-item"><strong>Runs :</strong> ${totalRuns}</div>
        </div>
        ${skills.length ? `<div class="agent-skills" style="margin-bottom: 16px;">${skills.map(s => `<span class="skill-tag">${s}</span>`).join('')}</div>` : ''}
        <button class="btn" onclick="triggerAgent('${agent.slug}', this)" style="margin-bottom: 16px;">\u{25B6}\u{FE0F} Lancer maintenant</button>

        <div class="modal-tabs">
          <button class="modal-tab active" onclick="switchTab('runs', this)">Runs</button>
          <button class="modal-tab" onclick="switchTab('prompt', this)">Prompt syst\u{00E8}me</button>
          <button class="modal-tab" onclick="switchTab('versions', this)">Versions</button>
        </div>

        <div id="tab-runs">
          <div class="run-history">
      `;

      if (!runs || runs.length === 0) {
        html += '<p class="empty-state">Aucun run pour le moment</p>';
      } else {
        html += runs.map(r => {
          const date = new Date(r.started_at).toLocaleString('fr-FR');
          const duration = r.duration_ms ? `${(r.duration_ms / 1000).toFixed(0)}s` : '\u{2014}';
          const rStatusLabel = STATUS_LABELS_RUN[r.status] || r.status;
          const statusColor = r.status === 'completed' ? '#22c55e' : r.status === 'failed' ? '#ef4444' : r.status === 'running' ? '#60a5fa' : '#71717a';
          const triggerLabel = TRIGGER_LABELS[r.trigger_type] || r.trigger_type;

          let outputPreview = '';
          if (r.output?.highlights) {
            const h = r.output.highlights;
            outputPreview = Array.isArray(h) ? h.map(x => '\u{2022} ' + x).join('\n') : String(h);
          } else if (r.output?.raw_output) {
            outputPreview = r.output.raw_output.slice(0, 300);
          } else if (r.output) {
            outputPreview = JSON.stringify(r.output, null, 2).slice(0, 300);
          }

          return `
            <div class="run-item run-${r.status}">
              <div class="run-header">
                <span style="color: ${statusColor}; font-weight: 600;">${rStatusLabel}${r.escalated ? ' \u{1F6A8}' : ''}</span>
                <span class="run-duration">${duration}</span>
              </div>
              <div class="run-trigger">${date} \u{2014} ${triggerLabel}${r.retry_count > 1 ? ' \u{2022} ' + r.retry_count + ' tentatives' : ''}${r.error_message ? ' \u{2022} ' + r.error_message : ''}</div>
              ${outputPreview ? `<div class="run-output">${outputPreview}</div>` : ''}
            </div>
          `;
        }).join('');
      }

      html += `
          </div>
        </div>

        <div id="tab-prompt" class="prompt-editor">
          <textarea class="prompt-textarea" id="prompt-textarea" oninput="updateCharCount()">${promptText}</textarea>
          <div class="prompt-actions">
            <button class="btn" onclick="savePrompt('${agent.id}', this)">Sauvegarder</button>
            <span class="prompt-status" id="prompt-status"></span>
            <span class="prompt-char-count" id="prompt-char-count">${(agent.system_prompt || '').length} caract\u{00E8}res</span>
          </div>
        </div>

        <div id="tab-versions" class="prompt-editor">
          <div class="version-list" id="version-list"><p class="empty-state">Chargement...</p></div>
        </div>
      `;

      document.getElementById('modal-content').innerHTML = html;
    }

    function switchTab(tab, btn) {
      document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      ['runs', 'prompt', 'versions'].forEach(t => {
        const el = document.getElementById('tab-' + t);
        if (el) {
          el.style.display = t === tab ? 'block' : 'none';
          if (t === tab) el.classList.add('visible');
          else el.classList.remove('visible');
        }
      });
      if (tab === 'versions' && currentModalAgentId) {
        loadVersions(currentModalAgentId);
      }
    }

    function updateCharCount() {
      const ta = document.getElementById('prompt-textarea');
      document.getElementById('prompt-char-count').textContent = `${ta.value.length} caractères`;
    }

    async function savePrompt(agentId, btn) {
      const ta = document.getElementById('prompt-textarea');
      const status = document.getElementById('prompt-status');
      const newPrompt = ta.value;

      btn.disabled = true;
      btn.textContent = 'Sauvegarde...';
      status.textContent = '';
      status.className = 'prompt-status';

      const { error } = await sb
        .from('agents')
        .update({ system_prompt: newPrompt })
        .eq('id', agentId);

      if (error) {
        status.textContent = 'Erreur : ' + error.message;
        status.classList.add('error');
      } else {
        // Auto-version (Point 14)
        await sb.from('prompt_versions').update({ is_active: false }).eq('agent_id', agentId).eq('is_active', true);
        const { data: lastV } = await sb.from('prompt_versions').select('version_number').eq('agent_id', agentId).order('version_number', { ascending: false }).limit(1);
        const newNum = (lastV?.[0]?.version_number || 0) + 1;
        await sb.from('prompt_versions').insert({
          agent_id: agentId, version_number: newNum, system_prompt: newPrompt,
          changed_by: 'tech', change_summary: 'Modification via dashboard', is_active: true
        });
        status.textContent = 'Sauvegard\u{00E9} (v' + newNum + ')';
        status.classList.add('saved');
        const agent = agents.find(a => a.id === agentId);
        if (agent) agent.system_prompt = newPrompt;
      }

      btn.disabled = false;
      btn.textContent = 'Sauvegarder';
      setTimeout(() => { status.textContent = ''; status.className = 'prompt-status'; }, 3000);
    }

    function closeModal(event) {
      if (event && event.target !== document.getElementById('modal-overlay')) return;
      document.getElementById('modal-overlay').style.display = 'none';
    }

    // ─── Prompt Versions (Point 14) ─────────────
    async function loadVersions(agentId) {
      const container = document.getElementById('version-list');
      const { data: versions } = await sb
        .from('prompt_versions')
        .select('*')
        .eq('agent_id', agentId)
        .order('version_number', { ascending: false })
        .limit(20);

      if (!versions || versions.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucune version</p>';
        return;
      }

      container.innerHTML = versions.map(v => {
        const date = new Date(v.created_at).toLocaleString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit' });
        return `
          <div class="version-item ${v.is_active ? 'active' : ''}">
            <span class="version-meta">v${v.version_number} \u{2014} ${date} \u{2014} ${v.changed_by}</span>
            <span class="version-summary">${v.change_summary || ''}</span>
            ${v.is_active ? '<span style="color:#22c55e;font-size:0.72rem;">active</span>' :
              `<button class="btn-xs" onclick="restoreVersion('${agentId}', '${v.id}', ${v.version_number})">Restaurer</button>`}
          </div>
        `;
      }).join('');
    }

    async function restoreVersion(agentId, versionId, versionNumber) {
      if (!confirm('Restaurer la version v' + versionNumber + ' ?')) return;

      const { data: version } = await sb
        .from('prompt_versions')
        .select('system_prompt')
        .eq('id', versionId)
        .single();

      if (!version) return;

      // Update agent prompt
      await sb.from('agents').update({ system_prompt: version.system_prompt }).eq('id', agentId);

      // Deactivate all versions for this agent
      await sb.from('prompt_versions').update({ is_active: false }).eq('agent_id', agentId);

      // Create new version as restore
      const { data: lastV } = await sb
        .from('prompt_versions')
        .select('version_number')
        .eq('agent_id', agentId)
        .order('version_number', { ascending: false })
        .limit(1);

      const newNum = (lastV?.[0]?.version_number || 0) + 1;
      await sb.from('prompt_versions').insert({
        agent_id: agentId,
        version_number: newNum,
        system_prompt: version.system_prompt,
        changed_by: 'tech',
        change_summary: 'Restauration de v' + versionNumber,
        is_active: true,
      });

      // Update local cache
      const agent = agents.find(a => a.id === agentId);
      if (agent) agent.system_prompt = version.system_prompt;

      // Refresh
      loadVersions(agentId);
      const ta = document.getElementById('prompt-textarea');
      if (ta) ta.value = version.system_prompt;
    }

    // ─── Trigger Manual Run ────────────────────
    async function triggerAgent(slug, btn) {
      btn.disabled = true;
      btn.textContent = '⏳ Lancement...';

      try {
        const res = await fetch(`${SUPABASE_URL}/functions/v1/run-agent`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-agent-key': 'aivancepro-agents-2026-secret-key',
          },
          body: JSON.stringify({ slug, trigger_type: 'manual' }),
        });

        if (!res.ok) throw new Error('Erreur ' + res.status);
        const data = await res.json();
        btn.textContent = '✅ Run créé — en attente du poller';
        setTimeout(() => { btn.disabled = false; btn.textContent = '▶ Lancer maintenant'; }, 5000);
      } catch (e) {
        btn.textContent = '❌ Erreur';
        setTimeout(() => { btn.disabled = false; btn.textContent = '▶ Lancer maintenant'; }, 3000);
      }
    }

    // ─── Architecture Flowchart ────────────────────
    let archiRendered = false;

    function renderArchitecture() {
      archiRendered = true;
      const container = document.getElementById('archi-container');

      const W = 960, H = 600;

      // Agent positions
      const nodes = [
        // Tech pole (left)
        { slug: 'agent-debug', icon: '\u{1F41B}', label: 'Debug', x: 120, y: 160, color: '#ef4444', pole: 'tech' },
        { slug: 'agent-dev', icon: '\u{1F6E0}', label: 'Dev', x: 120, y: 300, color: '#3b82f6', pole: 'tech' },
        { slug: 'agent-seo-geo', icon: '\u{1F50D}', label: 'SEO/GEO', x: 120, y: 440, color: '#22c55e', pole: 'tech' },
        // Marketing pole (right)
        { slug: 'agent-analyse', icon: '\u{1F4CA}', label: 'Analyse', x: 660, y: 160, color: '#a78bfa', pole: 'marketing' },
        { slug: 'agent-marketing', icon: '\u{1F4E3}', label: 'Marketing', x: 660, y: 300, color: '#f59e0b', pole: 'marketing' },
        { slug: 'agent-contenu', icon: '\u{270D}', label: 'Contenu', x: 660, y: 440, color: '#ec4899', pole: 'marketing' },
      ];

      // Data sources
      const sources = [
        { label: 'PostHog', x: 380, y: 80, connects: ['agent-debug', 'agent-analyse'] },
        { label: 'Supabase', x: 480, y: 80, connects: ['agent-debug', 'agent-dev', 'agent-analyse'] },
        { label: 'Search Console', x: 380, y: 530, connects: ['agent-seo-geo'] },
        { label: 'Notion', x: 480, y: 530, connects: ['agent-contenu'] },
        { label: 'Loops', x: 580, y: 530, connects: ['agent-analyse', 'agent-contenu'] },
      ];

      // Inter-agent task flows (from real data)
      const taskFlows = [
        { from: 'agent-analyse', to: 'agent-debug', label: 'bugs' },
        { from: 'agent-analyse', to: 'agent-marketing', label: 'acquisition' },
        { from: 'agent-debug', to: 'agent-dev', label: 'fix' },
        { from: 'agent-marketing', to: 'agent-contenu', label: 'contenu' },
        { from: 'agent-marketing', to: 'agent-seo-geo', label: 'audit' },
        { from: 'agent-seo-geo', to: 'agent-contenu', label: 'keywords' },
        { from: 'agent-seo-geo', to: 'agent-dev', label: 'code fix' },
      ];

      const getNode = slug => nodes.find(n => n.slug === slug);
      const NW = 140, NH = 50; // Node dimensions

      let svg = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
            <polygon points="0 0, 8 3, 0 6" fill="#3f3f46"/>
          </marker>
          <marker id="arrowheadTask" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
            <polygon points="0 0, 8 3, 0 6" fill="#f59e0b"/>
          </marker>
        </defs>

        <!-- Pole backgrounds -->
        <rect x="30" y="100" width="230" height="430" rx="16" fill="#0a0a12" stroke="#1e3a5f" stroke-width="1" opacity="0.5"/>
        <text x="145" y="130" text-anchor="middle" class="archi-pole-label" fill="#3b82f6">P\u{00D4}LE TECH</text>

        <rect x="570" y="100" width="230" height="430" rx="16" fill="#0f0a15" stroke="#3b1f6e" stroke-width="1" opacity="0.5"/>
        <text x="685" y="130" text-anchor="middle" class="archi-pole-label" fill="#a78bfa">P\u{00D4}LE MARKETING</text>

        <!-- Central hub -->
        <circle cx="${W/2}" cy="${H/2}" r="40" fill="#18181b" stroke="#27272a" stroke-width="1.5"/>
        <text x="${W/2}" y="${H/2 - 8}" text-anchor="middle" font-family="Inter" font-size="10" fill="#71717a" font-weight="600">POLLER</text>
        <text x="${W/2}" y="${H/2 + 8}" text-anchor="middle" font-family="Inter" font-size="8" fill="#52525b">claude -p</text>
        <circle cx="${W/2}" cy="${H/2}" r="40" fill="none" stroke="#4A90D9" stroke-width="0.5" opacity="0.3">
          <animate attributeName="r" values="40;50;40" dur="3s" repeatCount="indefinite"/>
          <animate attributeName="opacity" values="0.3;0.1;0.3" dur="3s" repeatCount="indefinite"/>
        </circle>
      `;

      // Draw source → agent connections (subtle)
      sources.forEach(src => {
        src.connects.forEach(slug => {
          const node = getNode(slug);
          if (!node) return;
          const sx = src.x + 40, sy = src.y + 12;
          const nx = node.x + NW/2, ny = node.y + (src.y < 200 ? 0 : NH);
          svg += `<line x1="${sx}" y1="${sy}" x2="${nx}" y2="${ny}" stroke="#27272a" stroke-width="0.8" stroke-dasharray="3 3" opacity="0.5"/>`;
        });
      });

      // Draw inter-agent task flows (curved)
      taskFlows.forEach(flow => {
        const from = getNode(flow.from);
        const to = getNode(flow.to);
        if (!from || !to) return;

        const fx = from.x + NW, fy = from.y + NH/2;
        const tx = to.x, ty = to.y + NH/2;

        // If same pole, curve differently
        if (from.pole === to.pole) {
          const cx = from.pole === 'tech' ? from.x - 30 : from.x + NW + 30;
          svg += `<path d="M${from.x + (from.pole === 'tech' ? 0 : NW)} ${fy} Q${cx} ${(fy+ty)/2} ${to.x + (from.pole === 'tech' ? 0 : NW)} ${ty}" class="archi-arrow task-flow"/>`;
        } else {
          // Cross-pole: curve through center
          const midX = W/2, midY = (fy + ty) / 2;
          svg += `<path d="M${fx} ${fy} Q${midX} ${midY} ${tx} ${ty}" class="archi-arrow task-flow"/>`;
        }

        // Label on the flow
        const lx = (fx + tx) / 2, ly = (fy + ty) / 2 - 8;
        svg += `<text x="${lx}" y="${ly}" text-anchor="middle" font-family="Inter" font-size="7" fill="#f59e0b" opacity="0.7">${flow.label}</text>`;
      });

      // Draw data sources
      sources.forEach(src => {
        svg += `<g class="archi-source">
          <rect x="${src.x}" y="${src.y}" width="80" height="24"/>
          <text x="${src.x + 40}" y="${src.y + 15}" text-anchor="middle">${src.label}</text>
        </g>`;
      });

      // Draw agent nodes
      nodes.forEach(n => {
        const agent = agents.find(a => a.slug === n.slug);
        const health = agent?.health_status || 'unknown';
        const healthColor = { healthy: '#22c55e', warning: '#f59e0b', critical: '#ef4444', unknown: '#52525b' }[health];
        const lastRun = agent?.last_successful_run_at ? timeAgo(new Date(agent.last_successful_run_at)) : 'jamais';
        const agentId = agent?.id || '';

        svg += `<g class="archi-node" onclick="openAgent('${agentId}')" data-slug="${n.slug}">
          <rect x="${n.x}" y="${n.y}" width="${NW}" height="${NH}" fill="#18181b" stroke="${n.color}" stroke-opacity="0.6"/>
          <circle cx="${n.x + NW - 12}" cy="${n.y + 12}" r="4" fill="${healthColor}" class="archi-health" data-health-slug="${n.slug}"/>
          <text x="${n.x + 16}" y="${n.y + 22}" class="archi-label">${n.icon} ${n.label}</text>
          <text x="${n.x + 16}" y="${n.y + 38}" class="archi-sublabel">${lastRun} \u{2022} ${agent?.status || 'idle'}</text>
        </g>`;

        // Line from node to center hub
        const nx = n.pole === 'tech' ? n.x + NW : n.x;
        const ny = n.y + NH/2;
        svg += `<line x1="${nx}" y1="${ny}" x2="${W/2 - 40}" y2="${H/2}" stroke="#27272a" stroke-width="0.8" opacity="0.3" ${n.pole === 'marketing' ? 'x2="' + (W/2 + 40) + '"' : ''}/>`;
      });

      // Human approval node
      svg += `<g class="archi-source">
        <rect x="${W/2 - 40}" y="${H - 70}" width="80" height="28" fill="#1c1917" stroke="#78350f" stroke-dasharray="0"/>
        <text x="${W/2}" y="${H - 52}" text-anchor="middle" font-size="10" fill="#fbbf24">\u{1F464} Humain</text>
      </g>`;
      svg += `<line x1="${W/2}" y1="${H/2 + 40}" x2="${W/2}" y2="${H - 70}" stroke="#78350f" stroke-width="1" stroke-dasharray="4 2" opacity="0.5"/>`;
      svg += `<text x="${W/2 + 4}" y="${H/2 + 70}" font-family="Inter" font-size="7" fill="#78350f" opacity="0.7">approbation</text>`;

      svg += '</svg>';

      // Legend
      svg += `<div class="archi-legend">
        <span><span class="legend-dot" style="background:#22c55e"></span> Healthy</span>
        <span><span class="legend-dot" style="background:#f59e0b"></span> Warning</span>
        <span><span class="legend-dot" style="background:#ef4444"></span> Critical</span>
        <span><span class="legend-line" style="background:#f59e0b"></span> T\u{00E2}che inter-agent</span>
        <span><span class="legend-line" style="background:#27272a;border-top:1px dashed #27272a"></span> Source de donn\u{00E9}es</span>
      </div>`;

      container.innerHTML = svg;
    }

    function updateArchiHealth() {
      agents.forEach(a => {
        const dot = document.querySelector(`[data-health-slug="${a.slug}"]`);
        if (dot) {
          const color = { healthy: '#22c55e', warning: '#f59e0b', critical: '#ef4444', unknown: '#52525b' }[a.health_status || 'unknown'];
          dot.setAttribute('fill', color);
        }
      });
    }

    // ─── Usage Stats ────────────────────────────
    async function renderUsageBar() {
      const container = document.getElementById('usage-bar');
      const now = new Date();
      const yesterday = new Date(now - 86400000);

      // Count runs in last 24h
      const { data: recentRuns } = await sb.from('agent_runs')
        .select('id,duration_ms,status,agent_id')
        .gte('started_at', yesterday.toISOString());

      const runs = recentRuns || [];
      const completed = runs.filter(r => r.status === 'completed');
      const failed = runs.filter(r => r.status === 'failed');
      const avgDuration = completed.length > 0
        ? Math.round(completed.reduce((s, r) => s + (r.duration_ms || 0), 0) / completed.length / 1000)
        : 0;

      // Runs per agent
      const perAgent = {};
      runs.forEach(r => {
        const agent = agents.find(a => a.id === r.agent_id);
        const name = agent ? agent.name.replace('Agent ', '') : '?';
        perAgent[name] = (perAgent[name] || 0) + 1;
      });
      const topAgent = Object.entries(perAgent).sort((a, b) => b[1] - a[1])[0];

      container.innerHTML = `
        <span class="health-bar-title">Usage 24h</span>
        <div class="usage-stat"><div class="val">${runs.length}</div><div class="lbl">Runs</div></div>
        <div class="usage-divider"></div>
        <div class="usage-stat"><div class="val">${completed.length}</div><div class="lbl">R\u{00E9}ussis</div></div>
        <div class="usage-divider"></div>
        <div class="usage-stat"><div class="val" style="color:${failed.length > 0 ? '#ef4444' : '#22c55e'}">${failed.length}</div><div class="lbl">\u{00C9}checs</div></div>
        <div class="usage-divider"></div>
        <div class="usage-stat"><div class="val">${avgDuration}s</div><div class="lbl">Dur\u{00E9}e moy</div></div>
        ${topAgent ? `<div class="usage-divider"></div><div class="usage-stat"><div class="val">${topAgent[1]}</div><div class="lbl">${topAgent[0]}</div></div>` : ''}
      `;
    }

    // ─── Global Views ─────────────────────────
    function switchGlobalView(view, btn) {
      document.querySelectorAll('.view-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      ['agents', 'archi', 'bugs', 'contacts', 'content'].forEach(v => {
        const el = document.getElementById('view-' + v);
        if (el) { el.style.display = v === view ? 'block' : 'none'; el.classList.toggle('active', v === view); }
      });
      if (view === 'archi') { if (!archiRendered) renderArchitecture(); updateArchiHealth(); }
      if (view === 'bugs') { loadBugsView(); loadExecResults(); }
      if (view === 'contacts') loadContactsView();
      if (view === 'content') loadContentView();
    }

    // ─── Bugs View ──────────────────────────────
    async function loadBugsView() {
      const container = document.getElementById('bugs-list');
      container.innerHTML = '<p class="empty-state">Chargement...</p>';

      const debugAgent = agents.find(a => a.slug === 'agent-debug');
      if (!debugAgent) { container.innerHTML = '<p class="empty-state">Agent Debug non trouv\u{00E9}</p>'; return; }

      const { data: runs } = await sb.from('agent_runs').select('output,started_at')
        .eq('agent_id', debugAgent.id).eq('status', 'completed')
        .order('started_at', { ascending: false }).limit(5);

      const allBugs = [];
      (runs || []).forEach(r => {
        const bugs = r.output?.output?.bugs_found || r.output?.bugs_found || [];
        bugs.forEach(b => allBugs.push({ ...b, date: r.started_at }));
      });

      if (allBugs.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucun bug d\u{00E9}tect\u{00E9}</p>';
        return;
      }

      const badge = document.getElementById('bugs-count');
      badge.textContent = allBugs.length;
      badge.style.display = 'inline';

      container.innerHTML = allBugs.map(b => {
        const sev = (b.severity || 'medium').toLowerCase();
        const fix = b.fix_proposal;
        return `
          <div class="bug-card severity-${sev}">
            <div class="bug-header">
              <span class="bug-title">${b.bug_id || 'Bug'} \u{2014} ${b.root_cause || 'Cause inconnue'}</span>
              <span class="severity-badge severity-${sev}">${sev}</span>
            </div>
            <div class="bug-meta">
              ${b.affected_users ? 'Utilisateurs : ' + b.affected_users + ' \u{2022} ' : ''}
              ${b.error_type || ''} ${b.error_message ? '\u{2014} ' + b.error_message : ''}
            </div>
            ${fix ? `
              <div class="bug-fix"><strong>${fix.file || ''}</strong>\n${fix.diff || fix.test || 'Pas de diff'}</div>
              <div class="bug-actions">
                <button class="btn-xs btn-approve" onclick="approveBug('${b.bug_id}', this)">Approuver le fix</button>
                <button class="btn-xs btn-reject" onclick="rejectBug('${b.bug_id}', this)">Rejeter</button>
              </div>
            ` : ''}
          </div>
        `;
      }).join('');
    }

    async function approveBug(bugId, btn) {
      btn.textContent = '\u{23F3} Cr\u{00E9}ation t\u{00E2}che...';
      btn.disabled = true;

      // Find the bug details from the card's data
      const card = btn.closest('.bug-card');
      const file = card.querySelector('.bug-fix strong')?.textContent || '';
      const diff = card.querySelector('.bug-fix')?.textContent?.replace(file, '').trim() || '';
      const rootCause = card.querySelector('.bug-title')?.textContent || '';

      // Get Agent Dev id
      const devAgent = agents.find(a => a.slug === 'agent-dev');
      const debugAgent = agents.find(a => a.slug === 'agent-debug');
      if (!devAgent) { btn.textContent = '\u{274C} Agent Dev introuvable'; return; }

      // Create approved task for Agent Dev
      const { error } = await sb.from('agent_tasks').insert({
        created_by_agent: debugAgent?.id || null,
        assigned_to_agent: devAgent.id,
        task_type: 'code_fix',
        payload: {
          bug_id: bugId,
          root_cause: rootCause,
          file: file,
          diff: diff,
          instructions: 'Appliquer le fix propos\u{00E9} par Agent Debug. Cr\u{00E9}er une branche, appliquer, build, commit, push.'
        },
        status: 'approved',
        approved_at: new Date().toISOString(),
        approved_by: 'tech'
      });

      if (error) {
        btn.textContent = '\u{274C} Erreur';
        console.error(error);
      } else {
        btn.textContent = '\u{2705} Approuv\u{00E9} \u{2014} en attente du poller';
        btn.parentElement.querySelector('.btn-reject').style.display = 'none';
      }
    }

    async function rejectBug(bugId, btn) {
      btn.textContent = 'Rejet\u{00E9}';
      btn.disabled = true;
      btn.parentElement.querySelector('.btn-approve').disabled = true;
    }

    // ─── Contacts View ──────────────────────────
    async function loadContactsView() {
      const container = document.getElementById('contacts-list');
      container.innerHTML = '<p class="empty-state">Chargement...</p>';

      // Get from outreach_contacts table
      const { data: dbContacts } = await sb.from('outreach_contacts')
        .select('*').order('updated_at', { ascending: false }).limit(100);

      // Also get from latest marketing run output
      const mktAgent = agents.find(a => a.slug === 'agent-marketing');
      let runContacts = [];
      if (mktAgent) {
        const { data: runs } = await sb.from('agent_runs').select('output')
          .eq('agent_id', mktAgent.id).eq('status', 'completed')
          .order('started_at', { ascending: false }).limit(3);
        (runs || []).forEach(r => {
          const c = r.output?.output?.contacts?.new || [];
          runContacts = runContacts.concat(c);
        });
      }

      const allContacts = (dbContacts || []).concat(
        runContacts.map(c => ({ ...c, status: 'identified', source: 'agent' }))
      );

      if (allContacts.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucun contact pour le moment</p>';
        return;
      }

      const platformIcons = { instagram: '\u{1F4F7}', tiktok: '\u{1F3B5}', youtube: '\u{1F3AC}', email: '\u{1F4E7}', twitter: '\u{1F426}', reddit: '\u{1F4AC}' };

      container.innerHTML = allContacts.map(c => {
        const icon = platformIcons[c.platform] || '\u{1F464}';
        const status = c.status || 'identified';
        return `
          <div class="contact-card">
            <div class="contact-avatar">${icon}</div>
            <div class="contact-info">
              <div class="contact-name">${c.name || 'Inconnu'}</div>
              <div class="contact-handle">${c.handle || c.platform || ''} ${c.followers ? '\u{2022} ' + c.followers + ' followers' : ''}</div>
            </div>
            <span class="contact-status-badge cs-${status}">${status}</span>
          </div>
        `;
      }).join('');
    }

    // ─── Content View ───────────────────────────
    async function loadContentView() {
      const container = document.getElementById('content-list');
      container.innerHTML = '<p class="empty-state">Chargement...</p>';

      const ctnAgent = agents.find(a => a.slug === 'agent-contenu');
      if (!ctnAgent) { container.innerHTML = '<p class="empty-state">Agent Contenu non trouv\u{00E9}</p>'; return; }

      const { data: runs } = await sb.from('agent_runs').select('output,started_at')
        .eq('agent_id', ctnAgent.id).eq('status', 'completed')
        .order('started_at', { ascending: false }).limit(5);

      const allContent = [];
      (runs || []).forEach(r => {
        const out = r.output?.output || r.output || {};
        (out.articles || []).forEach(a => allContent.push({ ...a, type: 'article', date: r.started_at }));
        (out.video_scripts || []).forEach(v => allContent.push({ ...v, type: 'video_script', date: r.started_at }));
        (out.emails || []).forEach(e => allContent.push({ ...e, type: 'email', date: r.started_at }));
      });

      if (allContent.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucun contenu produit pour le moment</p>';
        return;
      }

      const badge = document.getElementById('content-count');
      badge.textContent = allContent.length;
      badge.style.display = 'inline';

      const typeLabels = { article: 'Article', video_script: 'Script vid\u{00E9}o', email: 'Email', caption: 'Caption' };

      container.innerHTML = allContent.map(c => {
        const preview = c.content ? c.content.slice(0, 200) : c.body ? c.body.slice(0, 200) : '';
        return `
          <div class="content-card type-${c.type}">
            <div class="bug-header">
              <span class="bug-title">${c.title || 'Sans titre'}</span>
              <span class="content-type-badge">${typeLabels[c.type] || c.type}</span>
            </div>
            ${c.target_keyword ? `<div class="bug-meta">Keyword : ${c.target_keyword} ${c.word_count ? '\u{2022} ' + c.word_count + ' mots' : ''}</div>` : ''}
            ${preview ? `<div class="content-preview">${preview}...</div>` : ''}
            ${c.review_notes ? `<div class="review-notes">\u{26A0}\u{FE0F} ${c.review_notes}</div>` : ''}
            ${c.needs_medical_review ? '<div class="review-notes">\u{1F3E5} Review m\u{00E9}dicale requise</div>' : ''}
            <div class="bug-actions" style="margin-top:10px;">
              <button class="btn-xs btn-approve">Valider</button>
              <button class="btn-xs btn-reject">Rejeter</button>
            </div>
          </div>
        `;
      }).join('');
    }

    // ─── Exec Results (code_fix tasks) ────────
    async function loadExecResults() {
      const container = document.getElementById('exec-list');
      if (!container) return;

      const { data: tasks } = await sb.from('agent_tasks')
        .select('*')
        .eq('task_type', 'code_fix')
        .in('status', ['approved', 'executing', 'executed', 'rejected'])
        .order('approved_at', { ascending: false })
        .limit(10);

      if (!tasks || tasks.length === 0) {
        container.innerHTML = '<p class="empty-state">Aucune ex\u{00E9}cution de code</p>';
        return;
      }

      container.innerHTML = tasks.map(t => {
        const bugId = t.payload?.bug_id || '?';
        const statusColors = { approved: '#f59e0b', executing: '#60a5fa', executed: '#22c55e', rejected: '#ef4444' };
        const statusLabels = { approved: 'En attente', executing: 'En cours', executed: 'Ex\u{00E9}cut\u{00E9}', rejected: 'Rejet\u{00E9}' };
        const color = statusColors[t.status] || '#71717a';
        const label = statusLabels[t.status] || t.status;

        return `
          <div class="exec-result">
            <div class="exec-status" style="color:${color}">${label} \u{2014} ${bugId}</div>
            ${t.git_branch ? `<div class="exec-branch">\u{1F33F} ${t.git_branch}</div>` : ''}
            ${t.result_summary ? `<div style="font-size:0.8rem;color:#a1a1aa;margin-top:4px;">${t.result_summary}</div>` : ''}
            ${t.git_commit ? `<div style="font-size:0.72rem;color:#71717a;margin-top:4px;">Commit: ${t.git_commit}</div>` : ''}
          </div>
        `;
      }).join('');
    }

    // ─── Export CSV contacts ────────────────────
    async function exportContactsCSV() {
      const { data: contacts } = await sb.from('outreach_contacts')
        .select('*').order('created_at', { ascending: false });

      if (!contacts || contacts.length === 0) {
        alert('Aucun contact \u{00E0} exporter');
        return;
      }

      const headers = ['name', 'platform', 'handle', 'email', 'followers', 'niche', 'status', 'language', 'notes'];
      const csv = [headers.join(',')];
      contacts.forEach(c => {
        csv.push(headers.map(h => {
          const val = (c[h] || '').toString().replace(/"/g, '""');
          return `"${val}"`;
        }).join(','));
      });

      const blob = new Blob([csv.join('\n')], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `contacts_outreach_${new Date().toISOString().split('T')[0]}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    }

    // ─── Realtime ──────────────────────────────
    function setupRealtime() {
      sb.channel('agent-updates')
        .on('postgres_changes', { event: '*', schema: 'public', table: 'agent_runs' }, () => {
          loadData();
        })
        .on('postgres_changes', { event: '*', schema: 'public', table: 'agents' }, () => {
          loadData();
        })
        .subscribe();
    }
  </script>
</body>
</html>
