---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';

const langParam = Astro.url.searchParams.get('lang');
const lang = ['en', 'de'].includes(langParam!) ? langParam! : 'fr';
const titles: Record<string, string> = { fr: 'Forum communautaire - AIVancePro', en: 'Community Forum - AIVancePro', de: 'Community-Forum - AIVancePro' };
const descs: Record<string, string> = { fr: "Posez vos questions, partagez vos conseils et échangez avec la communauté AIVancePro.", en: "Ask questions, share tips and connect with the AIVancePro community.", de: "Stellen Sie Fragen, teilen Sie Tipps und tauschen Sie sich mit der AIVancePro-Community aus." };
---

<BaseLayout
  lang={lang}
  title={titles[lang]}
  description={descs[lang]}
  canonical="https://aivancepro.fr/forum/"
>
  <Fragment slot="head">
    <style is:global>
      .forum-container { max-width: 960px; margin: 0 auto; padding: 5rem 2rem 4rem; }
      .forum-header { margin-bottom: 2rem; }
      .forum-header h1 { font-size: 2rem; font-weight: 800; color: var(--text); margin-bottom: 0.25rem; }
      .forum-header p { color: var(--text-secondary); font-size: 0.95rem; }

      .forum-toolbar { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; align-items: center; flex-wrap: wrap; }
      .forum-search { flex: 1; min-width: 200px; padding: 0.65rem 1rem; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text); font-size: 0.9rem; font-family: inherit; outline: none; transition: border-color 0.2s; }
      .forum-search:focus { border-color: var(--blue); }
      .btn-new-post { padding: 0.65rem 1.25rem; border-radius: 12px; border: none; background: var(--blue); color: #fff; font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; white-space: nowrap; transition: all 0.2s; display: flex; align-items: center; gap: 0.4rem; box-shadow: 0 4px 15px rgba(74, 144, 217, 0.3); }
      .btn-new-post:hover { opacity: 0.92; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(74, 144, 217, 0.4); }
      .btn-new-post svg { width: 18px; height: 18px; }

      .forum-categories { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
      .cat-btn { padding: 0.4rem 0.9rem; border-radius: 50px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-secondary); font-size: 0.8rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; }
      .cat-btn:hover, .cat-btn.active { background: var(--blue); color: var(--white); border-color: var(--blue); }

      .forum-sort { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
      .sort-btn { padding: 0.3rem 0.7rem; border-radius: 8px; border: none; background: none; color: var(--text-muted); font-size: 0.8rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; }
      .sort-btn:hover, .sort-btn.active { color: var(--text); background: var(--bg-card); }

      /* Post cards — Reddit style */
      .forum-posts { display: flex; flex-direction: column; gap: 0.75rem; }
      .forum-post { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; cursor: pointer; transition: all 0.2s; display: flex; align-items: stretch; overflow: hidden; }
      .forum-post:hover { border-color: var(--blue); box-shadow: 0 2px 12px rgba(74,144,217,0.08); }
      .post-thumb { width: 120px; min-height: 100%; object-fit: cover; flex-shrink: 0; display: block; }
      .post-content { flex: 1; min-width: 0; padding: 1rem 1.25rem; }
      .post-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; font-size: 0.76rem; color: var(--text-muted); }
      .post-header .post-tag { padding: 0.12rem 0.5rem; border-radius: 50px; background: rgba(74,144,217,0.08); color: var(--blue); font-size: 0.68rem; font-weight: 600; }
      .post-header .post-tag.article { background: rgba(74,144,217,0.08); color: var(--blue); }
      .post-author { font-weight: 600; color: var(--text-secondary); }
      .post-title { font-size: 1.02rem; font-weight: 600; color: var(--text); line-height: 1.4; margin-bottom: 0.65rem; }
      /* Action bar (votes, comments, share, admin) */
      .post-actions { display: flex; align-items: center; gap: 0.15rem; }
      .post-action { display: flex; align-items: center; gap: 0.3rem; padding: 0.3rem 0.6rem; border-radius: 20px; border: none; background: none; color: var(--text-muted); font-size: 0.78rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.15s; }
      .post-action:hover { background: rgba(74,144,217,0.06); color: var(--text-secondary); }
      .post-action svg { width: 16px; height: 16px; }
      .post-action.votes { background: rgba(74,144,217,0.05); border-radius: 20px; }
      .post-action.votes:hover { background: rgba(74,144,217,0.1); }
      .post-action .score { font-weight: 700; color: var(--text); }
      .post-action.delete-action:hover { color: #ef4444; background: rgba(239,68,68,0.06); }
      .post-action.translate-btn { font-size: 0.72rem; }
      .post-action.translate-btn svg { width: 14px; height: 14px; }

      /* Share dropdown */
      .share-dropdown-wrap { position: relative; }
      .share-dropdown { position: absolute; bottom: calc(100% + 0.5rem); left: 50%; transform: translateX(-50%); background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.15); padding: 0.5rem; display: none; z-index: 100; white-space: nowrap; }
      .share-dropdown.open { display: flex; gap: 0.25rem; }
      .share-dropdown a, .share-dropdown button { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 8px; border: none; background: none; color: var(--text-muted); cursor: pointer; transition: all 0.15s; text-decoration: none; }
      .share-dropdown a:hover, .share-dropdown button:hover { background: rgba(74,144,217,0.08); }
      .share-dropdown .share-x:hover { color: #000; }
      .share-dropdown .share-fb:hover { color: #1877F2; }
      .share-dropdown .share-li:hover { color: #0A66C2; }
      .share-dropdown .share-copy:hover { color: var(--blue); }
      .share-dropdown .share-copy.copied { color: #22c55e; }
      .share-dropdown svg { width: 18px; height: 18px; }
      @media (prefers-color-scheme: dark) { .share-dropdown .share-x:hover { color: #fff; } }

      .forum-empty { text-align: center; padding: 4rem 2rem; color: var(--text-secondary); }
      .forum-empty h3 { font-size: 1.15rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
      .forum-empty p { font-size: 0.9rem; }
      .forum-loading { text-align: center; padding: 3rem; color: var(--text-muted); font-size: 0.9rem; }

      /* Modal */
      .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 1rem; }
      .modal-overlay.open { display: flex; }
      .modal-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; }
      .modal-box h2 { font-size: 1.3rem; font-weight: 800; color: var(--text); margin-bottom: 1.5rem; }
      .modal-field { margin-bottom: 1rem; }
      .modal-field label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text); margin-bottom: 0.35rem; }
      .modal-field input, .modal-field textarea, .modal-field select { width: 100%; padding: 0.65rem 0.85rem; border-radius: 10px; border: 1px solid var(--border); background: var(--bg); color: var(--text); font-size: 0.9rem; font-family: inherit; outline: none; transition: border-color 0.2s; box-sizing: border-box; }
      .modal-field input:focus, .modal-field textarea:focus, .modal-field select:focus { border-color: var(--blue); }
      .modal-field textarea { resize: vertical; min-height: 120px; }
      .modal-actions { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1.5rem; }
      .btn-cancel { padding: 0.6rem 1.25rem; border-radius: 10px; border: 1px solid var(--border); background: var(--bg); color: var(--text-secondary); font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; }
      .btn-submit { padding: 0.6rem 1.25rem; border-radius: 12px; border: none; background: var(--blue); color: #fff; font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 15px rgba(74, 144, 217, 0.3); }
      .btn-submit:hover { opacity: 0.92; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(74, 144, 217, 0.4); }
      .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }
      .modal-error { color: #ef4444; font-size: 0.85rem; margin-top: 0.5rem; }
      .auth-prompt { text-align: center; padding: 2rem; }
      .auth-prompt p { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 1rem; }
      .btn-login-link { display: inline-block; padding: 0.65rem 1.5rem; border-radius: 12px; background: var(--blue); color: #fff; text-decoration: none; font-weight: 600; font-size: 0.9rem; box-shadow: 0 4px 15px rgba(74, 144, 217, 0.3); transition: all 0.2s; }
      .btn-login-link:hover { opacity: 0.92; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(74, 144, 217, 0.4); }

      .media-btn:hover { color: var(--text-secondary); background: rgba(74,144,217,0.06); }

      @media (max-width: 768px) {
        .forum-container { padding: 4rem 1rem 3rem; }
        .forum-header h1 { font-size: 1.5rem; }
        .forum-toolbar { flex-direction: column; }
        .forum-search { width: 100%; }
        .forum-post { flex-direction: column; }
        .post-thumb { width: 100%; height: 160px; min-height: auto; }
        .post-content { padding: 0.85rem 1rem; }
        .post-title { font-size: 0.95rem; }
        .post-actions { flex-wrap: wrap; gap: 0.25rem; }
        .post-action { padding: 0.25rem 0.5rem; font-size: 0.72rem; }
        .forum-categories { gap: 0.35rem; }
        .cat-btn { padding: 0.35rem 0.7rem; font-size: 0.75rem; }
      }
    </style>
  </Fragment>

  <div class="forum-container">
    <div class="forum-header">
      <h1>Forum communautaire</h1>
      <p>Échangez avec la communauté AIVancePro — posez vos questions, partagez vos conseils.</p>
    </div>

    <div class="forum-toolbar">
      <input type="text" class="forum-search" id="forumSearch" placeholder="Rechercher un sujet...">
      <button class="btn-new-post" id="btnNewPost">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nouveau sujet
      </button>
    </div>

    <div class="forum-categories" id="forumCategories">
      <button class="cat-btn active" data-cat="all">Tous</button>
      <button class="cat-btn" data-cat="general">Général</button>
      <button class="cat-btn" data-cat="entrainement">Entraînement</button>
      <button class="cat-btn" data-cat="nutrition">Nutrition</button>
      <button class="cat-btn" data-cat="progression">Progression</button>
      <button class="cat-btn" data-cat="article">Articles & Guides</button>
    </div>

    <div class="forum-sort" id="forumSort">
      <button class="sort-btn active" data-sort="recent">Récents</button>
      <button class="sort-btn" data-sort="popular">Populaires</button>
      <button class="sort-btn" data-sort="unanswered">Sans réponse</button>
    </div>

    <div id="forumPosts" class="forum-posts">
      <div class="forum-loading">Chargement des discussions...</div>
    </div>
  </div>

  <div class="modal-overlay" id="newPostModal">
    <div class="modal-box">
      <div id="modalAuthPrompt" class="auth-prompt" style="display:none">
        <h2>Connectez-vous pour participer</h2>
        <p>Créez un compte ou connectez-vous pour poster sur le forum.</p>
        <a href="/login/?redirect=/forum/" class="btn-login-link">Se connecter</a>
      </div>
      <div id="modalPostForm" style="display:none">
        <h2>Nouveau sujet</h2>
        <div class="modal-field"><label for="postTitle">Titre</label><input type="text" id="postTitle" placeholder="Votre question ou sujet..." maxlength="200"></div>
        <div class="modal-field"><label for="postCategory">Catégorie</label><select id="postCategory"><option value="general">Général</option><option value="entrainement">Entraînement</option><option value="nutrition">Nutrition</option><option value="progression">Progression</option></select></div>
        <div class="modal-field"><label for="postBody">Message</label><textarea id="postBody" placeholder="Décrivez votre question ou partagez vos conseils..."></textarea></div>
        <div id="postMediaPreview"></div>
        <div class="modal-media-toolbar" style="display:flex;align-items:center;gap:0.35rem;margin-top:0.5rem">
          <button type="button" class="media-btn" title="Ajouter une image" style="background:none;border:none;cursor:pointer;color:var(--text-muted);padding:0.3rem;border-radius:6px;display:flex;align-items:center;position:relative"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><input type="file" accept="image/*" id="postImageInput" style="position:absolute;inset:0;opacity:0;cursor:pointer"></button>
          <button type="button" class="media-btn" id="postGifBtn" title="Ajouter un GIF" style="background:none;border:none;cursor:pointer;color:var(--text-muted);padding:0.3rem;border-radius:6px;display:flex;align-items:center;position:relative"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px"><rect x="2" y="4" width="20" height="16" rx="2"/><text x="12" y="15" text-anchor="middle" font-size="8" font-weight="bold" fill="currentColor" stroke="none">GIF</text></svg></button>
        </div>
        <p class="modal-error" id="postError" style="display:none"></p>
        <div class="modal-actions"><button class="btn-cancel" id="btnCancelPost">Annuler</button><button class="btn-submit" id="btnSubmitPost">Publier</button></div>
      </div>
    </div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
