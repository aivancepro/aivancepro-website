---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides', ({ data }) => data.lang === 'de'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  lang="de"
  title="Fitness- & Krafttraining-Ratgeber - AIVancePro"
  description="Vollständige Fitness- und Krafttraining-Ratgeber. Lernen Sie die Grundlagen, erstellen Sie Ihr Programm und machen Sie effektiv Fortschritte."
  canonical="https://aivancepro.fr/de/ratgeber/"
  alternates={{ fr: 'https://aivancepro.fr/guides/', en: 'https://aivancepro.fr/en/guides/', de: 'https://aivancepro.fr/de/ratgeber/' }}
>
  <Fragment slot="head">
    <style>
      .page-header {
        padding: 9rem 2rem 3rem;
        text-align: center;
        background: linear-gradient(180deg, var(--bg-card), var(--bg));
      }
      .section-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--blue);
        margin-bottom: 0.75rem;
      }
      .page-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }
      .page-header p {
        color: var(--gray-500);
        font-size: 1.1rem;
        max-width: 550px;
        margin: 0 auto;
      }
      .guides-grid {
        max-width: 1000px;
        margin: 0 auto;
        padding: 3rem 2rem 6rem;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
      .guide-card {
        background: var(--bg-card);
        border: 1px solid var(--gray-200);
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        color: var(--gray-900);
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        display: flex;
        flex-direction: column;
      }
      .guide-card:hover {
        border-color: rgba(74, 144, 217, 0.3);
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
      }
      .guide-card .card-image {
        width: 100%;
        height: 180px;
        background: linear-gradient(135deg, var(--gray-100), var(--gray-200));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gray-400);
        font-size: 0.8rem;
        font-weight: 500;
      }
      .guide-card .card-content {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .guide-card .tag {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        background: rgba(74, 144, 217, 0.06);
        border-radius: 50px;
        font-size: 0.7rem;
        color: var(--blue);
        font-weight: 600;
        margin-bottom: 0.75rem;
        width: fit-content;
      }
      .guide-card h2 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.35;
      }
      .guide-card p {
        color: var(--gray-500);
        font-size: 0.85rem;
        line-height: 1.6;
        flex: 1;
      }
      .guide-card .meta {
        margin-top: 1rem;
        font-size: 0.75rem;
        color: var(--gray-400);
        font-weight: 500;
      }
      @media (max-width: 768px) {
        .page-header { padding: 7rem 1.5rem 2rem; }
        .page-header h1 { font-size: 2rem; }
        .guides-grid { grid-template-columns: 1fr; }
      }
    </style>
  </Fragment>

  <header class="page-header">
    <div class="section-label">Ratgeber</div>
    <h1>Vollständige Ratgeber</h1>
    <p>Ausführliche Ratgeber, um jeden Aspekt Ihres Trainings zu meistern – vom Anfänger bis zum Fortgeschrittenen.</p>
  </header>

  <section class="guides-grid">
    {guides.map(guide => (
      <a href={`/de/ratgeber/${guide.data.slug}/`} class="guide-card">
        <div class="card-image img-placeholder">{guide.data.tag}</div>
        <div class="card-content">
          <span class="tag">{guide.data.tag}</span>
          <h2>{guide.data.title}</h2>
          <p>{guide.data.description}</p>
          <div class="meta">{guide.data.readTime}</div>
        </div>
      </a>
    ))}
  </section>

  <section class="final-cta">
    <h2>Setzen Sie es in die Praxis um</h2>
    <p>Laden Sie AIVancePro herunter und lassen Sie den KI-Coach diese Prinzipien auf Ihr Training anwenden.</p>
    <div class="store-badges" style="justify-content:center;margin-top:1.5rem;">
        <a href="https://apps.apple.com/app/aivancepro/id6756116760" class="store-badge-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="store-badge-text"><span class="small">Erhältlich im</span><span class="big">App Store</span></span>
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.aivancepro.app" class="store-badge-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
            <span class="store-badge-text"><span class="small">Erhältlich bei</span><span class="big">Google Play</span></span>
        </a>
    </div>
  </section>
</BaseLayout>
