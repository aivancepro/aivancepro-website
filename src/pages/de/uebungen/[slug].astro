---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import MuscleMap from '../../../components/MuscleMap.astro';
import { exercises, toSlug } from '../../../data/exercises-de.js';
import { enExerciseImages } from '../../../data/exercise-images.js';

// --- Helper: difficulty colors ---
const difficultyColors: Record<string, { bg: string; color: string }> = {
  "Anfänger": { bg: "rgba(16, 185, 129, 0.1)", color: "#10B981" },
  "Fortgeschritten": { bg: "rgba(245, 158, 11, 0.1)", color: "#F59E0B" },
  "Experte": { bg: "rgba(239, 68, 68, 0.1)", color: "#EF4444" },
};

// --- Helper: category labels ---
const categoryLabels: Record<string, string> = {
  pectoraux: "Brust",
  dos: "Rücken",
  epaules: "Schultern",
  biceps: "Bizeps",
  triceps: "Trizeps",
  jambes: "Beine",
  fessiers: "Gesäß",
  abdos: "Bauchmuskeln",
  "avant-bras": "Unterarme",
  fonctionnel: "Funktionell",
};

// --- Helper: secondary muscles by category ---
const secondaryMuscles: Record<string, { primary: string[]; secondary: string[] }> = {
  pectoraux: { primary: ["Großer Brustmuskel", "Kleiner Brustmuskel"], secondary: ["Vorderer Deltamuskel", "Trizeps", "Vorderer Sägemuskel"] },
  dos: { primary: ["Latissimus dorsi", "Trapezmuskel", "Rautenmuskel"], secondary: ["Bizeps", "Rückenstrecker", "Hinterer Deltamuskel"] },
  epaules: { primary: ["Vorderer Deltamuskel", "Seitlicher Deltamuskel", "Hinterer Deltamuskel"], secondary: ["Trapezmuskel", "Trizeps", "Vorderer Sägemuskel"] },
  biceps: { primary: ["Bizeps", "Brachialis"], secondary: ["Brachioradialis", "Unterarme", "Vorderer Deltamuskel"] },
  triceps: { primary: ["Trizeps (3 Köpfe)"], secondary: ["Vorderer Deltamuskel", "Brustmuskel", "Anconeus"] },
  jambes: { primary: ["Quadrizeps", "Beinbeuger", "Gesäßmuskel"], secondary: ["Adduktoren", "Waden", "Rumpfmuskulatur"] },
  fessiers: { primary: ["Großer Gesäßmuskel", "Mittlerer Gesäßmuskel", "Kleiner Gesäßmuskel"], secondary: ["Beinbeuger", "Quadrizeps", "Rumpfmuskulatur"] },
  abdos: { primary: ["Gerader Bauchmuskel", "Schräge Bauchmuskeln"], secondary: ["Querer Bauchmuskel", "Hüftbeuger", "Rückenstrecker"] },
  "avant-bras": { primary: ["Handgelenkbeuger", "Handgelenkstrecker"], secondary: ["Brachioradialis", "Pronator", "Supinator"] },
  fonctionnel: { primary: ["Mehrere Muskelgruppen"], secondary: ["Rumpfmuskulatur", "Stabilisatoren", "Haltungsmuskeln"] },
};

// --- Helper: generate steps ---
function getSteps(ex: typeof exercises[0]): string[] {
  const n = ex.name.toLowerCase();
  const eq = ex.equipment.toLowerCase();
  const cat = ex.category;

  if (n.includes('press') && !n.includes('pallof') && !n.includes('pull-apart') || n.includes('bench press')) {
    if (n.includes('incline')) {
      return [
        "Stellen Sie die Bank auf einen 30-45 Grad Winkel ein und setzen Sie sich fest mit den Füßen flach auf dem Boden.",
        `Greifen Sie ${eq.includes('dumbbell') ? 'die Kurzhanteln' : eq.includes('barbell') ? 'die Stange' : 'die Griffe'} mit einem angemessenen Griff, Arme über der Brust ausgestreckt.`,
        "Senken Sie langsam und kontrolliert ab, Ellbogen etwa 45 Grad vom Oberkörper entfernt.",
        "Drücken Sie nach oben und spannen Sie die obere Brustmuskulatur an, bis die Arme vollständig gestreckt sind.",
        "Wiederholen Sie die Bewegung, wobei die Schulterblätter zusammengezogen und der Rücken leicht gewölbt bleiben."
      ];
    }
    if (n.includes('decline')) {
      return [
        "Positionieren Sie sich auf einer Schrägbank (Decline) mit den Füßen unter den Polstern gesichert.",
        `Greifen Sie ${eq.includes('dumbbell') ? 'die Kurzhanteln' : 'die Stange'} mit einem angemessenen Griff, Arme ausgestreckt.`,
        "Senken Sie das Gewicht kontrolliert zur unteren Brust ab.",
        "Drücken Sie nach oben und spannen Sie die untere Brustmuskulatur kräftig an.",
        "Halten Sie die Schulterblätter zusammengezogen und vermeiden Sie ein Abprallen am tiefsten Punkt."
      ];
    }
    if (n.includes('overhead') || n.includes('shoulder') || n.includes('arnold') || n.includes('military')) {
      return [
        `Sitzen oder stehen Sie, ${eq.includes('dumbbell') ? 'Kurzhanteln auf Schulterhöhe' : eq.includes('barbell') ? 'Stange auf Schlüsselbeinhöhe' : 'Hände an den Griffen'}.`,
        "Spannen Sie Ihre Rumpfmuskulatur an und halten Sie den Rücken während der gesamten Bewegung gerade.",
        "Drücken Sie das Gewicht beim Ausatmen über den Kopf bis zur nahezu vollständigen Armstreckung.",
        "Senken Sie langsam zurück auf Schulterhöhe und kontrollieren Sie die exzentrische Phase.",
        "Vermeiden Sie ein übermäßiges Hohlkreuz und achten Sie auf eine gleichmäßige Atmung."
      ];
    }
    return [
      "Legen Sie sich auf eine Flachbank, Füße flach auf dem Boden, Schulterblätter gegen die Bank gedrückt.",
      `Greifen Sie ${eq.includes('dumbbell') ? 'die Kurzhanteln' : eq.includes('barbell') ? 'die Stange' : 'die Griffe'} schulterbreit oder etwas weiter.`,
      "Heben Sie das Gewicht ab und bringen Sie es über Ihre Brust, Arme gestreckt.",
      "Senken Sie langsam zur mittleren Brust ab, Ellbogen im 45-Grad-Winkel.",
      "Drücken Sie explosiv nach oben und spannen Sie die Brustmuskulatur bis zum Lockout an."
    ];
  }

  if (n.includes('fly') || n.includes('crossover') || n.includes('pec deck')) {
    return [
      `Positionieren Sie sich auf ${eq.includes('machine') ? 'der Maschine' : 'einer Flach- oder Schrägbank'}, Rücken fest angelehnt.`,
      `Greifen Sie ${eq.includes('dumbbell') ? 'die Kurzhanteln mit über der Brust ausgestreckten Armen' : eq.includes('cable') ? 'die Griffe auf jeder Seite' : 'die Maschinengriffe'}.`,
      "Öffnen Sie die Arme in einem Bogen, Ellbogen leicht gebeugt, und dehnen Sie die Brust.",
      "Führen Sie die Arme wieder zusammen und spannen Sie die Brustmuskulatur kräftig an.",
      "Kontrollieren Sie jede Wiederholung ohne Schwung, um das Schultergelenk zu schützen."
    ];
  }

  if (n.includes('push-up')) {
    return [
      `Gehen Sie in die Plank-Position, Hände ${n.includes('close') ? 'eng zusammen unter der Brust' : n.includes('wide') ? 'weiter als schulterbreit' : 'schulterbreit aufgestellt'}${n.includes('decline') ? ', Füße auf einer erhöhten Fläche' : n.includes('incline') ? ', Hände auf einer erhöhten Fläche' : ''}.`,
      "Halten Sie Ihren Körper von Kopf bis Fuß in einer Linie, Rumpfmuskulatur angespannt.",
      "Beugen Sie die Arme und senken Sie die Brust kontrolliert zum Boden.",
      "Drücken Sie sich beim Ausatmen zurück in die volle Streckung.",
      "Halten Sie die Rumpfspannung durchgehend und vermeiden Sie ein Durchhängen der Hüfte."
    ];
  }

  if (n.includes('pull-up') || n.includes('chin-up')) {
    const grip = n.includes('underhand') || n.includes('chin') ? 'Handflächen zu Ihnen (Untergriff)' : n.includes('neutral') ? 'Handflächen zueinander (Neutralgriff)' : 'Handflächen nach vorne (Obergriff)';
    const width = n.includes('close') ? 'Hände eng zusammen' : n.includes('wide') ? 'Hände weiter als schulterbreit' : 'Hände schulterbreit';
    return [
      `Greifen Sie die Stange mit ${grip}, ${width}.`,
      "Starten Sie aus dem Aushang, Schultern aktiviert (Schulterblätter nach unten und zusammengezogen).",
      "Ziehen Sie Ihren Körper nach oben, bis das Kinn über der Stange ist.",
      "Spannen Sie den Latissimus oben an und senken Sie sich langsam ab.",
      "Vermeiden Sie Schwung und kontrollieren Sie das Ablassen, um die Muskelarbeit zu maximieren."
    ];
  }

  if (n.includes('row') && !n.includes('upright')) {
    return [
      `Positionieren Sie sich ${eq.includes('machine') ? 'an der Maschine, Brust gegen das Polster' : eq.includes('cable') ? 'sitzend vor der unteren Rolle, Füße auf den Fußplatten' : 'mit 45 Grad vorgebeugt, Rücken gerade, Knie leicht gebeugt'}.`,
      `Greifen Sie ${eq.includes('dumbbell') ? 'die Kurzhantel mit einer Hand, die andere Hand auf der Bank' : eq.includes('cable') ? 'den Griff oder die Stange' : 'die Stange mit dem entsprechenden Griff'}.`,
      "Ziehen Sie das Gewicht zum Bauchnabel und drücken Sie die Schulterblätter zusammen.",
      "Halten Sie die Kontraktion eine Sekunde und lassen Sie dann langsam und kontrolliert nach.",
      "Halten Sie den Rücken neutral und vermeiden Sie Schwungholen mit dem Körper."
    ];
  }

  if (n.includes('pulldown') || n.includes('lat pull')) {
    return [
      "Setzen Sie sich an die Maschine, Oberschenkel unter den Polstern gesichert.",
      "Greifen Sie die Stange oder den Griff mit dem angegebenen Griff, Arme über dem Kopf gestreckt.",
      "Ziehen Sie die Stange zur oberen Brust und drücken Sie die Schulterblätter zusammen.",
      "Halten Sie die Kontraktion am tiefsten Punkt und kehren Sie langsam und kontrolliert zurück.",
      "Vermeiden Sie übermäßiges Zurücklehnen zum Schwungholen."
    ];
  }

  if (n.includes('deadlift') || n.includes('stiff-leg')) {
    return [
      `Stellen Sie sich vor ${eq.includes('barbell') ? 'die Langhantel' : 'die Kurzhanteln'}, Füße ${n.includes('sumo') ? 'weit auseinander, Zehen nach außen gedreht' : 'schulterbreit auseinander'}.`,
      "Beugen Sie sich in der Hüfte und knicken Sie die Knie, um das Gewicht zu greifen, Rücken gerade und Brust heraus.",
      "Spannen Sie die Rumpfmuskulatur an und drücken Sie den Boden mit den Füßen weg, um die Bewegung einzuleiten.",
      "Richten Sie sich auf, indem Sie Hüfte und Knie gleichzeitig strecken, die Stange nah am Körper.",
      "Drücken Sie oben den Gesäßmuskel zusammen und senken Sie ab, indem Sie die Hüfte nach hinten schieben."
    ];
  }

  if (n.includes('squat') && !n.includes('pistol') && !n.includes('sissy')) {
    return [
      `Positionieren Sie sich ${eq.includes('barbell') ? 'mit der Stange auf dem Trapezmuskel' : eq.includes('dumbbell') ? 'Kurzhanteln seitlich oder vor der Brust' : eq.includes('machine') ? 'in der Maschine, Schultern unter den Polstern' : 'Füße schulterbreit auseinander'}${n.includes('sumo') ? ', Füße weit auseinander, Zehen nach außen gedreht' : n.includes('bulgarian') ? ', hinterer Fuß auf einer Bank erhöht' : ''}.`,
      "Halten Sie den Oberkörper aufrecht, Blick nach vorne und Rumpfmuskulatur angespannt.",
      "Senken Sie sich ab, indem Sie die Hüfte nach hinten schieben, als würden Sie sich hinsetzen, Knie über den Zehen.",
      "Gehen Sie mindestens so tief, bis die Oberschenkel parallel zum Boden sind.",
      "Drücken Sie sich über die Fersen nach oben und spannen Sie Quadrizeps und Gesäßmuskel an."
    ];
  }

  if (n.includes('lunge') && !n.includes('bulgarian')) {
    return [
      `Stehen Sie aufrecht, ${eq.includes('barbell') ? 'Stange auf den Schultern' : eq.includes('dumbbell') ? 'Kurzhanteln seitlich' : 'Arme seitlich'}.`,
      "Machen Sie einen großen Schritt nach vorne (oder hinten) und halten Sie den Oberkörper aufrecht.",
      "Beugen Sie beide Knie auf 90 Grad, das hintere Knie schwebt knapp über dem Boden.",
      "Drücken Sie sich über die vordere Ferse zurück in die Ausgangsposition.",
      "Wechseln Sie die Beine ab oder arbeiten Sie je nach Variante eine Seite nach der anderen."
    ];
  }

  if (n.includes('curl') && !n.includes('leg curl') && !n.includes('hamstring') && !n.includes('nordic') && !n.includes('wrist')) {
    return [
      `Stehen oder sitzen Sie, ${eq.includes('barbell') ? 'Stange in der Hand' : eq.includes('dumbbell') ? 'Kurzhanteln in der Hand' : eq.includes('cable') ? 'vor der Rolle stehend' : 'Arme seitlich'}${n.includes('preacher') ? ', Arme auf dem Preacher-Polster' : n.includes('incline') ? ', Rücken gegen die Schrägbank gelehnt' : n.includes('concentration') ? ', Ellbogen am Oberschenkel abgestützt' : ''}.`,
      "Halten Sie die Ellbogen fixiert an den Seiten (außer bei bestimmten Varianten).",
      "Beugen Sie die Arme, indem Sie den Bizeps anspannen, um das Gewicht zu heben.",
      "Drücken Sie oben in der Bewegung eine Sekunde lang kräftig zusammen.",
      "Senken Sie langsam ab und kontrollieren Sie die exzentrische Phase, ohne das Gewicht fallen zu lassen."
    ];
  }

  if (n.includes('extension') || n.includes('pushdown') || n.includes('kickback')) {
    return [
      `Positionieren Sie sich ${eq.includes('cable') ? 'vor der oberen Rolle' : eq.includes('dumbbell') ? 'sitzend oder stehend' : 'an der Maschine'}${n.includes('overhead') ? ', Arme über dem Kopf' : n.includes('kickback') ? ', Oberkörper vorgebeugt, Arme seitlich' : ''}.`,
      `Greifen Sie ${eq.includes('cable') ? 'das Seil oder die Stange' : eq.includes('dumbbell') ? 'die Kurzhantel' : 'die Griffe'} mit festem Griff.`,
      "Halten Sie die Ellbogen fixiert und nah am Körper (außer bei Überkopf-Varianten).",
      "Strecken Sie die Arme und spannen Sie den Trizeps bis zum Lockout an.",
      "Kehren Sie langsam in die Ausgangsposition zurück und kontrollieren Sie das Gewicht."
    ];
  }

  if (n.includes('dip')) {
    return [
      `Greifen Sie die Parallelholme ${n.includes('bench') ? '(oder stützen Sie die Hände auf einer Bank, Füße davor)' : ''} und drücken Sie sich bis zur Armstreckung hoch.`,
      "Neigen Sie den Oberkörper leicht nach vorne, um die Brust zu beanspruchen, oder bleiben Sie aufrecht für den Trizeps.",
      "Senken Sie sich ab, indem Sie die Ellbogen auf 90 Grad beugen.",
      "Drücken Sie sich nach oben und spannen Sie Trizeps und Brustmuskulatur an.",
      "Kontrollieren Sie das Absenken und gehen Sie nicht zu tief, um die Schultern zu schützen."
    ];
  }

  if (n.includes('raise') || n.includes('reverse fly')) {
    const direction = n.includes('front') ? 'vor Ihrem Körper' : n.includes('bent') || n.includes('reverse') ? 'seitlich im vorgebeugten Zustand' : 'seitlich';
    return [
      `Stehen Sie${n.includes('bent') || n.includes('reverse') ? ' mit dem Oberkörper um 45 Grad vorgebeugt' : ''}, ${eq.includes('dumbbell') ? 'Kurzhanteln in der Hand' : eq.includes('cable') ? 'Kabelgriff in der Hand' : eq.includes('machine') ? 'Arme gegen die Maschinenpolster' : 'Band unter den Füßen'}.`,
      `Heben Sie die Arme ${direction} bis auf Schulterhöhe, Ellbogen leicht gebeugt.`,
      "Halten Sie die Kontraktion oben eine Sekunde lang.",
      "Senken Sie langsam und kontrolliert ab.",
      "Vermeiden Sie Schwung und halten Sie die Bewegung gleichmäßig und kontrolliert."
    ];
  }

  if (n.includes('shrug')) {
    return [
      `Stehen Sie aufrecht, ${eq.includes('barbell') ? 'Langhantel vor Ihnen' : eq.includes('dumbbell') ? 'Kurzhanteln seitlich' : 'Hände an den Maschinengriffen'}.`,
      "Ziehen Sie mit gestreckten Armen die Schultern so hoch wie möglich zu den Ohren.",
      "Halten Sie die Kontraktion oben 1-2 Sekunden.",
      "Senken Sie die Schultern langsam in die Ausgangsposition zurück.",
      "Halten Sie die Arme durchgehend gestreckt; nur die Schultern sollten sich bewegen."
    ];
  }

  if (n.includes('hip thrust') || n.includes('glute bridge')) {
    return [
      `${n.includes('bridge') ? 'Legen Sie sich auf den Boden' : 'Setzen Sie sich auf den Boden, oberer Rücken gegen eine Bank gelehnt'}, Knie gebeugt, Füße flach aufgestellt.`,
      `${eq.includes('barbell') ? 'Legen Sie die Langhantel mit einem Polster zum Schutz auf Ihre Hüfte.' : eq.includes('machine') ? 'Passen Sie die Maschine und das Hüftpolster an.' : 'Legen Sie optional ein Gewicht auf Ihre Hüfte.'}`,
      "Drücken Sie sich über die Fersen hoch, bis die Hüfte vollständig gestreckt ist.",
      "Spannen Sie den Gesäßmuskel oben 1-2 Sekunden kräftig an.",
      "Senken Sie die Hüfte langsam ab, ohne zwischen den Wiederholungen den Boden vollständig zu berühren."
    ];
  }

  if (n.includes('leg extension') || n.includes('leg curl')) {
    return [
      "Setzen Sie sich an die Maschine und passen Sie Sitz und Polster an Ihren Körper an.",
      "Legen Sie die Beine gegen das Polster, Hände an den seitlichen Griffen.",
      `${n.includes('extension') ? 'Strecken Sie die Beine und spannen Sie den Quadrizeps an.' : 'Beugen Sie die Beine und spannen Sie die Beinbeuger an.'}`,
      "Halten Sie die Kontraktion am Endpunkt eine Sekunde lang.",
      "Kehren Sie langsam in die Ausgangsposition zurück und kontrollieren Sie das Gewicht."
    ];
  }

  if (n.includes('crunch') || n.includes('sit-up') || n.includes('leg raise')) {
    return [
      `${n.includes('leg raise') || n.includes('hanging') ? 'Legen Sie sich auf den Boden (oder hängen Sie an der Stange)' : 'Legen Sie sich auf den Rücken, Knie gebeugt, Füße flach auf dem Boden'}${n.includes('decline') ? ' auf einer Schrägbank' : ''}.`,
      `${n.includes('weighted') || n.includes('plate') ? 'Halten Sie das Gewicht gegen die Brust oder mit ausgestreckten Armen.' : 'Legen Sie die Hände hinter den Kopf oder gekreuzt auf die Brust.'}`,
      `${n.includes('leg raise') || n.includes('hanging') ? 'Heben Sie die Beine an, indem Sie die unteren Bauchmuskeln anspannen.' : 'Heben Sie die Schultern vom Boden ab, indem Sie die Bauchmuskeln anspannen.'}`,
      "Atmen Sie während der Kontraktion aus und halten Sie die Position eine Sekunde.",
      "Senken Sie langsam ab, ohne die Spannung auf den Bauchmuskeln vollständig zu lösen."
    ];
  }

  if (n.includes('plank') && !n.includes('planche')) {
    return [
      "Stützen Sie sich auf Unterarme und Zehenspitzen (oder seitlich für die laterale Variante).",
      "Richten Sie Ihren Körper von Kopf bis Fuß aus, Bauchmuskeln und Gesäß angespannt.",
      "Halten Sie die Position, ohne die Hüfte durchhängen oder hochsteigen zu lassen.",
      "Atmen Sie gleichmäßig und kontrolliert während der gesamten Übung.",
      "Halten Sie die gewünschte Dauer (30 Sekunden bis 2 Minuten)."
    ];
  }

  if (n.includes('russian twist')) {
    return [
      "Setzen Sie sich auf den Boden, Knie gebeugt, Füße leicht vom Boden angehoben.",
      `${eq.includes('bodyweight') && !n.includes('weighted') ? 'Führen Sie die Hände vor Ihrem Körper zusammen.' : 'Halten Sie das Gewicht vor Ihrer Brust.'}`,
      "Lehnen Sie den Oberkörper leicht nach hinten, um die Bauchmuskeln zu aktivieren.",
      "Drehen Sie den Oberkörper zu einer Seite und dann zur anderen, bei jeder Drehung den Boden berühren.",
      "Halten Sie die Füße stabil und kontrollieren Sie die Bewegung ohne Hektik."
    ];
  }

  if (n.includes('kettlebell')) {
    if (n.includes('swing')) {
      return [
        "Stehen Sie mit den Füßen weiter als schulterbreit, Kettlebell auf dem Boden vor Ihnen.",
        "Greifen Sie die Kettlebell mit beiden Händen, Rücken gerade, Hüfte nach hinten geschoben.",
        "Schwingen Sie die Kettlebell zwischen Ihren Beinen hindurch und treiben Sie dann die Hüfte nach vorne.",
        "Lassen Sie die Kettlebell durch den Hüftschwung auf Schulterhöhe steigen.",
        "Kontrollieren Sie die Rückbewegung und verketten Sie die Wiederholungen in einer fließenden, kontinuierlichen Bewegung."
      ];
    }
    return [
      "Greifen Sie die Kettlebell mit festem Griff, Füße schulterbreit auseinander.",
      "Spannen Sie die Rumpfmuskulatur an und halten Sie den Rücken während der gesamten Übung neutral.",
      "Führen Sie die Bewegung kontrolliert und mit der spezifischen Technik aus.",
      "Halten Sie die Kontraktion am höchsten Punkt der Bewegung.",
      "Kehren Sie kontrolliert in die Ausgangsposition zurück."
    ];
  }

  if (n.includes('calf')) {
    return [
      `Positionieren Sie sich ${n.includes('seated') ? 'sitzend an der Maschine, Knie unter den Polstern' : 'stehend mit den Fußballen auf der Kante einer Stufe oder Maschine'}.`,
      `${eq.includes('barbell') ? 'Stange auf den Schultern.' : eq.includes('dumbbell') ? 'Kurzhanteln seitlich oder auf den Knien.' : 'Schultern unter den Maschinenpolstern.'}`,
      "Senken Sie die Fersen so weit wie möglich ab, um die Waden zu dehnen.",
      "Heben Sie sich so hoch wie möglich auf die Zehenspitzen und spannen Sie kräftig an.",
      "Halten Sie die Kontraktion oben 1-2 Sekunden und senken Sie dann langsam ab."
    ];
  }

  if (n.includes('leg press') || n.includes('hack squat')) {
    return [
      "Setzen Sie sich an die Maschine, Rücken fest gegen die Rückenlehne gedrückt.",
      `Stellen Sie die Füße auf die Plattform ${n.includes('high') ? 'in einer hohen Position, um den Gesäßmuskel zu beanspruchen' : 'schulterbreit auseinander'}.`,
      "Entriegeln Sie die Maschine und senken Sie die Plattform durch Beugen der Knie ab.",
      "Gehen Sie bis zu einem 90-Grad-Kniewinkel hinunter (oder tiefer, wenn die Beweglichkeit es erlaubt).",
      "Drücken Sie sich über die Fersen nach oben, ohne die Knie vollständig durchzustrecken."
    ];
  }

  if (n.includes('trx')) {
    return [
      "Passen Sie die TRX-Bänder auf die richtige Länge für die Übung an.",
      "Greifen Sie die Griffe oder platzieren Sie die Füße je nach Bedarf in den Schlaufen.",
      "Spannen Sie die Rumpfmuskulatur an und halten Sie eine korrekte Körperausrichtung.",
      "Führen Sie die Bewegung kontrolliert aus und nutzen Sie Ihr Körpergewicht als Widerstand.",
      "Passen Sie Ihren Körperwinkel an, um den Schwierigkeitsgrad zu erhöhen oder zu verringern."
    ];
  }

  if (eq.includes('resistance band') || eq.includes('band')) {
    return [
      "Befestigen Sie das Band an einem geeigneten Punkt oder unter Ihren Füßen.",
      "Greifen Sie das Band mit festem Griff und halten Sie eine Grundspannung aufrecht.",
      "Führen Sie die Bewegung aus und kontrollieren Sie den zunehmenden Bandwiderstand.",
      "Halten Sie die Kontraktion am Punkt der maximalen Spannung.",
      "Kehren Sie langsam in die Ausgangsposition zurück und kontrollieren Sie das Band."
    ];
  }

  if (n.includes('medicine ball')) {
    return [
      "Greifen Sie den Medizinball mit beiden Händen, Füße schulterbreit auseinander.",
      "Spannen Sie die Rumpfmuskulatur an und bereiten Sie sich auf die explosive Bewegung vor.",
      "Führen Sie den Wurf oder die Bewegung kraftvoll mit dem ganzen Körper aus.",
      "Kontrollieren Sie das Fangen und kehren Sie in die Ausgangsposition zurück.",
      "Verketten Sie die Wiederholungen bei guter Form und gleichmäßiger Intensität."
    ];
  }

  return [
    "Positionieren Sie sich in der richtigen Ausgangsposition für diese Übung.",
    "Spannen Sie die Rumpfmuskulatur an und achten Sie auf eine korrekte Körperausrichtung.",
    "Führen Sie die Bewegung kontrolliert und mit der richtigen Technik aus.",
    "Halten Sie die Kontraktion am höchsten Punkt der Bewegung eine Sekunde lang.",
    "Kehren Sie langsam in die Ausgangsposition zurück und wiederholen Sie die gewünschte Anzahl an Wiederholungen."
  ];
}

// --- Helper: generate common mistakes ---
function getMistakes(ex: typeof exercises[0]): string[] {
  const mistakesByCategory: Record<string, string[]> = {
    pectoraux: [
      "Das Gewicht von der Brust abprallen lassen, anstatt das Absenken zu kontrollieren.",
      "Die Hüfte von der Bank abheben oder den Rücken übermäßig wölben.",
      "Die Ellbogen auf 90 Grad abspreizen, was die Schultern überlastet."
    ],
    dos: [
      "Den Rücken während der Bewegung runden, was zu Verletzungen des unteren Rückens führen kann.",
      "Schwung mit dem Körper holen, anstatt gezielt mit dem Rücken zu ziehen.",
      "Die Schulterblätter am Ende der Kontraktion nicht zusammendrücken, was die Effektivität verringert."
    ],
    epaules: [
      "Das Gewicht zu hoch oder zu schnell mit Körperschwung heben.",
      "Den Rücken beim Überkopfdrücken übermäßig ins Hohlkreuz bringen.",
      "Zu schwere Gewichte verwenden, was die Form beeinträchtigt und das Verletzungsrisiko erhöht."
    ],
    biceps: [
      "Den Oberkörper schwingen, um Schwung zu erzeugen, anstatt den Bizeps zu isolieren.",
      "Die Arme nicht vollständig strecken, was den Bewegungsumfang einschränkt.",
      "Die Ellbogen nach vorne heben, wodurch die Arbeit auf die Deltamuskeln verlagert wird."
    ],
    triceps: [
      "Die Ellbogen während der Bewegung abspreizen, was die Trizeps-Isolation verringert.",
      "Schwung mit dem Körper nutzen, um das Gewicht zu drücken, anstatt es zu kontrollieren.",
      "Die volle Streckung nicht erreichen, wodurch die maximale Kontraktion fehlt."
    ],
    jambes: [
      "Die Knie während der Bewegung nach innen fallen lassen.",
      "Nicht tief genug gehen, was die Muskelrekrutierung einschränkt.",
      "Den Rücken runden, anstatt eine aufrechte und stabile Haltung beizubehalten."
    ],
    fessiers: [
      "Die Hüfte nicht hoch genug heben für eine vollständige Kontraktion.",
      "Den unteren Rücken ins Hohlkreuz bringen, anstatt das Becken in posteriorer Neigung zu halten.",
      "Über die Zehen statt über die Fersen drücken, was die Gesäßaktivierung verringert."
    ],
    abdos: [
      "Mit den Händen am Nacken ziehen, was zu Nackenschmerzen führen kann.",
      "Schwung nutzen, anstatt die Bewegung mit den Bauchmuskeln zu kontrollieren.",
      "Die Spannung auf den Bauchmuskeln während der Absenkphase nicht aufrechterhalten."
    ],
    "avant-bras": [
      "Den gesamten Arm bewegen, anstatt die Bewegung auf das Handgelenk zu isolieren.",
      "Zu viel Gewicht verwenden, was den Bewegungsumfang beeinträchtigt.",
      "Die exzentrische Phase vernachlässigen, indem das Gewicht zu schnell abgelassen wird."
    ],
    fonctionnel: [
      "Die Technik opfern, um schneller zu werden oder schwerer zu heben.",
      "Die Rumpfmuskulatur nicht anspannen, was die Stabilität und Bewegungseffizienz verringert.",
      "Das Aufwärmen vor explosiven Bewegungen auslassen, was das Verletzungsrisiko erhöht."
    ],
  };
  return mistakesByCategory[ex.category] || mistakesByCategory.fonctionnel;
}

// --- Static paths ---
export function getStaticPaths() {
  return exercises.map(ex => ({
    params: { slug: toSlug(ex.name) },
    props: { exercise: ex },
  }));
}

const { exercise } = Astro.props;
const slug = toSlug(exercise.name);
const dc = difficultyColors[exercise.difficulty] || { bg: "rgba(100,100,100,0.1)", color: "#888" };
const difficultyLabel = exercise.difficulty;
const equipmentLabel = exercise.equipment;
const muscles = secondaryMuscles[exercise.category] || secondaryMuscles.fonctionnel;
const steps = getSteps(exercise);
const mistakes = getMistakes(exercise);
const variations = exercises
  .filter(e => e.category === exercise.category && e.name !== exercise.name)
  .sort(() => 0.5 - Math.random())
  .slice(0, 3);

const canonical = `https://aivancepro.fr/de/uebungen/${slug}/`;
const hasImages = !!enExerciseImages[slug];
const catLabel = categoryLabels[exercise.category] || exercise.category;
---

<BaseLayout
  lang="de"
  title={`${exercise.name} - Vollständige Anleitung | AIVancePro`}
  description={`Erfahren Sie, wie Sie ${exercise.name} richtig ausführen. Vollständige Anleitung mit Technik, häufigen Fehlern und beanspruchten Muskeln.`}
  canonical={canonical}
  alternates={{ fr: `https://aivancepro.fr/exercices/${exercise.frSlug}/`, en: `https://aivancepro.fr/en/exercises/${slug}/`, de: canonical }}
>
  <Fragment slot="head">
    <style>
      .exercise-images { max-width: 900px; margin: 0 auto; padding: 0 2rem 2rem; display: flex; justify-content: center; gap: 1.5rem; }
      .exercise-images img { width: 280px; height: auto; border-radius: 14px; border: 1px solid var(--border); background: var(--bg-card); }

      .exercise-hero { padding: 8rem 2rem 3rem; text-align: center; background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%); }
      .exercise-hero h1 { font-size: 2.8rem; font-weight: 900; letter-spacing: -0.03em; color: var(--gray-900); margin-bottom: 1rem; }
      .exercise-hero h1 .gradient { color: inherit; }
      .breadcrumb { max-width: 900px; margin: 0 auto 2rem; padding: 0 2rem; display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--gray-500); flex-wrap: wrap; }
      .breadcrumb a { color: var(--blue); text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; }
      .breadcrumb .sep { color: var(--gray-400); }
      .exercise-content { max-width: 900px; margin: 0 auto; padding: 0 2rem 4rem; }
      .info-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; margin-bottom: 2.5rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .info-item { text-align: center; }
      .info-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--gray-500); margin-bottom: 0.5rem; }
      .info-value { font-size: 1.05rem; font-weight: 700; color: var(--gray-900); }
      .difficulty-badge { display: inline-block; padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 700; }
      .desc-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 2rem; margin-bottom: 2.5rem; }
      .desc-card p { color: var(--gray-700); font-size: 1.05rem; line-height: 1.8; }
      .section-title { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
      .section-title svg { width: 24px; height: 24px; color: var(--blue); }
      .steps-list { list-style: none; counter-reset: step; margin-bottom: 2.5rem; }
      .steps-list li { counter-increment: step; display: flex; gap: 1rem; align-items: flex-start; padding: 1rem 0; border-bottom: 1px solid var(--gray-100); }
      .steps-list li:last-child { border-bottom: none; }
      .step-num { flex-shrink: 0; width: 36px; height: 36px; background: var(--blue); color: var(--white); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.9rem; }
      .step-text { color: var(--gray-700); font-size: 0.95rem; line-height: 1.6; padding-top: 0.4rem; }
      .mistakes-list { list-style: none; margin-bottom: 2.5rem; }
      .mistakes-list li { display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.75rem 0; color: var(--gray-700); font-size: 0.95rem; line-height: 1.6; }
      .mistakes-list li svg { width: 20px; height: 20px; color: #EF4444; flex-shrink: 0; margin-top: 0.15rem; }
      .muscles-section { display: grid; grid-template-columns: auto 1fr; gap: 2rem; align-items: start; margin-bottom: 2.5rem; }
      .muscles-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      .muscles-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.5rem; }
      .muscles-card h4 { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem; }
      .muscles-card.primary h4 { color: var(--blue); }
      .muscles-card.secondary h4 { color: var(--blue); }
      .muscles-card ul { list-style: none; }
      .muscles-card li { padding: 0.35rem 0; color: var(--gray-700); font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; }
      .muscles-card li::before { content: ''; width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
      .muscles-card.primary li::before { background: var(--blue); }
      .muscles-card.secondary li::before { background: var(--blue); }
      .variations-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 3rem; }
      .variation-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem; text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; }
      .variation-card:hover { border-color: rgba(37,99,235,0.3); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.05); }
      .variation-card h4 { font-size: 0.9rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.5rem; line-height: 1.3; }
      .variation-card .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
      .variation-card .tag { padding: 0.15rem 0.5rem; border-radius: 50px; font-size: 0.6rem; font-weight: 600; }
      .tag-muscle { background: rgba(37,99,235,0.1); color: var(--blue); }
      .tag-equipment { background: rgba(74,144,217,0.1); color: var(--blue); }
      .cta-box { background: linear-gradient(135deg, rgba(37,99,235,0.05), rgba(74,144,217,0.05)); border: 1px solid rgba(37,99,235,0.15); border-radius: 20px; padding: 3rem 2rem; text-align: center; }
      .cta-box h3 { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.75rem; }
      .cta-box p { color: var(--gray-500); font-size: 1rem; max-width: 450px; margin: 0 auto 1.5rem; }
      .btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--blue); color: var(--white); text-decoration: none; font-size: 1rem; font-weight: 600; padding: 0.875rem 2rem; border-radius: 12px; transition: opacity 0.2s, transform 0.2s; box-shadow: 0 4px 15px rgba(37,99,235,0.3); }
      .btn-primary:hover { opacity: 0.92; transform: translateY(-2px); }
      @media (max-width: 768px) {
        .exercise-hero h1 { font-size: 2rem; }
        .exercise-images { flex-direction: column; align-items: center; gap: 1rem; }
        .exercise-images img { width: 220px; }
        .info-card { grid-template-columns: 1fr; }
        .muscles-section { grid-template-columns: 1fr; justify-items: center; }
        .muscles-section .muscle-map-wrapper { max-width: 320px; }
        .muscles-grid { grid-template-columns: 1fr; }
        .variations-grid { grid-template-columns: 1fr; }
      }
    </style>
  </Fragment>

  <section class="exercise-hero">
    <div class="breadcrumb">
      <a href="/de/">Startseite</a>
      <span class="sep">&rsaquo;</span>
      <a href="/de/uebungen/">Übungen</a>
      <span class="sep">&rsaquo;</span>
      <span>{exercise.name}</span>
    </div>
    <h1><span class="gradient">{exercise.name}</span></h1>
  </section>

  {hasImages && (
    <div class="exercise-images">
      <img src={`/assets/exercises/${slug}-0.jpg`} alt={`${exercise.name} - Ausgangsposition`} />
      <img src={`/assets/exercises/${slug}-1.jpg`} alt={`${exercise.name} - Endposition`} />
    </div>
  )}

  <div class="exercise-content">
    <div class="info-card">
      <div class="info-item">
        <div class="info-label">Muskelgruppe</div>
        <div class="info-value">{exercise.muscle}</div>
      </div>
      <div class="info-item">
        <div class="info-label">Ausrüstung</div>
        <div class="info-value">{equipmentLabel}</div>
      </div>
      <div class="info-item">
        <div class="info-label">Schwierigkeit</div>
        <div class="info-value">
          <span class="difficulty-badge" style={`background:${dc.bg};color:${dc.color}`}>{difficultyLabel}</span>
        </div>
      </div>
    </div>

    <div class="desc-card">
      <p>{exercise.desc}</p>
    </div>

    <h2 class="section-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      Ausführung der Übung
    </h2>
    <ol class="steps-list">
      {steps.map((step, i) => (
        <li>
          <span class="step-num">{i + 1}</span>
          <span class="step-text">{step}</span>
        </li>
      ))}
    </ol>

    <h2 class="section-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
      Häufige Fehler vermeiden
    </h2>
    <ul class="mistakes-list">
      {mistakes.map(m => (
        <li>
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          {m}
        </li>
      ))}
    </ul>

    <h2 class="section-title">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      Beanspruchte Muskeln
    </h2>
    <div class="muscles-section">
      <MuscleMap category={exercise.category} />
      <div class="muscles-grid">
        <div class="muscles-card primary">
          <h4>Primäre Muskeln</h4>
          <ul>
            {muscles.primary.map(m => <li>{m}</li>)}
          </ul>
        </div>
        <div class="muscles-card secondary">
          <h4>Sekundäre Muskeln</h4>
          <ul>
            {muscles.secondary.map(m => <li>{m}</li>)}
          </ul>
        </div>
      </div>
    </div>

    {variations.length > 0 && (
      <>
        <h2 class="section-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16m-7 6h7"/></svg>
          Ähnliche Übungen
        </h2>
        <div class="variations-grid">
          {variations.map(v => (
            <a href={`/de/uebungen/${toSlug(v.name)}/`} class="variation-card">
              <h4>{v.name}</h4>
              <div class="tags">
                <span class="tag tag-muscle">{v.muscle}</span>
                <span class="tag tag-equipment">{v.equipment}</span>
              </div>
            </a>
          ))}
        </div>
      </>
    )}

    <div class="cta-box">
      <h3>Fügen Sie diese Übung Ihrem Training hinzu</h3>
      <p>Laden Sie AIVancePro herunter, um Ihre Leistung zu verfolgen, personalisiertes KI-Coaching zu erhalten und schneller Fortschritte zu machen.</p>
      <div class="store-badges" style="justify-content:center;margin-top:1.5rem;">
        <a href="https://apps.apple.com/app/aivancepro/id6756116760" class="store-badge-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="store-badge-text"><span class="small">Erhältlich im</span><span class="big">App Store</span></span>
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.aivancepro.app" class="store-badge-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
            <span class="store-badge-text"><span class="small">Erhältlich bei</span><span class="big">Google Play</span></span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
