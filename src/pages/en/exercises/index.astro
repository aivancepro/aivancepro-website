---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { exercises, toSlug } from '../../../data/exercises-en.js';

const difficultyColors = {
  "Beginner": { bg: "rgba(16, 185, 129, 0.1)", color: "#10B981" },
  "Intermediate": { bg: "rgba(245, 158, 11, 0.1)", color: "#F59E0B" },
  "Advanced": { bg: "rgba(239, 68, 68, 0.1)", color: "#EF4444" },
};

const totalCount = exercises.length;

const muscleGroups = [
  { id: "pectoraux", label: "Chest", icon: "💪" },
  { id: "dos", label: "Back", icon: "🔙" },
  { id: "epaules", label: "Shoulders", icon: "🏋️" },
  { id: "biceps", label: "Biceps", icon: "💪" },
  { id: "triceps", label: "Triceps", icon: "🦾" },
  { id: "jambes", label: "Legs", icon: "🦵" },
  { id: "fessiers", label: "Glutes", icon: "🍑" },
  { id: "abdos", label: "Abs", icon: "🎯" },
  { id: "avant-bras", label: "Forearms", icon: "✊" },
  { id: "fonctionnel", label: "Functional", icon: "⚡" },
];

const equipmentList = [
  { id: "Barbell", label: "Barbell", icon: "🏋️" },
  { id: "Dumbbells", label: "Dumbbells", icon: "🏋️" },
  { id: "Machine", label: "Machine", icon: "⚙️" },
  { id: "Cable", label: "Cable", icon: "🔗" },
  { id: "Bodyweight", label: "Bodyweight", icon: "🧍" },
  { id: "Bodyweight + load", label: "Weighted", icon: "🎒" },
  { id: "Smith machine", label: "Smith machine", icon: "🏗️" },
  { id: "Kettlebell", label: "Kettlebell", icon: "🔔" },
  { id: "EZ Bar", label: "EZ Bar", icon: "〰️" },
  { id: "Resistance band", label: "Resistance band", icon: "🪢" },
  { id: "TRX", label: "TRX", icon: "🪢" },
  { id: "Landmine", label: "Landmine", icon: "💣" },
  { id: "Medicine ball", label: "Medicine ball", icon: "⚽" },
];

const muscleGroupCounts = {};
muscleGroups.forEach(m => {
  muscleGroupCounts[m.id] = exercises.filter(e => e.category === m.id).length;
});

const equipmentCounts = {};
equipmentList.forEach(eq => {
  equipmentCounts[eq.id] = exercises.filter(e => e.equipment === eq.id).length;
});
---

<BaseLayout
  lang="en"
  title={`Exercise Library - ${totalCount} Strength Training Exercises - AIVancePro`}
  description={`Discover our library of ${totalCount} strength training and fitness exercises. Filter by muscle group or equipment and find the perfect exercise.`}
  canonical="https://aivancepro.fr/en/exercises/"
  alternates={{ fr: 'https://aivancepro.fr/exercices/', en: 'https://aivancepro.fr/en/exercises/', de: 'https://aivancepro.fr/de/uebungen/' }}
>
  <Fragment slot="head">
    <style>
        .page-header { padding: 9rem 2rem 2rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); }
        .section-label { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); margin-bottom: 0.75rem; }
        .page-header h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; }
        .page-header p { color: var(--gray-500); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

        .browse-section { max-width: 1100px; margin: 0 auto; padding: 3rem 2rem 0; }
        .browse-section h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 1.25rem; }
        .browse-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem; }
        .browse-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1rem; text-align: center; cursor: pointer; transition: all 0.2s; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; font-family: inherit; }
        .browse-card:hover { border-color: var(--blue); transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.15); }
        .browse-card.active { border-color: var(--blue); background: rgba(37,99,235,0.08); }
        .browse-card .browse-icon { font-size: 1.5rem; line-height: 1; }
        .browse-card .browse-label { font-size: 0.85rem; font-weight: 700; }
        .browse-card .browse-count { font-size: 0.7rem; color: var(--gray-400); }

        .filter-bar { max-width: 1100px; margin: 2.5rem auto 0; padding: 0 2rem; }
        .filter-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
        .filter-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--gray-400); min-width: fit-content; }
        .filter-btn { padding: 0.4rem 0.9rem; border-radius: 50px; border: 1px solid var(--border); background: var(--bg-card); color: var(--gray-500); font-size: 0.8rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; }
        .filter-btn:hover, .filter-btn.active { background: var(--blue); color: var(--white); border-color: var(--blue); }
        .filter-btn-equip:hover, .filter-btn-equip.active { background: var(--blue); color: var(--white); border-color: var(--blue); }

        .search-bar { max-width: 500px; margin: 1.5rem auto 0; padding: 0 2rem; }
        .search-input { width: 100%; padding: 0.7rem 1.25rem; border-radius: 12px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text); font-size: 0.9rem; font-family: inherit; outline: none; transition: border-color 0.2s; box-sizing: border-box; }
        .search-input::placeholder { color: var(--gray-400); }
        .search-input:focus { border-color: var(--blue); }

        .exercises-grid { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 4rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }

        .exercise-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; gap: 0.5rem; text-decoration: none; color: inherit; }
        .exercise-card:hover { border-color: rgba(37,99,235,0.25); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
        .exercise-card h3 { font-size: 0.95rem; font-weight: 700; line-height: 1.3; color: var(--text); }
        .exercise-card .desc { color: var(--gray-500); font-size: 0.8rem; line-height: 1.5; }
        .exercise-card .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-top: auto; }
        .exercise-card .tag { padding: 0.15rem 0.55rem; border-radius: 50px; font-size: 0.65rem; font-weight: 600; white-space: nowrap; }
        .tag-muscle { background: rgba(37,99,235,0.1); color: var(--blue); }
        .tag-equipment { background: rgba(147,51,234,0.1); color: var(--blue); }
        .tag-difficulty { font-size: 0.6rem; font-weight: 700; }

        .exercises-count { text-align: center; padding: 1rem 2rem 0; color: var(--gray-400); font-size: 0.85rem; }

        .no-results { text-align: center; padding: 3rem 2rem; color: var(--gray-400); font-size: 1rem; display: none; }

        @media (max-width: 1024px) {
            .exercises-grid { grid-template-columns: repeat(2, 1fr); }
            .browse-grid { grid-template-columns: repeat(4, 1fr); }
        }
        @media (max-width: 768px) {
            .page-header { padding: 7rem 1.5rem 2rem; }
            .page-header h1 { font-size: 2rem; }
            .exercises-grid { grid-template-columns: 1fr; }
            .browse-grid { grid-template-columns: repeat(3, 1fr); }
            .browse-section { padding: 2rem 1.5rem 0; }
            .filter-bar { padding: 0 1.5rem; }
        }
        @media (max-width: 480px) {
            .browse-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
  </Fragment>

    <header class="page-header">
        <div class="section-label">Exercises</div>
        <h1>Exercise Library</h1>
        <p>{totalCount} exercises with detailed instructions. Browse by muscle group, equipment or search for an exercise.</p>
    </header>

    <section class="browse-section">
        <h2>Browse by Muscle Group</h2>
        <div class="browse-grid">
            {muscleGroups.map(m => (
                <button class="browse-card" data-browse="muscle" data-value={m.id}>
                    <span class="browse-icon">{m.icon}</span>
                    <span class="browse-label">{m.label}</span>
                    <span class="browse-count">{muscleGroupCounts[m.id]} exercises</span>
                </button>
            ))}
        </div>
    </section>

    <section class="browse-section">
        <h2>Browse by Equipment</h2>
        <div class="browse-grid">
            {equipmentList.map(eq => (
                <button class="browse-card" data-browse="equipment" data-value={eq.id}>
                    <span class="browse-icon">{eq.icon}</span>
                    <span class="browse-label">{eq.label}</span>
                    <span class="browse-count">{equipmentCounts[eq.id]} exercises</span>
                </button>
            ))}
        </div>
    </section>

    <div class="filter-bar" id="filterBar">
        <div class="filter-row">
            <span class="filter-label">Muscle:</span>
            <button class="filter-btn active" data-filter="muscle" data-value="all">All</button>
            {muscleGroups.map(m => (
                <button class="filter-btn" data-filter="muscle" data-value={m.id}>{m.label}</button>
            ))}
        </div>
        <div class="filter-row">
            <span class="filter-label">Equipment:</span>
            <button class="filter-btn filter-btn-equip active" data-filter="equipment" data-value="all">All</button>
            {equipmentList.map(eq => (
                <button class="filter-btn filter-btn-equip" data-filter="equipment" data-value={eq.id}>{eq.label}</button>
            ))}
        </div>
    </div>

    <div class="search-bar">
        <input type="text" class="search-input" id="search" placeholder="Search an exercise..." autocomplete="off" />
    </div>

    <div class="exercises-count"><span id="count">{totalCount}</span> exercises shown</div>

    <div class="no-results" id="no-results">No exercise found.</div>

    <section class="exercises-grid" id="grid">
        {exercises.map((ex) => {
            const dc = difficultyColors[ex.difficulty] || { bg: "rgba(100,100,100,0.1)", color: "#888" };
            const slug = toSlug(ex.name);
            return (
                <a href={`/en/exercises/${slug}/`} class="exercise-card" data-muscle={ex.category} data-equipment={ex.equipment} data-name={ex.name.toLowerCase()}>
                    <h3>{ex.name}</h3>
                    <p class="desc">{ex.desc}</p>
                    <div class="tags">
                        <span class="tag tag-muscle">{ex.muscle}</span>
                        <span class="tag tag-equipment">{ex.equipment}</span>
                        <span class="tag tag-difficulty" style={`background:${dc.bg};color:${dc.color}`}>{ex.difficulty}</span>
                    </div>
                </a>
            );
        })}
    </section>

    <section class="final-cta">
        <h2>{totalCount} exercises in your pocket</h2>
        <p>Download AIVancePro to access all exercises with videos, instructions and direct integration into your workouts.</p>
        <a href="https://apps.apple.com/app/aivancepro/id6756116760" class="btn-primary" target="_blank" rel="noopener">Download for free</a>
        <a href="https://play.google.com/store/apps/details?id=com.aivancepro.app" class="btn-secondary" target="_blank" rel="noopener">Get it on Google Play</a>
    </section>

    <script is:inline>
        (function() {
            var currentMuscle = 'all';
            var currentEquipment = 'all';
            var searchQuery = '';
            var countEl = document.getElementById('count');
            var noResults = document.getElementById('no-results');
            var grid = document.getElementById('grid');

            function normalize(str) {
                return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            }

            function update() {
                var cards = document.querySelectorAll('.exercise-card');
                var count = 0;
                cards.forEach(function(card) {
                    var matchMuscle = currentMuscle === 'all' || card.dataset.muscle === currentMuscle;
                    var matchEquipment = currentEquipment === 'all' || card.dataset.equipment === currentEquipment;
                    var matchSearch = !searchQuery || normalize(card.dataset.name).indexOf(searchQuery) !== -1;
                    if (matchMuscle && matchEquipment && matchSearch) {
                        card.style.display = '';
                        count++;
                    } else {
                        card.style.display = 'none';
                    }
                });
                countEl.textContent = count;
                noResults.style.display = count === 0 ? 'block' : 'none';
                grid.style.display = count === 0 ? 'none' : '';
            }

            document.querySelectorAll('[data-filter="muscle"]').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-filter="muscle"]').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    currentMuscle = btn.dataset.value;
                    document.querySelectorAll('[data-browse="muscle"]').forEach(function(c) { c.classList.remove('active'); });
                    if (currentMuscle !== 'all') {
                        document.querySelector('[data-browse="muscle"][data-value="' + currentMuscle + '"]')?.classList.add('active');
                    }
                    update();
                });
            });

            document.querySelectorAll('[data-filter="equipment"]').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-filter="equipment"]').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    currentEquipment = btn.dataset.value;
                    document.querySelectorAll('[data-browse="equipment"]').forEach(function(c) { c.classList.remove('active'); });
                    if (currentEquipment !== 'all') {
                        document.querySelector('[data-browse="equipment"][data-value="' + currentEquipment + '"]')?.classList.add('active');
                    }
                    update();
                });
            });

            document.querySelectorAll('[data-browse="muscle"]').forEach(function(card) {
                card.addEventListener('click', function() {
                    var val = card.dataset.value;
                    var isActive = card.classList.contains('active');
                    document.querySelectorAll('[data-browse="muscle"]').forEach(function(c) { c.classList.remove('active'); });
                    document.querySelectorAll('[data-filter="muscle"]').forEach(function(b) { b.classList.remove('active'); });
                    if (isActive) {
                        currentMuscle = 'all';
                        document.querySelector('[data-filter="muscle"][data-value="all"]').classList.add('active');
                    } else {
                        currentMuscle = val;
                        card.classList.add('active');
                        var filterBtn = document.querySelector('[data-filter="muscle"][data-value="' + val + '"]');
                        if (filterBtn) filterBtn.classList.add('active');
                    }
                    update();
                    document.getElementById('filterBar').scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });

            document.querySelectorAll('[data-browse="equipment"]').forEach(function(card) {
                card.addEventListener('click', function() {
                    var val = card.dataset.value;
                    var isActive = card.classList.contains('active');
                    document.querySelectorAll('[data-browse="equipment"]').forEach(function(c) { c.classList.remove('active'); });
                    document.querySelectorAll('[data-filter="equipment"]').forEach(function(b) { b.classList.remove('active'); });
                    if (isActive) {
                        currentEquipment = 'all';
                        document.querySelector('[data-filter="equipment"][data-value="all"]').classList.add('active');
                    } else {
                        currentEquipment = val;
                        card.classList.add('active');
                        var filterBtn = document.querySelector('[data-filter="equipment"][data-value="' + val + '"]');
                        if (filterBtn) filterBtn.classList.add('active');
                    }
                    update();
                    document.getElementById('filterBar').scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });

            document.getElementById('search').addEventListener('input', function(e) {
                searchQuery = normalize(e.target.value);
                update();
            });
        })();
    </script>
</BaseLayout>
