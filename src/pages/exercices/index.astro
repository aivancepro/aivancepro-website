---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { exercises, toSlug } from '../../data/exercises-fr.js';
import { frontParts, backParts } from '../../data/musclePathsData.js';

// ── Build-time SVG generation ──────────────────────────────
const PRIMARY_COLOR        = '#4A90D9';
const INACTIVE_DARK_MODE   = '#c8c8e0'; // light body → visible on dark cards
const INACTIVE_LIGHT_MODE  = '#252535'; // dark body  → visible on light cards
const STRUCT_DARK_MODE     = '#9090b0';
const STRUCT_LIGHT_MODE    = '#1c1c28';
const STROKE_DARK_MODE     = '#0d0d14';
const STROKE_LIGHT_MODE    = '#0d0d14';
const STRUCTURAL           = new Set(['head','hair','hands','feet','ankles','knees','neck','tibialis']);

function buildGroupSvg(primarySlugs, view = 'front', theme = 'dark') {
  const inactiveColor = theme === 'light' ? INACTIVE_LIGHT_MODE : INACTIVE_DARK_MODE;
  const structColor   = theme === 'light' ? STRUCT_LIGHT_MODE   : STRUCT_DARK_MODE;
  const strokeColor   = theme === 'light' ? STROKE_LIGHT_MODE   : STROKE_DARK_MODE;
  const primary = new Set(primarySlugs);
  const fill = (slug) => STRUCTURAL.has(slug) ? structColor : primary.has(slug) ? PRIMARY_COLOR : inactiveColor;
  let body = '';
  const render = (parts) => parts.forEach(p => {
    const paths = [...(p.paths?.left||[]), ...(p.paths?.right||[]), ...(p.paths?.common||[])];
    body += `<g fill="${fill(p.slug)}" stroke="${strokeColor}" stroke-width="0.5">`;
    paths.forEach(d => { body += `<path d="${d}"/>`; });
    body += '</g>';
  });
  if (view === 'front' || view === 'both') render(frontParts);
  if (view === 'back'  || view === 'both') render(backParts);
  const vb = view === 'back' ? '860 80 600 1260' : view === 'both' ? '40 80 1380 1280' : '80 80 600 1260';
  return `data:image/svg+xml,${encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" viewBox="${vb}">${body}</svg>`)}`;
}

// ── Equipment photos (Pexels CDN, free license, hotlink OK) ─
const EQUIP_PHOTO_IDS: Record<string, number> = {
  'Barre':                   841130,   // person holding barbell
  'Haltères':                4164763,  // silver dumbbells on rack
  'Machine':                 3838937,  // sportsman on exercise machine
  'Câble':                   1480520,  // woman on cable & pulley machine
  'Poids du corps':          4162491,  // man doing push-ups
  'Poids du corps + charge': 6975783,  // closed-fist push-up on floor
  'Smith machine':           3837757,  // sportsman on bench in modern gym
  'Kettlebell':              2836961,  // kettlebell object shot
  'Barre EZ':                4793228,  // metal barbell on stand close-up
  'Élastique':               6339598,  // man with resistance band
  'TRX':                     4162489,  // man doing push-ups at the gym
  'Landmine':                31616776, // green weight plate on barbell
  'Médecine ball':           4720521,  // man with exercise ball
};

function equipPhoto(id: string): string {
  const photoId = EQUIP_PHOTO_IDS[id];
  if (!photoId) return '';
  return `https://images.pexels.com/photos/${photoId}/pexels-photo-${photoId}.jpeg?auto=compress&cs=tinysrgb&w=400&h=280&dpr=1`;
}

// ── Difficulty colors ──────────────────────────────────────
const difficultyColors = {
  "Débutant":      { bg: "rgba(16, 185, 129, 0.1)",  color: "#10B981" },
  "Intermédiaire": { bg: "rgba(245, 158, 11, 0.1)",  color: "#F59E0B" },
  "Avancé":        { bg: "rgba(239, 68, 68, 0.1)",   color: "#EF4444" },
};

const totalCount = exercises.length;

// ── Muscle groups with build-time SVG ─────────────────────
const muscleGroups = [
  { id: "pectoraux",   label: "Pectoraux",   slugs: ['chest'],                               view: 'front' },
  { id: "dos",         label: "Dos",         slugs: ['upper-back','trapezius','lower-back'], view: 'back'  },
  { id: "epaules",     label: "Épaules",     slugs: ['deltoids'],                            view: 'front' },
  { id: "biceps",      label: "Biceps",      slugs: ['biceps'],                              view: 'front' },
  { id: "triceps",     label: "Triceps",     slugs: ['triceps'],                             view: 'back'  },
  { id: "jambes",      label: "Jambes",      slugs: ['quadriceps','calves'],                 view: 'front' },
  { id: "fessiers",    label: "Fessiers",    slugs: ['gluteal'],                             view: 'back'  },
  { id: "abdos",       label: "Abdos",       slugs: ['abs','obliques'],                      view: 'front' },
  { id: "avant-bras",  label: "Avant-bras",  slugs: ['forearm'],                             view: 'front' },
  { id: "fonctionnel", label: "Fonctionnel", slugs: ['chest','abs','deltoids','quadriceps'], view: 'front' },
].map(m => ({
  ...m,
  svgDark:  buildGroupSvg(m.slugs, m.view, 'dark'),
  svgLight: buildGroupSvg(m.slugs, m.view, 'light'),
}));

// ── Equipment list ─────────────────────────────────────────
const equipmentList = [
  { id: "Barre",                   label: "Barre"          },
  { id: "Haltères",                label: "Haltères"       },
  { id: "Machine",                 label: "Machine"        },
  { id: "Câble",                   label: "Câble"          },
  { id: "Poids du corps",          label: "Poids du corps" },
  { id: "Poids du corps + charge", label: "Lesté"          },
  { id: "Smith machine",           label: "Smith machine"  },
  { id: "Kettlebell",              label: "Kettlebell"     },
  { id: "Barre EZ",                label: "Barre EZ"       },
  { id: "Élastique",               label: "Élastique"      },
  { id: "TRX",                     label: "TRX"            },
  { id: "Landmine",                label: "Landmine"       },
  { id: "Médecine ball",           label: "Médecine ball"  },
];

const muscleGroupCounts = {};
muscleGroups.forEach(m => {
  muscleGroupCounts[m.id] = exercises.filter(e => e.category === m.id).length;
});

const equipmentCounts = {};
equipmentList.forEach(eq => {
  equipmentCounts[eq.id] = exercises.filter(e => e.equipment === eq.id).length;
});
---

<BaseLayout
  lang="fr"
  title={`Bibliothèque d'exercices - ${totalCount} exercices de musculation - AIVancePro`}
  description={`Découvrez notre bibliothèque de ${totalCount} exercices de musculation et fitness. Filtrez par groupe musculaire ou par équipement et trouvez l'exercice parfait.`}
  canonical="https://aivancepro.fr/exercices/"
  alternates={{ fr: 'https://aivancepro.fr/exercices/', en: 'https://aivancepro.fr/en/exercises/', de: 'https://aivancepro.fr/de/uebungen/' }}
>
  <Fragment slot="head">
    <style>
        .page-header { padding: 9rem 2rem 2rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); border-bottom: 1px solid var(--border); }
        .section-label { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); margin-bottom: 0.75rem; }
        .page-header h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; }
        .page-header p { color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }

        .browse-section { max-width: 1100px; margin: 0 auto; padding: 3rem 2rem 0; }
        .browse-section h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 1.25rem; }

        /* Muscle group cards — taller to show body SVG */
        .muscle-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem; }
        .muscle-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 0.75rem 0.5rem; text-align: center; cursor: pointer; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: center; gap: 0.35rem; overflow: hidden; }
        .muscle-card:hover { border-color: var(--blue); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(74,144,217,0.12); }
        .muscle-card.active { border-color: var(--blue); background: rgba(74,144,217,0.08); }
        .muscle-card img { height: 80px; width: auto; max-width: 100%; display: block; }
        /* Dark mode (default): show dark variant, hide light variant */
        .muscle-card .muscle-svg-light { display: none; }
        .muscle-card .muscle-svg-dark  { display: block; }
        /* Light mode: reverse */
        [data-theme="light"] .muscle-card .muscle-svg-dark  { display: none; }
        [data-theme="light"] .muscle-card .muscle-svg-light { display: block; }
        .muscle-card .browse-label { font-size: 0.82rem; font-weight: 700; }
        .muscle-card .browse-count { font-size: 0.68rem; color: var(--text-muted); }

        /* Equipment cards — photo style */
        .equip-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem; }
        .equip-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 0; text-align: center; cursor: pointer; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; text-decoration: none; color: inherit; display: flex; flex-direction: column; align-items: stretch; overflow: hidden; }
        .equip-card:hover { border-color: var(--blue); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(74,144,217,0.12); }
        .equip-card.active { border-color: var(--blue); }
        .equip-card img { width: 100%; height: 100px; object-fit: cover; display: block; flex-shrink: 0; }
        .equip-card .equip-text { padding: 0.65rem 0.5rem 0.75rem; display: flex; flex-direction: column; gap: 0.15rem; }
        .equip-card .browse-label { font-size: 0.82rem; font-weight: 700; }
        .equip-card .browse-count { font-size: 0.68rem; color: var(--text-muted); }

        .filter-bar { max-width: 1100px; margin: 2.5rem auto 0; padding: 0 2rem; }
        .filter-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
        .filter-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); min-width: fit-content; }
        .filter-btn { padding: 0.4rem 0.9rem; border-radius: 50px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-secondary); font-size: 0.8rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; }
        .filter-btn:hover, .filter-btn.active { background: var(--blue); color: var(--white); border-color: var(--blue); }

        .search-bar { max-width: 500px; margin: 1.5rem auto 0; padding: 0 2rem; }
        .search-input { width: 100%; padding: 0.7rem 1.25rem; border-radius: 12px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text); font-size: 0.9rem; font-family: inherit; outline: none; transition: border-color 0.2s; box-sizing: border-box; }
        .search-input::placeholder { color: var(--text-muted); }
        .search-input:focus { border-color: var(--blue); }

        .exercises-grid { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 4rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
        .exercise-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; gap: 0.5rem; text-decoration: none; color: inherit; }
        .exercise-card:hover { border-color: var(--blue); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(74,144,217,0.1); }
        .exercise-card h3 { font-size: 0.95rem; font-weight: 700; line-height: 1.3; color: var(--text); }
        .exercise-card .desc { color: var(--text-secondary); font-size: 0.8rem; line-height: 1.5; }
        .exercise-card .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-top: auto; }
        .exercise-card .tag { padding: 0.15rem 0.55rem; border-radius: 50px; font-size: 0.65rem; font-weight: 600; white-space: nowrap; }
        .tag-muscle    { background: rgba(74,144,217,0.1); color: var(--blue); }
        .tag-equipment { background: rgba(74,144,217,0.06); color: var(--blue); }
        .tag-difficulty { font-size: 0.6rem; font-weight: 700; }

        .exercises-count { text-align: center; padding: 1rem 2rem 0; color: var(--text-muted); font-size: 0.85rem; }
        .no-results { text-align: center; padding: 3rem 2rem; color: var(--text-muted); font-size: 1rem; display: none; }

        .final-cta { padding: 5rem 2rem; text-align: center; background: var(--bg-card); border-top: 1px solid var(--border); }
        .final-cta h2 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; color: var(--text); }
        .final-cta p  { color: var(--text-secondary); font-size: 1rem; max-width: 500px; margin: 0 auto 2rem; }

        @media (max-width: 1024px) {
            .exercises-grid { grid-template-columns: repeat(2, 1fr); }
            .muscle-grid, .equip-grid { grid-template-columns: repeat(4, 1fr); }
        }
        @media (max-width: 768px) {
            .page-header { padding: 7rem 1.5rem 2rem; }
            .page-header h1 { font-size: 2rem; }
            .exercises-grid { grid-template-columns: 1fr; }
            .muscle-grid, .equip-grid { grid-template-columns: repeat(3, 1fr); }
            .browse-section { padding: 2rem 1.5rem 0; }
            .filter-bar { padding: 0 1.5rem; }
        }
        @media (max-width: 480px) {
            .muscle-grid, .equip-grid { grid-template-columns: repeat(2, 1fr); }
        }
    </style>
  </Fragment>

    <header class="page-header">
        <div class="section-label">Exercices</div>
        <h1>Bibliothèque d'exercices</h1>
        <p>{totalCount} exercices avec instructions détaillées. Explorez par groupe musculaire, par équipement ou recherchez un exercice.</p>
    </header>

    <section class="browse-section">
        <h2>Explorer par groupe musculaire</h2>
        <div class="muscle-grid">
            {muscleGroups.map(m => (
                <button class="muscle-card" data-browse="muscle" data-value={m.id}>
                    <img src={m.svgDark}  class="muscle-svg-dark"  alt={m.label} loading="lazy" />
                    <img src={m.svgLight} class="muscle-svg-light" alt={m.label} loading="lazy" />
                    <span class="browse-label">{m.label}</span>
                    <span class="browse-count">{muscleGroupCounts[m.id]} exercices</span>
                </button>
            ))}
        </div>
    </section>

    <section class="browse-section">
        <h2>Explorer par équipement</h2>
        <div class="equip-grid">
            {equipmentList.map(eq => (
                <button class="equip-card" data-browse="equipment" data-value={eq.id}>
                    <img src={equipPhoto(eq.id)} alt={eq.label} loading="lazy" />
                    <span class="equip-text">
                        <span class="browse-label">{eq.label}</span>
                        <span class="browse-count">{equipmentCounts[eq.id]} exercices</span>
                    </span>
                </button>
            ))}
        </div>
    </section>

    <div class="filter-bar" id="filterBar">
        <div class="filter-row">
            <span class="filter-label">Muscle :</span>
            <button class="filter-btn active" data-filter="muscle" data-value="all">Tous</button>
            {muscleGroups.map(m => (
                <button class="filter-btn" data-filter="muscle" data-value={m.id}>{m.label}</button>
            ))}
        </div>
        <div class="filter-row">
            <span class="filter-label">Équipement :</span>
            <button class="filter-btn active" data-filter="equipment" data-value="all">Tous</button>
            {equipmentList.map(eq => (
                <button class="filter-btn" data-filter="equipment" data-value={eq.id}>{eq.label}</button>
            ))}
        </div>
    </div>

    <div class="search-bar">
        <input type="text" class="search-input" id="search" placeholder="Rechercher un exercice..." autocomplete="off" />
    </div>

    <div class="exercises-count"><span id="count">{totalCount}</span> exercices affichés</div>
    <div class="no-results" id="no-results">Aucun exercice trouvé.</div>

    <section class="exercises-grid" id="grid">
        {exercises.map((ex) => {
            const dc = difficultyColors[ex.difficulty] || { bg: "rgba(100,100,100,0.1)", color: "#888" };
            const slug = toSlug(ex.name);
            return (
                <a href={`/exercices/${slug}/`} class="exercise-card" data-muscle={ex.category} data-equipment={ex.equipment} data-name={ex.name.toLowerCase()}>
                    <h3>{ex.name}</h3>
                    <p class="desc">{ex.desc}</p>
                    <div class="tags">
                        <span class="tag tag-muscle">{ex.muscle}</span>
                        <span class="tag tag-equipment">{ex.equipment}</span>
                        <span class="tag tag-difficulty" style={`background:${dc.bg};color:${dc.color}`}>{ex.difficulty}</span>
                    </div>
                </a>
            );
        })}
    </section>

    <section class="final-cta">
        <h2>{totalCount} exercices dans votre poche</h2>
        <p>Téléchargez AIVancePro pour accéder à tous les exercices avec vidéos, instructions et intégration directe dans vos séances.</p>
        <div class="store-badges" style="justify-content:center;margin-top:1.5rem;">
            <a href="https://apps.apple.com/fr/app/aivancepro/id6756116760" class="store-badge-link" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                <span class="store-badge-text"><span class="small">Disponible sur</span><span class="big">App Store</span></span>
            </a>
            <a href="https://play.google.com/store/apps/details?id=com.aivancepro.app" class="store-badge-link" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
                <span class="store-badge-text"><span class="small">Disponible sur</span><span class="big">Google Play</span></span>
            </a>
        </div>
    </section>

    <script is:inline>
        (function() {
            var currentMuscle = 'all';
            var currentEquipment = 'all';
            var searchQuery = '';
            var countEl = document.getElementById('count');
            var noResults = document.getElementById('no-results');
            var grid = document.getElementById('grid');

            function normalize(str) {
                return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
            }

            function update() {
                var cards = document.querySelectorAll('.exercise-card');
                var count = 0;
                cards.forEach(function(card) {
                    var matchMuscle = currentMuscle === 'all' || card.dataset.muscle === currentMuscle;
                    var matchEquipment = currentEquipment === 'all' || card.dataset.equipment === currentEquipment;
                    var matchSearch = !searchQuery || normalize(card.dataset.name).indexOf(searchQuery) !== -1;
                    if (matchMuscle && matchEquipment && matchSearch) { card.style.display = ''; count++; }
                    else { card.style.display = 'none'; }
                });
                countEl.textContent = count;
                noResults.style.display = count === 0 ? 'block' : 'none';
                grid.style.display = count === 0 ? 'none' : '';
            }

            document.querySelectorAll('[data-filter="muscle"]').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-filter="muscle"]').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    currentMuscle = btn.dataset.value;
                    document.querySelectorAll('[data-browse="muscle"]').forEach(function(c) { c.classList.remove('active'); });
                    if (currentMuscle !== 'all') {
                        var bc = document.querySelector('[data-browse="muscle"][data-value="' + currentMuscle + '"]');
                        if (bc) bc.classList.add('active');
                    }
                    update();
                });
            });

            document.querySelectorAll('[data-filter="equipment"]').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('[data-filter="equipment"]').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    currentEquipment = btn.dataset.value;
                    document.querySelectorAll('[data-browse="equipment"]').forEach(function(c) { c.classList.remove('active'); });
                    if (currentEquipment !== 'all') {
                        var bc = document.querySelector('[data-browse="equipment"][data-value="' + currentEquipment + '"]');
                        if (bc) bc.classList.add('active');
                    }
                    update();
                });
            });

            document.querySelectorAll('[data-browse="muscle"]').forEach(function(card) {
                card.addEventListener('click', function() {
                    var val = card.dataset.value;
                    var isActive = card.classList.contains('active');
                    document.querySelectorAll('[data-browse="muscle"]').forEach(function(c) { c.classList.remove('active'); });
                    document.querySelectorAll('[data-filter="muscle"]').forEach(function(b) { b.classList.remove('active'); });
                    if (isActive) {
                        currentMuscle = 'all';
                        document.querySelector('[data-filter="muscle"][data-value="all"]').classList.add('active');
                    } else {
                        currentMuscle = val;
                        card.classList.add('active');
                        var fb = document.querySelector('[data-filter="muscle"][data-value="' + val + '"]');
                        if (fb) fb.classList.add('active');
                    }
                    update();
                    document.getElementById('filterBar').scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });

            document.querySelectorAll('[data-browse="equipment"]').forEach(function(card) {
                card.addEventListener('click', function() {
                    var val = card.dataset.value;
                    var isActive = card.classList.contains('active');
                    document.querySelectorAll('[data-browse="equipment"]').forEach(function(c) { c.classList.remove('active'); });
                    document.querySelectorAll('[data-filter="equipment"]').forEach(function(b) { b.classList.remove('active'); });
                    if (isActive) {
                        currentEquipment = 'all';
                        document.querySelector('[data-filter="equipment"][data-value="all"]').classList.add('active');
                    } else {
                        currentEquipment = val;
                        card.classList.add('active');
                        var fb = document.querySelector('[data-filter="equipment"][data-value="' + val + '"]');
                        if (fb) fb.classList.add('active');
                    }
                    update();
                    document.getElementById('filterBar').scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });

            document.getElementById('search').addEventListener('input', function(e) {
                searchQuery = normalize(e.target.value);
                update();
            });
        })();
    </script>
</BaseLayout>
