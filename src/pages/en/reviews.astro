---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
const starSvg = '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';

const reviews = [
  {
    text: "&ldquo;I&rsquo;d been going to the gym for about 6 months and hit a point where I didn&rsquo;t know what to do anymore, just repeating the same stuff. I was too lazy to make my own program and a coach is too expensive. I tried the AI coach randomly and honestly it&rsquo;s amazing. You tell it what equipment you have and how long you want to train and it gives you a full session. At first I thought it would be generic but no, it really adapts. What made me go pro is the tracking &mdash; you see your stats evolve over sessions and it&rsquo;s super motivating. I progressed more in 2 months with the app than in 4 months on my own. Honestly for the price it&rsquo;s a steal.&rdquo;",
    author: "Theo Lpe",
    source: "App Store",
  },
  {
    text: "&ldquo;Very good app, with great tracking and solid advice. I recommend it.&rdquo;",
    author: "Nathou.S",
    source: "App Store",
  },
];
---

<BaseLayout
  lang={lang}
  title="User Reviews - AIVancePro"
  description="Discover what AIVancePro users think. Thousands of athletes trust our AI coach for their training."
  canonical="https://aivancepro.fr/en/reviews/"
  alternates={{ fr: 'https://aivancepro.fr/avis/', en: 'https://aivancepro.fr/en/reviews/', de: 'https://aivancepro.fr/de/bewertungen/' }}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "AIVancePro",
      "operatingSystem": "iOS, Android",
      "applicationCategory": "HealthApplication",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "bestRating": "5",
        "ratingCount": "2",
        "reviewCount": "2"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Theo Lpe" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "I tried the AI coach randomly and honestly it's amazing. You tell it what equipment you have and how long you want to train and it gives you a full session. It really adapts. I progressed more in 2 months with the app than in 4 months on my own. For the price it's a steal."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Nathou.S" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "Very good app, with great tracking and solid advice. I recommend it."
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aivancepro.fr/en/" },
        { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://aivancepro.fr/en/reviews/" }
      ]
    }
  ]}
>
  <Fragment slot="head">
    <style>
      .reviews-hero {
          padding: 5.5rem 2rem 3rem;
          text-align: center;
          background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
      }
      .reviews-hero h1 {
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: -0.03em;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .reviews-hero p {
          font-size: 1.15rem;
          color: var(--gray-500);
          max-width: 600px;
          margin: 0 auto;
      }
      .reviews-section {
          padding: 3rem 2rem 6rem;
          background: var(--bg-alt);
      }
      .reviews-inner {
          max-width: 1100px;
          margin: 0 auto;
          text-align: center;
      }
      .reviews-grid {
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
          margin-bottom: 2.5rem;
      }
      .review-card {
          background: var(--bg-card);
          border: 1px solid var(--border);
          border-radius: 16px;
          padding: 1.75rem;
          text-align: left;
          transition: transform 0.2s, box-shadow 0.2s;
      }
      .review-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 8px 30px rgba(0,0,0,0.12);
      }
      .review-stars {
          display: flex;
          gap: 2px;
          margin-bottom: 1rem;
      }
      .review-stars :global(svg) {
          width: 18px;
          height: 18px;
          color: #FBBF24;
      }
      .review-text {
          font-size: 0.95rem;
          color: var(--gray-700);
          line-height: 1.7;
          margin-bottom: 1.25rem;
      }
      .review-author {
          font-size: 0.85rem;
          font-weight: 600;
          color: var(--gray-900);
      }
      .review-source {
          font-size: 0.75rem;
          color: var(--gray-400);
          margin-top: 0.15rem;
      }
      .review-cta {
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          color: var(--blue);
          font-weight: 600;
          font-size: 0.95rem;
          text-decoration: none;
          transition: opacity 0.2s;
      }
      .review-cta:hover { opacity: 0.8; }
      .review-cta svg { width: 18px; height: 18px; }

      @media (max-width: 768px) {
          .reviews-hero h1 { font-size: 2rem; }
          .reviews-grid { grid-template-columns: 1fr; }
      }
    </style>
  </Fragment>

  <section class="reviews-hero">
      <h1>User Reviews</h1>
      <p>Thousands of athletes trust AIVancePro for their training. Discover what they think.</p>
  </section>

  <section class="reviews-section">
      <div class="reviews-inner">
          <div class="reviews-grid">
              {reviews.map((review, i) => (
                  <div class="review-card">
                      <div class="review-stars" set:html={starSvg.repeat(5)} />
                      <p class="review-text" set:html={review.text} />
                      <div class="review-author">{review.author}</div>
                      <div class="review-source">{review.source}</div>
                  </div>
              ))}
          </div>

          <a href="https://apps.apple.com/app/aivancepro/id6756116760?action=write-review" class="review-cta" target="_blank" rel="noopener">
              Leave a review on the App Store
              <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </a>
      </div>
  </section>
</BaseLayout>
