---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides', ({ data }) => data.lang === 'de'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  lang="de"
  title="Fitness- & Krafttraining-Ratgeber - AIVancePro"
  description="Vollständige Fitness- und Krafttraining-Ratgeber. Lernen Sie die Grundlagen, erstellen Sie Ihr Programm und machen Sie effektiv Fortschritte."
  canonical="https://aivancepro.fr/de/ratgeber/"
  alternates={{ fr: 'https://aivancepro.fr/guides/', en: 'https://aivancepro.fr/en/guides/', de: 'https://aivancepro.fr/de/ratgeber/' }}
>
  <Fragment slot="head">
    <style>
      .page-header {
        padding: 9rem 2rem 3rem;
        text-align: center;
        background: linear-gradient(180deg, var(--bg-card), var(--bg));
      }
      .section-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--blue);
        margin-bottom: 0.75rem;
      }
      .page-header h1 {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 1rem;
      }
      .page-header p {
        color: var(--gray-500);
        font-size: 1.1rem;
        max-width: 550px;
        margin: 0 auto;
      }
      .guides-grid {
        max-width: 1000px;
        margin: 0 auto;
        padding: 3rem 2rem 6rem;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
      .guide-card {
        background: var(--bg-card);
        border: 1px solid var(--gray-200);
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        color: var(--gray-900);
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        display: flex;
        flex-direction: column;
      }
      .guide-card:hover {
        border-color: rgba(37, 99, 235, 0.3);
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
      }
      .guide-card .card-image {
        width: 100%;
        height: 180px;
        background: linear-gradient(135deg, var(--gray-100), var(--gray-200));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gray-400);
        font-size: 0.8rem;
        font-weight: 500;
      }
      .guide-card .card-content {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      .guide-card .tag {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        background: rgba(37, 99, 235, 0.06);
        border-radius: 50px;
        font-size: 0.7rem;
        color: var(--blue);
        font-weight: 600;
        margin-bottom: 0.75rem;
        width: fit-content;
      }
      .guide-card h2 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.35;
      }
      .guide-card p {
        color: var(--gray-500);
        font-size: 0.85rem;
        line-height: 1.6;
        flex: 1;
      }
      .guide-card .meta {
        margin-top: 1rem;
        font-size: 0.75rem;
        color: var(--gray-400);
        font-weight: 500;
      }
      @media (max-width: 768px) {
        .page-header { padding: 7rem 1.5rem 2rem; }
        .page-header h1 { font-size: 2rem; }
        .guides-grid { grid-template-columns: 1fr; }
      }
    </style>
  </Fragment>

  <header class="page-header">
    <div class="section-label">Ratgeber</div>
    <h1>Vollständige Ratgeber</h1>
    <p>Ausführliche Ratgeber, um jeden Aspekt Ihres Trainings zu meistern – vom Anfänger bis zum Fortgeschrittenen.</p>
  </header>

  <section class="guides-grid">
    {guides.map(guide => (
      <a href={`/de/ratgeber/${guide.data.slug}/`} class="guide-card">
        <div class="card-image img-placeholder">{guide.data.tag}</div>
        <div class="card-content">
          <span class="tag">{guide.data.tag}</span>
          <h2>{guide.data.title}</h2>
          <p>{guide.data.description}</p>
          <div class="meta">{guide.data.readTime}</div>
        </div>
      </a>
    ))}
  </section>

  <section class="final-cta">
    <h2>Setzen Sie es in die Praxis um</h2>
    <p>Laden Sie AIVancePro herunter und lassen Sie den KI-Coach diese Prinzipien auf Ihr Training anwenden.</p>
    <a href="https://apps.apple.com/app/aivancepro/id6756116760" class="btn-primary" target="_blank" rel="noopener">Kostenlos herunterladen</a>
  </section>
</BaseLayout>
