---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="fr"
  title="Discussion - Forum AIVancePro"
  description="Discussion sur le forum communautaire AIVancePro."
  noindex={true}
>
  <Fragment slot="head">
    <style>
      .topic-container { max-width: 820px; margin: 0 auto; padding: 7rem 2rem 4rem; }
      .topic-back { display: inline-flex; align-items: center; gap: 0.35rem; color: var(--text-secondary); text-decoration: none; font-size: 0.85rem; margin-bottom: 1.5rem; transition: color 0.2s; }
      .topic-back:hover { color: var(--blue); }
      .topic-back svg { width: 16px; height: 16px; }

      /* Original post */
      .topic-post { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; margin-bottom: 2rem; }
      .topic-post-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; }
      .topic-title { font-size: 1.4rem; font-weight: 800; color: var(--text); line-height: 1.3; flex: 1; }
      .topic-tag { padding: 0.2rem 0.6rem; border-radius: 50px; background: rgba(74,144,217,0.08); color: var(--blue); font-size: 0.72rem; font-weight: 600; white-space: nowrap; margin-left: 0.75rem; margin-top: 0.25rem; }
      .topic-tag.article { background: rgba(147,51,234,0.08); color: #9333EA; }
      .topic-body { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.8; white-space: pre-wrap; word-break: break-word; }
      .topic-body a { color: var(--blue); }
      .topic-footer { display: flex; align-items: center; gap: 1rem; margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
      .topic-author { font-size: 0.82rem; color: var(--text-muted); }
      .topic-author strong { color: var(--text-secondary); font-weight: 600; }
      .topic-time { font-size: 0.82rem; color: var(--text-muted); }

      /* Vote buttons */
      .vote-actions { display: flex; align-items: center; gap: 0.3rem; }
      .vote-btn { background: none; border: 1px solid var(--border); border-radius: 8px; padding: 0.3rem; cursor: pointer; color: var(--text-muted); transition: all 0.2s; display: flex; align-items: center; justify-content: center; }
      .vote-btn:hover { border-color: var(--blue); color: var(--blue); }
      .vote-btn.voted { border-color: var(--blue); color: var(--blue); background: rgba(74,144,217,0.08); }
      .vote-btn.down.voted { border-color: #ef4444; color: #ef4444; background: rgba(239,68,68,0.08); }
      .vote-btn svg { width: 16px; height: 16px; }
      .vote-score { font-size: 0.9rem; font-weight: 700; color: var(--text); min-width: 20px; text-align: center; }

      /* Action buttons */
      .action-btn { background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 0.78rem; font-family: inherit; display: flex; align-items: center; gap: 0.25rem; transition: color 0.2s; padding: 0.2rem 0.4rem; border-radius: 6px; }
      .action-btn:hover { color: var(--text-secondary); background: var(--bg-elevated, rgba(0,0,0,0.05)); }
      .action-btn svg { width: 14px; height: 14px; }
      .action-spacer { flex: 1; }

      /* Replies */
      .replies-header { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 1rem; }
      .replies-list { display: flex; flex-direction: column; gap: 0; }
      .reply-item { padding: 1rem 0; border-bottom: 1px solid var(--border); }
      .reply-item:first-child { border-top: 1px solid var(--border); }
      .reply-body { color: var(--text-secondary); font-size: 0.92rem; line-height: 1.7; white-space: pre-wrap; word-break: break-word; margin-bottom: 0.5rem; }
      .reply-body a { color: var(--blue); }
      .reply-footer { display: flex; align-items: center; gap: 0.75rem; font-size: 0.78rem; color: var(--text-muted); flex-wrap: wrap; }
      .reply-footer strong { color: var(--text-secondary); font-weight: 600; }

      /* Reply form */
      .reply-form { margin-top: 2rem; }
      .reply-form h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.75rem; }
      .reply-form textarea { width: 100%; padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text); font-size: 0.9rem; font-family: inherit; outline: none; resize: vertical; min-height: 100px; box-sizing: border-box; transition: border-color 0.2s; }
      .reply-form textarea:focus { border-color: var(--blue); }
      .reply-form-actions { display: flex; justify-content: flex-end; margin-top: 0.75rem; }
      .btn-reply { padding: 0.6rem 1.25rem; border-radius: 10px; border: none; background: var(--blue); color: #fff; font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: background 0.2s; }
      .btn-reply:hover { background: var(--blue-hover, #1d4ed8); }
      .btn-reply:disabled { opacity: 0.5; cursor: not-allowed; }
      .reply-error { color: #ef4444; font-size: 0.85rem; margin-top: 0.5rem; }

      /* Auth prompt */
      .reply-auth { text-align: center; padding: 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; margin-top: 2rem; }
      .reply-auth p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.75rem; }
      .reply-auth a { color: var(--blue); font-weight: 600; }

      /* Article link */
      .article-link { display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.5rem 0.85rem; border-radius: 10px; background: rgba(147,51,234,0.06); border: 1px solid rgba(147,51,234,0.15); color: #9333EA; text-decoration: none; font-size: 0.82rem; font-weight: 600; margin-bottom: 1rem; transition: background 0.2s; }
      .article-link:hover { background: rgba(147,51,234,0.12); }
      .article-link svg { width: 14px; height: 14px; }

      /* Toast */
      .toast { position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%); padding: 0.75rem 1.5rem; border-radius: 10px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text); font-size: 0.85rem; font-weight: 600; z-index: 9999; display: none; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
      .toast.show { display: block; }

      .topic-loading { text-align: center; padding: 4rem; color: var(--text-muted); }

      @media (max-width: 768px) {
        .topic-container { padding: 6rem 1rem 3rem; }
        .topic-title { font-size: 1.15rem; }
      }
    </style>
  </Fragment>

  <div class="topic-container">
    <a href="/forum/" class="topic-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Retour au forum
    </a>

    <div id="topicContent">
      <div class="topic-loading">Chargement...</div>
    </div>

    <div id="repliesSection"></div>
    <div id="replyFormSection"></div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script is:inline>
  (function() {
    var SUPABASE_URL = 'https://vzmtvhcvyqzkmestdbko.supabase.co';
    var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ6bXR2aGN2eXF6a21lc3RkYmtvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA4OTA0MTEsImV4cCI6MjA4NjQ2NjQxMX0.rvBz2uIsr3YtLIw84Kor3eVFpH4FiXVZgbufiJH3uio';
    var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

    var postId = new URLSearchParams(window.location.search).get('id');
    if (!postId) {
      document.getElementById('topicContent').innerHTML = '<div class="topic-loading">Discussion introuvable.</div>';
      return;
    }

    var currentUser = null;
    var userVotes = {};

    var catLabels = {
      general: 'Général', entrainement: 'Entraînement',
      nutrition: 'Nutrition', progression: 'Progression'
    };

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str || '';
      return div.innerHTML;
    }

    function linkify(text) {
      return escapeHtml(text).replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" rel="noopener">$1</a>');
    }

    function formatTimeAgo(dateStr) {
      var diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
      if (diff < 60) return "à l'instant";
      if (diff < 3600) return Math.floor(diff / 60) + ' min';
      if (diff < 86400) return Math.floor(diff / 3600) + ' h';
      if (diff < 2592000) return Math.floor(diff / 86400) + ' j';
      return new Date(dateStr).toLocaleDateString('fr-FR');
    }

    function formatDate(dateStr) {
      return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    function showToast(msg) {
      var t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(function() { t.classList.remove('show'); }, 3000);
    }

    async function loadUserVotes() {
      if (!currentUser) return;
      var res = await sb.from('forum_votes').select('*').eq('user_id', currentUser.id);
      if (res.data) {
        res.data.forEach(function(v) { userVotes[v.target_type + ':' + v.target_id] = v.value; });
      }
    }

    async function vote(targetId, targetType, value) {
      if (!currentUser) { showToast('Connectez-vous pour voter'); return; }
      var key = targetType + ':' + targetId;
      var existing = userVotes[key];
      if (existing === value) {
        await sb.from('forum_votes').delete().match({ user_id: currentUser.id, target_id: targetId, target_type: targetType });
        delete userVotes[key];
      } else {
        if (existing) {
          await sb.from('forum_votes').delete().match({ user_id: currentUser.id, target_id: targetId, target_type: targetType });
        }
        await sb.from('forum_votes').insert({ user_id: currentUser.id, target_id: targetId, target_type: targetType, value: value });
        userVotes[key] = value;
      }
      loadTopic();
    }

    async function report(targetId, targetType) {
      if (!currentUser) { showToast('Connectez-vous pour signaler'); return; }
      var res = await sb.from('forum_reports').insert({
        reporter_id: currentUser.id, target_id: targetId,
        target_type: targetType, reason: 'inappropriate'
      });
      if (res.error && res.error.code === '23505') showToast('Vous avez déjà signalé ce contenu');
      else if (res.error) showToast('Erreur lors du signalement');
      else showToast('Contenu signalé — merci');
    }

    function voteHtml(id, type, score) {
      var upClass = userVotes[type + ':' + id] === 1 ? ' voted' : '';
      var downClass = userVotes[type + ':' + id] === -1 ? ' voted' : '';
      return '<div class="vote-actions">' +
        '<button class="vote-btn up' + upClass + '" data-vote-id="' + id + '" data-vote-type="' + type + '" data-vote-val="1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg></button>' +
        '<span class="vote-score">' + (score || 0) + '</span>' +
        '<button class="vote-btn down' + downClass + '" data-vote-id="' + id + '" data-vote-type="' + type + '" data-vote-val="-1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></button>' +
      '</div>';
    }

    function reportBtn(id, type) {
      return '<button class="action-btn" data-report-id="' + id + '" data-report-type="' + type + '">' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>' +
        'Signaler</button>';
    }

    async function loadTopic() {
      var container = document.getElementById('topicContent');
      var res = await sb.from('forum_posts').select('*').eq('id', postId).single();
      if (res.error || !res.data) {
        container.innerHTML = '<div class="topic-loading">Discussion introuvable.</div>';
        return;
      }
      var post = res.data;
      document.title = post.title + ' - Forum AIVancePro';

      var catClass = post.article_slug ? 'article' : '';
      var catText = post.article_slug ? 'Article' : (catLabels[post.category] || post.category);
      var articleLink = '';
      if (post.article_slug && post.article_type) {
        var prefix = post.article_type === 'guide' ? '/guides/' : '/blog/';
        articleLink = '<a href="' + prefix + post.article_slug + '/" class="article-link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>Lire l\'article</a>';
      }

      container.innerHTML =
        '<div class="topic-post">' + articleLink +
          '<div class="topic-post-header"><div class="topic-title">' + escapeHtml(post.title) + '</div>' +
            '<span class="topic-tag ' + catClass + '">' + catText + '</span></div>' +
          '<div class="topic-body">' + linkify(post.body) + '</div>' +
          '<div class="topic-footer">' + voteHtml(post.id, 'post', post.upvotes) +
            '<span class="topic-author">par <strong>' + escapeHtml(post.author_name) + '</strong></span>' +
            '<span class="topic-time">' + formatDate(post.created_at) + '</span>' +
            '<span class="action-spacer"></span>' + reportBtn(post.id, 'post') +
          '</div></div>';

      loadReplies();
    }

    async function loadReplies() {
      var section = document.getElementById('repliesSection');
      var res = await sb.from('forum_replies').select('*').eq('post_id', postId).order('created_at', { ascending: true });
      if (res.error) {
        section.innerHTML = '<p style="color:var(--text-muted)">Erreur de chargement des réponses.</p>';
        return;
      }
      var replies = res.data || [];
      var html = '<h3 class="replies-header">' + replies.length + ' réponse' + (replies.length !== 1 ? 's' : '') + '</h3>';
      if (replies.length > 0) {
        html += '<div class="replies-list">';
        replies.forEach(function(r) {
          html += '<div class="reply-item"><div class="reply-body">' + linkify(r.body) + '</div>' +
            '<div class="reply-footer">' + voteHtml(r.id, 'reply', r.upvotes) +
              '<strong>' + escapeHtml(r.author_name) + '</strong>' +
              '<span>' + formatTimeAgo(r.created_at) + '</span>' +
              '<span class="action-spacer"></span>' + reportBtn(r.id, 'reply') +
            '</div></div>';
        });
        html += '</div>';
      }
      section.innerHTML = html;

      var formSection = document.getElementById('replyFormSection');
      if (currentUser) {
        formSection.innerHTML =
          '<div class="reply-form"><h3>Votre réponse</h3>' +
            '<textarea id="replyBody" placeholder="Partagez votre avis ou répondez à la question..."></textarea>' +
            '<p class="reply-error" id="replyError" style="display:none"></p>' +
            '<div class="reply-form-actions"><button class="btn-reply" id="btnSubmitReply">Répondre</button></div></div>';
        document.getElementById('btnSubmitReply').addEventListener('click', submitReply);
      } else {
        formSection.innerHTML =
          '<div class="reply-auth"><p>Connectez-vous pour participer à la discussion.</p>' +
            '<a href="/login/?redirect=/forum/topic/?id=' + postId + '">Se connecter</a></div>';
      }
    }

    async function submitReply() {
      var body = document.getElementById('replyBody').value.trim();
      var errEl = document.getElementById('replyError');
      var btn = document.getElementById('btnSubmitReply');
      if (!body || body.length < 5) {
        errEl.textContent = 'La réponse doit contenir au moins 5 caractères.';
        errEl.style.display = ''; return;
      }
      errEl.style.display = 'none';
      btn.disabled = true; btn.textContent = 'Envoi...';
      var authorName = currentUser.user_metadata?.display_name || currentUser.user_metadata?.full_name || currentUser.email?.split('@')[0] || 'Utilisateur';
      var res = await sb.from('forum_replies').insert({
        post_id: postId, body: body,
        author_id: currentUser.id, author_name: authorName
      });
      btn.disabled = false; btn.textContent = 'Répondre';
      if (res.error) {
        errEl.textContent = 'Erreur : ' + res.error.message;
        errEl.style.display = ''; return;
      }
      document.getElementById('replyBody').value = '';
      loadReplies();
      loadTopic();
    }

    document.addEventListener('click', function(e) {
      var voteBtn = e.target.closest('[data-vote-id]');
      if (voteBtn) {
        vote(voteBtn.dataset.voteId, voteBtn.dataset.voteType, parseInt(voteBtn.dataset.voteVal));
        return;
      }
      var reportBtnEl = e.target.closest('[data-report-id]');
      if (reportBtnEl) {
        if (confirm('Voulez-vous signaler ce contenu comme inapproprié ?')) {
          report(reportBtnEl.dataset.reportId, reportBtnEl.dataset.reportType);
        }
      }
    });

    sb.auth.getSession().then(async function(res) {
      if (res.data.session) {
        currentUser = res.data.session.user;
        await loadUserVotes();
      }
      loadTopic();
    });
  })();
  </script>
</BaseLayout>
