---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'de';
const starSvg = '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';

const reviews = [
  {
    text: "&laquo; Der KI-Coach ist unglaublich, er versteht genau, was ich brauche, und erstellt perfekt angepasste Trainingseinheiten. Ich habe in 2 Monaten mehr Fortschritte gemacht als in einem Jahr allein. &raquo;",
    author: "Thomas L.",
    source: "App Store",
  },
  {
    text: "&laquo; Die App ist super komplett: &Uuml;bungen, Vorlagen, Fortschrittsverfolgung, Community... Alles ist dabei. Und der automatische Pausentimer ist ein echtes Plus im Fitnessstudio. &raquo;",
    author: "Marie D.",
    source: "App Store",
  },
  {
    text: "&laquo; Ich nutze AIVancePro seit 3 Monaten und die Challenges mit Freunden machen das Training so viel spa&szlig;iger. Das Badge-System motiviert, regelm&auml;&szlig;ig zu bleiben. Top! &raquo;",
    author: "Julien R.",
    source: "Google Play",
  },
];
---

<BaseLayout
  lang={lang}
  title="Nutzerbewertungen - AIVancePro"
  description="Entdecken Sie, was AIVancePro-Nutzer denken. Tausende Sportler vertrauen unserem KI-Coach f&uuml;r ihr Training."
  canonical="https://aivancepro.fr/de/bewertungen/"
  alternates={{ fr: 'https://aivancepro.fr/avis/', en: 'https://aivancepro.fr/en/reviews/', de: 'https://aivancepro.fr/de/bewertungen/' }}
>
  <Fragment slot="head">
    <style>
      .reviews-hero {
          padding: 8rem 2rem 4rem;
          text-align: center;
          background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
      }
      .reviews-hero h1 {
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: -0.03em;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .reviews-hero p {
          font-size: 1.15rem;
          color: var(--gray-500);
          max-width: 600px;
          margin: 0 auto;
      }
      .reviews-section {
          padding: 3rem 2rem 6rem;
          background: var(--bg-alt);
      }
      .reviews-inner {
          max-width: 1100px;
          margin: 0 auto;
          text-align: center;
      }
      .reviews-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 1.5rem;
          margin-bottom: 2.5rem;
      }
      .review-card {
          background: var(--bg-card);
          border: 1px solid var(--border);
          border-radius: 16px;
          padding: 1.75rem;
          text-align: left;
          transition: transform 0.2s, box-shadow 0.2s;
      }
      .review-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 8px 30px rgba(0,0,0,0.12);
      }
      .review-stars {
          display: flex;
          gap: 2px;
          margin-bottom: 1rem;
      }
      .review-stars :global(svg) {
          width: 18px;
          height: 18px;
          color: #FBBF24;
      }
      .review-text {
          font-size: 0.95rem;
          color: var(--gray-700);
          line-height: 1.7;
          margin-bottom: 1.25rem;
      }
      .review-author {
          font-size: 0.85rem;
          font-weight: 600;
          color: var(--gray-900);
      }
      .review-source {
          font-size: 0.75rem;
          color: var(--gray-400);
          margin-top: 0.15rem;
      }
      .review-cta {
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          color: var(--blue);
          font-weight: 600;
          font-size: 0.95rem;
          text-decoration: none;
          transition: opacity 0.2s;
      }
      .review-cta:hover { opacity: 0.8; }
      .review-cta svg { width: 18px; height: 18px; }

      @media (max-width: 768px) {
          .reviews-hero h1 { font-size: 2rem; }
          .reviews-grid { grid-template-columns: 1fr; }
      }
    </style>
  </Fragment>

  <section class="reviews-hero">
      <h1>Nutzerbewertungen</h1>
      <p>Tausende Sportler vertrauen AIVancePro f&uuml;r ihr Training. Entdecken Sie, was sie denken.</p>
  </section>

  <section class="reviews-section">
      <div class="reviews-inner">
          <div class="reviews-grid">
              {reviews.map((review, i) => (
                  <div class="review-card">
                      <div class="review-stars" set:html={starSvg.repeat(5)} />
                      <p class="review-text" set:html={review.text} />
                      <div class="review-author">{review.author}</div>
                      <div class="review-source">{review.source}</div>
                  </div>
              ))}
          </div>

          <a href="https://apps.apple.com/de/app/aivancepro/id6756116760?action=write-review" class="review-cta" target="_blank" rel="noopener">
              Bewertung im App Store hinterlassen
              <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </a>
      </div>
  </section>
</BaseLayout>
