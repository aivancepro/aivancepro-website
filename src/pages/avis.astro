---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = 'fr';
const starSvg = '<svg viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';

const reviews = [
  {
    text: "&laquo; &Ccedil;a fait genre 6 mois que je vais en salle et j'arrivais &agrave; un point o&ugrave; je savais plus trop quoi faire, je refaisais les m&ecirc;mes trucs &agrave; chaque fois. J'avais la flemme de me faire un programme et un coach c'est trop cher pour moi. J'ai test&eacute; le coach IA un peu au hasard et en vrai c'est ouf. Tu lui dis ce que t'as comme matos et en combien de temps tu veux t'entra&icirc;ner et il te sort une s&eacute;ance compl&egrave;te. Au d&eacute;but je pensais que &ccedil;a serait g&eacute;n&eacute;rique mais non il s'adapte vraiment. Le truc qui m'a fait passer pro c'est le suivi, tu vois tes stats &eacute;voluer au fil des s&eacute;ances et &ccedil;a motive grave. Genre en vrai j'ai plus progress&eacute; en 2 mois avec l'app qu'en 4 mois tout seul. Franchement pour le prix c'est donn&eacute;. &raquo;",
    author: "Theo Lpe",
    source: "App Store",
  },
  {
    text: "&laquo; Tr&egrave;s bonne application, avec un suivi et de bons conseils, je recommande. &raquo;",
    author: "Nathou.S",
    source: "App Store",
  },
  {
    text: "&laquo; Apr&egrave;s avoir encha&icirc;n&eacute; des s&eacute;ries &agrave; l&rsquo;aveugle sans r&eacute;sultat concret, cette appli a ajout&eacute; une motivation +++. &Ccedil;a m&rsquo;a relanc&eacute;. &raquo;",
    author: "JAMS 02",
    source: "App Store",
  },
];
---

<BaseLayout
  lang={lang}
  title="Avis utilisateurs - AIVancePro"
  description="D&eacute;couvrez les avis des utilisateurs d'AIVancePro. Des milliers de sportifs font confiance &agrave; notre coach IA pour leur entra&icirc;nement."
  canonical="https://aivancepro.fr/avis/"
  alternates={{ fr: 'https://aivancepro.fr/avis/', en: 'https://aivancepro.fr/en/reviews/', de: 'https://aivancepro.fr/de/bewertungen/' }}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "MobileApplication",
      "name": "AIVancePro",
      "operatingSystem": "iOS, Android",
      "applicationCategory": "HealthApplication",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "bestRating": "5",
        "ratingCount": "3",
        "reviewCount": "3"
      },
      "review": [
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Theo Lpe" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "J'ai test\u00e9 le coach IA un peu au hasard et en vrai c'est ouf. Tu lui dis ce que t'as comme matos et en combien de temps tu veux t'entra\u00eener et il te sort une s\u00e9ance compl\u00e8te. Au d\u00e9but je pensais que \u00e7a serait g\u00e9n\u00e9rique mais non il s'adapte vraiment. J'ai plus progress\u00e9 en 2 mois avec l'app qu'en 4 mois tout seul. Franchement pour le prix c'est donn\u00e9."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "Nathou.S" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "Tr\u00e8s bonne application, avec un suivi et de bons conseils, je recommande."
        },
        {
          "@type": "Review",
          "author": { "@type": "Person", "name": "JAMS 02" },
          "reviewRating": { "@type": "Rating", "ratingValue": "5" },
          "reviewBody": "Apr\u00e8s avoir encha\u00een\u00e9 des s\u00e9ries \u00e0 l'aveugle sans r\u00e9sultat concret, cette appli a ajout\u00e9 une motivation +++. \u00c7a m'a relanc\u00e9."
        }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://aivancepro.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Avis", "item": "https://aivancepro.fr/avis/" }
      ]
    }
  ]}
>
  <Fragment slot="head">
    <style>
      .reviews-hero {
          padding: 5.5rem 2rem 3rem;
          text-align: center;
          background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
      }
      .reviews-hero h1 {
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: -0.03em;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .reviews-hero p {
          font-size: 1.15rem;
          color: var(--gray-500);
          max-width: 600px;
          margin: 0 auto;
      }
      .reviews-section {
          padding: 3rem 2rem 6rem;
          background: var(--bg-alt);
      }
      .reviews-inner {
          max-width: 1100px;
          margin: 0 auto;
          text-align: center;
      }
      .reviews-grid {
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
          margin-bottom: 2.5rem;
      }
      .review-card {
          background: var(--bg-card);
          border: 1px solid var(--border);
          border-radius: 16px;
          padding: 1.75rem;
          text-align: left;
          transition: transform 0.2s, box-shadow 0.2s;
      }
      .review-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 8px 30px rgba(0,0,0,0.12);
      }
      .review-stars {
          display: flex;
          gap: 2px;
          margin-bottom: 1rem;
      }
      .review-stars :global(svg) {
          width: 18px;
          height: 18px;
          color: #FBBF24;
      }
      .review-text {
          font-size: 0.95rem;
          color: var(--gray-700);
          line-height: 1.7;
          margin-bottom: 1.25rem;
      }
      .review-author {
          font-size: 0.85rem;
          font-weight: 600;
          color: var(--gray-900);
      }
      .review-source {
          font-size: 0.75rem;
          color: var(--gray-400);
          margin-top: 0.15rem;
      }
      .review-cta {
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          color: var(--blue);
          font-weight: 600;
          font-size: 0.95rem;
          text-decoration: none;
          transition: opacity 0.2s;
      }
      .review-cta:hover { opacity: 0.8; }
      .review-cta svg { width: 18px; height: 18px; }

      @media (max-width: 768px) {
          .reviews-hero h1 { font-size: 2rem; }
          .reviews-grid { grid-template-columns: 1fr; }
      }
    </style>
  </Fragment>

  <section class="reviews-hero">
      <h1>Avis utilisateurs</h1>
      <p>Des milliers de sportifs font confiance &agrave; AIVancePro pour leur entra&icirc;nement. D&eacute;couvrez ce qu'ils en pensent.</p>
  </section>

  <section class="reviews-section">
      <div class="reviews-inner">
          <div class="reviews-grid">
              {reviews.map((review, i) => (
                  <div class="review-card">
                      <div class="review-stars" set:html={starSvg.repeat(5)} />
                      <p class="review-text" set:html={review.text} />
                      <div class="review-author">{review.author}</div>
                      <div class="review-source">{review.source}</div>
                  </div>
              ))}
          </div>

          <a href="https://apps.apple.com/fr/app/aivancepro/id6756116760?action=write-review" class="review-cta" target="_blank" rel="noopener">
              Laisser un avis sur l'App Store
              <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </a>
      </div>
  </section>
</BaseLayout>
