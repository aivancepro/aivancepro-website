---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'fr');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const siteBase = 'https://aivancepro.fr';
const resolveImage = (img?: string) => img ? (img.startsWith('/') ? siteBase + img : img) : siteBase + '/assets/og-image.png';

const related = (await getCollection('blog', ({ data }) =>
  data.lang === 'fr' &&
  data.category === post.data.category &&
  data.slug !== post.data.slug
)).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);
---

<ArticleLayout
  lang={post.data.lang}
  title={post.data.title}
  description={post.data.description}
  canonical={post.data.canonical}
  alternates={post.data.alternates}
  tag={post.data.tag}
  category={post.data.category}
  date={post.data.date}
  dateModified={post.data.dateModified}
  readTime={post.data.readTime}
  backLink="/blog/"
  backLabel="Retour au blog"
  image={post.data.image}
  author={post.data.author}
  relatedArticles={related}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.data.title,
      "description": post.data.description,
      "datePublished": post.data.date,
      "dateModified": post.data.dateModified || post.data.date,
      "keywords": post.data.keywords,
      "inLanguage": "fr",
      "wordCount": wordCount,
      "articleSection": post.data.tag,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": post.data.canonical,
      },
      "image": resolveImage(post.data.image),
      "thumbnailUrl": resolveImage(post.data.image),
      "author": {
        "@type": "Person",
        "name": post.data.author || "Theo Stanmore",
        "url": "https://aivancepro.fr/",
      },
      "publisher": {
        "@type": "Organization",
        "name": "AIVancePro",
        "url": "https://aivancepro.fr",
        "logo": {
          "@type": "ImageObject",
          "url": "https://aivancepro.fr/logo.png",
        },
      },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://aivancepro.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://aivancepro.fr/blog/" },
        { "@type": "ListItem", "position": 3, "name": post.data.title, "item": post.data.canonical },
      ],
    },
  ]}
>
  <Content />
</ArticleLayout>
