---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://aivancepro.fr/about/#alexandre-saraiva",
    "name": "Alexandre Saraiva",
    "jobTitle": "Gr\u00fcnder & KI-Fitness-Coach",
    "url": "https://aivancepro.fr/de/about/",
    "image": "https://aivancepro.fr/assets/og-image.png",
    "description": "Gr\u00fcnder von AIVancePro, leidenschaftlicher Kraftsportler und KI-Enthusiast. Entwickler einer KI-gest\u00fctzten Fitness-Coaching-App.",
    "sameAs": [
      "https://www.instagram.com/aivancepro/",
      "https://www.tiktok.com/@aivancepro",
      "https://x.com/AIVancePro",
      "https://www.youtube.com/channel/UC8MGuOS22H-jXfe8Haqw8LA",
      "https://www.linkedin.com/company/aivancepro",
      "https://www.reddit.com/user/AIVancePro"
    ],
    "knowsAbout": [
      "Krafttraining",
      "Fitness-Coaching",
      "K\u00fcnstliche Intelligenz",
      "Sportern\u00e4hrung",
      "Trainingsplanung",
      "Muskelhypertrophie"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "AS Corporation"
    },
    "founder": {
      "@type": "Organization",
      "name": "AIVancePro",
      "url": "https://aivancepro.fr"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://aivancepro.fr/#organization",
    "name": "AIVancePro",
    "url": "https://aivancepro.fr",
    "logo": "https://aivancepro.fr/assets/logo-512.png",
    "description": "KI-gest\u00fctzte Fitness-Coaching-App. Personalisierte Trainingspl\u00e4ne, Fortschrittsverfolgung und Ern\u00e4hrungsberatung.",
    "founder": {
      "@type": "Person",
      "name": "Alexandre Saraiva",
      "@id": "https://aivancepro.fr/about/#alexandre-saraiva"
    },
    "sameAs": [
      "https://www.instagram.com/aivancepro/",
      "https://www.tiktok.com/@aivancepro",
      "https://x.com/AIVancePro",
      "https://www.youtube.com/channel/UC8MGuOS22H-jXfe8Haqw8LA",
      "https://www.linkedin.com/company/aivancepro",
      "https://www.reddit.com/user/AIVancePro"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://aivancepro.fr/de/" },
      { "@type": "ListItem", "position": 2, "name": "\u00dcber uns", "item": "https://aivancepro.fr/de/about/" }
    ]
  }
];
---

<BaseLayout
  lang="de"
  title="\u00dcber Alexandre Saraiva - Gr\u00fcnder von AIVancePro"
  description="Lernen Sie Alexandre Saraiva kennen, Gr\u00fcnder von AIVancePro. Luft- und Raumfahrtingenieur und leidenschaftlicher Kraftsportler, entwickelt er intelligente Fitness-Coaching-Tools."
  canonical="https://aivancepro.fr/de/about/"
  alternates={{ fr: 'https://aivancepro.fr/about/', en: 'https://aivancepro.fr/en/about/', de: 'https://aivancepro.fr/de/about/' }}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <style>
      .page-header { padding: 9rem 2rem 3rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); }
      .section-label { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); margin-bottom: 0.75rem; }
      .page-header h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; color: var(--gray-900); }
      .page-header p { color: var(--gray-500); font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.7; }

      .about-content { max-width: 800px; margin: 0 auto; padding: 3rem 2rem 4rem; }

      .author-card { display: flex; gap: 2rem; align-items: flex-start; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 20px; padding: 2.5rem; margin-bottom: 3rem; }
      .author-avatar { width: 120px; height: 120px; border-radius: 50%; background: var(--blue); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #fff; font-size: 2.5rem; font-weight: 800; }
      .author-info h2 { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.25rem; }
      .author-role { color: var(--blue); font-weight: 600; font-size: 0.95rem; margin-bottom: 0.75rem; }
      .author-bio { color: var(--gray-600); font-size: 0.95rem; line-height: 1.7; text-align: justify; }
      .author-socials { display: flex; gap: 0.75rem; margin-top: 1rem; }
      .author-socials a { color: var(--gray-400); transition: color 0.2s; }
      .author-socials a:hover { color: var(--blue); }
      .author-socials svg { width: 20px; height: 20px; }

      .about-section { margin-bottom: 2.5rem; }
      .about-section h2 { font-size: 1.4rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1rem; }
      .about-section p { color: var(--gray-600); font-size: 0.95rem; line-height: 1.8; margin-bottom: 1rem; text-align: justify; }
      .about-section ul { padding-left: 1.5rem; margin-bottom: 1rem; }
      .about-section li { color: var(--gray-600); font-size: 0.95rem; line-height: 1.8; margin-bottom: 0.5rem; }
      .about-section a { color: var(--blue); text-decoration: underline; }
      .about-section strong { color: var(--gray-900); }

      .expertise-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
      .expertise-item { background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: 12px; padding: 1.25rem; text-align: center; }
      .expertise-item .icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
      .expertise-item h3 { font-size: 0.95rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.25rem; }
      .expertise-item p { font-size: 0.85rem; color: var(--gray-500); margin: 0; text-align: center; }

      .cta-box { background: var(--blue); border-radius: 20px; padding: 2.5rem; text-align: center; color: #fff; margin-top: 3rem; }
      .cta-box h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.75rem; color: #fff; }
      .cta-box p { opacity: 0.9; margin-bottom: 1.5rem; font-size: 0.95rem; }
      .cta-box .btn { display: inline-block; background: #fff; color: var(--blue); font-weight: 700; padding: 0.75rem 2rem; border-radius: 12px; text-decoration: none; font-size: 0.95rem; transition: transform 0.2s; }
      .cta-box .btn:hover { transform: translateY(-2px); }

      .back { display: inline-block; margin-top: 2rem; color: var(--gray-500); text-decoration: none; font-size: 0.9rem; }
      .back:hover { color: var(--gray-900); }

      /* ── Timeline ── */
      .timeline-section { margin-bottom: 2.5rem; }
      .timeline-section h2 { font-size: 1.4rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1.5rem; }
      .timeline { position: relative; padding-left: 2rem; }
      .timeline::before { content: ''; position: absolute; left: 7px; top: 6px; bottom: 6px; width: 2px; background: var(--gray-200); }
      .timeline-item { position: relative; margin-bottom: 1.75rem; }
      .timeline-item:last-child { margin-bottom: 0; }
      .timeline-dot { position: absolute; left: -2rem; top: 4px; width: 16px; height: 16px; border-radius: 50%; background: var(--blue); border: 3px solid var(--bg); box-shadow: 0 0 0 2px var(--blue); flex-shrink: 0; }
      .timeline-date { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--blue); margin-bottom: 0.2rem; }
      .timeline-title { font-size: 1rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.2rem; }
      .timeline-desc { font-size: 0.9rem; color: var(--gray-500); line-height: 1.6; }

      @media (max-width: 768px) {
        .page-header { padding: 7rem 1.5rem 2rem; }
        .page-header h1 { font-size: 2rem; }
        .author-card { flex-direction: column; align-items: center; text-align: center; }
        .author-socials { justify-content: center; }
      }
    </style>
  </Fragment>

  <header class="page-header">
    <div class="section-label">&Uuml;ber uns</div>
    <h1>Die Geschichte hinter AIVancePro</h1>
    <p>Eine Fitness-Coaching-App, geboren aus der Leidenschaft f&uuml;r Krafttraining und k&uuml;nstliche Intelligenz.</p>
  </header>

  <div class="about-content">
    <div class="author-card">
      <div class="author-avatar">AS</div>
      <div class="author-info">
        <h2>Alexandre Saraiva</h2>
        <div class="author-role">Gr&uuml;nder &amp; Entwickler</div>
        <p class="author-bio">
          Luft- und Raumfahrtingenieur und leidenschaftlicher Kraftsportler seit meinem 15. Lebensjahr. Ich habe unz&auml;hlige Stunden damit verbracht, Hypertrophie, Kraft und Trainingsplanung zu studieren, um meine Fortschritte zu optimieren. Nachdem ich einen Personal Coach engagiert hatte, um wirklich individuelle Betreuung zu bekommen, wurde mir klar, dass <strong>Personalisierung der Schl&uuml;ssel zum Erfolg ist</strong> &mdash; aber f&uuml;r die meisten Menschen unerreichbar bleibt. So entstand die Idee f&uuml;r AIVancePro.
        </p>
        <div class="author-socials">
          <a href="https://www.instagram.com/aivancepro/" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
          <a href="https://x.com/AIVancePro" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
          <a href="https://www.linkedin.com/company/aivancepro" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
          <a href="https://www.youtube.com/channel/UC8MGuOS22H-jXfe8Haqw8LA" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="timeline-section">
      <h2>Die wichtigsten Meilensteine</h2>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-date">Juli 2025</div>
          <div class="timeline-title">Die Idee</div>
          <div class="timeline-desc">Eine KI-gest&uuml;tzte Fitness-Coaching-App, zug&auml;nglich f&uuml;r alle.</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-date">Oktober 2025</div>
          <div class="timeline-title">Erster Prototyp</div>
          <div class="timeline-desc">Erste Tests mit Beta-Nutzern.</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-date">Januar 2026</div>
          <div class="timeline-title">Offizieller Start</div>
          <div class="timeline-desc">AIVancePro verf&uuml;gbar auf iOS und Android.</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-date">M&auml;rz 2026</div>
          <div class="timeline-title">Community</div>
          <div class="timeline-desc">Start des Forums, soziale Funktionen und &uuml;ber 240 &Uuml;bungen.</div>
        </div>
      </div>
    </div>

    <div class="about-section">
      <h2>Mein Werdegang</h2>
      <p>
        Ich trainiere seit meinem 15. Lebensjahr. In all diesen Jahren habe ich unz&auml;hlige Stunden damit verbracht, zu verstehen, wie Hypertrophie und Kraft funktionieren, wissenschaftliche Studien zu lesen und meine Programme anzupassen, um maximale Fortschritte zu erzielen.
      </p>
      <p>
        Eines Tages entschied ich mich, einen Personal Coach zu engagieren, um wirklich individuelle Betreuung zu bekommen. Ich stellte ihm dutzende Fragen, nahm seine Ratschl&auml;ge auf, und diese Erfahrung war entscheidend. Mir wurde klar, dass <strong>Personalisierung der Schl&uuml;ssel zum Fortschritt ist</strong> &mdash; aber f&uuml;r die meisten ein Luxus bleibt, den sie sich nicht leisten k&ouml;nnen.
      </p>
      <p>
        Neben meinem Beruf als Luft- und Raumfahrtingenieur war ich schon immer von Softwareentwicklung begeistert. Die Idee lag nahe: <strong>Meine Trainingserfahrung und meine technischen F&auml;higkeiten kombinieren, um einen KI-Coach zu schaffen, der f&uuml;r alle zug&auml;nglich ist</strong>. So entstand AIVancePro im Jahr 2025.
      </p>
    </div>

    <div class="about-section">
      <h2>Fachgebiete</h2>
      <div class="expertise-grid">
        <div class="expertise-item">
          <div class="icon">&#x1F4AA;</div>
          <h3>Krafttraining</h3>
          <p>Hypertrophie, Kraft, Planung</p>
        </div>
        <div class="expertise-item">
          <div class="icon">&#x1F916;</div>
          <h3>K&uuml;nstliche Intelligenz</h3>
          <p>KI im Fitnessbereich</p>
        </div>
        <div class="expertise-item">
          <div class="icon">&#x1F34E;</div>
          <h3>Sportern&auml;hrung</h3>
          <p>Makros, Timing, Nahrungserg&auml;nzung</p>
        </div>
        <div class="expertise-item">
          <div class="icon">&#x1F4CA;</div>
          <h3>Fortschrittsverfolgung</h3>
          <p>RPE, Volumen, Periodisierung</p>
        </div>
      </div>
    </div>

    <div class="about-section">
      <h2>Die AIVancePro-Mission</h2>
      <p>
        Unser Ziel ist einfach: <strong>Intelligentes Fitness-Coaching f&uuml;r alle zug&auml;nglich machen</strong>. Egal ob Anf&auml;nger oder Fortgeschrittener &mdash; AIVancePro passt sich an dein Niveau, deine Ziele und deine Ausstattung an und erstellt Programme, die mit dir wachsen.
      </p>
      <p>
        Jede Funktion basiert auf aktuellen wissenschaftlichen Daten und echtem Nutzerfeedback. Die App integriert progressive &Uuml;berlastung, RPE-basierte Autoregulation und Periodisierung &mdash; die gleichen Methoden, die professionelle Coaches verwenden.
      </p>
    </div>

    <div class="about-section">
      <h2>Warum mir vertrauen?</h2>
      <ul>
        <li><strong>8 Jahre Training</strong> im Kraftsport und Fitness</li>
        <li><strong>Luft- und Raumfahrtingenieur</strong> &mdash; wissenschaftliche Pr&auml;zision angewandt auf Fitness</li>
        <li><strong>Wissenschaftlich fundiert</strong> &mdash; jede Funktion basiert auf ver&ouml;ffentlichten Studien</li>
        <li><strong>Aktiver Nutzer</strong> &mdash; ich trainiere t&auml;glich mit AIVancePro</li>
        <li><strong>Aktive Community</strong> &mdash; tausende Nutzer auf iOS und Android</li>
        <li><strong>Transparent</strong> &mdash; unsere <a href="/de/ratgeber/">kostenlosen Ratgeber</a> und unser <a href="/de/blog/">Blog</a> teilen Wissen ohne Barrieren</li>
      </ul>
    </div>

    <div class="cta-box">
      <h2>Bereit, intelligenter zu trainieren?</h2>
      <p>Schlie&szlig;e dich tausenden Nutzern an, die mit AIVancePro Fortschritte machen.</p>
      <div class="store-badges" style="justify-content:center;margin-top:1.5rem;">
        <a href="https://apps.apple.com/de/app/aivancepro/id6756116760" class="store-badge-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            <span class="store-badge-text"><span class="small">Erhältlich im</span><span class="big">App Store</span></span>
        </a>
        <a href="https://play.google.com/store/apps/details?id=com.aivancepro.app" class="store-badge-link" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
            <span class="store-badge-text"><span class="small">Erhältlich bei</span><span class="big">Google Play</span></span>
        </a>
      </div>
    </div>

    <a href="/de/" class="back">&larr; Zur&uuml;ck zur Startseite</a>
  </div>
</BaseLayout>
