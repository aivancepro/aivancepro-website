---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const {
  lang = 'fr',
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage = 'https://aivancepro.fr/assets/og-image.png',
  alternates = {},
  jsonLd,
  noFooter = false,
} = Astro.props;

const localeMap = { fr: 'fr_FR', en: 'en_GB', de: 'de_DE' };
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" sizes="64x64" href="/assets/favicon-64.png">
    <link rel="icon" type="image/png" sizes="48x48" href="/assets/favicon-48.png">
    <link rel="apple-touch-icon" sizes="128x128" href="/assets/apple-touch-icon.png">
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {alternates.fr && <link rel="alternate" hreflang="fr" href={alternates.fr} />}
    {alternates.en && <link rel="alternate" hreflang="en" href={alternates.en} />}
    {alternates.de && <link rel="alternate" hreflang="de" href={alternates.de} />}
    {alternates.fr && <link rel="alternate" hreflang="x-default" href={alternates.fr} />}
    <meta property="og:type" content={ogType}>
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:title" content={title}>
    {description && <meta property="og:description" content={description} />}
    <meta property="og:site_name" content="AIVancePro">
    <meta property="og:image" content={ogImage}>
    <meta property="og:locale" content={localeMap[lang] || 'fr_FR'}>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={title}>
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage}>
    {jsonLd && (Array.isArray(jsonLd)
      ? jsonLd.map(block => <script type="application/ld+json" set:html={JSON.stringify(block)} />)
      : <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <slot name="head" />
</head>
<body>
    <Nav lang={lang} />
    <slot />
    {!noFooter && <Footer lang={lang} />}
</body>
</html>
