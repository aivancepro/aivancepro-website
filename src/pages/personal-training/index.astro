---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="fr"
  title="Personal Training : Coach personnel vs Coach IA - AIVancePro"
  description="D&eacute;couvrez les avantages du personal training et comment l'IA r&eacute;volutionne le coaching personnel. Comparatif coach traditionnel vs coach IA."
  canonical="https://aivancepro.fr/personal-training/"
