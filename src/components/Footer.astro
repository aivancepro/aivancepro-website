---
import { t } from '../i18n.js';

const { lang = 'fr' } = Astro.props;
const i = t[lang];
---

<footer>
    <div class="footer-inner">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href={i.links.home} class="logo">
                    <picture><source srcset="/assets/logo.webp" type="image/webp"><img src="/assets/logo.png" alt="AIVancePro" width="34" height="34" decoding="async"></picture>
                    <span class="logo-text">AIVancePro</span>
                </a>
                <p>{i.footer.tagline}</p>
                <div class="newsletter-form">
                    <p class="newsletter-title">{i.newsletter.title}</p>
                    <p class="newsletter-subtitle">{i.newsletter.subtitle}</p>
                    <form id="newsletterForm" data-lang={lang} data-success={i.newsletter.success} data-error={i.newsletter.error} data-duplicate={i.newsletter.duplicate}>
                        <div class="newsletter-input-wrap">
                            <input type="email" id="newsletterEmail" placeholder={i.newsletter.placeholder} required>
                            <button type="submit">{i.newsletter.button}</button>
                        </div>
                        <p class="newsletter-msg" id="newsletterMsg"></p>
                    </form>
                </div>
            </div>

            <div class="footer-col">
                <p class="footer-col-title">{i.footer.product}</p>
                <ul>
                    <li><a href={i.links.features}>{i.nav.features}</a></li>
                    <li><a href={i.links.exercises}>{i.nav.exercises}</a></li>
                    <li><a href={i.links.gettingStarted}>{i.nav.gettingStarted}</a></li>
                    <li><a href={i.links.aiTransparency}>{i.nav.aiTransparency}</a></li>
                    <li><a href={i.links.reviews}>{i.nav.reviews}</a></li>
                    <li><a href={i.links.pricing}>{i.nav.pricing}</a></li>
                    <li><a href={i.links.changelog}>{i.nav.changelog}</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <p class="footer-col-title">{i.nav.articles}</p>
                <ul>
                    <li><a href={i.links.blog}>{i.nav.blog}</a></li>
                    <li><a href={i.links.guides}>{i.nav.guides}</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <p class="footer-col-title">{i.nav.help}</p>
                <ul>
                    <li><a href={i.links.faq}>{i.nav.faq}</a></li>
                    <li><a href={i.links.support}>{i.footer.support}</a></li>
                    <li><a href={i.links.about}>{i.nav.about}</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <p class="footer-col-title">{i.footer.legal}</p>
                <ul>
                    <li><a href={i.links.privacy}>{i.footer.privacy}</a></li>
                    <li><a href={i.links.terms}>{i.footer.terms}</a></li>
                </ul>
            </div>
        </div>

        <div class="footer-bottom">
            <p>{i.footer.copyright}</p>
            <div class="footer-social">
                <a href="https://www.instagram.com/aivancepro/" target="_blank" rel="noopener" aria-label="Instagram">
