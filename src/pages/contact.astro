---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="fr"
  title="Contact - AIVancePro"
  description="Contactez l'équipe AIVancePro. Questions, suggestions, partenariats ou support technique — nous vous répondons sous 24h."
  canonical="https://aivancepro.fr/contact/"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Contact AIVancePro",
    "url": "https://aivancepro.fr/contact/",
    "description": "Contactez l'équipe AIVancePro pour toute question.",
    "mainEntity": {
      "@type": "Organization",
      "name": "AIVancePro",
      "url": "https://aivancepro.fr",
      "email": "aivancepro@gmail.com",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "availableLanguage": ["French", "English"]
      }
    }
  }}
>
  <Fragment slot="head">
    <style>
      .contact-header {
        padding: 9rem 2rem 3rem;
        text-align: center;
        background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
        border-bottom: 1px solid var(--border);
      }
      .contact-header .section-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--blue);
        margin-bottom: 0.75rem;
      }
      .contact-header h1 {
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }
      .contact-header p {
        color: var(--text-secondary);
        font-size: 1.05rem;
        max-width: 520px;
        margin: 0 auto;
      }

      .contact-content {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 2rem 6rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
      }

      .contact-form-section h2 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
      }
      .form-field {
        margin-bottom: 1.25rem;
      }
      .form-field label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.4rem;
      }
      .form-field input,
      .form-field textarea,
      .form-field select {
        width: 100%;
        padding: 0.7rem 0.9rem;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text);
        font-size: 0.9rem;
        font-family: inherit;
        outline: none;
        transition: border-color 0.2s;
        box-sizing: border-box;
      }
      .form-field input:focus,
      .form-field textarea:focus,
      .form-field select:focus {
        border-color: var(--blue);
      }
      .form-field textarea {
        resize: vertical;
        min-height: 140px;
      }
      .btn-submit {
        padding: 0.7rem 1.5rem;
        border-radius: 12px;
        border: none;
        background: var(--blue);
        color: #fff;
        font-size: 0.9rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 15px rgba(74, 144, 217, 0.3);
      }
      .btn-submit:hover {
        opacity: 0.92;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(74, 144, 217, 0.4);
      }
      .btn-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
      }
      .form-success {
        display: none;
        padding: 1rem 1.25rem;
        background: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.2);
        border-radius: 10px;
        color: #10B981;
        font-size: 0.9rem;
        font-weight: 600;
        margin-top: 1rem;
      }
      .form-error {
        display: none;
        padding: 1rem 1.25rem;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.2);
        border-radius: 10px;
        color: #ef4444;
        font-size: 0.9rem;
        margin-top: 1rem;
      }

      .contact-info-section h2 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
      }
      .info-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }
      .info-card .icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(74, 144, 217, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .info-card .icon svg {
        width: 20px;
        height: 20px;
        color: var(--blue);
      }
      .info-card h3 {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.25rem;
      }
      .info-card p {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.5;
      }
      .info-card a {
        color: var(--blue);
        text-decoration: none;
      }
      .info-card a:hover {
        text-decoration: underline;
      }

      .social-links {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
      }
      .social-links a {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        transition: all 0.2s;
        text-decoration: none;
      }
      .social-links a:hover {
        border-color: var(--blue);
        color: var(--blue);
      }
      .social-links svg {
        width: 18px;
        height: 18px;
      }

      @media (max-width: 768px) {
        .contact-header { padding: 7rem 1.5rem 2rem; }
        .contact-header h1 { font-size: 2rem; }
        .contact-content {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }
    </style>
  </Fragment>

  <header class="contact-header">
    <div class="section-label">Contact</div>
    <h1>Nous contacter</h1>
    <p>Une question, une suggestion ou un partenariat ? Nous vous répondons sous 24h.</p>
  </header>

  <div class="contact-content">
    <div class="contact-form-section">
      <h2>Envoyez-nous un message</h2>
      <form id="contactForm">
        <div class="form-field">
          <label for="contactName">Nom</label>
          <input type="text" id="contactName" name="name" placeholder="Votre nom" required>
        </div>
        <div class="form-field">
          <label for="contactEmail">Email</label>
          <input type="email" id="contactEmail" name="email" placeholder="votre@email.com" required>
        </div>
        <div class="form-field">
          <label for="contactSubject">Sujet</label>
          <select id="contactSubject" name="subject">
            <option value="question">Question générale</option>
            <option value="bug">Signaler un bug</option>
            <option value="suggestion">Suggestion</option>
            <option value="partenariat">Partenariat</option>
            <option value="autre">Autre</option>
          </select>
        </div>
        <div class="form-field">
          <label for="contactMessage">Message</label>
          <textarea id="contactMessage" name="message" placeholder="Décrivez votre demande..." required></textarea>
        </div>
        <button type="submit" class="btn-submit" id="btnSubmit">Envoyer</button>
        <div class="form-success" id="formSuccess">Message envoyé avec succès ! Nous vous répondrons sous 24h.</div>
        <div class="form-error" id="formError"></div>
      </form>
    </div>

    <div class="contact-info-section">
      <h2>Autres moyens de contact</h2>

      <div class="info-card">
        <div class="icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <h3>Email</h3>
          <p><a href="mailto:aivancepro@gmail.com">aivancepro@gmail.com</a></p>
        </div>
      </div>

      <div class="info-card">
        <div class="icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div>
          <h3>Forum communautaire</h3>
          <p>Posez vos questions et échangez avec la communauté sur le <a href="/forum/">forum</a>.</p>
        </div>
      </div>

      <div class="info-card">
        <div class="icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div>
          <h3>FAQ & Support</h3>
          <p>Consultez notre <a href="/support/">centre d'assistance</a> pour les questions fréquentes.</p>
        </div>
      </div>

      <div class="info-card">
        <div class="icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/></svg>
        </div>
        <div>
          <h3>Réseaux sociaux</h3>
          <p>Suivez-nous pour les dernières actus et conseils fitness.</p>
          <div class="social-links">
            <a href="https://instagram.com/aivancepro" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
            <a href="https://tiktok.com/@aivancepro" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 3 15.57 6.33 6.33 0 0 0 9.37 22a6.33 6.33 0 0 0 6.38-6.22V9.4a8.16 8.16 0 0 0 3.84.96V7.1a4.85 4.85 0 0 1-1-.41z"/></svg></a>
            <a href="https://x.com/aivancepro" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
            <a href="https://youtube.com/@aivancepro" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 0 0 .5 6.19 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.81 3.02 3.02 0 0 0 2.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.81zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg></a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
  document.getElementById('contactForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    var btn = document.getElementById('btnSubmit');
    var successEl = document.getElementById('formSuccess');
    var errorEl = document.getElementById('formError');
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    var form = document.getElementById('contactForm');
    var formData = new FormData(form);

    btn.disabled = true;
    btn.textContent = 'Envoi...';

    try {
      var res = await fetch('https://formsubmit.co/ajax/aivancepro@gmail.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          name: formData.get('name'),
          email: formData.get('email'),
          subject: formData.get('subject'),
          message: formData.get('message')
        })
      });
      if (!res.ok) throw new Error('Erreur serveur');
      successEl.style.display = '';
      form.reset();
    } catch(err) {
      errorEl.textContent = 'Erreur lors de l\'envoi. Essayez par email : aivancepro@gmail.com';
      errorEl.style.display = '';
    }
    btn.disabled = false;
    btn.textContent = 'Envoyer';
  });
  </script>
</BaseLayout>
