  "Avancé": { bg: "rgba(239, 68, 68, 0.1)", color: "#EF4444" },
};

const totalCount = exercises.length;
---

<BaseLayout
  lang="fr"
  title={`Bibliothèque d'exercices - ${totalCount} exercices de musculation - AIVancePro`}
  description={`Découvrez notre bibliothèque de ${totalCount} exercices de musculation et fitness. Filtrez par groupe musculaire et trouvez l'exercice parfait.`}
  canonical="https://aivancepro.fr/exercices/"
  alternates={{ fr: 'https://aivancepro.fr/exercices/', en: 'https://aivancepro.fr/en/exercises/', de: 'https://aivancepro.fr/de/uebungen/' }}
>
  <Fragment slot="head">
    <style>
        .page-header { padding: 9rem 2rem 2rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); }
        .section-label { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); margin-bottom: 0.75rem; }
        .page-header h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; }
        .page-header p { color: var(--gray-500); font-size: 1.1rem; max-width: 550px; margin: 0 auto; }

        .filter-bar { max-width: 1100px; margin: 2rem auto 0; display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; padding: 0 2rem; }
        .filter-btn { padding: 0.5rem 1.1rem; border-radius: 50px; border: 1px solid var(--border); background: var(--bg-card); color: var(--gray-500); font-size: 0.85rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; }
        .filter-btn:hover, .filter-btn.active { background: var(--blue); color: var(--white); border-color: var(--blue); }

        .search-bar { max-width: 500px; margin: 1.5rem auto 0; padding: 0 2rem; }
        .search-input { width: 100%; padding: 0.7rem 1.25rem; border-radius: 12px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text); font-size: 0.9rem; font-family: inherit; outline: none; transition: border-color 0.2s; }
        .search-input::placeholder { color: var(--gray-400); }
        .search-input:focus { border-color: var(--blue); }

        .exercises-grid { max-width: 1100px; margin: 0 auto; padding: 2rem 2rem 4rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }

        .exercise-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; gap: 0.6rem; }
        .exercise-card:hover { border-color: rgba(37,99,235,0.25); transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
        .exercise-card h3 { font-size: 0.95rem; font-weight: 700; line-height: 1.3; }
        .exercise-card .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }
        .exercise-card .tag { padding: 0.15rem 0.55rem; border-radius: 50px; font-size: 0.65rem; font-weight: 600; white-space: nowrap; }
        .tag-muscle { background: rgba(37,99,235,0.1); color: var(--blue); }
        .tag-equipment { background: rgba(147,51,234,0.1); color: var(--purple); }
        .tag-difficulty { font-size: 0.6rem; font-weight: 700; }

        .exercises-count { text-align: center; padding: 1rem 2rem 0; color: var(--gray-400); font-size: 0.85rem; }

        .cta-section { padding: 5rem 2rem; text-align: center; background: var(--bg-alt); }
        .cta-section h2 { font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem; }
        .cta-section p { color: var(--gray-500); font-size: 1rem; max-width: 480px; margin: 0 auto 2rem; }
        .btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: linear-gradient(135deg, var(--blue), var(--purple)); color: var(--white); text-decoration: none; font-size: 1rem; font-weight: 600; padding: 0.875rem 2rem; border-radius: 12px; transition: opacity 0.2s, transform 0.2s; box-shadow: 0 4px 15px rgba(37,99,235,0.3); }
        .btn-primary:hover { opacity: 0.92; transform: translateY(-2px); }

        .no-results { text-align: center; padding: 3rem 2rem; color: var(--gray-400); font-size: 1rem; display: none; }

        @media (max-width: 1024px) { .exercises-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 768px) {
            .page-header { padding: 7rem 1.5rem 2rem; }
            .page-header h1 { font-size: 2rem; }
            .exercises-grid { grid-template-columns: 1fr; }
        }
    </style>
  </Fragment>

    <header class="page-header">
        <div class="section-label">Exercices</div>
        <h1>Biblioth&egrave;que d'exercices</h1>
        <p>{totalCount} exercices avec instructions d&eacute;taill&eacute;es. Filtrez par groupe musculaire pour trouver l'exercice qu'il vous faut.</p>
    </header>

    <div class="filter-bar">
        <button class="filter-btn active" data-filter="all">Tous</button>
        <button class="filter-btn" data-filter="pectoraux">Pectoraux</button>
        <button class="filter-btn" data-filter="dos">Dos</button>
        <button class="filter-btn" data-filter="epaules">&Eacute;paules</button>
        <button class="filter-btn" data-filter="biceps">Biceps</button>
        <button class="filter-btn" data-filter="triceps">Triceps</button>
        <button class="filter-btn" data-filter="jambes">Jambes</button>
        <button class="filter-btn" data-filter="fessiers">Fessiers</button>
        <button class="filter-btn" data-filter="abdos">Abdos</button>
        <button class="filter-btn" data-filter="avant-bras">Avant-bras</button>
        <button class="filter-btn" data-filter="fonctionnel">Fonctionnel</button>
    </div>

    <div class="search-bar">
        <input type="text" class="search-input" id="search" placeholder="Rechercher un exercice..." autocomplete="off" />
    </div>

    <div class="exercises-count"><span id="count">{totalCount}</span> exercices affich&eacute;s</div>

    <div class="no-results" id="no-results">Aucun exercice trouv&eacute;.</div>

    <section class="exercises-grid" id="grid">
        {exercises.map((ex) => {
            const dc = difficultyColors[ex.difficulty] || { bg: "rgba(100,100,100,0.1)", color: "#888" };
            return (
                <div class="exercise-card" data-muscle={ex.category} data-name={ex.name.toLowerCase()}>
                    <h3>{ex.name}</h3>
                    <div class="tags">
                        <span class="tag tag-muscle">{ex.muscle}</span>
                        <span class="tag tag-equipment">{ex.equipment}</span>
                        <span class="tag tag-difficulty" style={`background:${dc.bg};color:${dc.color}`}>{ex.difficulty}</span>
                    </div>
                </div>
            );
        })}
    </section>

    <section class="cta-section">
        <h2>{totalCount} exercices dans votre poche</h2>
        <p>T&eacute;l&eacute;chargez AIVancePro pour acc&eacute;der &agrave; tous les exercices avec vid&eacute;os, instructions et int&eacute;gration directe dans vos s&eacute;ances.</p>
        <a href="https://apps.apple.com/fr/app/aivancepro/id6756116760" class="btn-primary" target="_blank" rel="noopener">T&eacute;l&eacute;charger gratuitement</a>
    </section>

    <script is:inline>
        (function() {
            var currentFilter = 'all';
            var searchQuery = '';
            var countEl = document.getElementById('count');
            var noResults = document.getElementById('no-results');
            var grid = document.getElementById('grid');

            function update() {
                var cards = document.querySelectorAll('.exercise-card');
                var count = 0;
                cards.forEach(function(card) {
                    var matchFilter = currentFilter === 'all' || card.dataset.muscle === currentFilter;
                    var matchSearch = !searchQuery || card.dataset.name.indexOf(searchQuery) !== -1;
                    if (matchFilter && matchSearch) {
                        card.style.display = '';
                        count++;
                    } else {
                        card.style.display = 'none';
                    }
                });
                countEl.textContent = count;
                noResults.style.display = count === 0 ? 'block' : 'none';
                grid.style.display = count === 0 ? 'none' : '';
            }

            document.querySelectorAll('.filter-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    currentFilter = btn.dataset.filter;
                    update();
                });
            });

            document.getElementById('search').addEventListener('input', function(e) {
                searchQuery = e.target.value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                update();
            });
        })();
    </script>
</BaseLayout>
