---
import BaseLayout from '../../layouts/BaseLayout.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://aivancepro.fr/about/#alexandre-saraiva",
    "name": "Alexandre Saraiva",
    "jobTitle": "Founder & Developer",
    "url": "https://aivancepro.fr/en/about/",
    "image": "https://aivancepro.fr/assets/og-image.png",
    "description": "Founder of AIVancePro, aerospace engineer passionate about strength training. Creator of an AI-powered fitness coaching app.",
    "sameAs": [
      "https://www.instagram.com/aivancepro/",
      "https://www.tiktok.com/@aivancepro",
      "https://x.com/AIVancePro",
      "https://www.youtube.com/channel/UC8MGuOS22H-jXfe8Haqw8LA",
      "https://www.linkedin.com/company/aivancepro",
      "https://www.reddit.com/user/AIVancePro"
    ],
    "knowsAbout": [
      "strength training",
      "fitness coaching",
      "artificial intelligence",
      "sports nutrition",
      "workout programming",
      "muscle hypertrophy"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "AS Corporation"
    },
    "founder": {
      "@type": "Organization",
      "name": "AIVancePro",
      "url": "https://aivancepro.fr"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://aivancepro.fr/#organization",
    "name": "AIVancePro",
    "url": "https://aivancepro.fr",
    "logo": "https://aivancepro.fr/assets/logo-512.png",
    "description": "AI-powered fitness coaching app. Personalized workout programs, progress tracking, and nutrition guidance.",
    "founder": {
      "@type": "Person",
      "name": "Alexandre Saraiva",
      "@id": "https://aivancepro.fr/about/#alexandre-saraiva"
    },
    "sameAs": [
      "https://www.instagram.com/aivancepro/",
      "https://www.tiktok.com/@aivancepro",
      "https://x.com/AIVancePro",
      "https://www.youtube.com/channel/UC8MGuOS22H-jXfe8Haqw8LA",
      "https://www.linkedin.com/company/aivancepro",
      "https://www.reddit.com/user/AIVancePro"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aivancepro.fr/en/" },
      { "@type": "ListItem", "position": 2, "name": "About", "item": "https://aivancepro.fr/en/about/" }
    ]
  }
];
---

<BaseLayout
  lang="en"
  title="About Alexandre Saraiva - Founder of AIVancePro"
  description="Meet Alexandre Saraiva, founder of AIVancePro. Passionate about strength training and AI, he builds smart, personalized fitness coaching tools."
  canonical="https://aivancepro.fr/en/about/"
  alternates={{ fr: 'https://aivancepro.fr/about/', en: 'https://aivancepro.fr/en/about/', de: 'https://aivancepro.fr/de/about/' }}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <style>
      .page-header { padding: 9rem 2rem 3rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); }
      .section-label { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); margin-bottom: 0.75rem; }
      .page-header h1 { font-size: 2.8rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; color: var(--gray-900); }
      .page-header p { color: var(--gray-500); font-size: 1.1rem; max-width: 600px; margin: 0 auto; line-height: 1.7; }

      .about-content { max-width: 800px; margin: 0 auto; padding: 3rem 2rem 4rem; }

      .author-card { display: flex; gap: 2rem; align-items: flex-start; background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 20px; padding: 2.5rem; margin-bottom: 3rem; }
      .author-avatar { width: 120px; height: 120px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--purple)); display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #fff; font-size: 2.5rem; font-weight: 800; }
      .author-info h2 { font-size: 1.5rem; font-weight: 800; color: var(--gray-900); margin-bottom: 0.25rem; }
      .author-role { color: var(--blue); font-weight: 600; font-size: 0.95rem; margin-bottom: 0.75rem; }
      .author-bio { color: var(--gray-600); font-size: 0.95rem; line-height: 1.7; text-align: justify; }
      .author-socials { display: flex; gap: 0.75rem; margin-top: 1rem; }
      .author-socials a { color: var(--gray-400); transition: color 0.2s; }
      .author-socials a:hover { color: var(--blue); }
      .author-socials svg { width: 20px; height: 20px; }

      .about-section { margin-bottom: 2.5rem; }
      .about-section h2 { font-size: 1.4rem; font-weight: 700; color: var(--gray-900); margin-bottom: 1rem; }
      .about-section p { color: var(--gray-600); font-size: 0.95rem; line-height: 1.8; margin-bottom: 1rem; text-align: justify; }
      .about-section ul { padding-left: 1.5rem; margin-bottom: 1rem; }
      .about-section li { color: var(--gray-600); font-size: 0.95rem; line-height: 1.8; margin-bottom: 0.5rem; }
      .about-section strong { color: var(--gray-900); }

      .expertise-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
      .expertise-item { background: var(--bg-card); border: 1px solid var(--gray-200); border-radius: 12px; padding: 1.25rem; text-align: center; }
      .expertise-item .icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
      .expertise-item h3 { font-size: 0.95rem; font-weight: 700; color: var(--gray-900); margin-bottom: 0.25rem; }
      .expertise-item p { font-size: 0.85rem; color: var(--gray-500); margin: 0; }

      .cta-box { background: linear-gradient(135deg, var(--blue), var(--purple)); border-radius: 20px; padding: 2.5rem; text-align: center; color: #fff; margin-top: 3rem; }
      .cta-box h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.75rem; color: #fff; }
      .cta-box p { opacity: 0.9; margin-bottom: 1.5rem; font-size: 0.95rem; }
      .cta-box .btn { display: inline-block; background: #fff; color: var(--blue); font-weight: 700; padding: 0.75rem 2rem; border-radius: 12px; text-decoration: none; font-size: 0.95rem; transition: transform 0.2s; }
      .cta-box .btn:hover { transform: translateY(-2px); }

      .back { display: inline-block; margin-top: 2rem; color: var(--gray-500); text-decoration: none; font-size: 0.9rem; }
      .back:hover { color: var(--gray-900); }

      @media (max-width: 768px) {
        .page-header { padding: 7rem 1.5rem 2rem; }
        .page-header h1 { font-size: 2rem; }
        .author-card { flex-direction: column; align-items: center; text-align: center; }
        .author-socials { justify-content: center; }
      }
    </style>
  </Fragment>

  <header class="page-header">
    <div class="section-label">About</div>
    <h1>The story behind AIVancePro</h1>
    <p>A fitness coaching app born from a passion for strength training and artificial intelligence.</p>
  </header>

  <div class="about-content">
    <div class="author-card">
      <div class="author-avatar">AS</div>
      <div class="author-info">
        <h2>Alexandre Saraiva</h2>
        <div class="author-role">Founder &amp; Developer</div>
        <p class="author-bio">
          Aerospace engineer by trade and passionate lifter since the age of 15, I spent countless hours studying hypertrophy, strength, and training programming to optimize my progress. After hiring a personal coach to get truly tailored guidance, I realized that <strong>personalization is the key to results</strong> &mdash; but remains out of reach for most people. That&rsquo;s how the idea for AIVancePro was born.
        </p>
        <div class="author-socials">
          <a href="https://www.instagram.com/aivancepro/" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
          <a href="https://x.com/AIVancePro" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
          <a href="https://www.linkedin.com/company/aivancepro" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
          <a href="https://www.youtube.com/channel/UC8MGuOS22H-jXfe8Haqw8LA" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
        </div>
      </div>
    </div>

    <div class="about-section">
      <h2>My journey</h2>
      <p>
        I&rsquo;ve been training since I was 15. Throughout those years, I spent countless hours studying how hypertrophy and strength work, reading scientific research, and fine-tuning my programs to maximize progress.
      </p>
      <p>
        One day, I decided to hire a personal coach to get truly personalized guidance. I asked him dozens of questions, absorbed his advice, and that experience was a turning point. I understood that <strong>personalization is the key to progress</strong> &mdash; but it remained a luxury most people couldn&rsquo;t afford.
      </p>
      <p>
        Alongside my career as an aerospace engineer, I&rsquo;ve always been passionate about software development. The idea came naturally: <strong>combine my training experience and technical skills to build an AI coach accessible to everyone</strong>. That&rsquo;s how AIVancePro was born in 2025.
      </p>
    </div>

    <div class="about-section">
      <h2>Areas of expertise</h2>
      <div class="expertise-grid">
        <div class="expertise-item">
          <div class="icon">&#x1F4AA;</div>
          <h3>Strength training</h3>
          <p>Hypertrophy, strength, programming</p>
        </div>
        <div class="expertise-item">
          <div class="icon">&#x1F916;</div>
          <h3>Artificial intelligence</h3>
          <p>AI applied to fitness</p>
        </div>
        <div class="expertise-item">
          <div class="icon">&#x1F34E;</div>
          <h3>Sports nutrition</h3>
          <p>Macros, timing, supplements</p>
        </div>
        <div class="expertise-item">
          <div class="icon">&#x1F4CA;</div>
          <h3>Progress tracking</h3>
          <p>RPE, volume, periodization</p>
        </div>
      </div>
    </div>

    <div class="about-section">
      <h2>The AIVancePro mission</h2>
      <p>
        Our goal is simple: <strong>make smart fitness coaching accessible to everyone</strong>. Whether you're a beginner or advanced, AIVancePro adapts to your level, goals, and equipment to create programs that evolve with you.
      </p>
      <p>
        Every feature is built on recent scientific data and real user feedback. The app integrates progressive overload principles, RPE-based autoregulation, and periodization &mdash; the same methods used by professional coaches.
      </p>
    </div>

    <div class="about-section">
      <h2>Why trust me?</h2>
      <ul>
        <li><strong>8 years of training</strong> in strength training and fitness</li>
        <li><strong>Aerospace engineer</strong> &mdash; scientific rigor applied to fitness</li>
        <li><strong>Science-based</strong> &mdash; every feature is backed by published research</li>
        <li><strong>Active user</strong> &mdash; I train with AIVancePro daily</li>
        <li><strong>Active community</strong> &mdash; thousands of users on iOS and Android</li>
        <li><strong>Transparent</strong> &mdash; our <a href="/en/guides/">free guides</a> and <a href="/en/blog/">blog</a> share knowledge without barriers</li>
      </ul>
    </div>

    <div class="cta-box">
      <h2>Ready to train smarter?</h2>
      <p>Join thousands of users progressing with AIVancePro.</p>
      <a href="https://apps.apple.com/app/aivancepro/id6756116760" class="btn" target="_blank" rel="noopener">Download for free</a>
    </div>

    <a href="/en/" class="back">&larr; Back to home</a>
  </div>
</BaseLayout>
