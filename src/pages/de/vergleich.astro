---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="de"
  title="AIVancePro vs Konkurrenz - Fitness-App Vergleich"
  description="Vergleichen Sie AIVancePro mit Fitbod, Strong, JEFIT und Hevy. Entdecken Sie, warum AIVancePro der beste KI-Coach f&uuml;r Krafttraining ist."
  canonical="https://aivancepro.fr/de/vergleich/"
  alternates={{ fr: 'https://aivancepro.fr/comparaison/', en: 'https://aivancepro.fr/en/comparison/', de: 'https://aivancepro.fr/de/vergleich/' }}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: 'https://aivancepro.fr/de/' },
      { '@type': 'ListItem', position: 2, name: 'Vergleich', item: 'https://aivancepro.fr/de/vergleich/' }
    ]
  }}
>
  <Fragment slot="head">
    <style>
      .comp-hero {
          padding: 8rem 2rem 4rem;
          text-align: center;
          background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
      }
      .comp-hero .section-label {
          display: inline-flex;
          align-items: center;
          gap: 0.4rem;
          font-size: 0.8rem;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.08em;
          color: var(--blue);
          margin-bottom: 0.75rem;
      }
      .comp-hero h1 {
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: -0.03em;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .comp-hero p {
          font-size: 1.15rem;
          color: var(--gray-500);
          max-width: 600px;
          margin: 0 auto;
      }

      /* Comparison Table */
      .comp-table-section {
          padding: 3rem 2rem 5rem;
      }
      .comp-table-wrapper {
          max-width: 1100px;
          margin: 0 auto;
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          border-radius: 16px;
      }
      .comp-table {
          width: 100%;
          min-width: 700px;
          border-collapse: collapse;
          background: var(--bg-card);
          border-radius: 16px;
          overflow: hidden;
          box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
      }
      .comp-table th,
      .comp-table td {
          padding: 1rem 1.25rem;
          text-align: center;
          border-bottom: 1px solid var(--gray-100);
          font-size: 0.9rem;
      }
      .comp-table th {
          background: var(--bg-elevated);
          color: var(--text);
          font-weight: 700;
          font-size: 0.85rem;
          text-transform: uppercase;
          letter-spacing: 0.05em;
      }
      .comp-table th:first-child {
          text-align: left;
      }
      .comp-table td:first-child {
          text-align: left;
          font-weight: 500;
          color: var(--gray-700);
      }
      .comp-table tr:last-child td {
          border-bottom: none;
      }
      .comp-table .check {
          color: var(--green);
          font-size: 1.2rem;
      }
      .comp-table .cross {
          color: #ef4444;
          font-size: 1.1rem;
      }
      .comp-table .featured-col {
          background: rgba(74, 144, 217, 0.06);
      }
      .comp-table th.featured-col {
          background: rgba(74, 144, 217, 0.15);
          color: var(--blue);
      }
      .comp-table td.price-cell {
          font-weight: 700;
          color: var(--gray-900);
          font-size: 0.85rem;
      }
      .comp-table td.price-cell.featured-col {
          color: var(--blue);
      }

      /* Why AIVancePro */
      .why-section {
          padding: 5rem 2rem;
          background: var(--bg-card);
      }
      .why-section h2 {
          text-align: center;
          font-size: 2rem;
          font-weight: 800;
          margin-bottom: 1rem;
          color: var(--gray-900);
      }
      .why-section > p {
          text-align: center;
          color: var(--gray-500);
          max-width: 600px;
          margin: 0 auto 3rem;
          font-size: 1.05rem;
      }
      .why-grid {
          max-width: 1100px;
          margin: 0 auto;
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: 1.5rem;
      }
      .why-card {
          background: var(--bg-elevated);
          border: 1px solid var(--border-light);
          border-radius: 16px;
          padding: 2rem 1.5rem;
          text-align: center;
          transition: transform 0.2s, box-shadow 0.2s;
      }
      .why-card:hover {
          transform: translateY(-4px);
          box-shadow: 0 12px 40px rgba(0, 0, 0, 0.06);
      }
      .why-card .icon {
          width: 48px;
          height: 48px;
          margin: 0 auto 1rem;
          background: rgba(74, 144, 217, 0.1);
          border-radius: 12px;
          display: flex;
          align-items: center;
          justify-content: center;
      }
      .why-card .icon svg {
          width: 24px;
          height: 24px;
          color: var(--blue);
      }
      .why-card h3 {
          font-size: 1.05rem;
          font-weight: 700;
          color: var(--gray-900);
          margin-bottom: 0.5rem;
      }
      .why-card p {
          font-size: 0.88rem;
          color: var(--gray-500);
          line-height: 1.6;
      }

      /* CTA */
      .comp-cta {
          padding: 5rem 2rem;
          text-align: center;
      }
      .comp-cta h2 {
          font-size: 2.2rem;
          font-weight: 900;
          letter-spacing: -0.02em;
          color: var(--gray-900);
          margin-bottom: 0.75rem;
      }
      .comp-cta p {
          font-size: 1.05rem;
          color: var(--gray-500);
          max-width: 500px;
          margin: 0 auto 2rem;
      }

      @media (max-width: 768px) {
          .comp-hero { padding: 7rem 1.25rem 3rem; }
          .comp-hero h1 { font-size: 2.2rem; }
          .comp-hero p { font-size: 1rem; }
          .comp-table-section { padding: 2rem 1.25rem 4rem; }
          .comp-table { font-size: 0.8rem; min-width: 600px; }
          .comp-table th, .comp-table td { padding: 0.75rem 0.5rem; }
          .why-section { padding: 3rem 1.25rem; }
          .why-section h2 { font-size: 1.7rem; }
          .why-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
          .comp-cta { padding: 3rem 1.25rem; }
          .comp-cta h2 { font-size: 1.8rem; }
      }
      @media (max-width: 480px) {
          .comp-hero { padding: 6.5rem 1rem 2.5rem; }
          .comp-hero h1 { font-size: 1.8rem; }
          .comp-table-section { padding: 1.5rem 1rem 3rem; }
          .why-section { padding: 2.5rem 1rem; }
          .why-grid { grid-template-columns: 1fr; }
          .comp-cta { padding: 2.5rem 1rem; }
      }
    </style>
  </Fragment>

    <!-- Hero -->
    <section class="comp-hero">
        <div class="section-label">Vergleich</div>
        <h1>AIVancePro vs die <span class="gradient">Konkurrenz</span></h1>
        <p>Erfahren Sie, wie sich AIVancePro von anderen Fitness-Apps durch seinen KI-Coach und erweiterte Funktionen abhebt.</p>
    </section>

    <!-- Comparison Table -->
    <section class="comp-table-section">
        <div class="comp-table-wrapper">
        <table class="comp-table">
            <thead>
                <tr>
                    <th>Funktion</th>
                    <th class="featured-col">AIVancePro</th>
                    <th>Fitbod</th>
                    <th>Strong</th>
                    <th>JEFIT</th>
                    <th>Hevy</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>KI-Coach (Gespr&auml;ch)</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                </tr>
                <tr>
                    <td>KI-Trainingseinheiten</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                </tr>
                <tr>
                    <td>Intelligente Periodisierung</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                </tr>
                <tr>
                    <td>&Uuml;bertrainings-Analyse</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                </tr>
                <tr>
                    <td>Auto. Gewichtsanpassung</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                </tr>
                <tr>
                    <td>&Uuml;bungsalternativen</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                </tr>
                <tr>
                    <td>Trainingspl&auml;ne</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="check">&#10003;</td>
                    <td class="cross">&#10007;</td>
                </tr>
                <tr>
                    <td>Fortschrittsverfolgung</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                </tr>
                <tr>
                    <td>&Uuml;bungsbibliothek (240+)</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                </tr>
                <tr>
                    <td>Community &amp; Gruppen</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="cross">&#10007;</td>
                    <td class="cross">&#10007;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                </tr>
                <tr>
                    <td>Integrierter Timer</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                </tr>
                <tr>
                    <td>Offline-Modus</td>
                    <td class="check featured-col">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                    <td class="check">&#10003;</td>
                </tr>
                <tr>
                    <td>Preis</td>
                    <td class="price-cell featured-col">Kostenlos / 6,99&euro;/Monat</td>
                    <td class="price-cell">12,99$/Monat</td>
                    <td class="price-cell">4,99$/Monat</td>
                    <td class="price-cell">6,99$/Monat</td>
                    <td class="price-cell">9,99$/Monat</td>
                </tr>
            </tbody>
        </table>
        </div>
    </section>

    <!-- Why AIVancePro -->
    <section class="why-section">
        <h2>Warum <span class="gradient">AIVancePro</span> w&auml;hlen?</h2>
        <p>Was uns von anderen Fitness-Apps unterscheidet.</p>
        <div class="why-grid">
            <div class="why-card">
                <div class="icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3>KI-Coach im Gespr&auml;ch</h3>
                <p>Stellen Sie Fragen in nat&uuml;rlicher Sprache und erhalten Sie personalisierte Antworten. Keine andere App bietet einen wirklich interaktiven KI-Coach.</p>
            </div>
            <div class="why-card">
                <div class="icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
                </div>
                <h3>&Uuml;bertrainings-Erkennung</h3>
                <p>AIVancePro erkennt &Uuml;bertrainings-Signale und passt Ihre Empfehlungen an, um Verletzungen vorzubeugen.</p>
            </div>
            <div class="why-card">
                <div class="icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <h3>Community &amp; Challenges</h3>
                <p>Erstellen Sie Gruppen, starten Sie Challenges mit Freunden und bleiben Sie motiviert mit einer aktiven Community.</p>
            </div>
            <div class="why-card">
                <div class="icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <h3>Unschlagbarer Preis</h3>
                <p>Ein gro&szlig;z&uuml;giger kostenloser Plan und ein Pro-Abo f&uuml;r 6,99&euro;/Monat &mdash; g&uuml;nstiger als die meisten Konkurrenten.</p>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="comp-cta">
        <h2>Bereit f&uuml;r AIVancePro?</h2>
        <p>Laden Sie die App kostenlos herunter und erleben Sie den Unterschied eines echten KI-Coaches.</p>
        <div class="store-badges" style="justify-content:center;margin-top:1.5rem;">
            <a href="https://apps.apple.com/app/aivancepro/id6756116760" class="store-badge-link" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                <span class="store-badge-text"><span class="small">Verf&uuml;gbar im</span><span class="big">App Store</span></span>
            </a>
            <a href="https://play.google.com/store/apps/details?id=com.aivancepro.app" class="store-badge-link" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
                <span class="store-badge-text"><span class="small">Verf&uuml;gbar bei</span><span class="big">Google Play</span></span>
            </a>
        </div>
    </section>
</BaseLayout>
