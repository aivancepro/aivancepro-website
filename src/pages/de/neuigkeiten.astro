---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="de"
  title="Neuigkeiten - AIVancePro | Changelog und Updates"
  description="Entdecken Sie die neuesten Updates von AIVancePro. Neue Funktionen, Verbesserungen und Fehlerbehebungen f&uuml;r Ihren KI-Fitness-Coach."
  canonical="https://aivancepro.fr/de/neuigkeiten/"
  alternates={{ fr: 'https://aivancepro.fr/nouveautes/', en: 'https://aivancepro.fr/en/changelog/', de: 'https://aivancepro.fr/de/neuigkeiten/' }}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Startseite', item: 'https://aivancepro.fr/de/' },
      { '@type': 'ListItem', position: 2, name: 'Neuigkeiten', item: 'https://aivancepro.fr/de/neuigkeiten/' },
    ]
  }}
>
  <Fragment slot="head">
    <style>
      .changelog-hero {
          padding: 8rem 2rem 4rem;
          text-align: center;
          background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%);
      }
      .changelog-hero h1 {
          font-size: 3rem;
          font-weight: 900;
          letter-spacing: -0.03em;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .changelog-hero h1 .gradient {
          color: inherit;
      }
      .changelog-hero p {
          font-size: 1.15rem;
          color: var(--gray-500);
          max-width: 550px;
          margin: 0 auto;
      }
      .timeline-section {
          padding: 3rem 2rem 5rem;
          max-width: 800px;
          margin: 0 auto;
          position: relative;
      }
      .timeline-line {
          position: absolute;
          left: 28px;
          top: 3rem;
          bottom: 5rem;
          width: 2px;
          background: linear-gradient(180deg, var(--blue), var(--blue), var(--gray-200));
          border-radius: 2px;
      }
      .timeline-item {
          position: relative;
          padding-left: 68px;
          margin-bottom: 2.5rem;
      }
      .timeline-dot {
          position: absolute;
          left: 20px;
          top: 1.8rem;
          width: 18px;
          height: 18px;
          border-radius: 50%;
          background: var(--blue);
          border: 3px solid var(--bg);
          box-shadow: 0 0 0 3px rgba(74, 144, 217, 0.2);
          z-index: 1;
      }
      .timeline-card {
          background: var(--bg-card);
          border: 1px solid var(--gray-200);
          border-left: 3px solid var(--blue);
          border-radius: 16px;
          padding: 2rem;
          transition: transform 0.2s, box-shadow 0.2s;
      }
      .timeline-card:hover {
          transform: translateY(-2px);
          box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
      }
      .version-header {
          display: flex;
          align-items: center;
          gap: 1rem;
          margin-bottom: 1rem;
          flex-wrap: wrap;
      }
      .version-badge {
          background: var(--blue);
          color: var(--white);
          font-size: 0.8rem;
          font-weight: 700;
          padding: 0.3rem 0.8rem;
          border-radius: 50px;
          letter-spacing: 0.02em;
      }
      .version-date {
          font-size: 0.85rem;
          color: var(--gray-500);
          font-weight: 500;
      }
      .version-title {
          font-size: 1.3rem;
          font-weight: 800;
          color: var(--gray-900);
          margin-bottom: 1rem;
      }
      .changelog-list {
          list-style: none;
          display: flex;
          flex-direction: column;
          gap: 0.6rem;
      }
      .changelog-list li {
          display: flex;
          align-items: flex-start;
          gap: 0.6rem;
          font-size: 0.92rem;
          color: var(--gray-700);
          line-height: 1.5;
      }
      .changelog-list li svg {
          width: 18px;
          height: 18px;
          color: var(--blue);
          flex-shrink: 0;
          margin-top: 2px;
      }
      @media (max-width: 768px) {
          .changelog-hero h1 { font-size: 2.2rem; }
          .timeline-line { left: 18px; }
          .timeline-dot { left: 10px; top: 1.6rem; width: 16px; height: 16px; }
          .timeline-item { padding-left: 48px; }
          .timeline-card { padding: 1.5rem; }
          .version-title { font-size: 1.1rem; }
      }
    </style>
  </Fragment>

    <!-- Hero -->
    <section class="changelog-hero">
        <h1>Was ist <span class="gradient">neu</span></h1>
        <p>Entdecken Sie die neuesten Updates und Verbesserungen von AIVancePro.</p>
    </section>

    <!-- Timeline -->
    <section class="timeline-section">
        <div class="timeline-line"></div>

        <!-- Version 2.0 -->
        <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card">
                <div class="version-header">
                    <span class="version-badge">v2.0</span>
                    <span class="version-date">Februar 2026</span>
                </div>
                <div class="version-title">Komplette &Uuml;berarbeitung</div>
                <ul class="changelog-list">
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Vollst&auml;ndige Migration zu Supabase (Auth, DB, Echtzeit)</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Neuer KI-Coach mit OpenAI-Streaming</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Bild-Uploads &uuml;ber Cloudinary</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>OneSignal Push-Benachrichtigungen</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Echtzeit-Pr&auml;senzsystem</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Nutzer blockieren und melden</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Verbesserungen bei Benachrichtigungen und Benutzersuche</li>
                </ul>
            </div>
        </div>

        <!-- Version 1.5 -->
        <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card">
                <div class="version-header">
                    <span class="version-badge">v1.5</span>
                    <span class="version-date">Januar 2026</span>
                </div>
                <div class="version-title">Community &amp; Soziales</div>
                <ul class="changelog-list">
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Community-Seite mit Feed, Gruppen, Challenges</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Privates Nachrichtensystem</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Bestenlisten und Ranglisten</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Soziales Teilen von Leistungen</li>
                </ul>
            </div>
        </div>

        <!-- Version 1.0 -->
        <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-card">
                <div class="version-header">
                    <span class="version-badge">v1.0</span>
                    <span class="version-date">Dezember 2025</span>
                </div>
                <div class="version-title">Erstver&ouml;ffentlichung</div>
                <ul class="changelog-list">
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Erstver&ouml;ffentlichung f&uuml;r iOS &amp; Android</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>KI-Coach mit Konversation</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>&Uuml;ber 240 &Uuml;bungen mit Videos</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Fortschrittsverfolgung mit Diagrammen</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Trainingsvorlagen-System</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>Integrierter Pausentimer</li>
                    <li><svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>2 Pl&auml;ne: Kostenlos und Pro (6,99&euro;/Monat)</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="final-cta">
        <h2>Bereit zum Ausprobieren?</h2>
        <p>Laden Sie AIVancePro herunter und genie&szlig;en Sie alle Funktionen sofort.</p>
        <div class="store-badges" style="justify-content:center;margin-top:1.5rem;">
            <a href="https://apps.apple.com/app/aivancepro/id6756116760" class="store-badge-link" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                <span class="store-badge-text"><span class="small">Erhältlich im</span><span class="big">App Store</span></span>
            </a>
            <a href="https://play.google.com/store/apps/details?id=com.aivancepro.app" class="store-badge-link" target="_blank" rel="noopener">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
                <span class="store-badge-text"><span class="small">Erhältlich bei</span><span class="big">Google Play</span></span>
            </a>
        </div>
    </section>
</BaseLayout>
