---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../i18n.js';

const lang = 'fr';
const i = t[lang];
---

<BaseLayout
  lang={lang}
  title="Télécharger AIVancePro — Votre Coach Fitness IA"
  description="Téléchargez AIVancePro gratuitement sur iPhone et Android. Votre coach sportif IA personnel, disponible 24/7."
  canonical="https://aivancepro.fr/telecharger/"
  alternates={{ fr: 'https://aivancepro.fr/telecharger/', en: 'https://aivancepro.fr/en/download/', de: 'https://aivancepro.fr/de/herunterladen/' }}
>
  <Fragment slot="head">
    <style>
      .download-page {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 4rem 1.5rem;
      }
      .download-content {
        max-width: 540px;
      }
      .download-content h1 {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 1rem;
        color: var(--text-primary);
      }
      .download-content p {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin-bottom: 2.5rem;
        line-height: 1.6;
      }
      .download-content .store-badges {
        justify-content: center;
      }
      .download-loading {
        color: var(--text-secondary);
        font-size: 0.95rem;
        margin-top: 2rem;
      }
    </style>
  </Fragment>

  <section class="download-page">
    <div class="download-content" id="download-content" style="display:none">
      <h1>Téléchargez AIVancePro</h1>
      <p>Votre coach sportif IA personnel. Programmes d'entraînement sur mesure, suivi de progression et coaching intelligent — disponible 24/7.</p>
      <div class="store-badges">
        <a href={i.links.appStore} class="store-badge-link" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span class="store-badge-text"><span class="small">Disponible sur</span><span class="big">App Store</span></span>
        </a>
        <a href={i.links.playStore} class="store-badge-link" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
          <span class="store-badge-text"><span class="small">Disponible sur</span><span class="big">Google Play</span></span>
        </a>
      </div>
    </div>
    <p class="download-loading" id="download-loading">Redirection en cours…</p>
  </section>

  <script define:vars={{ appStoreUrl: i.links.appStore, playStoreUrl: i.links.playStore }}>
    const ua = navigator.userAgent;
    const isIOS = /iPhone|iPad|iPod/i.test(ua);
    const isAndroid = /Android/i.test(ua);

    if (isIOS) {
      window.location.replace(appStoreUrl);
    } else if (isAndroid) {
      window.location.replace(playStoreUrl);
    } else {
      document.getElementById('download-content').style.display = '';
      document.getElementById('download-loading').style.display = 'none';
    }
  </script>
</BaseLayout>
