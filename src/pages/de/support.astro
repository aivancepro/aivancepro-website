---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  lang="de"
  title="Support & Kontakt - AIVancePro"
  description="AIVancePro-Hilfezentrum. FAQ, Kontaktformular und technischer Support f&uuml;r die KI-Fitness-Coaching-App."
  canonical="https://aivancepro.fr/de/support/"
  alternates={{ fr: 'https://aivancepro.fr/support/', en: 'https://aivancepro.fr/en/support/', de: 'https://aivancepro.fr/de/support/' }}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "Support & Kontakt AIVancePro",
    "url": "https://aivancepro.fr/de/support/",
    "mainEntity": {
      "@type": "Organization",
      "name": "AIVancePro",
      "url": "https://aivancepro.fr",
      "email": "aivancepro@gmail.com",
      "contactPoint": { "@type": "ContactPoint", "contactType": "customer support", "availableLanguage": ["French", "English"] }
    }
  }}
>
  <Fragment slot="head">
    <style>
      .page-header { padding: 9rem 2rem 2rem; text-align: center; background: linear-gradient(180deg, var(--bg-card), var(--bg)); border-bottom: 1px solid var(--border); }
      .section-label { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--blue); margin-bottom: 0.75rem; }
      .page-header h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
      .page-header p { color: var(--text-secondary); font-size: 1.05rem; max-width: 550px; margin: 0 auto; }

      /* FAQ */
      .faq-section { max-width: 800px; margin: 0 auto; padding: 3rem 2rem 2rem; }
      .faq-section h2 { font-size: 1.4rem; font-weight: 800; margin-bottom: 1.5rem; }
      .faq-list { max-width: 700px; }
      .faq-item { border-bottom: 1px solid var(--border); }
      .faq-question { width: 100%; background: none; border: none; text-align: left; padding: 1.25rem 0; font-size: 1rem; font-weight: 600; color: var(--text); cursor: pointer; display: flex; justify-content: space-between; align-items: center; font-family: inherit; transition: color 0.2s; gap: 1rem; }
      .faq-question:hover { color: var(--blue); }
      .faq-question svg { width: 20px; height: 20px; color: var(--text-muted); transition: transform 0.3s; flex-shrink: 0; }
      .faq-item.open .faq-question svg { transform: rotate(180deg); }
      .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
      .faq-answer-inner { padding: 0 0 1.25rem; font-size: 0.92rem; color: var(--text-secondary); line-height: 1.7; }
      .faq-answer-inner ol { padding-left: 1.5rem; margin-top: 0.5rem; }
      .faq-answer-inner ol li { margin-bottom: 0.3rem; }
      .faq-item.open .faq-answer { max-height: 300px; }

      /* Legal links */
      .legal-links { max-width: 800px; margin: 0 auto; padding: 0 2rem 2rem; }
      .legal-links h2 { font-size: 1.2rem; font-weight: 700; margin-bottom: 0.75rem; }
      .legal-links ul { list-style: none; padding: 0; display: flex; gap: 1.5rem; }
      .legal-links a { color: var(--blue); text-decoration: none; font-size: 0.9rem; }
      .legal-links a:hover { text-decoration: underline; }

      /* Divider */
      .section-divider { max-width: 800px; margin: 1rem auto; padding: 0 2rem; }
      .section-divider hr { border: none; border-top: 1px solid var(--border); }

      /* Contact section */
      .contact-section { max-width: 900px; margin: 0 auto; padding: 2rem 2rem 5rem; }
      .contact-section > h2 { font-size: 1.4rem; font-weight: 800; margin-bottom: 1.5rem; text-align: center; }
      .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }

      .form-field { margin-bottom: 1.25rem; }
      .form-field label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; }
      .form-field input, .form-field textarea, .form-field select { width: 100%; padding: 0.7rem 0.9rem; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text); font-size: 0.9rem; font-family: inherit; outline: none; transition: border-color 0.2s; box-sizing: border-box; }
      .form-field input:focus, .form-field textarea:focus, .form-field select:focus { border-color: var(--blue); }
      .form-field textarea { resize: vertical; min-height: 120px; }
      .btn-submit { padding: 0.7rem 1.5rem; border-radius: 12px; border: none; background: var(--blue); color: #fff; font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 15px rgba(74, 144, 217, 0.3); }
      .btn-submit:hover { opacity: 0.92; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(74, 144, 217, 0.4); }
      .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
      .form-success { padding: 1rem 1.25rem; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2); border-radius: 10px; color: #10B981; font-size: 0.9rem; font-weight: 600; margin-bottom: 1.5rem; }
      .form-error { padding: 1rem 1.25rem; background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2); border-radius: 10px; color: #ef4444; font-size: 0.9rem; margin-top: 1rem; }

      .info-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem; margin-bottom: 1rem; display: flex; align-items: flex-start; gap: 1rem; }
      .info-card .icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(74,144,217,0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .info-card .icon svg { width: 20px; height: 20px; color: var(--blue); }
      .info-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.25rem; }
      .info-card p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; margin: 0; }
      .info-card a { color: var(--blue); text-decoration: none; }
      .info-card a:hover { text-decoration: underline; }

      .social-links { display: flex; gap: 0.75rem; margin-top: 0.75rem; align-items: center; }
      .social-links a { color: var(--text-muted); transition: color 0.2s; text-decoration: none; display: flex; }
      .social-links a:hover { color: var(--blue); }
      .social-links svg { width: 20px; height: 20px; }

      @media (max-width: 768px) {
        .page-header { padding: 7rem 1.5rem 2rem; }
        .page-header h1 { font-size: 2rem; }
        .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
      }
    </style>
  </Fragment>

  <header class="page-header">
    <div class="section-label">Support & Kontakt</div>
    <h1>Wie k&ouml;nnen wir Ihnen helfen?</h1>
    <p>Sehen Sie unsere FAQ oder senden Sie uns eine Nachricht. Wir antworten innerhalb von 24 Stunden.</p>
  </header>

  <!-- FAQ -->
  <section class="faq-section">
    <h2>H&auml;ufig gestellte Fragen</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Die App startet nicht oder zeigt einen leeren Bildschirm
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">
          <ol>
            <li>Stellen Sie sicher, dass Sie die neueste Version aus dem App Store oder Google Play installiert haben.</li>
            <li>&Uuml;berpr&uuml;fen Sie Ihre Internetverbindung (WLAN oder mobile Daten).</li>
            <li>Erzwingen Sie das Schlie&szlig;en der App und starten Sie sie neu.</li>
          </ol>
        </div></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Wie l&ouml;sche ich mein Konto und meine Daten?
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">
          Sie k&ouml;nnen Ihr Konto direkt in den Einstellungen der App l&ouml;schen oder uns unter <a href="mailto:aivancepro@gmail.com">aivancepro@gmail.com</a> kontaktieren.
        </div></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Ist die App kostenlos?
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">
          Ja, AIVancePro bietet eine kostenlose Version mit den wesentlichen Funktionen. Das Pro-Abonnement f&uuml;r 6,99&euro;/Monat schaltet erweiterte Funktionen frei, wie 250 KI-Nachrichten, Trainingspl&auml;ne bis zu 12 Wochen und erweiterte Analysen. Sehen Sie unsere <a href="/de/preise/">Preise</a>.
        </div></div>
      </div>
      <div class="faq-item">
        <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
          Wie k&uuml;ndige ich mein Abonnement?
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">
          Abonnements werden &uuml;ber den App Store (iOS) oder Google Play (Android) verwaltet. Um zu k&uuml;ndigen, gehen Sie zu den Einstellungen Ihres Stores > Abonnements > AIVancePro > K&uuml;ndigen.
        </div></div>
      </div>
    </div>
  </section>

  <!-- Legal -->
  <div class="legal-links">
    <h2>Rechtliche Hinweise</h2>
    <ul>
      <li><a href="/de/datenschutz/">Datenschutzerkl&auml;rung</a></li>
      <li><a href="/de/agb/">Allgemeine Gesch&auml;ftsbedingungen</a></li>
    </ul>
  </div>

  <div class="section-divider"><hr></div>

  <!-- Contact -->
  <section class="contact-section" id="contact">
    <h2>Kontaktieren Sie uns</h2>
    <div class="contact-grid">
      <div>
        <div class="form-success" id="formSuccess" style="display:none">Nachricht erfolgreich gesendet! Wir antworten innerhalb von 24 Stunden.</div>
        <div class="form-error" id="formError" style="display:none"></div>
        <form id="contactForm">
          <div class="form-field">
            <label for="contactName">Name</label>
            <input type="text" id="contactName" name="name" placeholder="Ihr Name" required>
          </div>
          <div class="form-field">
            <label for="contactEmail">E-Mail</label>
            <input type="email" id="contactEmail" name="email" placeholder="ihre@email.com" required>
          </div>
          <div class="form-field">
            <label for="contactSubject">Betreff</label>
            <select id="contactSubject" name="subject">
              <option value="Allgemeine Frage">Allgemeine Frage</option>
              <option value="Fehler melden">Fehler melden</option>
              <option value="Vorschlag">Vorschlag</option>
              <option value="Partnerschaft">Partnerschaft</option>
              <option value="Sonstiges">Sonstiges</option>
            </select>
          </div>
          <div class="form-field">
            <label for="contactMessage">Nachricht</label>
            <textarea id="contactMessage" name="message" placeholder="Beschreiben Sie Ihre Anfrage..." required></textarea>
          </div>
          <button type="submit" class="btn-submit">Senden</button>
        </form>
      </div>

      <div>
        <div class="info-card">
          <div class="icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h3>E-Mail</h3>
            <p><a href="mailto:aivancepro@gmail.com">aivancepro@gmail.com</a></p>
          </div>
        </div>

        <div class="info-card">
          <div class="icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <div>
            <h3>Community-Forum</h3>
            <p>Stellen Sie Ihre Fragen im <a href="/forum/?lang=de">Forum</a>.</p>
          </div>
        </div>

        <div class="info-card">
          <div class="icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/></svg>
          </div>
          <div>
            <h3>Soziale Netzwerke</h3>
            <p>Folgen Sie uns f&uuml;r Fitness-News.</p>
            <div class="social-links">
              <a href="https://www.instagram.com/aivancepro/" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
              <a href="https://www.tiktok.com/@aivancepro" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13.2a8.16 8.16 0 005.58 2.17V12a4.83 4.83 0 01-3.77-1.54V6.69h3.77z"/></svg></a>
              <a href="https://x.com/AIVancePro" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
              <a href="https://www.youtube.com/channel/UC8MGuOS22H-jXfe8Haqw8LA" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
              <a href="https://www.linkedin.com/company/aivancepro" target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
              <a href="https://www.reddit.com/user/AIVancePro" target="_blank" rel="noopener" aria-label="Reddit"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 01-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 01.042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 014.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 01.14-.197.35.35 0 01.238-.042l2.906.617a1.214 1.214 0 011.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 00-.231.094.33.33 0 000 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 000-.462.342.342 0 00-.462 0c-.545.533-1.684.73-2.512.73-.828 0-1.953-.21-2.498-.73a.327.327 0 00-.219-.095z"/></svg></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
  document.getElementById('contactForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = this.querySelector('.btn-submit');
    var successEl = document.getElementById('formSuccess');
    var errorEl = document.getElementById('formError');
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    var name = document.getElementById('contactName').value.trim();
    var email = document.getElementById('contactEmail').value.trim();
    var subject = document.getElementById('contactSubject').value;
    var message = document.getElementById('contactMessage').value.trim();

    if (!name || !email || !message) return;

    btn.disabled = true;
    btn.textContent = 'Senden...';

    var payload = JSON.stringify({ name: name, email: email, subject: subject, message: message });

    // Send email via Formsubmit
    fetch('https://formsubmit.co/ajax/aivancepro@gmail.com', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: payload
    }).catch(function() {});

    // Save + push notification via Edge Function
    fetch('https://vzmtvhcvyqzkmestdbko.supabase.co/functions/v1/contactNotify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: payload
    })
    .then(function(res) {
      if (!res.ok) throw new Error('err');
      successEl.style.display = 'block';
      successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      document.getElementById('contactForm').reset();
    })
    .catch(function() {
      errorEl.textContent = 'Fehler. Versuchen Sie es per E-Mail: aivancepro@gmail.com';
      errorEl.style.display = 'block';
    })
    .finally(function() {
      btn.disabled = false;
      btn.textContent = 'Senden';
    });
  });
  </script>
</BaseLayout>
