---
import BaseLayout from './BaseLayout.astro';
import { t } from '../i18n.js';

const {
  lang = 'fr',
  title,
  description,
  canonical,
  alternates = {},
  tag,
  category,
  date,
  dateModified,
  readTime,
  backLink,
  backLabel,
  jsonLd,
  image,
  author,
  relatedArticles = [],
} = Astro.props;

// Compute optimized image paths for <picture> element
const imageBase = image ? image.replace(/\.(png|jpe?g|webp)$/i, '') : '';
const imageAvif = imageBase ? `${imageBase}.avif` : '';
const imageWebp = imageBase ? `${imageBase}.webp` : '';
const imageSmallAvif = imageBase ? `${imageBase}-small.avif` : '';
const imageSmallWebp = imageBase ? `${imageBase}-small.webp` : '';

const i = t[lang];
const ctaLabels = {
  fr: { title: 'Essayez le coaching IA gratuitement', text: 'Téléchargez AIVancePro et découvrez un entraînement vraiment personnalisé.', btn: 'Télécharger gratuitement' },
  en: { title: 'Try AI coaching for free', text: 'Download AIVancePro and discover truly personalized training.', btn: 'Download for free' },
  de: { title: 'KI-Coaching kostenlos testen', text: 'Laden Sie AIVancePro herunter und entdecken Sie wirklich personalisiertes Training.', btn: 'Kostenlos herunterladen' },
};
const cta = ctaLabels[lang];

const relatedLabels = {
  fr: 'Articles similaires',
  en: 'Related articles',
  de: 'Ähnliche Artikel',
};

const tocLabels = {
  fr: 'Sommaire',
  en: 'Table of contents',
  de: 'Inhaltsverzeichnis',
};

const blogPrefixes = { fr: '/blog/', en: '/en/blog/', de: '/de/blog/' };
const guidePrefixes = { fr: '/guides/', en: '/en/guides/', de: '/de/ratgeber/' };
---

<BaseLayout
  lang={lang}
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  ogImage={image || 'https://aivancepro.fr/assets/og-image.png'}
  alternates={alternates}
  jsonLd={jsonLd}
  articleDate={date}
  articleModified={dateModified || date}
  articleAuthor={author || 'Theo Stanmore'}
  articleSection={tag}
  articleTag={category}
>
  <Fragment slot="head">
    {image && image !== '/og-image.png' && (
      <link rel="preload" as="image" type="image/avif" imagesrcset={`${imageSmallAvif} 400w, ${imageAvif} 750w`} imagesizes="(max-width: 768px) calc(100vw - 4rem), 750px" />
    )}
    <style is:global>
      .reading-progress { position: fixed; top: 0; left: 0; height: 3px; background: var(--blue); z-index: 9999; width: 100%; transform-origin: left; transform: scaleX(0); will-change: transform; }
      .article-header { padding: 6rem 2rem 1.5rem; text-align: center; background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg) 100%); border-bottom: 1px solid var(--border); }
      .tag { display: inline-block; padding: 0.25rem 0.75rem; background: rgba(74,144,217,0.1); border-radius: 50px; font-size: 0.75rem; color: var(--blue); font-weight: 600; margin-bottom: 1rem; }
      .article-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; line-height: 1.2; color: var(--text); letter-spacing: -0.02em; text-wrap: balance; }
      .meta { color: var(--text-secondary); margin-bottom: 0; font-size: 0.9rem; }
      .breadcrumb { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1rem; }
      .breadcrumb a { color: var(--text-secondary); text-decoration: none; }
      .breadcrumb a:hover { color: var(--blue); }
      .article-hero-image { max-width: 820px; margin: 2rem auto 0; padding: 0 2rem; }
      .article-hero-image img { width: 100%; height: auto; border-radius: 12px; display: block; }
      .article-content { max-width: 820px; margin: 0 auto; padding: 3rem 2rem 4rem; }
      .article-content h2 { font-size: 1.5rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 1rem; color: var(--text); text-wrap: balance; }
      .article-content h3 { font-size: 1.15rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; color: var(--text); text-wrap: balance; }
      .article-content p { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 1.2rem; line-height: 1.8; text-align: justify; }
      .article-content ul, .article-content ol { padding-left: 1.5rem; margin-bottom: 1.2rem; }
      .article-content li { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0.5rem; text-align: justify; }
      .article-content strong { color: var(--text); }
      .article-content a { color: var(--blue); }
      .article-content .table-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; border-radius: 16px; margin-bottom: 1.5rem; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2); margin-left: -6rem; margin-right: -6rem; width: calc(100% + 12rem); }
      .article-content table { width: 100%; border-collapse: collapse; background: var(--bg-card); border-radius: 16px; overflow: hidden; }
      .article-content th { background: var(--bg-elevated); font-weight: 700; color: var(--text); text-align: center; padding: 0.7rem 0.65rem; border-bottom: 1px solid var(--border); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.03em; }
      .article-content th:first-child { text-align: left; }
      .article-content td { padding: 0.7rem 0.65rem; border-bottom: 1px solid var(--border); color: var(--text-secondary); font-size: 0.8rem; text-align: center; }
      .article-content td:first-child { text-align: left; font-weight: 500; color: var(--text); min-width: 100px; }
      .article-content tr:last-child td { border-bottom: none; }
      .article-content thead { position: sticky; top: 0; }
      .article-content h2 a, .article-content h3 a { color: inherit; text-decoration: none; }
      .article-content h2 a:hover, .article-content h3 a:hover { color: var(--blue); }
      .program-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; }
      .program-box h4 { color: var(--blue); font-size: 1rem; margin-bottom: 0.75rem; }
      .client-toc { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; }
      .client-toc summary { font-weight: 700; font-size: 1rem; color: var(--text); cursor: pointer; list-style: none; display: flex; align-items: center; gap: 0.5rem; }
      .client-toc summary::-webkit-details-marker { display: none; }
      .client-toc summary::before { content: ''; display: inline-block; width: 6px; height: 6px; border-right: 2px solid var(--text-secondary); border-bottom: 2px solid var(--text-secondary); transform: rotate(-45deg); transition: transform 0.2s; }
      .client-toc[open] summary::before { transform: rotate(45deg); }
      .client-toc ol { margin: 1rem 0 0; padding-left: 1.5rem; }
      .client-toc li { margin-bottom: 0.4rem; font-size: 0.9rem; }
      .client-toc a { color: var(--text-secondary); text-decoration: none; }
      .client-toc a:hover { color: var(--blue); }
      .related-articles { max-width: 820px; margin: 0 auto; padding: 0 2rem 3rem; }
      .related-articles h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--text); }
      .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
      .related-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; text-decoration: none; color: var(--text); transition: border-color 0.2s, transform 0.2s; display: flex; flex-direction: column; }
      .related-card:hover { border-color: var(--blue); transform: translateY(-2px); }
      .related-card .related-img { width: 100%; height: 140px; object-fit: cover; display: block; }
      .related-card .related-body { padding: 1rem 1.25rem 1.25rem; }
      .related-card .related-tag { display: inline-block; padding: 0.15rem 0.5rem; background: rgba(74,144,217,0.1); border-radius: 50px; font-size: 0.65rem; color: var(--blue); font-weight: 600; margin-bottom: 0.5rem; }
      .related-card h4 { font-size: 0.9rem; font-weight: 600; line-height: 1.4; margin-bottom: 0.4rem; }
      .related-card .related-meta { font-size: 0.75rem; color: var(--text-muted); }
      .article-newsletter { max-width: 820px; margin: 0 auto; padding: 0 2rem 3rem; }
      .article-newsletter-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 2.5rem; text-align: center; }
      .article-newsletter-card h3 { font-size: 1.4rem; font-weight: 800; color: var(--text); margin: 0 0 0.5rem; }
      .article-newsletter-card .nl-text { color: var(--text-secondary); font-size: 0.95rem; margin: 0 0 1.5rem; }
      .article-newsletter-card .newsletter-input-wrap { max-width: 420px; margin: 0 auto; display: flex; gap: 0; border-radius: 10px; overflow: hidden; border: 1px solid var(--border); background: var(--bg); transition: border-color 0.2s; }
      .article-newsletter-card .newsletter-input-wrap:focus-within { border-color: var(--blue); }
      .article-newsletter-card .newsletter-input-wrap input { flex: 1; padding: 0.75rem 1rem; background: transparent; border: none; color: var(--text); font-size: 0.9rem; outline: none; }
      .article-newsletter-card .newsletter-input-wrap button { padding: 0.75rem 1.25rem; background: var(--blue); color: #fff; border: none; font-weight: 600; font-size: 0.85rem; cursor: pointer; white-space: nowrap; transition: background 0.2s; }
      .article-newsletter-card .newsletter-input-wrap button:hover { background: var(--blue-hover, #1d4ed8); }
      .article-newsletter-card .newsletter-msg { font-size: 0.85rem; margin-top: 0.75rem; }
      .article-newsletter-card .newsletter-msg.success { color: var(--green, #22c55e); }
      .article-newsletter-card .newsletter-msg.error { color: var(--red, #ef4444); }
      .final-cta { padding: 5rem 2rem; text-align: center; background: var(--bg-card); border-top: 1px solid var(--border); }
      .final-cta h3 { font-size: 2.2rem; font-weight: 800; margin-bottom: 1rem; margin-top: 0; color: var(--text); }
      .final-cta p { color: var(--text-secondary); font-size: 1.1rem; max-width: 500px; margin: 0 auto 2.5rem; }
      .back { display: inline-block; margin-top: 2rem; color: var(--text-secondary); text-decoration: none; font-size: 0.9rem; }
      .back:hover { color: var(--text); }
      /* Share bar */
      .share-bar { display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.25rem; }
      .share-btn { display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 10px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-muted); cursor: pointer; transition: all 0.2s; text-decoration: none; }
      .share-btn:hover { border-color: var(--blue); transform: translateY(-2px); }
      .share-btn.share-x:hover { color: var(--text); }
      .share-btn.share-fb:hover { color: #1877F2; }
      .share-btn.share-li:hover { color: #0A66C2; }
      .share-btn.share-copy:hover { color: var(--blue); }
      .share-btn.share-copy.copied { color: #22c55e; border-color: #22c55e; }
      .share-btn svg { width: 18px; height: 18px; }
      @media (prefers-color-scheme: dark) { .share-btn.share-x:hover { color: #fff; } }
      .article-faq { margin-top: 2.5rem; }
      .article-faq h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 1rem; color: var(--text); text-transform: uppercase; letter-spacing: 0.02em; }
      .faq-list { display: flex; flex-direction: column; gap: 0; }
      .faq-item { border-bottom: 1px solid var(--border); }
      .faq-question { display: flex; justify-content: space-between; align-items: center; width: 100%; padding: 1.25rem 0; background: none; border: none; cursor: pointer; font-size: 1rem; font-weight: 500; color: var(--text-secondary); text-align: left; gap: 1rem; font-family: inherit; transition: color 0.2s; }
      .faq-question:hover { color: var(--text); }
      .faq-icon { position: relative; width: 24px; height: 24px; flex-shrink: 0; }
      .faq-icon::before, .faq-icon::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--text-secondary); border-radius: 1px; transition: transform 0.3s, opacity 0.3s; }
      .faq-icon::before { width: 16px; height: 2px; }
      .faq-icon::after { width: 2px; height: 16px; }
      .faq-item.open .faq-question { font-weight: 600; color: var(--text); }
      .faq-item.open .faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); opacity: 0; }
      .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
      .faq-answer-inner { padding: 0 0 1.5rem; font-size: 0.95rem; color: var(--text-secondary); line-height: 1.8; }
      .article-forum { max-width: 820px; margin: 0 auto; padding: 0 2rem 2rem; }
      .article-forum-card { display: flex; align-items: center; gap: 1rem; padding: 1.25rem 1.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; text-decoration: none; color: inherit; transition: border-color 0.2s, transform 0.2s; }
      .article-forum-card:hover { border-color: var(--blue); transform: translateY(-2px); }
      .article-forum-icon { width: 40px; height: 40px; border-radius: 10px; background: rgba(74,144,217,0.08); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
      .article-forum-icon svg { width: 20px; height: 20px; color: var(--blue); }
      .article-forum-text { flex: 1; }
      .article-forum-text strong { display: block; font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 0.15rem; }
      .article-forum-text span { font-size: 0.82rem; color: var(--text-secondary); }
      .article-forum-arrow { color: var(--text-muted); }
      .article-forum-arrow svg { width: 20px; height: 20px; }
      @media (max-width: 768px) {
        .article-header { padding: 4.5rem 1.5rem 1.5rem; }
        .article-header h1 { font-size: 1.8rem; }
        .related-grid { grid-template-columns: 1fr; }
        .article-content .table-wrapper { margin-left: -1.5rem; margin-right: -1.5rem; width: calc(100% + 3rem); border-radius: 0; }
        .article-content th, .article-content td { padding: 0.6rem 0.5rem; font-size: 0.75rem; }
      }
    </style>
  </Fragment>

  <div class="reading-progress" id="readingProgress"></div>

  <header class="article-header">
    <div class="breadcrumb-nav" role="navigation" aria-label="Breadcrumb">
      <a href={i.links.home}>{i.breadcrumb.home}</a>
      <span class="sep">/</span>
      {backLink && <a href={backLink}>{backLink.includes('guide') || backLink.includes('ratgeber') ? i.breadcrumb.guides : i.breadcrumb.blog}</a>}
      {backLink && <span class="sep">/</span>}
      <span class="current">{title}</span>
    </div>
    {tag && <span class="tag">{tag}</span>}
    <h1>{title}</h1>
    {date && <p class="meta">{date}{readTime ? ` · ${readTime}` : ''}</p>}
    <div class="share-bar" id="share-bar">
      <a class="share-btn share-x" id="share-x" href="#" target="_blank" rel="noopener" title="X / Twitter">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a class="share-btn share-fb" id="share-fb" href="#" target="_blank" rel="noopener" title="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a class="share-btn share-li" id="share-li" href="#" target="_blank" rel="noopener" title="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <button class="share-btn share-copy" id="share-copy" title="Copier le lien">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>
  </header>

  {image && image !== '/og-image.png' && (
    <div class="article-hero-image">
      <img src={image} alt={title} loading="eager" width="750" height="422" fetchpriority="high" decoding="async" />
    </div>
  )}

  <article class="article-content" id="articleContent">
    <div class="client-toc" id="clientToc" style="display:none">
      <details open>
        <summary>{tocLabels[lang]}</summary>
        <ol id="tocList"></ol>
      </details>
    </div>

    <slot />

    {backLink && <a href={backLink} class="back">&larr; {backLabel}</a>}

    <div class="share-buttons" data-title={title} data-url={canonical}>
      <span>{i.share.title}</span>
      <a class="share-btn" id="shareX" target="_blank" rel="noopener" aria-label="X/Twitter">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a class="share-btn" id="shareFB" target="_blank" rel="noopener" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a class="share-btn" id="shareLinkedIn" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <button class="share-btn" id="shareCopy" aria-label="Copy link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      </button>
    </div>
  </article>

  {relatedArticles.length > 0 && (
    <section class="related-articles">
      <h3>{relatedLabels[lang]}</h3>
      <div class="related-grid">
        {relatedArticles.map((rel: any) => {
          const prefix = backLink?.includes('guide') || backLink?.includes('ratgeber') ? guidePrefixes[lang] : blogPrefixes[lang];
          return (
            <a href={`${prefix}${rel.data.slug}/`} class="related-card">
              {rel.data.image && <img src={rel.data.image} alt="" class="related-img" loading="lazy" decoding="async" />}
              <div class="related-body">
                {rel.data.tag && <span class="related-tag">{rel.data.tag}</span>}
                <h4>{rel.data.title}</h4>
                <div class="related-meta">{rel.data.date}{rel.data.readTime ? ` · ${rel.data.readTime}` : ''}</div>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  {lang === 'fr' && (
    <section class="article-forum" id="articleForum" style="display:none">
      <a href="/forum/" class="article-forum-card" id="articleForumLink">
        <div class="article-forum-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div class="article-forum-text">
          <strong>Discuter de cet article sur le forum</strong>
          <span>Posez vos questions et échangez avec la communauté</span>
        </div>
        <div class="article-forum-arrow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </div>
      </a>
    </section>
  )}

  <script is:inline>
  (function() {
    // Share buttons
    var wrap = document.querySelector('.share-buttons');
    if (wrap) {
      var url = encodeURIComponent(wrap.dataset.url || window.location.href);
      var title = encodeURIComponent(wrap.dataset.title || document.title);
      var x = document.getElementById('shareX');
      var fb = document.getElementById('shareFB');
      var li = document.getElementById('shareLinkedIn');
      var cp = document.getElementById('shareCopy');
      if (x) x.href = 'https://x.com/intent/tweet?text=' + title + '&url=' + url;
      if (fb) fb.href = 'https://www.facebook.com/sharer/sharer.php?u=' + url;
      if (li) li.href = 'https://www.linkedin.com/sharing/share-offsite/?url=' + url;
      if (cp) cp.addEventListener('click', function() {
        navigator.clipboard.writeText(decodeURIComponent(url));
        cp.style.color = 'var(--green)';
        cp.style.borderColor = 'var(--green)';
        setTimeout(function() { cp.style.color = ''; cp.style.borderColor = ''; }, 2000);
      });
    }

    // Share buttons
    (function() {
      var url = encodeURIComponent(window.location.href);
      var title = encodeURIComponent(document.title);
      var xBtn = document.getElementById('share-x');
      var fbBtn = document.getElementById('share-fb');
      var liBtn = document.getElementById('share-li');
      var copyBtn = document.getElementById('share-copy');
      if (xBtn) xBtn.href = 'https://x.com/intent/tweet?text=' + title + '&url=' + url;
      if (fbBtn) fbBtn.href = 'https://www.facebook.com/sharer/sharer.php?u=' + url;
      if (liBtn) liBtn.href = 'https://www.linkedin.com/sharing/share-offsite/?url=' + url;
      if (copyBtn) copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(window.location.href).then(function() {
          copyBtn.classList.add('copied');
          setTimeout(function() { copyBtn.classList.remove('copied'); }, 2000);
        });
      });
    })();

    // Reading progress bar (GPU-accelerated with scaleX)
    var bar = document.getElementById('readingProgress');
    if (bar) {
      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            var h = document.documentElement.scrollHeight - window.innerHeight;
            var progress = h > 0 ? window.scrollY / h : 0;
            bar.style.transform = 'scaleX(' + Math.min(progress, 1) + ')';
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }

    // Wrap tables in .table-wrapper for styling
    document.querySelectorAll('.article-content table').forEach(function(table) {
      if (!table.parentElement.classList.contains('table-wrapper')) {
        var wrapper = document.createElement('div');
        wrapper.className = 'table-wrapper';
        table.parentNode.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      }
    });

    // Client-side ToC (fallback for articles without remark-toc)
    var content = document.getElementById('articleContent');
    var tocWrap = document.getElementById('clientToc');
    var tocList = document.getElementById('tocList');
    if (content && tocWrap && tocList) {
      var headings = content.querySelectorAll('h2[id]');
      if (headings.length >= 4) {
        headings.forEach(function(h) {
          var li = document.createElement('li');
          var a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          li.appendChild(a);
          tocList.appendChild(li);
        });
        tocWrap.style.display = '';
      }
    }
    // FAQ accordion
    var faqH2 = null;
    var faqKeywords = ['faq', 'questions fréquentes', 'frequently asked questions', 'häufig gestellte fragen'];
    content && content.querySelectorAll('h2').forEach(function(h) {
      var txt = h.textContent.trim().toLowerCase();
      for (var k = 0; k < faqKeywords.length; k++) {
        if (txt === faqKeywords[k] || txt.indexOf(faqKeywords[k]) === 0) { faqH2 = h; break; }
      }
    });
    if (faqH2) {
      var faqSection = document.createElement('div');
      faqSection.className = 'article-faq';
      var faqTitle = document.createElement('h2');
      faqTitle.textContent = faqH2.textContent;
      faqSection.appendChild(faqTitle);
      var faqListEl = document.createElement('div');
      faqListEl.className = 'faq-list';
      faqSection.appendChild(faqListEl);

      // Collect FAQ items: find siblings after h2 until next h2, hr, or end
      var siblings = [];
      var next = faqH2.nextElementSibling;
      while (next && next.tagName !== 'H2' && next.tagName !== 'HR') {
        siblings.push(next);
        next = next.nextElementSibling;
      }

      // Parse questions & answers
      var i = 0;
      while (i < siblings.length) {
        var el = siblings[i];
        var questionText = null;
        var answerEls = [];

        // h3 question
        if (el.tagName === 'H3') {
          questionText = el.textContent;
          i++;
          while (i < siblings.length && siblings[i].tagName !== 'H3' && !(siblings[i].tagName === 'P' && siblings[i].querySelector('strong') && siblings[i].childNodes.length === 1)) {
            answerEls.push(siblings[i]);
            i++;
          }
        }
        // p > strong question (bold only paragraph)
        else if (el.tagName === 'P' && el.querySelector('strong') && el.textContent.trim() === el.querySelector('strong').textContent.trim()) {
          questionText = el.querySelector('strong').textContent;
          i++;
          while (i < siblings.length && siblings[i].tagName !== 'H3' && !(siblings[i].tagName === 'P' && siblings[i].querySelector('strong') && siblings[i].textContent.trim() === (siblings[i].querySelector('strong') ? siblings[i].querySelector('strong').textContent.trim() : ''))) {
            answerEls.push(siblings[i]);
            i++;
          }
        }
        else { i++; continue; }

        if (questionText) {
          var item = document.createElement('div');
          item.className = 'faq-item';
          var btn = document.createElement('button');
          btn.className = 'faq-question';
          btn.textContent = questionText;
          var icon = document.createElement('span');
          icon.className = 'faq-icon';
          btn.appendChild(icon);
          btn.addEventListener('click', function() { this.parentElement.classList.toggle('open'); var ans = this.nextElementSibling; if (this.parentElement.classList.contains('open')) { ans.style.maxHeight = ans.scrollHeight + 'px'; } else { ans.style.maxHeight = '0'; } });
          item.appendChild(btn);
          var answer = document.createElement('div');
          answer.className = 'faq-answer';
          var ansInner = document.createElement('div');
          ansInner.className = 'faq-answer-inner';
          answerEls.forEach(function(a) { ansInner.appendChild(a.cloneNode(true)); });
          answer.appendChild(ansInner);
          item.appendChild(answer);
          faqListEl.appendChild(item);
        }
      }

      // Replace original FAQ section
      siblings.forEach(function(s) { s.remove(); });
      faqH2.replaceWith(faqSection);
    }

    // Forum link for FR articles
    var forumSection = document.getElementById('articleForum');
    var forumLink = document.getElementById('articleForumLink');
    if (forumSection && forumLink) {
      var path = window.location.pathname;
      var slug = null;
      var articleType = null;
      var blogMatch = path.match(/^(?:\/(?:en|de))?\/blog\/([^/]+)\/?$/);
      var guideMatch = path.match(/^(?:\/(?:en|de))?\/(?:guides|ratgeber)\/([^/]+)\/?$/);
      if (blogMatch) { slug = blogMatch[1]; articleType = 'blog'; }
      else if (guideMatch) { slug = guideMatch[1]; articleType = 'guide'; }

      if (slug) {
        var SB_URL = 'https://vzmtvhcvyqzkmestdbko.supabase.co';
        var SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ6bXR2aGN2eXF6a21lc3RkYmtvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA4OTA0MTEsImV4cCI6MjA4NjQ2NjQxMX0.rvBz2uIsr3YtLIw84Kor3eVFpH4FiXVZgbufiJH3uio';
        var articleTitle = document.querySelector('.article-title')?.textContent || document.querySelector('.article-header h1')?.textContent || slug;

        var articleDesc = document.querySelector('meta[name="description"]')?.content || '';
        var pageLang = document.documentElement.lang || 'fr';
        var forumCTA = {
          fr: '\u{1F4AC} Qu\'en pensez-vous ? Partagez vos questions, retours d\'exp\u00e9rience ou avis dans les commentaires !',
          en: '\u{1F4AC} What do you think? Share your questions, experiences or opinions in the comments!',
          de: '\u{1F4AC} Was denkt ihr? Teilt eure Fragen, Erfahrungen oder Meinungen in den Kommentaren!'
        };
        var forumRead = { fr: 'Lire l\'article complet', en: 'Read the full article', de: 'Den ganzen Artikel lesen' };
        var forumIntro = (articleDesc ? articleDesc + '\n\n' : '')
          + '\u2014\n\n'
          + (forumCTA[pageLang] || forumCTA.fr) + '\n\n'
          + '\u{1F4D6} ' + (forumRead[pageLang] || forumRead.fr) + ' : ' + window.location.href;

        // Check if a forum post already exists for this article
        fetch(SB_URL + '/rest/v1/forum_posts?article_slug=eq.' + slug + '&limit=1', {
          headers: { 'apikey': SB_KEY, 'Content-Type': 'application/json' }
        }).then(function(r) { return r.json(); }).then(function(posts) {
          if (posts && posts.length > 0) {
            forumLink.href = '/forum/topic/?id=' + posts[0].id;
            var countText = posts[0].reply_count > 0 ? posts[0].reply_count + ' réponse' + (posts[0].reply_count > 1 ? 's' : '') : 'Soyez le premier à commenter';
            forumSection.querySelector('.article-forum-text span').textContent = countText;
            forumSection.style.display = '';
          } else {
            // Auto-create forum topic for this article if user is logged in
            var storageKey = 'sb-vzmtvhcvyqzkmestdbko-auth-token';
            var raw = localStorage.getItem(storageKey);
            var token = null;
            try { var parsed = JSON.parse(raw); if (parsed && parsed.access_token) token = parsed.access_token; } catch(e) {}

            if (token) {
              // Decode JWT to get user info
              var payload = JSON.parse(atob(token.split('.')[1]));
              fetch(SB_URL + '/rest/v1/forum_posts', {
                method: 'POST',
                headers: { 'apikey': SB_KEY, 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json', 'Prefer': 'return=representation' },
                body: JSON.stringify({
                  title: articleTitle,
                  body: forumIntro,
                  category: 'article',
                  article_slug: slug,
                  article_type: articleType,
                  author_id: payload.sub,
                  author_name: 'AIVancePro'
                })
              }).then(function(r) { return r.json(); }).then(function(newPost) {
                if (newPost && newPost[0] && newPost[0].id) {
                  forumLink.href = '/forum/topic/?id=' + newPost[0].id;
                  forumSection.querySelector('.article-forum-text span').textContent = 'Soyez le premier à commenter';
                } else {
                  forumLink.href = '/forum/?article=' + slug + '&type=' + articleType;
                }
                forumSection.style.display = '';
              }).catch(function() { forumLink.href = '/forum/?article=' + slug + '&type=' + articleType; forumSection.style.display = ''; });
            } else {
              forumLink.href = '/forum/?article=' + slug + '&type=' + articleType;
              forumSection.style.display = '';
            }
          }
        }).catch(function() {
          forumLink.href = '/forum/';
          forumSection.style.display = '';
        });
      }
    }
  })();
  </script>

  <section class="article-newsletter">
    <div class="article-newsletter-card">
      <h3>{i.newsletter.articleTitle}</h3>
      <p class="nl-text">{i.newsletter.articleText}</p>
      <form class="newsletter-form-el" data-lang={lang} data-success={i.newsletter.success} data-error={i.newsletter.error} data-duplicate={i.newsletter.duplicate}>
        <div class="newsletter-input-wrap">
          <input type="email" placeholder={i.newsletter.placeholder} required>
          <button type="submit">{i.newsletter.button}</button>
        </div>
        <p class="newsletter-msg"></p>
      </form>
    </div>
  </section>

  <section class="final-cta">
    <h3>{cta.title}</h3>
    <p>{cta.text}</p>
    <div class="store-badges" style="justify-content:center;margin-top:1.5rem;">
      <a href={i.links.appStore} class="store-badge-link" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        <span class="store-badge-text"><span class="small">{lang === 'de' ? 'Erhältlich im' : lang === 'en' ? 'Available on' : 'Disponible sur'}</span><span class="big">App Store</span></span>
      </a>
      <a href={i.links.playStore} class="store-badge-link" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.67c-.38-.39-.58-.94-.58-1.6V1.93c0-.66.2-1.21.58-1.6l.08-.08L14.74 11.7v.22L3.26 23.38l-.08-.08z"/><path d="M18.56 15.58l-3.82-3.84v-.22l3.82-3.84.08.05 4.53 2.57c1.29.73 1.29 1.93 0 2.67l-4.53 2.57-.08.04z" opacity=".8"/><path d="M18.65 15.53L14.74 11.6 3.18 23.2c.43.45 1.13.51 1.93.06l13.54-7.73" opacity=".6"/><path d="M18.65 7.68L5.11.95c-.8-.45-1.5-.39-1.93.06L14.74 12.6l3.91-3.92z" opacity=".6"/></svg>
        <span class="store-badge-text"><span class="small">{lang === 'de' ? 'Erhältlich bei' : lang === 'en' ? 'Available on' : 'Disponible sur'}</span><span class="big">Google Play</span></span>
      </a>
    </div>
  </section>
</BaseLayout>
