                <div class="plan-name">Pro</div>
                <div class="price">6.99&euro; <span>/ month</span></div>
                <div class="price-desc">To progress seriously</div>
                <div style="display:inline-block;padding:0.25rem 0.75rem;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);border-radius:50px;font-size:0.75rem;font-weight:600;color:#10B981;margin-bottom:1.5rem">7-day free trial</div>
                <ul class="pricing-features">
