---
import { languages, t } from '../i18n.js';

const { lang = 'fr' } = Astro.props;
const i = t[lang];
const chevronSvg = `<svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>`;
const currentLang = languages[lang];
---

<nav>
    <div class="nav-inner">
        <a href={i.links.home} class="logo">
            <img src="/assets/logo.png" alt="AIVancePro" width="34" height="34" decoding="async">
            <span class="logo-text">AIVancePro</span>
        </a>

        <ul class="nav-center">
            <li><a href={i.links.home}>{i.nav.home}</a></li>
            <li class="dropdown">
                <button class="dropdown-toggle">
                    {i.nav.product}
                    <Fragment set:html={chevronSvg} />
                </button>
                <div class="dropdown-menu">
                    <a href={i.links.features}>{i.nav.features}</a>
                    <a href={i.links.exercises}>{i.nav.exercises}</a>
                    <a href={i.links.gettingStarted}>{i.nav.gettingStarted}</a>
                    <a href={i.links.aiTransparency}>{i.nav.aiTransparency}</a>
                    <a href={i.links.reviews}>{i.nav.reviews}</a>
                    <a href={i.links.changelog}>{i.nav.changelog}</a>
                    <a href={i.links.comparison}>{i.nav.comparison}</a>
                </div>
            </li>
            <li><a href={i.links.pricing}>{i.nav.pricing}</a></li>
            <li class="dropdown">
                <button class="dropdown-toggle">
                    {i.nav.articles}
                    <Fragment set:html={chevronSvg} />
                </button>
                <div class="dropdown-menu">
                    <a href={i.links.blog}>{i.nav.blog}</a>
                    <a href={i.links.guides}>{i.nav.guides}</a>
                </div>
            </li>
            {i.links.forum && <li><a href={i.links.forum}>{i.nav.forum}</a></li>}
            <li class="dropdown">
                <button class="dropdown-toggle">
                    {i.nav.help}
                    <Fragment set:html={chevronSvg} />
                </button>
                <div class="dropdown-menu">
                    <a href={i.links.faq}>{i.nav.faq}</a>
                    <a href={i.links.support}>{i.nav.support}</a>
                    <a href={i.links.about}>{i.nav.about}</a>
                </div>
            </li>
        </ul>

        <div class="nav-right">
            <button class="theme-toggle" id="searchBtn" aria-label="Search" onclick="document.getElementById('searchOverlay').classList.add('open');document.getElementById('searchInput').focus()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
                <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            </button>
            <span class="nav-divider"></span>
            <div class="lang-dropdown">
                <button class="lang-dropdown-toggle">
                    <span class="flag">{currentLang.flag}</span> {currentLang.short}
                    <svg width="12" height="12" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
                </button>
                <div class="lang-dropdown-menu">
                    {Object.entries(languages).map(([code, l]) => (
                        <a href={t[code].links.home} class={code === lang ? 'active' : ''}>
                            <span class="flag">{l.flag}</span> {l.label}
                        </a>
                    ))}
                </div>
            </div>
            <a href={i.links.login} class="nav-login" id="nav-login-link" data-account-url={i.links.account}>{i.nav.login}</a>
            <a href={i.links.appStore} class="nav-cta" target="_blank" rel="noopener">{i.nav.download}</a>
            <button class="mobile-menu-btn" onclick="document.getElementById('mobileMenu').classList.add('open');document.body.style.overflow='hidden'" aria-label={i.nav.menu}>
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Menu -->
<div id="mobileMenu" class="mobile-menu">
    <button class="mobile-menu-close" onclick="document.getElementById('mobileMenu').classList.remove('open');document.body.style.overflow=''" aria-label={i.nav.close}>&times;</button>
    <a href={i.links.home}>{i.nav.home}</a>
    <span class="mobile-section-label">{i.nav.product}</span>
    <div class="mobile-sub">
        <a href={i.links.features}>{i.nav.features}</a>
        <a href={i.links.exercises}>{i.nav.exercises}</a>
        <a href={i.links.gettingStarted}>{i.nav.gettingStarted}</a>
        <a href={i.links.aiTransparency}>{i.nav.aiTransparency}</a>
        <a href={i.links.reviews}>{i.nav.reviews}</a>
        <a href={i.links.changelog}>{i.nav.changelog}</a>
        <a href={i.links.comparison}>{i.nav.comparison}</a>
    </div>
    <a href={i.links.pricing}>{i.nav.pricing}</a>
    <span class="mobile-section-label">{i.nav.articles}</span>
    <div class="mobile-sub">
        <a href={i.links.blog}>{i.nav.blog}</a>
        <a href={i.links.guides}>{i.nav.guides}</a>
    </div>
    {i.links.forum && <a href={i.links.forum}>{i.nav.forum}</a>}
    <span class="mobile-section-label">{i.nav.help}</span>
    <div class="mobile-sub">
        <a href={i.links.faq}>{i.nav.faq}</a>
        <a href={i.links.support}>{i.nav.support}</a>
        {i.links.contact && <a href={i.links.contact}>Contact</a>}
        <a href={i.links.about}>{i.nav.about}</a>
    </div>
    <a href={i.links.login} id="mobile-login-link" data-account-url={i.links.account}>{i.nav.login}</a>
    {Object.entries(languages).filter(([code]) => code !== lang).map(([code, l]) => (
        <a href={t[code].links.home}>{l.flag} {l.label}</a>
    ))}
</div>

<script is:inline>
(function() {
  // Touch support for dropdowns (tablets showing desktop nav)
  document.querySelectorAll('.lang-dropdown-toggle, .dropdown-toggle').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var parent = btn.closest('.lang-dropdown, .dropdown');
      if (!parent) return;
      var isOpen = parent.classList.contains('touch-open');
      document.querySelectorAll('.touch-open').forEach(function(el) { el.classList.remove('touch-open'); });
      if (!isOpen) parent.classList.add('touch-open');
    });
  });
  document.addEventListener('click', function() {
    document.querySelectorAll('.touch-open').forEach(function(el) { el.classList.remove('touch-open'); });
  });

  // Theme toggle
  var themeBtn = document.getElementById('themeToggle');
  if (themeBtn) {
    var saved = localStorage.getItem('theme');
    if (saved) document.documentElement.setAttribute('data-theme', saved);
    themeBtn.addEventListener('click', function() {
      var current = document.documentElement.getAttribute('data-theme');
      var next = current === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  }

  // Search modal JS is in BaseLayout.astro (runs after overlay is in DOM)

  // Auth state check
  var storageKey = 'sb-vzmtvhcvyqzkmestdbko-auth-token';
  try {
    var raw = localStorage.getItem(storageKey);
    if (!raw) return;
    var parsed = JSON.parse(raw);
    if (!parsed || !parsed.access_token) return;
    var exp = parsed.expires_at;
    if (exp && exp * 1000 < Date.now()) return;
    var labels = { fr: 'Mon compte', en: 'My Account', de: 'Mein Konto' };
    var lang = document.documentElement.lang || 'fr';
    var label = labels[lang] || labels.fr;
    var navLink = document.getElementById('nav-login-link');
    var mobileLink = document.getElementById('mobile-login-link');
    if (navLink) {
      navLink.href = navLink.dataset.accountUrl;
      navLink.textContent = label;
    }
    if (mobileLink) {
      mobileLink.href = mobileLink.dataset.accountUrl;
      mobileLink.textContent = label;
    }
  } catch(e) {}

})();
</script>
